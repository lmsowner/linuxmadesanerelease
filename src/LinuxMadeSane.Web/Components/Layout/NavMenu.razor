<div class="nav-shell">
    <div class="nav-shell-top">
        <div class="brand-lockup">
            <button class="brand-link"
                    type="button"
                    title="About Linux Made Sane"
                    aria-label="About Linux Made Sane"
                    data-about-open>
                <span class="brand-mark">
                    <img class="brand-logo" src="/images/lms-logo.png" alt="" />
                </span>
            </button>
        </div>
    </div>

    <div class="sidebar-section">
        <div class="nav-button-list">
            @foreach (var item in NavItems)
            {
                <UiNavButton Href="@item.Href"
                             Label="@item.Label"
                             Match="@item.Match"
                             Preview="@item.Preview"
                             IconName="@item.Icon"
                             AdditionalActivePathPrefixes="@item.AdditionalActivePathPrefixes" />
            }
        </div>
    </div>

    <div class="sidebar-footer">
        @if (IsAuthenticated)
        {
            <div class="sidebar-account">
                <span class="sidebar-account-chip"
                      title="@LmsAccountLabel"
                      aria-label="@LmsAccountLabel">
                    <span class="sidebar-account-kicker">LMS Account</span>
                    <span class="sidebar-account-value">@AuthenticatedEmail</span>
                </span>

                <form method="post" action="/auth/logout" class="sidebar-logout-form">
                    <UiCommandButton Label="Sign out"
                                     Glyph="UiIconGlyph.SignOut"
                                     Type="submit"
                                     Variant="UiButtonVariant.Toolbar" />
                </form>
            </div>
        }

    </div>
</div>

@code {
    [Parameter] public bool IsAuthenticated { get; set; }
    [Parameter] public string AuthenticatedEmail { get; set; } = string.Empty;

    private string LmsAccountLabel => string.IsNullOrWhiteSpace(AuthenticatedEmail)
        ? "Signed in LMS account"
        : $"LMS Account: {AuthenticatedEmail}";

    private static readonly IReadOnlyList<NavItem> NavItems =
    [
        new("/", "Overview", UiIconName.Overview, NavLinkMatch.All),
        new("/hosts", "Hosts", UiIconName.Hosts),
        new("/integrations", "Integrations", UiIconName.Integrations),
        new("/scheduling", "Scheduling", UiIconName.Scheduling),
        new("/commands", "Runbooks", UiIconName.Runbooks),
        new("/ai", "AI Services", UiIconName.AiOverview),
        new("/rdp-optimizer", "Desktop Manager", UiIconName.RdpOptimizer),
        new("/settings", "LMS Security", UiIconName.Security),
        new("/shares/identities", "Users and Groups", UiIconName.UsersGroups),
        new("/sftp-server", "SFTP Server", UiIconName.SftpServer),
        new("/shares", "Network Shares", UiIconName.Shares, NavLinkMatch.All, AdditionalActivePathPrefixes: ["/shares/mounts", "/shares/manager"]),
        new("/services", "Services", UiIconName.Services)
    ];

    private sealed record NavItem(
        string Href,
        string Label,
        UiIconName Icon,
        NavLinkMatch Match = NavLinkMatch.Prefix,
        bool Preview = false,
        IReadOnlyList<string>? AdditionalActivePathPrefixes = null);
}
