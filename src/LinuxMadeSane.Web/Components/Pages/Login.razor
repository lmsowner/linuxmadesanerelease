@page "/login"
@layout AuthLayout

<script type="module" src="@Assets["Components/Pages/Login.razor.js"]"></script>

<PageTitle>LMS Account Login | Linux Made Sane</PageTitle>

<div class="auth-login-shell">
    <section class="auth-login-showcase">
        <div class="auth-login-copy">
            <p class="eyebrow">Linux Made Sane</p>
            <h1>Secure access without the usual nonsense.</h1>
            <p class="auth-login-lead">LMS keeps the front door clean, quick, and easy to understand.</p>
        </div>

        <div class="auth-login-art-frame">
            <img class="auth-login-art" src="/images/lms-splash.png" alt="Linux Made Sane penguin illustration" />
        </div>

        <div class="auth-login-feature-grid">
            <article class="auth-login-feature">
                <span class="auth-login-feature-tag">Simple</span>
                <p>Less setup theatre, fewer moving parts, and a front door that feels obvious.</p>
            </article>

            <article class="auth-login-feature">
                <span class="auth-login-feature-tag">Fast</span>
                <p>Jump straight into LMS without wading through a wall of admin jargon first.</p>
            </article>

            <article class="auth-login-feature">
                <span class="auth-login-feature-tag">Sane</span>
                <p>Nice defaults, clean wiring, and a calmer way to manage the stuff behind your network.</p>
            </article>
        </div>
    </section>

    <section class="surface-card auth-login-panel">
        <div class="section-heading auth-login-heading">
            <div>
                <p class="eyebrow">Authentication</p>
                <h2>Username or email + authenticator OTP</h2>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <p class="callout error">@Error</p>
        }

        <div class="auth-login-security-note">
            <p class="auth-login-security-kicker">Protected by design</p>
            <p>LMS account sign-ins use your username or email plus a six-digit authenticator code, giving you a proper second factor without turning access into a chore.</p>
        </div>

        <form method="post" action="/auth/login" class="stack-form auth-login-form">
            <input type="hidden" name="returnUrl" value="@NormalizedReturnUrl" />

            <label class="auth-login-field-group">
                <span>Username or email</span>
                <div class="auth-login-field-shell auth-login-email-shell">
                    <input name="identifier" type="text" value="@Email" autocomplete="username" placeholder="you@example.com" required />
                </div>
            </label>

            <label class="auth-login-field-group auth-login-otp-group">
                <span>Authenticator code</span>
                <input type="hidden" name="otpCode" data-otp-hidden />

                <div class="auth-login-otp-grid" data-otp-grid role="group" aria-label="Authenticator code">
                    <input class="auth-login-otp-box"
                           type="text"
                           inputmode="numeric"
                           autocomplete="one-time-code"
                           maxlength="1"
                           aria-label="OTP digit 1"
                           data-otp-digit
                           required />
                    <input class="auth-login-otp-box"
                           type="text"
                           inputmode="numeric"
                           autocomplete="off"
                           maxlength="1"
                           aria-label="OTP digit 2"
                           data-otp-digit
                           required />
                    <input class="auth-login-otp-box"
                           type="text"
                           inputmode="numeric"
                           autocomplete="off"
                           maxlength="1"
                           aria-label="OTP digit 3"
                           data-otp-digit
                           required />
                    <input class="auth-login-otp-box"
                           type="text"
                           inputmode="numeric"
                           autocomplete="off"
                           maxlength="1"
                           aria-label="OTP digit 4"
                           data-otp-digit
                           required />
                    <input class="auth-login-otp-box"
                           type="text"
                           inputmode="numeric"
                           autocomplete="off"
                           maxlength="1"
                           aria-label="OTP digit 5"
                           data-otp-digit
                           required />
                    <input class="auth-login-otp-box"
                           type="text"
                           inputmode="numeric"
                           autocomplete="off"
                           maxlength="1"
                           aria-label="OTP digit 6"
                           data-otp-digit
                           required />
                </div>

                <span class="helper-text auth-login-otp-helper">Enter the 6-digit code from your authenticator app.</span>
            </label>
        </form>
    </section>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    private string NormalizedReturnUrl => NormalizeReturnUrl(ReturnUrl);

    private static string NormalizeReturnUrl(string? returnUrl)
    {
        if (string.IsNullOrWhiteSpace(returnUrl))
        {
            return "/";
        }

        var trimmed = returnUrl.Trim();
        return trimmed.StartsWith("/", StringComparison.Ordinal) &&
               !trimmed.StartsWith("//", StringComparison.Ordinal) &&
               !trimmed.StartsWith("/\\", StringComparison.Ordinal)
            ? trimmed
            : "/";
    }
}
