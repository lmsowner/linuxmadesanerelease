@page "/login"
@page "/LMSMFALogin"
@layout AuthLayout
@using LinuxMadeSane.Application.Contracts.EdgeGateway
@inject LocalAccessRecoveryService AccessRecovery
@inject NavigationManager Navigation

<script type="module" src="@Assets["Components/Pages/Login.razor.js"]"></script>

<PageTitle>LMS Account Login | Linux Made Sane</PageTitle>

<div class="auth-login-shell">
    <section class="auth-login-showcase">
        <img class="auth-login-art" src="/images/lms-auth-panel.png" alt="Linux Made Sane secure access artwork" />
    </section>

    <section class="auth-login-panel">
        <div class="auth-login-heading">
            <p class="eyebrow">Linux Made Sane</p>
            <h1>Verify access.</h1>
            <p>Email and MFA. No LMS password.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <p class="callout error">@Error</p>
        }

        <form method="post"
              action="@LoginPostPath"
              class="stack-form auth-login-form"
              data-passkey-options-url="@PasskeyOptionsPath"
              data-passkey-complete-url="@PasskeyCompletePath"
              data-email-mfa-send-url="@EmailMfaSendPath"
              data-email-mfa-complete-url="@EmailMfaCompletePath">
            <input type="hidden" name="returnUrl" value="@NormalizedReturnUrl" />

            <label class="auth-login-field-group">
                <span>Email</span>
                <div class="auth-login-field-shell auth-login-email-shell">
                    <input name="email" type="email" value="@Email" autocomplete="email" placeholder="you@example.com" required />
                </div>
            </label>

            <div class="auth-login-methods" aria-label="Available sign-in methods">
                <div class="auth-login-method active">
                    <span class="auth-login-method-icon">MFA</span>
                    <span>Authenticator code</span>
                </div>
                <button class="auth-login-method auth-login-method-button" type="button" data-passkey-login>
                    <span class="auth-login-method-icon">MFA</span>
                    <span>Device passkey</span>
                </button>
                <button class="auth-login-method auth-login-method-button" type="button" data-email-mfa-send>
                    <span class="auth-login-method-icon">MAIL</span>
                    <span>Email code/link</span>
                </button>
            </div>

            <p class="callout auth-login-status" data-passkey-status hidden></p>

            <label class="auth-login-field-group auth-login-email-code-group" data-email-code-group hidden>
                <span>Email code</span>
                <input type="hidden" data-email-code-hidden />

                <div class="auth-login-otp-grid" data-email-code-grid role="group" aria-label="Email sign-in code">
                    <input class="auth-login-otp-box"
                           type="text"
                           inputmode="numeric"
                           autocomplete="one-time-code"
                           maxlength="1"
                           aria-label="Email code digit 1"
                           data-email-code-digit />
                    <input class="auth-login-otp-box"
                           type="text"
                           inputmode="numeric"
                           autocomplete="off"
                           maxlength="1"
                           aria-label="Email code digit 2"
                           data-email-code-digit />
                    <input class="auth-login-otp-box"
                           type="text"
                           inputmode="numeric"
                           autocomplete="off"
                           maxlength="1"
                           aria-label="Email code digit 3"
                           data-email-code-digit />
                    <input class="auth-login-otp-box"
                           type="text"
                           inputmode="numeric"
                           autocomplete="off"
                           maxlength="1"
                           aria-label="Email code digit 4"
                           data-email-code-digit />
                    <input class="auth-login-otp-box"
                           type="text"
                           inputmode="numeric"
                           autocomplete="off"
                           maxlength="1"
                           aria-label="Email code digit 5"
                           data-email-code-digit />
                    <input class="auth-login-otp-box"
                           type="text"
                           inputmode="numeric"
                           autocomplete="off"
                           maxlength="1"
                           aria-label="Email code digit 6"
                           data-email-code-digit />
                </div>

                <span class="helper-text auth-login-otp-helper">Use the 6-digit email code, or open the secure link from your inbox.</span>
            </label>

            <label class="auth-login-field-group auth-login-otp-group">
                <span>MFA code</span>
                <input class="auth-login-code-input"
                       name="otpCode"
                       type="text"
                       inputmode="numeric"
                       autocomplete="one-time-code"
                       maxlength="6"
                       pattern="[0-9]{6}"
                       placeholder="123456"
                       aria-label="Authenticator code"
                       data-otp-input
                       required />

                <span class="helper-text auth-login-otp-helper">Enter the 6-digit code. LMS verifies automatically when the code is complete.</span>
            </label>

            <button class="auth-login-submit" type="submit">Verify code</button>

            <p class="auth-login-footnote">For Edge Gateway routes, LMS checks this local session before proxying.</p>
        </form>

        @if (showRecovery && !IsEdgeGatewayLogin)
        {
            <form method="post" action="/auth/recovery" class="stack-form auth-recovery-form">
                <input type="hidden" name="returnUrl" value="@NormalizedReturnUrl" />
                <input type="hidden" name="recovery" value="@Recovery" />

                <div class="auth-recovery-heading">
                    <p>Lost access recovery</p>
                    <span>Use the code printed by the installer on this LMS host.</span>
                </div>

                <label class="auth-login-field-group">
                    <span>LMS email</span>
                    <div class="auth-login-field-shell auth-login-email-shell">
                        <input name="email" type="email" value="@Email" autocomplete="email" placeholder="you@example.com" required />
                    </div>
                </label>

                <label class="auth-login-field-group">
                    <span>Recovery code</span>
                    <div class="auth-login-field-shell">
                        <input name="recoveryCode"
                               type="text"
                               autocomplete="one-time-code"
                               inputmode="text"
                               placeholder="XXXX-XXXX-XXXX-XXXX"
                               required />
                    </div>
                </label>

                <button class="auth-recovery-submit" type="submit">Recover access</button>
            </form>
        }
    </section>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    [SupplyParameterFromQuery]
    public string? Recovery { get; set; }

    private bool showRecovery;

    private bool IsEdgeGatewayLogin =>
        new Uri(Navigation.Uri).AbsolutePath.Equals(EdgeGatewayAuthenticationPaths.Login, StringComparison.OrdinalIgnoreCase);

    private string NormalizedReturnUrl => NormalizeReturnUrl(ReturnUrl);

    private string LoginPostPath => IsEdgeGatewayLogin ? EdgeGatewayAuthenticationPaths.LoginPost : "/auth/login";

    private string PasskeyOptionsPath => IsEdgeGatewayLogin ? EdgeGatewayAuthenticationPaths.PasskeyOptions : "/api/passkeys/login/options";

    private string PasskeyCompletePath => IsEdgeGatewayLogin ? EdgeGatewayAuthenticationPaths.PasskeyComplete : "/api/passkeys/login/complete";

    private string EmailMfaSendPath => IsEdgeGatewayLogin ? EdgeGatewayAuthenticationPaths.EmailSend : "/api/email-mfa/login/send";

    private string EmailMfaCompletePath => IsEdgeGatewayLogin ? EdgeGatewayAuthenticationPaths.EmailComplete : "/api/email-mfa/login/complete";

    protected override async Task OnParametersSetAsync()
    {
        showRecovery = await AccessRecovery.HasActiveChallengeAsync(Recovery);
    }

    private static string NormalizeReturnUrl(string? returnUrl)
    {
        if (string.IsNullOrWhiteSpace(returnUrl))
        {
            return "/";
        }

        var trimmed = returnUrl.Trim();
        return trimmed.StartsWith("/", StringComparison.Ordinal) &&
               !trimmed.StartsWith("//", StringComparison.Ordinal) &&
               !trimmed.StartsWith("/\\", StringComparison.Ordinal)
            ? trimmed
            : "/";
    }
}
