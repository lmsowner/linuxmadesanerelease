    private string GetPassword(TerminalTabState terminalTab) =>
        ConnectionSecretStore.Get(terminalTab.SecretHandle).Password;

    private string GetPrivateKey(TerminalTabState terminalTab) =>
        ConnectionSecretStore.Get(terminalTab.SecretHandle).PrivateKey;

    private string GetPrivateKeyPassphrase(TerminalTabState terminalTab) =>
        ConnectionSecretStore.Get(terminalTab.SecretHandle).PrivateKeyPassphrase;

    private void SetPassword(TerminalTabState terminalTab, string? value)
    {
        var existing = ConnectionSecretStore.Get(terminalTab.SecretHandle);
        terminalTab.SecretHandle = ConnectionSecretStore.Save(terminalTab.SecretHandle, value, existing.PrivateKey, existing.PrivateKeyPassphrase);
    }

    private void SetPrivateKey(TerminalTabState terminalTab, string? value)
    {
        var existing = ConnectionSecretStore.Get(terminalTab.SecretHandle);
        terminalTab.SecretHandle = ConnectionSecretStore.Save(terminalTab.SecretHandle, existing.Password, value, existing.PrivateKeyPassphrase);
    }

    private void SetPrivateKeyPassphrase(TerminalTabState terminalTab, string? value)
    {
        var existing = ConnectionSecretStore.Get(terminalTab.SecretHandle);
        terminalTab.SecretHandle = ConnectionSecretStore.Save(terminalTab.SecretHandle, existing.Password, existing.PrivateKey, value);
    }

    private async Task LoadCredentialProfilesAsync()
    {
        if (!userId.HasValue || tab is null)
        {
            credentialProfiles = [];
            return;
        }

        credentialProfiles = await CredentialProfileService.ListAsync(userId.Value, tab.HostId);
    }

    private async Task SelectConnectionProfileAsync(TerminalTabState terminalTab, string value)
    {
        terminalTab.ConnectionProfileKey = value;
        terminalTab.ErrorMessage = string.Empty;

        if (value == ConnectionProfileSelectionKeys.HostDefault)
        {
            var host = hosts.FirstOrDefault(item => item.Id == terminalTab.HostId);
            if (host is not null)
            {
                terminalTab.Username = host.Username.Trim();
                terminalTab.ConnectionProfileName = host.Username.Trim();
                terminalTab.PreferStoredCredentials = HasConfiguredStoredCredentials(host);
                ConnectionSecretStore.Delete(terminalTab.SecretHandle);
                terminalTab.SecretHandle = null;
            }

            return;
        }

        if (value == ConnectionProfileSelectionKeys.LinkedLinuxUser)
        {
            terminalTab.Username = currentLinuxUsername;
            terminalTab.ConnectionProfileName = currentLinuxUsername;
            terminalTab.PreferStoredCredentials = false;
            ConnectionSecretStore.Delete(terminalTab.SecretHandle);
            terminalTab.SecretHandle = null;
            return;
        }

        if (!ConnectionProfileSelectionKeys.TryParseSaved(value, out var profileId) || !userId.HasValue)
        {
            return;
        }

        var credentials = await CredentialProfileService.ResolveAsync(userId.Value, terminalTab.HostId, profileId);
        if (credentials is null)
        {
            terminalTab.ErrorMessage = "Credential profile not found.";
            return;
        }

        terminalTab.Username = credentials.Username;
        terminalTab.ConnectionProfileName = credentials.Name;
        terminalTab.PreferStoredCredentials = false;
        terminalTab.SecretHandle = ConnectionSecretStore.Save(
            terminalTab.SecretHandle,
            credentials.Password,
            credentials.PrivateKey,
            credentials.PrivateKeyPassphrase);
    }

    private async Task<TerminalConnectionRequest> BuildTerminalConnectionRequestAsync(TerminalTabState terminalTab)
    {
        var username = terminalTab.Username.Trim();
        var password = string.IsNullOrWhiteSpace(GetPassword(terminalTab)) ? null : GetPassword(terminalTab);
        var privateKey = string.IsNullOrWhiteSpace(GetPrivateKey(terminalTab)) ? null : GetPrivateKey(terminalTab);
        var privateKeyPassphrase = string.IsNullOrWhiteSpace(GetPrivateKeyPassphrase(terminalTab))
            ? null
            : GetPrivateKeyPassphrase(terminalTab);
        var preferStoredCredentials = terminalTab.PreferStoredCredentials;

        if (ConnectionProfileSelectionKeys.TryParseSaved(terminalTab.ConnectionProfileKey, out var profileId) && userId.HasValue)
        {
            var credentials = await CredentialProfileService.ResolveAsync(userId.Value, terminalTab.HostId, profileId);
            if (credentials is not null)
            {
                username = credentials.Username;
                password = string.IsNullOrWhiteSpace(credentials.Password) ? null : credentials.Password;
                privateKey = string.IsNullOrWhiteSpace(credentials.PrivateKey) ? null : credentials.PrivateKey;
                privateKeyPassphrase = string.IsNullOrWhiteSpace(credentials.PrivateKeyPassphrase)
                    ? null
                    : credentials.PrivateKeyPassphrase;
                preferStoredCredentials = false;
            }
        }

        return new TerminalConnectionRequest(
            username,
            password,
            privateKey,
            privateKeyPassphrase,
            preferStoredCredentials,
            terminalColumns,
            terminalRows,
            terminalTab.DefaultWorkingDirectory);
    }

    private async Task SaveConnectionProfileAsync(TerminalTabState terminalTab)
    {
        if (!userId.HasValue)
        {
            terminalTab.ErrorMessage = "Sign in before saving connection profiles.";
            return;
        }

        try
        {
            var secrets = ConnectionSecretStore.Get(terminalTab.SecretHandle);
            var editor = new UserManagedHostCredentialProfileEditor
            {
                Id = ConnectionProfileSelectionKeys.TryParseSaved(terminalTab.ConnectionProfileKey, out var profileId)
                    ? profileId
                    : null,
                UserId = userId.Value,
                ManagedHostId = terminalTab.HostId,
                Name = terminalTab.ConnectionProfileName,
                Username = terminalTab.Username,
                Password = secrets.Password,
                PrivateKey = secrets.PrivateKey,
                PrivateKeyPassphrase = secrets.PrivateKeyPassphrase
            };

            var saved = await CredentialProfileService.SaveAsync(editor);
            await LoadCredentialProfilesAsync();
            terminalTab.ConnectionProfileKey = ConnectionProfileSelectionKeys.Saved(saved.Id);
            terminalTab.ConnectionProfileName = saved.Name;
            terminalTab.PreferStoredCredentials = false;
            terminalTab.ErrorMessage = string.Empty;
        }
        catch (Exception exception)
        {
            terminalTab.ErrorMessage = exception.Message;
        }
    }

    private async Task DeleteConnectionProfileAsync(TerminalTabState terminalTab)
    {
        if (!userId.HasValue ||
            !ConnectionProfileSelectionKeys.TryParseSaved(terminalTab.ConnectionProfileKey, out var profileId))
        {
            return;
        }

        await CredentialProfileService.DeleteAsync(userId.Value, terminalTab.HostId, profileId);
        await LoadCredentialProfilesAsync();
        await SelectConnectionProfileAsync(terminalTab, ConnectionProfileSelectionKeys.HostDefault);
    }

    private bool CanDeleteSelectedConnectionProfile(TerminalTabState terminalTab) =>
        userId.HasValue && ConnectionProfileSelectionKeys.TryParseSaved(terminalTab.ConnectionProfileKey, out _);

    private bool ShouldShowLinkedLinuxUserOption(TerminalTabState terminalTab)
    {
        var host = hosts.FirstOrDefault(item => item.Id == terminalTab.HostId);
        return !string.IsNullOrWhiteSpace(currentLinuxUsername) &&
               host is not null &&
               !string.Equals(currentLinuxUsername, host.Username, StringComparison.Ordinal);
    }

    private string BuildHostDefaultProfileLabel(TerminalTabState terminalTab)
    {
        var host = hosts.FirstOrDefault(item => item.Id == terminalTab.HostId);
        var username = host?.Username.Trim() ?? terminalTab.Username.Trim();
        return string.IsNullOrWhiteSpace(username)
            ? "Host default"
            : $"Host default ({username})";
    }

    private string BuildLinkedLinuxUserProfileLabel() =>
        string.IsNullOrWhiteSpace(currentLinuxUsername)
            ? "My Linux user"
            : $"My Linux user ({currentLinuxUsername})";

    private static string FormatCredentialProfileOption(UserManagedHostCredentialProfileSummary profile) =>
        string.Equals(profile.Name, profile.Username, StringComparison.Ordinal)
            ? profile.Name
            : $"{profile.Name} ({profile.Username})";

    private static bool HasConfiguredStoredCredentials(ManagedHost host) =>
        !string.IsNullOrWhiteSpace(host.PasswordSecretReference) ||
        !string.IsNullOrWhiteSpace(host.PrivateKeySecretReference);

    private async Task DisposeTerminalClientAsync()
    {
        if (!terminalInitialized)
        {
            return;
        }

        try
        {
            await JSRuntime.InvokeVoidAsync("lmsTerminal.disposeTerminal", terminalClientId);
        }
        catch (JSDisconnectedException)
        {
        }
        finally
        {
            terminalInitialized = false;
        }
    }

