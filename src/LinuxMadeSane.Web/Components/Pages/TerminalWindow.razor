    private string GetPassword(TerminalTabState terminalTab) =>
        ConnectionSecretStore.Get(terminalTab.SecretHandle).Password;

    private string GetPrivateKey(TerminalTabState terminalTab) =>
        ConnectionSecretStore.Get(terminalTab.SecretHandle).PrivateKey;

    private string GetPrivateKeyPassphrase(TerminalTabState terminalTab) =>
        ConnectionSecretStore.Get(terminalTab.SecretHandle).PrivateKeyPassphrase;

    private void SetPassword(TerminalTabState terminalTab, string? value)
    {
        var existing = ConnectionSecretStore.Get(terminalTab.SecretHandle);
        terminalTab.SecretHandle = ConnectionSecretStore.Save(terminalTab.SecretHandle, value, existing.PrivateKey, existing.PrivateKeyPassphrase);
    }

    private void SetPrivateKey(TerminalTabState terminalTab, string? value)
    {
        var existing = ConnectionSecretStore.Get(terminalTab.SecretHandle);
        terminalTab.SecretHandle = ConnectionSecretStore.Save(terminalTab.SecretHandle, existing.Password, value, existing.PrivateKeyPassphrase);
    }

    private void SetPrivateKeyPassphrase(TerminalTabState terminalTab, string? value)
    {
        var existing = ConnectionSecretStore.Get(terminalTab.SecretHandle);
        terminalTab.SecretHandle = ConnectionSecretStore.Save(terminalTab.SecretHandle, existing.Password, existing.PrivateKey, value);
    }

    private async Task DisposeTerminalClientAsync()
    {
        if (!terminalInitialized)
        {
            return;
        }

        try
        {
            await JSRuntime.InvokeVoidAsync("lmsTerminal.disposeTerminal", terminalClientId);
        }
        catch (JSDisconnectedException)
        {
        }
        finally
        {
            terminalInitialized = false;
        }
    }

    private static void IgnoreClick()
    {
    }

    public async ValueTask DisposeAsync()
    {
        pollingCts?.Cancel();
        pollingCts?.Dispose();
        TerminalSessionService.OutputAppended -= HandleTerminalOutputAppended;

        await DisposeTerminalClientAsync();

        dotNetReference?.Dispose();
    }
}
