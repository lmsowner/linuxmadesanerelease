    {
        RemoteAccessSshAuthenticationMode.Password => "Password",
        RemoteAccessSshAuthenticationMode.PasswordAndKey => "Password + certificate / key",
        RemoteAccessSshAuthenticationMode.KeyOnly => "Certificate / key only",
        _ => mode.ToString()
    };

    private static string BuildSshModeHelperText(RemoteAccessSshAuthenticationMode mode) => mode switch
    {
        RemoteAccessSshAuthenticationMode.Password => "SSH accepts a password only for this user.",
        RemoteAccessSshAuthenticationMode.PasswordAndKey => "SSH requires both a password and imported public-key or certificate-authority material.",
        RemoteAccessSshAuthenticationMode.KeyOnly => "SSH rejects passwords and only accepts imported public-key or certificate-authority material.",
        _ => string.Empty
    };

    private static string BuildAuthorizedKeyHelperText(RemoteAccessSshAuthenticationMode mode) => mode switch
    {
        RemoteAccessSshAuthenticationMode.Password => "Optional. Paste OpenSSH public keys or cert-authority entries if you want this user ready for certificate / key login later.",
        RemoteAccessSshAuthenticationMode.PasswordAndKey => "Required. Paste one or more OpenSSH public keys or cert-authority entries for the certificate / key step.",
        RemoteAccessSshAuthenticationMode.KeyOnly => "Required. Paste one or more OpenSSH public keys or cert-authority entries because passwords will be rejected.",
        _ => string.Empty
