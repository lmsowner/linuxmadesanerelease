        GetPickableGroups()
            .Select(group => new UiIdentityTokenPickerItem(
                group.GroupName,
                group.GroupName,
                FormatList(group.Members),
                $"{group.GroupName} {string.Join(' ', group.Members)}"))
            .ToArray();

    private IReadOnlyList<UiIdentityTokenPickerItem> GetGroupMemberPickerItems() =>
        GetHumanUsers()
            .Select(user => new UiIdentityTokenPickerItem(
                user.UserName,
                user.DisplayName,
                user.UserName,
                $"{user.DisplayName} {user.UserName} {user.HomeDirectory}"))
            .ToArray();

    private IReadOnlyList<string> GetSelectedSupplementaryGroups() =>
        ParseCsv(userEditor.SupplementaryGroupsCsv);

    private Task ToggleSupplementaryGroupAsync(string groupName)
    {
        var selectedGroups = GetSelectedSupplementaryGroups().ToHashSet(StringComparer.OrdinalIgnoreCase);
        if (!selectedGroups.Add(groupName))
        {
            selectedGroups.Remove(groupName);
        }

        userEditor.SupplementaryGroupsCsv = string.Join(", ", selectedGroups.OrderBy(group => group, StringComparer.OrdinalIgnoreCase));
        return Task.CompletedTask;
    }

    private Task RemoveSupplementaryGroupAsync(string groupName)
    {
        var selectedGroups = GetSelectedSupplementaryGroups().ToHashSet(StringComparer.OrdinalIgnoreCase);
        selectedGroups.Remove(groupName);
        userEditor.SupplementaryGroupsCsv = string.Join(", ", selectedGroups.OrderBy(group => group, StringComparer.OrdinalIgnoreCase));
        return Task.CompletedTask;
    }

    private bool IsSupplementaryGroupSelected(string groupName) =>
        GetSelectedSupplementaryGroups().Contains(groupName, StringComparer.OrdinalIgnoreCase);

    private IReadOnlyList<string> GetSelectedGroupMembers() =>
        ParseCsv(groupEditor.MembersCsv);

    private Task ToggleGroupMemberAsync(string userName)
    {
        var members = GetSelectedGroupMembers().ToHashSet(StringComparer.OrdinalIgnoreCase);
        if (!members.Add(userName))
        {
            members.Remove(userName);
        }

        groupEditor.MembersCsv = string.Join(", ", members.OrderBy(member => member, StringComparer.OrdinalIgnoreCase));
        return Task.CompletedTask;
    }

    private Task RemoveGroupMemberAsync(string userName)
    {
        var members = GetSelectedGroupMembers().ToHashSet(StringComparer.OrdinalIgnoreCase);
        members.Remove(userName);
        groupEditor.MembersCsv = string.Join(", ", members.OrderBy(member => member, StringComparer.OrdinalIgnoreCase));
        return Task.CompletedTask;
    }

    private bool IsGroupMemberSelected(string userName) =>
        GetSelectedGroupMembers().Contains(userName, StringComparer.OrdinalIgnoreCase);

    private bool IsUserSelected(Guid userId) =>
        selectedUserId.HasValue && selectedUserId.Value == userId;

    private bool IsGroupSelected(Guid groupId) =>
        selectedGroupId.HasValue && selectedGroupId.Value == groupId;

    private bool IsWorkingGroup(LinuxShareGroup group)
    {
        var humanUsers = GetHumanUsers();
        return group.Members.Any(member => humanUsers.Any(user => user.UserName.Equals(member, StringComparison.OrdinalIgnoreCase))) ||
               humanUsers.Any(user => user.PrimaryGroup.Equals(group.GroupName, StringComparison.OrdinalIgnoreCase) ||
                                      user.SupplementaryGroups.Contains(group.GroupName, StringComparer.OrdinalIgnoreCase)) ||
               CommonWorkingGroups.Contains(group.GroupName);
    }

    private static bool IsHumanUser(LinuxShareUser user) =>
        user.HomeDirectory.StartsWith("/home/", StringComparison.OrdinalIgnoreCase) &&
        !IsNonInteractiveShell(user.LoginShell);

    private static bool IsNonInteractiveShell(string shell) =>
        shell.EndsWith("/nologin", StringComparison.OrdinalIgnoreCase) ||
        shell.EndsWith("/false", StringComparison.OrdinalIgnoreCase);

    private static IReadOnlyList<string> ParseCsv(string value) =>
        value.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

    private static string FormatList(IReadOnlyList<string> values) =>
        values.Count == 0 ? "No explicit members" : string.Join(", ", values);

    private static IReadOnlyList<string> GetUserGroups(LinuxShareUser user) =>
        new[] { user.PrimaryGroup }
            .Concat(user.SupplementaryGroups)
            .Where(static group => !string.IsNullOrWhiteSpace(group))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private static string GetUserFullName(LinuxShareUser user) =>
        string.IsNullOrWhiteSpace(user.DisplayName) || user.DisplayName.Equals(user.UserName, StringComparison.OrdinalIgnoreCase)
            ? "-"
            : user.DisplayName;

    private static string FormatUserId(LinuxShareUser user) =>
        user.Uid < 0 ? "-" : user.Uid.ToString();

    private static string FormatGroupId(LinuxShareGroup group) =>
        group.Gid < 0 ? "-" : group.Gid.ToString();

    private static string FormatLoginState(LinuxShareUser user) =>
        user.IsEnabled ? "Login enabled" : "No login shell";

    private LocalUserAccessViewModel? GetUserAccess(LinuxShareUser user) =>
        viewModel?.UserAccessPolicies.FirstOrDefault(item =>
            item.UserName.Equals(user.UserName, StringComparison.OrdinalIgnoreCase));

    private string GetSshAccessLabel(LinuxShareUser user)
    {
        var policy = GetUserAccess(user);
        return policy?.SshAuthenticationMode is null
            ? "System default"
            : GetSshModeLabel(policy.SshAuthenticationMode.Value);
    }

    private bool HasImportedKeys(LinuxShareUser user) =>
        GetUserAccess(user)?.HasAuthorizedKeys == true;

    private DateTimeOffset? GetPasswordChangedAtUtc(LinuxShareUser user) =>
        GetUserAccess(user)?.PasswordChangedAtUtc;

    private DateTimeOffset? GetPasswordChangedAtUtcForSelectedUser() =>
        localPasswordResetModel is null
            ? null
            : GetUserAccessByName(localPasswordResetModel.UserName)?.PasswordChangedAtUtc;


    private LocalUserAccessViewModel? GetUserAccessByName(string userName) =>
        viewModel?.UserAccessPolicies.FirstOrDefault(item =>
            item.UserName.Equals(userName, StringComparison.OrdinalIgnoreCase));

    private static bool UserMatchesFilter(LinuxShareUser user, string filter) =>
        user.DisplayName.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
        user.UserName.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
        user.PrimaryGroup.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
        user.SupplementaryGroups.Any(group => group.Contains(filter, StringComparison.OrdinalIgnoreCase)) ||
        user.HomeDirectory.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
        user.LoginShell.Contains(filter, StringComparison.OrdinalIgnoreCase);

    private RenderFragment RenderGroupChips(IReadOnlyList<string> values) => @<div class="identity-group-chip-row">
        @if (values.Count == 0)
        {
            <span class="identity-group-chip muted">No groups</span>
        }
        else
        {
            @foreach (var value in values.Take(5))
            {
                <span class="identity-group-chip">@value</span>
            }

            @if (values.Count > 5)
            {
                <span class="identity-group-chip muted">+@(values.Count - 5)</span>
            }
        }
    </div>;

