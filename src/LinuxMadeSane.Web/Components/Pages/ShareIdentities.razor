    private static async Task<string> AppendImportedAuthorizedKeysAsync(string existingEntries, InputFileChangeEventArgs args)
    {
        const long maxImportBytes = 128 * 1024;
        var importedBlocks = new List<string>();

        foreach (var file in args.GetMultipleFiles())
        {
            await using var stream = file.OpenReadStream(maxImportBytes);
            using var reader = new StreamReader(stream);
            var content = await reader.ReadToEndAsync();
            if (!string.IsNullOrWhiteSpace(content))
            {
                importedBlocks.Add(content);
            }
        }

        if (importedBlocks.Count == 0)
        {
            return existingEntries;
        }

        return string.Join(
            Environment.NewLine,
            $"{existingEntries}{Environment.NewLine}{string.Join(Environment.NewLine, importedBlocks)}"
                .Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));
    }

    private string GetDefaultPrimaryGroup() =>
        string.IsNullOrWhiteSpace(userEditor.UserName) ? "username" : userEditor.UserName.Trim().ToLowerInvariant();

    private string GetDefaultHomeDirectory() =>
        $"/home/{GetDefaultPrimaryGroup()}";

