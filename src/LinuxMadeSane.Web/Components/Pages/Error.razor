@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<div class="page-shell">
    <section class="surface-card">
        <p class="eyebrow">Unhandled error</p>
        <h1>Request processing failed</h1>
        <p>An unexpected exception reached the UI pipeline. Use the request identifier below for diagnostics.</p>

        @if (ShowRequestId)
        {
            <p><strong>Request ID:</strong> <code>@RequestId</code></p>
        }

        <p>Detailed exception output is only shown when <code>ASPNETCORE_ENVIRONMENT=Development</code>.</p>
    </section>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
