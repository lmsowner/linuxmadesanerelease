@page "/hosts/{HostId:guid}/files"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using LinuxMadeSane.Web.Components.Ui

<PageTitle>Files | Linux Made Sane</PageTitle>

<div class="page-shell host-files-page">
    <section class="surface-card compact-toolbar page-header-toolbar">
        <div class="page-header-copy">
            <p class="eyebrow">File browser</p>
            <h1 class="section-title-compact">Files</h1>
            <details class="page-intro-details">
                <summary>About this browser</summary>
                <p class="hero-copy page-intro-copy">Browse the LMS filesystem or a remote host, pop the browser into separate windows, and use file actions from the explorer without dropping into a shell.</p>
            </details>
        </div>
        <div class="page-header-actions">
            <UiCommandButton Label="Back to details" Glyph="UiIconGlyph.Info" Variant="UiButtonVariant.Ghost" Href="@($"/hosts/{HostId}")" />
        </div>
    </section>

    <div class="host-file-page-stack">
        <HostFileBrowserWorkspace HostId="@HostId" InitialPath="@Path" ManagePageTitle="true" />
    </div>
</div>

@code {
    [Parameter]
    public Guid HostId { get; set; }

    [SupplyParameterFromQuery]
    public string? Path { get; set; }
}
