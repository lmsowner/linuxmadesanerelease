        }

        return "success";
    }

    private static string GetTrustedNetworkAuthPillText(TrustedNetworkEntryViewModel entry) =>
        entry.IsAuthenticationEnabled ? "Auth on" : "Auth off";

    private bool TryBuildRiskWarning(
        Guid? entryId,
        string label,
        string addressOrCidr,
        bool targetEnabled,
        bool targetAuthenticationEnabled,
        out string title,
        out string message,
        out string currentAccessWarning,
        out string recoveryWarning,
        out bool requiresTypedConfirmation)
    {
        if (targetEnabled && !targetAuthenticationEnabled)
        {
            title = string.Empty;
            message = string.Empty;
            currentAccessWarning = string.Empty;
            recoveryWarning = string.Empty;
            requiresTypedConfirmation = false;
            return false;
        }

        var plannedEntries = BuildPlannedTrustedNetworkEntries(
            entryId,
            label,
            addressOrCidr,
            targetEnabled,
            targetAuthenticationEnabled);

        PlannedAccessOutcome? currentSessionOutcome = null;
        if (IPAddress.TryParse(currentAccess.RemoteAddress, out var remoteAddress))
        {
            currentSessionOutcome = EvaluatePlannedAccess(plannedEntries, remoteAddress);
        }

        var loopbackIpv4Outcome = EvaluatePlannedAccess(plannedEntries, IPAddress.Loopback);
        var loopbackIpv6Outcome = EvaluatePlannedAccess(plannedEntries, IPAddress.IPv6Loopback);
        var hasDirectConsoleRecovery =
            loopbackIpv4Outcome == PlannedAccessOutcome.FullAccess ||
            loopbackIpv6Outcome == PlannedAccessOutcome.FullAccess;

        var currentSessionAffected =
            currentSessionOutcome.HasValue &&
            currentSessionOutcome.Value != PlannedAccessOutcome.FullAccess;
        var consoleRecoveryAffected = !hasDirectConsoleRecovery;

        if (!currentSessionAffected && !consoleRecoveryAffected)
        {
            title = string.Empty;
            message = string.Empty;
            currentAccessWarning = string.Empty;
            recoveryWarning = string.Empty;
            requiresTypedConfirmation = false;
            return false;
        }

        title = !targetEnabled ? "Disable access rule?" : "Enable authentication on this interface?";
        message = !targetEnabled
            ? "This change reduces access on a rule that Linux Made Sane is actively using."
            : "This change stops direct access and forces sign-in on a rule that Linux Made Sane is actively using.";

        currentAccessWarning = currentSessionAffected
            ? $"Current session after this change: {DescribePlannedAccess(currentSessionOutcome!.Value)} from {currentAccess.RemoteAddress}."
            : string.Empty;

        recoveryWarning = consoleRecoveryAffected
            ? $"Direct localhost recovery would no longer be available. Planned localhost state: 127.0.0.1 = {DescribePlannedAccess(loopbackIpv4Outcome)}, ::1 = {DescribePlannedAccess(loopbackIpv6Outcome)}. If this locks you out, log into the server console and run Linux Made Sane with unlock-security, then reopen http://127.0.0.1:5080 to fix LMS Accounts."
            : "If this browser session gets stranded, recover from the server console over localhost. If localhost access also fails, run Linux Made Sane with unlock-security.";

        requiresTypedConfirmation = true;
        return true;
    }

    private IReadOnlyList<TrustedNetworkEntry> BuildPlannedTrustedNetworkEntries(
        Guid? entryId,
        string label,
        string addressOrCidr,
        bool targetEnabled,
        bool targetAuthenticationEnabled)
    {
        var now = DateTimeOffset.UtcNow;
        var plannedEntries = page.TrustedNetworks
            .Select(entry => new TrustedNetworkEntry(
                entry.Id,
                entry.Label,
                entry.AddressOrCidr,
                entry.Description,
                entry.IsEnabled,
                entry.IsEnabled && !entry.IsAuthenticationEnabled,
                entry.IsAuthenticationEnabled,
                entry.IsBuiltIn,
                now,
                now))
            .ToList();

        var plannedRule = new TrustedNetworkEntry(
            entryId ?? Guid.NewGuid(),
            string.IsNullOrWhiteSpace(label) ? "Planned access rule" : label.Trim(),
            addressOrCidr.Trim(),
            string.Empty,
            targetEnabled,
            targetEnabled && !targetAuthenticationEnabled,
            targetAuthenticationEnabled,
            false,
            now,
            now);

        var existingIndex = entryId.HasValue
            ? plannedEntries.FindIndex(entry => entry.Id == entryId.Value)
            : -1;

        if (existingIndex >= 0)
        {
            var existing = plannedEntries[existingIndex];
            plannedEntries[existingIndex] = plannedRule with
            {
                Description = existing.Description,
                IsBuiltIn = existing.IsBuiltIn,
                CreatedAtUtc = existing.CreatedAtUtc
            };
        }
        else
        {
            plannedEntries.Add(plannedRule);
        }

        return plannedEntries;
    }

    private static PlannedAccessOutcome EvaluatePlannedAccess(
        IReadOnlyList<TrustedNetworkEntry> entries,
        IPAddress address)
    {
        var match = TrustedNetworkMatcher.Match(address, entries);
        if (match is null || !match.IsEnabled)
        {
            return PlannedAccessOutcome.Blocked;
        }

        return match.IsAuthenticationEnabled
            ? PlannedAccessOutcome.LoginRequired
            : PlannedAccessOutcome.FullAccess;
    }

    private static string DescribePlannedAccess(PlannedAccessOutcome outcome) =>
        outcome switch
        {
            PlannedAccessOutcome.FullAccess => "Full access",
            PlannedAccessOutcome.LoginRequired => "Login required",
            _ => "No access"
        };

    private void ShowNetworkRiskModal(
        string title,
        string message,
        string currentAccessWarning,
        string recoveryWarning,
        bool requiresTypedConfirmation,
        Func<Task> action)
    {
        networkRiskModalTitle = title;
        networkRiskModalMessage = message;
        networkRiskCurrentAccessWarning = currentAccessWarning;
        networkRiskRecoveryWarning = recoveryWarning;
        networkRiskRequiresTypedConfirmation = requiresTypedConfirmation;
        networkRiskAcknowledged = false;
        networkRiskConfirmationInput = string.Empty;
        pendingNetworkRiskAction = action;
        showNetworkRiskModal = true;
    }

    private Task CancelNetworkRiskAsync()
    {
        showNetworkRiskModal = false;
        pendingNetworkRiskAction = null;
        networkRiskModalMessage = string.Empty;
        networkRiskCurrentAccessWarning = string.Empty;
        networkRiskRecoveryWarning = string.Empty;
        networkRiskRequiresTypedConfirmation = false;
        networkRiskAcknowledged = false;
        networkRiskConfirmationInput = string.Empty;
        return Task.CompletedTask;
    }

    private async Task ConfirmNetworkRiskAsync()
    {
        var action = pendingNetworkRiskAction;
        showNetworkRiskModal = false;
        pendingNetworkRiskAction = null;
        networkRiskModalMessage = string.Empty;
        networkRiskCurrentAccessWarning = string.Empty;
        networkRiskRecoveryWarning = string.Empty;
        networkRiskRequiresTypedConfirmation = false;
        networkRiskAcknowledged = false;
        networkRiskConfirmationInput = string.Empty;
        if (action is not null)
        {
            await action();
        }
    }

    private async Task CreateUserAsync()
    {
        isSavingUser = true;
        userMessage = null;

        try
        {
            provisioningResult = await SecuritySettingsService.CreateUserAsync(userEditor);
            userEditor = new SecurityUserEditor();
            userMessage = "LMS account created. Finish authenticator setup in the authenticator app.";
            userMessageIsError = false;
            await LoadAsync();
        }
        catch (Exception exception)
        {
            userMessage = exception.Message;
            userMessageIsError = true;
        }
        finally
        {
            isSavingUser = false;
        }
    }

    private async Task ToggleUserAsync(SecurityUserViewModel user)
    {
        try
        {
            await SecuritySettingsService.SetUserEnabledAsync(user.Id, !user.IsEnabled);
            userMessage = user.IsEnabled ? "LMS account disabled." : "LMS account enabled.";
            userMessageIsError = false;
            await LoadAsync();
        }
        catch (Exception exception)
        {
            userMessage = exception.Message;
            userMessageIsError = true;
        }
    }

    private async Task ResetUserOtpAsync(SecurityUserViewModel user)
    {
        try
        {
            provisioningResult = await SecuritySettingsService.ResetUserOtpAsync(user.Id);
            userMessage = "Authenticator secret rotated. Re-register it in the authenticator app.";
            userMessageIsError = false;
            await LoadAsync();
        }
        catch (Exception exception)
        {
            userMessage = exception.Message;
            userMessageIsError = true;
        }
    }

    private async Task DeleteUserAsync(SecurityUserViewModel user)
    {
        try
        {
            await SecuritySettingsService.DeleteUserAsync(user.Id);
            if (provisioningResult?.UserId == user.Id)
            {
                provisioningResult = null;
            }

            userMessage = "LMS account deleted.";
            userMessageIsError = false;
            await LoadAsync();
        }
        catch (Exception exception)
        {
            userMessage = exception.Message;
            userMessageIsError = true;
        }
    }

    private static string FormatTimestamp(DateTimeOffset? value, string fallback) =>
        value?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? fallback;

    private sealed record LocalNetworkInterfaceView(
        string Id,
        string Name,
        string Description,
        string Type,
        string Status,
        string MacAddress,
        string Speed,
        IReadOnlyList<NetworkAddressView> Addresses,
        IReadOnlyList<string> Gateways,
        IReadOnlyList<string> DnsServers)
    {
        public bool IsUp => Status.Equals("Up", StringComparison.OrdinalIgnoreCase);
    }

    private sealed record NetworkAddressView(IPAddress Address, string Family, int PrefixLength)
    {
        public string Display => PrefixLength > 0 ? $"{Address}/{PrefixLength}" : Address.ToString();
    }

    private enum PlannedAccessOutcome
    {
        FullAccess,
        LoginRequired,
        Blocked
    }
