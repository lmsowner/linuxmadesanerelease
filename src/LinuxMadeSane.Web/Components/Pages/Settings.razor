@page "/settings"
@rendermode InteractiveServer
@using System.Net
@using System.Net.NetworkInformation
@using System.Net.Sockets
@using LinuxMadeSane.Application.Interfaces
@using LinuxMadeSane.Application.Services
@using LinuxMadeSane.Core.Abstractions
@using LinuxMadeSane.Core.Models
@using Microsoft.AspNetCore.Components.Forms
@inject ISecuritySettingsService SecuritySettingsService
@inject ITrustedNetworkAccessService TrustedNetworkAccessService

<PageTitle>LMS Security | Linux Made Sane</PageTitle>

<div class="page-shell">
    <UiHeroPanel Title="LMS Security" Compact="true" />

    @if (!isLoaded)
    {
        <section class="surface-card">
            <p class="meta-text">Loading LMS account settings...</p>
        </section>
    }
    else
    {
        <TabControl ActiveValue="@activeTab"
                    ActiveValueChanged="HandleTabChangedAsync"
                    Class="page-tab-control security-tab-control"
                    PanelClass="page-tab-panel security-tab-panel">
            <ChildContent>
                <TabPage Value="@TrustedNetworksTabValue" Title="Network Interfaces">
                    <Header>
                        <div class="security-tab-header">
                            <span class="security-tab-title">Network Interfaces</span>
                            <span class="security-tab-count">@networkInterfaces.Count</span>
                        </div>
                    </Header>
                    <ChildContent>
                        <div class="security-tab-content network-interface-content">
                            <div class="section-heading">
                                <div>
                                    <p class="eyebrow">Interface access</p>
                                    <h2>Grouped by NIC</h2>
                                    <p class="meta-text">Each local network interface shows the access rules covering its addresses. A rule can allow direct access, require sign-in, or be disabled.</p>
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(networkMessage))
                            {
                                <p class="callout @(networkMessageIsError ? "error" : "success")">@networkMessage</p>
                            }

                            <details class="surface-subcard security-network-editor" open="@IsNetworkEditorOpen">
                                <summary>
                                    <span>
                                        <strong>@(networkEditor.Id.HasValue ? "Edit access rule" : "Add access rule")</strong>
                                        <span class="meta-text">CIDR rules control direct access, username + OTP, or no access for matching networks.</span>
                                    </span>
                                    <span class="status-pill neutral">@(page.TrustedNetworks.Count) rules</span>
                                </summary>

                                <EditForm Model="@networkEditor" OnValidSubmit="SaveNetworkAsync" class="stack-form security-network-editor-form">
                                    <DataAnnotationsValidator />

                                    <div class="field-row">
                                        <UiTextField @bind-Value="networkEditor.Label" Label="Label" />
                                        <UiTextField @bind-Value="networkEditor.AddressOrCidr" Label="Address or CIDR" />
                                    </div>

                                    <UiTextField @bind-Value="networkEditor.Description" Label="Description" />

                                    <div class="field-row">
                                        <UiCheckboxField @bind-Value="networkEditor.IsEnabled" Label="Rule enabled" />
                                        <UiCheckboxField @bind-Value="networkEditor.IsAuthenticationEnabled" Label="Authentication enabled" Helper="Require username or email plus OTP before allowing access." />
                                    </div>

                                    <div class="toolbar-row">
                                        <UiCommandButton Label="@(isSavingNetwork ? "Saving..." : networkEditor.Id.HasValue ? "Save rule" : "Add rule")"
                                                         Glyph="@(networkEditor.Id.HasValue ? UiIconGlyph.Connect : UiIconGlyph.Plus)"
                                                         Type="submit"
                                                         Disabled="@isSavingNetwork" />
                                        @if (networkEditor.Id.HasValue)
                                        {
                                            <UiCommandButton Label="Cancel edit" Glyph="UiIconGlyph.Clear" Variant="UiButtonVariant.Ghost" OnClick="CancelNetworkEditAsync" />
                                        }
                                    </div>
                                </EditForm>
                            </details>

                            @if (networkInterfaces.Count == 0)
                            {
                                <div class="empty-state">
                                    <h3>No network interfaces were reported</h3>
                                    <p>The saved access rule list is still available in the additional ranges section below.</p>
                                </div>
                            }
                            else
                            {
                                <div class="network-interface-list">
                                    @foreach (var networkInterface in networkInterfaces)
                                    {
                                        var interfaceRanges = GetTrustedNetworksForInterface(networkInterface);

                                        <article class="surface-subcard network-interface-card">
                                            <div class="network-interface-header">
                                                <div class="network-interface-heading">
                                                    <span class="network-interface-status-dot @(networkInterface.IsUp ? "up" : "down")" aria-hidden="true"></span>
                                                    <div>
                                                        <h3>@networkInterface.Name</h3>
                                                        <p>@networkInterface.Description</p>
                                                    </div>
                                                </div>

                                                <div class="token-row compact-token-row">
                                                    <span class="status-pill @(networkInterface.IsUp ? "success" : "neutral")">@networkInterface.Status</span>
                                                    <span class="status-pill neutral">@networkInterface.Type</span>
                                                    <span class="status-pill neutral">@interfaceRanges.Count rule(s)</span>
                                                </div>
                                            </div>

                                            <div class="network-address-strip">
                                                @foreach (var address in GetPrimaryAddresses(networkInterface))
                                                {
                                                    <code>@address.Display</code>
                                                }
                                            </div>

                                            @if (interfaceRanges.Count == 0)
                                            {
                                                <p class="meta-text">No access rules currently match this NIC address.</p>
                                            }
                                            else
                                            {
                                                <div class="trusted-range-list">
                                                    @foreach (var entry in interfaceRanges)
                                                    {
                                                        <div class="trusted-range-row @(!entry.IsEnabled ? "trusted-range-row-disabled" : string.Empty)">
                                                            <div class="trusted-range-main">
                                                                <strong>@entry.Label</strong>
                                                                <code>@entry.AddressOrCidr</code>
                                                                @if (!string.IsNullOrWhiteSpace(entry.Description))
                                                                {
                                                                    <span class="meta-text">@entry.Description</span>
                                                                }
                                                            </div>
                                                            <div class="trusted-range-access">
                                                                @if (entry.IsEnabled)
                                                                {
                                                                    <div class="trusted-range-pill-row">
                                                                        <span class="status-pill @GetTrustedNetworkAccessPillClass(entry)">@GetTrustedNetworkAccessSummary(entry)</span>
                                                                        <span class="status-pill success">@GetTrustedNetworkAuthPillText(entry)</span>
                                                                    </div>
                                                                }
                                                                else
                                                                {
                                                                    <span class="status-pill @GetTrustedNetworkAccessPillClass(entry)">@GetTrustedNetworkAccessSummary(entry)</span>
                                                                }
                                                                @if (!string.IsNullOrWhiteSpace(GetTrustedNetworkAccessMeta(entry)))
                                                                {
                                                                    <span class="meta-text">@GetTrustedNetworkAccessMeta(entry)</span>
                                                                }
                                                            </div>
                                                            @if (entry.IsEnabled)
                                                            {
                                                                <div class="trusted-range-meta">
                                                                    <span class="status-pill neutral">@(entry.IsBuiltIn ? "Built-in" : "Custom")</span>
                                                                </div>
                                                            }
                                                            <div class="trusted-range-actions">
                                                                @if (!entry.IsBuiltIn && entry.IsEnabled)
                                                                {
                                                                    <UiCommandButton Label="Edit"
                                                                                     Glyph="UiIconGlyph.Edit"
                                                                                     Variant="UiButtonVariant.Action"
                                                                                     OnClick="@(() => BeginNetworkEdit(entry))"
                                                                                     Disabled="@(!entry.IsEnabled)" />
                                                                }
                                                                @if (entry.IsEnabled)
                                                                {
                                                                    <UiCommandButton Label="@(entry.IsAuthenticationEnabled ? "Auth off" : "Auth on")"
                                                                                     Glyph="@(entry.IsAuthenticationEnabled ? UiIconGlyph.Disconnect : UiIconGlyph.Connect)"
                                                                                     Variant="UiButtonVariant.Action"
                                                                                     OnClick="@(() => ToggleAuthenticationAccessAsync(entry))"
                                                                                     Disabled="@(!entry.IsEnabled)" />
                                                                }
                                                                <UiCommandButton Label="@(entry.IsEnabled ? "Disable" : "Enable")"
                                                                                 Glyph="@(entry.IsEnabled ? UiIconGlyph.Disconnect : UiIconGlyph.Connect)"
                                                                                 Variant="UiButtonVariant.Action"
                                                                                 OnClick="@(() => ToggleTrustedNetworkAsync(entry))" />
                                                                @if (!entry.IsBuiltIn && entry.IsEnabled)
                                                                {
                                                                    <UiCommandButton Label="Delete"
                                                                                     Glyph="UiIconGlyph.Delete"
                                                                                     Variant="UiButtonVariant.Danger"
                                                                                     OnClick="@(() => DeleteTrustedNetworkAsync(entry))"
                                                                                     Disabled="@(!entry.IsEnabled)" />
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }

                                            <details class="network-interface-details">
                                                <summary>
                                                    <span>Interface details</span>
                                                    <span class="meta-text">addresses, DNS, gateway, MAC, speed</span>
                                                </summary>

                                                <dl class="network-interface-detail-grid">
                                                    <div>
                                                        <dt>Interface ID</dt>
                                                        <dd>@networkInterface.Id</dd>
                                                    </div>
                                                    <div>
                                                        <dt>MAC</dt>
                                                        <dd>@networkInterface.MacAddress</dd>
                                                    </div>
                                                    <div>
                                                        <dt>Speed</dt>
                                                        <dd>@networkInterface.Speed</dd>
                                                    </div>
                                                    <div>
                                                        <dt>Addresses</dt>
                                                        <dd>@FormatAddressList(networkInterface.Addresses)</dd>
                                                    </div>
                                                    <div>
                                                        <dt>Gateways</dt>
                                                        <dd>@FormatStringList(networkInterface.Gateways)</dd>
                                                    </div>
                                                    <div>
                                                        <dt>DNS</dt>
                                                        <dd>@FormatStringList(networkInterface.DnsServers)</dd>
                                                    </div>
                                                </dl>
                                            </details>
                                        </article>
                                    }
                                </div>
                            }

                        </div>
                    </ChildContent>
                </TabPage>

                <TabPage Value="@RemoteAccessUsersTabValue" Title="LMS Accounts">
                    <Header>
                        <div class="security-tab-header">
                            <span class="security-tab-title">LMS Accounts</span>
                            <span class="security-tab-count">@(page.Users.Count)</span>
                        </div>
                    </Header>
                    <ChildContent>
                        <div class="security-tab-content remote-access-content">
                            <div class="section-heading">
                                <div>
                                    <p class="eyebrow">LMS accounts</p>
                                    <h2>Accounts and authenticator access</h2>
                                    <p class="meta-text">Create LMS accounts with email-based sign-in and authenticator OTP. These accounts identify the operator; dedicated runner access controls what LMS can execute on a machine.</p>
                                </div>
                            </div>

                            <section class="surface-subcard security-runner-access-panel">
                                <div class="security-runner-access-copy">
                                    <p class="eyebrow">Automation trust model</p>
                                    <h3>Privileged automation is explicit</h3>
                                    <p>LMS is a control plane. If you want terminals, runbooks, patching, service management, and repair workflows to run without password prompts, the target machine needs a dedicated LMS runner account with key-based login and passwordless sudo.</p>
                                    <p>LMS treats that as an intentional grant of elevated control. Secrets are stored through the protected secret store, sudo automation is non-interactive, and privileged workflows should be traceable back to the signed-in LMS account that requested them.</p>
                                </div>

                                <div class="security-runner-access-pills">
                                    <span class="status-pill neutral">Dedicated runner</span>
                                    <span class="status-pill neutral">Public key login</span>
                                    <span class="status-pill warning">sudo -n</span>
                                    <span class="status-pill neutral">Operator traceability</span>
                                </div>
                            </section>

                            @if (!string.IsNullOrWhiteSpace(userMessage))
                            {
                                <p class="callout @(userMessageIsError ? "error" : "success")">@userMessage</p>
                            }

                            <section class="surface-subcard remote-access-create-panel">
                                <div class="remote-access-panel-heading">
                                    <div>
                                        <h3>Create LMS account</h3>
                                        <p>Create an LMS account and issue the authenticator QR for app access.</p>
                                    </div>
                                    <span class="status-pill neutral">Email + OTP</span>
                                </div>

                                <EditForm Model="@userEditor" OnValidSubmit="CreateUserAsync" class="stack-form">
                                    <DataAnnotationsValidator />

                                    <UiTextField @bind-Value="userEditor.Email"
                                                 Label="Email"
                                                 Type="email"
                                                 Helper="Used for Linux Made Sane sign-in and OTP verification." />

                                    <div class="toolbar-row">
                                        <UiCommandButton Label="@(isSavingUser ? "Registering..." : "Register account")"
                                                         Glyph="UiIconGlyph.Plus"
                                                         Type="submit"
                                                         Disabled="@isSavingUser" />
                                    </div>
                                </EditForm>
                            </section>

                            @if (provisioningResult is not null)
                            {
                                <div class="surface-subcard otp-provisioning-panel remote-access-provisioning-panel">
                                    <UiQrCode Payload="@provisioningResult.OtpUri"
                                              Class="otp-provisioning-qr"
                                              Title="Authenticator setup QR"
                                              AriaLabel="Authenticator setup QR"
                                              Caption="Scan this in your authenticator app" />

                                    <div class="stack-list">
                                        <ServiceMetricComponent TagName="div" Label="Provisioned email" Value="@provisioningResult.Email" />
                                        <ServiceMetricComponent TagName="div" Label="Manual key" Value="@provisioningResult.ManualEntryKey" />
                                        <ServiceMetricComponent TagName="div" Label="OTP URI" Value="@provisioningResult.OtpUri" />
                                        <p class="meta-text">Scan the QR code or enter the manual key in your authenticator app. If you reset OTP, the new QR is shown here again.</p>
                                    </div>
                                </div>
                            }

                            @if (page.Users.Count == 0)
                            {
                                <div class="empty-state">
                                    <h3>No LMS accounts</h3>
                                    <p>Create at least one LMS account before enabling authenticated access on interfaces that should require sign-in.</p>
                                </div>
                            }
                            else
                            {
                                <table class="remote-access-user-table">
                                    <thead>
                                        <tr>
                                            <th>Account</th>
                                            <th>Status</th>
                                            <th>Last login</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var user in page.Users)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@user.Email</strong>
                                                    @if (!user.HasOtpSecret)
                                                    {
                                                        <div class="meta-text">Authenticator secret missing</div>
                                                    }
                                                </td>
                                                <td>
                                                    <div class="remote-access-status-stack">
                                                        <span class="status-pill @(user.IsEnabled ? "success" : "neutral")">@(user.IsEnabled ? "Enabled" : "Disabled")</span>
                                                        <span class="status-pill @(user.HasOtpSecret ? "neutral" : "warning")">@(user.HasOtpSecret ? "OTP ready" : "OTP missing")</span>
                                                    </div>
                                                </td>
                                                <td>@FormatTimestamp(user.LastLoginAtUtc, "Never")</td>
                                                <td class="actions-cell">
                                                    <UiCommandButton Label="@(user.IsEnabled ? "Disable" : "Enable")"
                                                                     Glyph="@(user.IsEnabled ? UiIconGlyph.Disconnect : UiIconGlyph.Connect)"
                                                                     Variant="UiButtonVariant.Action"
                                                                     OnClick="@(() => ToggleUserAsync(user))" />
                                                    <UiCommandButton Label="Reset OTP" Glyph="UiIconGlyph.Refresh" Variant="UiButtonVariant.Action" OnClick="@(() => ResetUserOtpAsync(user))" />
                                                    <UiCommandButton Label="Delete" Glyph="UiIconGlyph.Delete" Variant="UiButtonVariant.Danger" OnClick="@(() => DeleteUserAsync(user))" />
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </ChildContent>
                </TabPage>
            </ChildContent>
        </TabControl>
    }
</div>

<UiModal IsOpen="@showNetworkRiskModal"
         Title="@networkRiskModalTitle"
         CloseOnBackdrop="false"
         OnClose="CancelNetworkRiskAsync">
    <ChildContent>
        <div class="stack-form">
            <p class="callout warning">@networkRiskModalMessage</p>
            @if (!string.IsNullOrWhiteSpace(networkRiskCurrentAccessWarning))
            {
                <p class="callout warning">@networkRiskCurrentAccessWarning</p>
            }
            @if (!string.IsNullOrWhiteSpace(networkRiskRecoveryWarning))
            {
                <p class="callout error">@networkRiskRecoveryWarning</p>
            }
            @if (networkRiskRequiresTypedConfirmation)
            {
                <UiCheckboxField @bind-Value="networkRiskAcknowledged"
                                 Label="I understand this can strand the current session or remove direct localhost access." />
                <UiTextField @bind-Value="networkRiskConfirmationInput"
                             Label="Type UNLOCK to continue"
                             Helper="If you lose access, log into the server and run Linux Made Sane with unlock-security from the server console." />
            }
            <div class="toolbar-row">
                <UiCommandButton Label="Apply risky change"
                                 Glyph="UiIconGlyph.Connect"
                                 OnClick="ConfirmNetworkRiskAsync"
                                 Disabled="@(!IsNetworkRiskConfirmationSatisfied)" />
                <UiCommandButton Label="Cancel"
                                 Glyph="UiIconGlyph.Clear"
                                 Variant="UiButtonVariant.Ghost"
                                 OnClick="CancelNetworkRiskAsync" />
            </div>
        </div>
    </ChildContent>
</UiModal>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private SecuritySettingsPageViewModel page = new([], []);
    private IReadOnlyList<LocalNetworkInterfaceView> networkInterfaces = [];
    private TrustedNetworkAccessResult currentAccess = new("unknown", "unknown", false, null, false, false, false, false, false);
    private TrustedNetworkEntryEditor networkEditor = new();
    private SecurityUserEditor userEditor = new();
    private SecurityUserProvisioningViewModel? provisioningResult;
    private bool isLoaded;
    private bool isSavingNetwork;
    private bool isSavingUser;
    private string? networkMessage;
    private bool networkMessageIsError;
    private string? userMessage;
    private bool userMessageIsError;
    private string activeTab = TrustedNetworksTabValue;
    private bool showNetworkRiskModal;
    private string networkRiskModalTitle = "Confirm security change";
    private string networkRiskModalMessage = string.Empty;
    private string networkRiskCurrentAccessWarning = string.Empty;
    private string networkRiskRecoveryWarning = string.Empty;
    private Func<Task>? pendingNetworkRiskAction;
    private bool networkRiskRequiresTypedConfirmation;
    private bool networkRiskAcknowledged;
    private string networkRiskConfirmationInput = string.Empty;

    private const string TrustedNetworksTabValue = "trusted-networks";
    private const string RemoteAccessUsersTabValue = "remote-access-users";

    private bool IsNetworkRiskConfirmationSatisfied =>
        !networkRiskRequiresTypedConfirmation ||
        (networkRiskAcknowledged &&
         string.Equals(networkRiskConfirmationInput?.Trim(), "UNLOCK", StringComparison.Ordinal));

    private bool IsNetworkEditorOpen =>
        networkEditor.Id.HasValue || page.TrustedNetworks.Count == 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        isLoaded = true;
    }

    private async Task LoadAsync()
    {
        page = await SecuritySettingsService.GetPageAsync();
        networkInterfaces = LoadNetworkInterfaces();
        currentAccess = await TrustedNetworkAccessService.EvaluateAsync(
            HttpContext?.Connection.RemoteIpAddress,
            HttpContext?.Request.Host.Host);
    }

    private Task HandleTabChangedAsync(string? value)
    {
        activeTab = string.IsNullOrWhiteSpace(value) ? TrustedNetworksTabValue : value;
        return Task.CompletedTask;
    }

    private async Task SaveNetworkAsync()
    {
        if (TryBuildRiskWarning(
                networkEditor.Id,
                networkEditor.Label,
                networkEditor.AddressOrCidr,
                networkEditor.IsEnabled,
                networkEditor.IsAuthenticationEnabled,
                out var warningTitle,
                out var warningMessage,
                out var currentAccessWarning,
                out var recoveryWarning,
                out var requiresTypedConfirmation))
        {
            ShowNetworkRiskModal(
                warningTitle,
                warningMessage,
                currentAccessWarning,
                recoveryWarning,
                requiresTypedConfirmation,
                SaveNetworkCoreAsync);
            return;
        }

        await SaveNetworkCoreAsync();
    }

    private async Task SaveNetworkCoreAsync()
    {
        isSavingNetwork = true;
        networkMessage = null;

        try
        {
            await SecuritySettingsService.SaveTrustedNetworkAsync(networkEditor);
            networkMessage = networkEditor.Id.HasValue ? "Access rule updated." : "Access rule added.";
            networkMessageIsError = false;
            networkEditor = new TrustedNetworkEntryEditor();
            await LoadAsync();
        }
        catch (Exception exception)
        {
            networkMessage = exception.Message;
            networkMessageIsError = true;
        }
        finally
        {
            isSavingNetwork = false;
        }
    }

    private Task CancelNetworkEditAsync()
    {
        networkEditor = new TrustedNetworkEntryEditor();
        return Task.CompletedTask;
    }

    private void BeginNetworkEdit(TrustedNetworkEntryViewModel entry)
    {
        networkEditor = new TrustedNetworkEntryEditor
        {
            Id = entry.Id,
            Label = entry.Label,
            AddressOrCidr = entry.AddressOrCidr,
            Description = entry.Description,
            IsEnabled = entry.IsEnabled,
            IsTrustedAccessEnabled = entry.IsTrustedAccessEnabled,
            IsAuthenticationEnabled = entry.IsAuthenticationEnabled
        };
    }

    private async Task ToggleTrustedNetworkAsync(TrustedNetworkEntryViewModel entry)
    {
        var targetEnabled = !entry.IsEnabled;
        if (TryBuildRiskWarning(
                entry.Id,
                entry.Label,
                entry.AddressOrCidr,
                targetEnabled,
                entry.IsAuthenticationEnabled,
                out var warningTitle,
                out var warningMessage,
                out var currentAccessWarning,
                out var recoveryWarning,
                out var requiresTypedConfirmation))
        {
            ShowNetworkRiskModal(
                warningTitle,
                warningMessage,
                currentAccessWarning,
                recoveryWarning,
                requiresTypedConfirmation,
                () => ToggleTrustedNetworkCoreAsync(entry));
            return;
        }

        await ToggleTrustedNetworkCoreAsync(entry);
    }

    private async Task ToggleTrustedNetworkCoreAsync(TrustedNetworkEntryViewModel entry)
    {
        try
        {
            await SecuritySettingsService.SetTrustedNetworkEnabledAsync(entry.Id, !entry.IsEnabled);
            networkMessage = entry.IsEnabled ? "Access rule disabled." : "Access rule enabled.";
            networkMessageIsError = false;
            await LoadAsync();
        }
        catch (Exception exception)
        {
            networkMessage = exception.Message;
            networkMessageIsError = true;
        }
    }

    private async Task ToggleAuthenticationAccessAsync(TrustedNetworkEntryViewModel entry)
    {
        var targetAuthenticationEnabled = !entry.IsAuthenticationEnabled;
        if (TryBuildRiskWarning(
                entry.Id,
                entry.Label,
                entry.AddressOrCidr,
                entry.IsEnabled,
                targetAuthenticationEnabled,
                out var warningTitle,
                out var warningMessage,
                out var currentAccessWarning,
                out var recoveryWarning,
                out var requiresTypedConfirmation))
        {
            ShowNetworkRiskModal(
                warningTitle,
                warningMessage,
                currentAccessWarning,
                recoveryWarning,
                requiresTypedConfirmation,
                () => ToggleAuthenticationAccessCoreAsync(entry));
            return;
        }

        await ToggleAuthenticationAccessCoreAsync(entry);
    }

    private async Task ToggleAuthenticationAccessCoreAsync(TrustedNetworkEntryViewModel entry)
    {
        try
        {
            await SecuritySettingsService.SetTrustedNetworkAuthenticationEnabledAsync(entry.Id, !entry.IsAuthenticationEnabled);
            networkMessage = entry.IsAuthenticationEnabled ? "Authenticated access disabled." : "Authenticated access enabled.";
            networkMessageIsError = false;
            await LoadAsync();
        }
        catch (Exception exception)
        {
            networkMessage = exception.Message;
            networkMessageIsError = true;
        }
    }

    private async Task DeleteTrustedNetworkAsync(TrustedNetworkEntryViewModel entry)
    {
        try
        {
            await SecuritySettingsService.DeleteTrustedNetworkAsync(entry.Id);
            networkMessage = "Access rule deleted.";
            networkMessageIsError = false;
            if (networkEditor.Id == entry.Id)
            {
                networkEditor = new TrustedNetworkEntryEditor();
            }

            await LoadAsync();
        }
        catch (Exception exception)
        {
            networkMessage = exception.Message;
            networkMessageIsError = true;
        }
    }

    private IReadOnlyList<TrustedNetworkEntryViewModel> GetTrustedNetworksForInterface(LocalNetworkInterfaceView networkInterface) =>
        page.TrustedNetworks
            .Where(entry => NetworkEntryMatchesInterface(entry, networkInterface))
            .ToArray();

    private static bool NetworkEntryMatchesInterface(TrustedNetworkEntryViewModel entry, LocalNetworkInterfaceView networkInterface) =>
        networkInterface.Addresses.Any(address => TrustedNetworkContainsAddress(entry.AddressOrCidr, address.Address));

    private static IReadOnlyList<NetworkAddressView> GetPrimaryAddresses(LocalNetworkInterfaceView networkInterface) =>
        networkInterface.Addresses
            .OrderBy(address => address.Family == "IPv4" ? 0 : 1)
            .ThenBy(address => address.Address.ToString(), StringComparer.OrdinalIgnoreCase)
            .Take(4)
            .ToArray();

    private static IReadOnlyList<LocalNetworkInterfaceView> LoadNetworkInterfaces()
    {
        try
        {
            return NetworkInterface.GetAllNetworkInterfaces()
                .Select(BuildNetworkInterfaceView)
                .OrderByDescending(networkInterface => networkInterface.IsUp)
                .ThenBy(networkInterface => networkInterface.Type == "Loopback" ? 1 : 0)
                .ThenBy(networkInterface => networkInterface.Name, StringComparer.OrdinalIgnoreCase)
                .ToArray();
        }
        catch
        {
            return [];
        }
    }

    private static LocalNetworkInterfaceView BuildNetworkInterfaceView(NetworkInterface networkInterface)
    {
        var properties = GetIPProperties(networkInterface);
        var addresses = properties?.UnicastAddresses
            .Select(address => new NetworkAddressView(NormalizeAddress(address.Address), GetAddressFamilyLabel(address.Address), address.PrefixLength))
            .Where(address => IsUsefulAddress(address.Address))
            .ToArray() ?? [];

        var gateways = properties?.GatewayAddresses
            .Select(address => NormalizeAddress(address.Address).ToString())
            .Where(static value => !string.IsNullOrWhiteSpace(value))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray() ?? [];

        var dnsServers = properties?.DnsAddresses
            .Select(address => NormalizeAddress(address).ToString())
            .Where(static value => !string.IsNullOrWhiteSpace(value))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray() ?? [];

        return new LocalNetworkInterfaceView(
            networkInterface.Id,
            networkInterface.Name,
            string.IsNullOrWhiteSpace(networkInterface.Description) ? networkInterface.Name : networkInterface.Description,
            networkInterface.NetworkInterfaceType.ToString(),
            networkInterface.OperationalStatus.ToString(),
            FormatMacAddress(networkInterface.GetPhysicalAddress()),
            FormatLinkSpeed(networkInterface.Speed),
            addresses,
            gateways,
            dnsServers);
    }

    private static IPInterfaceProperties? GetIPProperties(NetworkInterface networkInterface)
    {
        try
        {
            return networkInterface.GetIPProperties();
        }
        catch
        {
