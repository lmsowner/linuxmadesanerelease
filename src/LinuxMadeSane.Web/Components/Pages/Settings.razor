        minutes = SecuritySessionPolicy.NormalizeSessionLifetimeMinutes(user.SessionLifetimeMinutes);
        sessionLifetimeEditors[user.Id] = minutes;
        return minutes;
    }

    private void SetSessionLifetimeEditorPart(
        Guid userId,
        SessionLifetimePart part,
        ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var value))
        {
            return;
        }

        var currentMinutes = sessionLifetimeEditors.TryGetValue(userId, out var minutes)
            ? minutes
            : SecuritySessionPolicy.DefaultSessionLifetimeMinutes;
        sessionLifetimeEditors[userId] = BuildSessionLifetimeMinutes(currentMinutes, part, value);
    }

