    private async Task SaveUserSettingsAsync(SecurityUserViewModel user)
    {
        var linuxUsername = GetLinuxUsernameEditor(user).Trim();
        if (string.IsNullOrWhiteSpace(linuxUsername))
        {
            userMessage = "Enter the Linux user this LMS account should use.";
            userMessageIsError = true;
            return;
        }

        if (!sessionLifetimeEditors.TryGetValue(user.Id, out var minutes))
        {
            minutes = user.SessionLifetimeMinutes;
        }

        savingLinuxUsernames.Add(user.Id);
        savingSessionLifetimes.Add(user.Id);
        userMessage = null;

        try
        {
            var normalizedMinutes = SecuritySessionPolicy.NormalizeSessionLifetimeMinutes(minutes);
            var editor = await SecuritySettingsService.GetUserEditorAsync(user.Id);
            editor.LinuxUsername = linuxUsername;
            editor.SessionLifetimeMinutes = normalizedMinutes;
            await SecuritySettingsService.SaveUserAsync(editor);
            sessionLifetimeEditors[user.Id] = normalizedMinutes;
            userMessage = $"Saved account settings for {user.Email}.";
            userMessageIsError = false;
            await LoadAsync();
        }
        catch (Exception exception)
        {
            userMessage = exception.Message;
            userMessageIsError = true;
        }
        finally
        {
            savingLinuxUsernames.Remove(user.Id);
            savingSessionLifetimes.Remove(user.Id);
        }
    }

    private bool IsSavingUserSettings(Guid userId) =>
        savingLinuxUsernames.Contains(userId) ||
        savingSessionLifetimes.Contains(userId);

