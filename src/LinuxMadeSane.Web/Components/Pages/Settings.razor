    private string BuildLmsLoginUrl(string? email)
    {
        var loginUri = new Uri(new Uri(Navigation.BaseUri), "login");
        if (string.IsNullOrWhiteSpace(email))
        {
            return loginUri.ToString();
        }

        var builder = new UriBuilder(loginUri)
        {
            Query = $"email={Uri.EscapeDataString(email.Trim())}"
        };
        return builder.Uri.ToString();
    }

