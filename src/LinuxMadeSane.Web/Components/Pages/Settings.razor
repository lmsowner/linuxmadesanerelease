</div>

<UiModal IsOpen="@showNetworkRiskModal"
         Title="@networkRiskModalTitle"
         CloseOnBackdrop="false"
         OnClose="CancelNetworkRiskAsync">
    <ChildContent>
        <div class="stack-form">
            <p class="callout warning">@networkRiskModalMessage</p>
            @if (!string.IsNullOrWhiteSpace(networkRiskCurrentAccessWarning))
            {
                <p class="callout warning">@networkRiskCurrentAccessWarning</p>
            }
            @if (!string.IsNullOrWhiteSpace(networkRiskRecoveryWarning))
            {
                <p class="callout error">@networkRiskRecoveryWarning</p>
            }
            @if (networkRiskRequiresTypedConfirmation)
            {
                <UiCheckboxField @bind-Value="networkRiskAcknowledged"
                                 Label="I understand this can strand the current session or remove direct localhost access." />
                <UiTextField @bind-Value="networkRiskConfirmationInput"
                             Label="Type UNLOCK to continue"
                             Helper="If you lose access, log into the server and run Linux Made Sane with unlock-security from the server console." />
            }
            <div class="toolbar-row">
                <UiCommandButton Label="Apply risky change"
                                 Glyph="UiIconGlyph.Connect"
                                 OnClick="ConfirmNetworkRiskAsync"
                                 Disabled="@(!IsNetworkRiskConfirmationSatisfied)" />
                <UiCommandButton Label="Cancel"
                                 Glyph="UiIconGlyph.Clear"
                                 Variant="UiButtonVariant.Ghost"
                                 OnClick="CancelNetworkRiskAsync" />
            </div>
        </div>
    </ChildContent>
</UiModal>

<UiModal IsOpen="@showGraphHelpModal"
         Title="Microsoft Graph email setup"
         Subtitle="Create a small Entra app registration for LMS email delivery."
         Class="security-graph-help-modal"
         OnClose="CloseGraphHelpModal">
    <ChildContent>
        <div class="security-graph-help-body">
            <p class="callout warning">Use a dedicated mailbox for LMS. Microsoft Graph <code>Mail.Send</code> as an application permission is broad until your Microsoft 365 admin restricts it to the LMS sender mailbox.</p>

            <section class="surface-subcard security-graph-help-section">
                <h3>1. Create the Entra app</h3>
                <ol class="security-graph-help-steps">
                    <li>Open Microsoft Entra admin center.</li>
                    <li>Go to <strong>Applications -> App registrations -> New registration</strong>.</li>
                    <li>Name it something obvious, for example <strong>Linux Made Sane Mail</strong>.</li>
                    <li>Set supported account type to <strong>Accounts in this organizational directory only</strong>.</li>
                    <li>Leave redirect URI blank. LMS uses client credentials, not an interactive Microsoft login.</li>
                    <li>After creation, copy <strong>Application (client) ID</strong> and <strong>Directory (tenant) ID</strong>.</li>
                </ol>
            </section>

            <section class="surface-subcard security-graph-help-section">
                <h3>2. Add the Graph permission</h3>
                <ol class="security-graph-help-steps">
                    <li>Open the app registration, then <strong>API permissions -> Add a permission -> Microsoft Graph</strong>.</li>
                    <li>Choose <strong>Application permissions</strong>. Do not choose delegated permissions.</li>
                    <li>Add <strong>Mail.Send</strong>.</li>
                    <li>Click <strong>Grant admin consent</strong> for the tenant.</li>
                </ol>
            </section>

            <section class="surface-subcard security-graph-help-section">
                <h3>3. Create the secret</h3>
                <ol class="security-graph-help-steps">
                    <li>Open <strong>Certificates & secrets -> Client secrets -> New client secret</strong>.</li>
                    <li>Use a clear name, for example <strong>LMS email delivery</strong>.</li>
                    <li>Copy the secret <strong>Value</strong> immediately. Do not copy the Secret ID.</li>
                    <li>Paste the value into LMS. It is stored in the protected LMS secret store.</li>
                </ol>
            </section>

            <section class="surface-subcard security-graph-help-section">
                <h3>4. Fill in LMS</h3>
                <div class="security-graph-help-points">
                    <div class="security-graph-help-point">
                        <strong>Provider</strong>
                        <span>Microsoft Graph</span>
                    </div>
                    <div class="security-graph-help-point">
                        <strong>Sender email</strong>
                        <span>The mailbox LMS sends from, for example <code>serviceaccount@example.com</code>.</span>
                    </div>
                    <div class="security-graph-help-point">
                        <strong>Tenant ID</strong>
                        <span>Directory (tenant) ID from the app overview.</span>
                    </div>
                    <div class="security-graph-help-point">
                        <strong>Client ID</strong>
                        <span>Application (client) ID from the app overview.</span>
                    </div>
                    <div class="security-graph-help-point">
                        <strong>Client secret</strong>
                        <span>The secret Value, not the Secret ID.</span>
                    </div>
                    <div class="security-graph-help-point">
                        <strong>Authority</strong>
                        <span><code>https://login.microsoftonline.com/</code></span>
                    </div>
                    <div class="security-graph-help-point">
                        <strong>Graph base URL</strong>
                        <span><code>https://graph.microsoft.com/v1.0</code></span>
                    </div>
                </div>
            </section>

            <section class="surface-subcard security-graph-help-section">
                <h3>5. Restrict the mailbox</h3>
                <p class="meta-text">Strongly recommended: restrict the app so it can only send as the LMS mailbox. The simplest Exchange Online route is an application access policy scoped to a mail-enabled security group containing the LMS sender mailbox.</p>
                <pre class="security-graph-help-code"><code>Connect-ExchangeOnline
New-ApplicationAccessPolicy -AppId &lt;client-id&gt; -PolicyScopeGroupId &lt;mail-enabled-security-group&gt; -AccessRight RestrictAccess -Description "Restrict Linux Made Sane mail sender"
Test-ApplicationAccessPolicy -Identity serviceaccount@example.com -AppId &lt;client-id&gt;</code></pre>
                <p class="meta-text">If your tenant uses newer Exchange application RBAC instead, use the tenant standard. The important bit is the same: LMS should only be able to send from the LMS sender mailbox.</p>
            </section>

            <section class="surface-subcard security-graph-help-section">
                <h3>Common failures</h3>
                <div class="security-graph-help-points">
                    <div class="security-graph-help-point">
                        <strong>401 / invalid_client</strong>
                        <span>Wrong tenant, wrong client ID, expired secret, or Secret ID copied instead of secret Value.</span>
                    </div>
                    <div class="security-graph-help-point">
                        <strong>403 / access denied</strong>
                        <span>Admin consent is missing, Mail.Send was added as delegated instead of application, or mailbox restriction blocks the sender.</span>
                    </div>
                    <div class="security-graph-help-point">
                        <strong>404 / resource not found</strong>
                        <span>The sender email is not a valid Exchange Online mailbox in that tenant.</span>
                    </div>
                    <div class="security-graph-help-point">
                        <strong>Test hangs or times out</strong>
                        <span>Check outbound HTTPS from the LMS host to Microsoft login and Graph endpoints.</span>
                    </div>
                </div>
            </section>
        </div>
    </ChildContent>
    <Footer>
        <UiCommandButton Label="Close"
                         Glyph="UiIconGlyph.Clear"
                         Variant="UiButtonVariant.Ghost"
                         OnClick="CloseGraphHelpModal" />
    </Footer>
</UiModal>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private SecuritySettingsPageViewModel page = new([], [], BuildDefaultMessagingViewModel());
    private IReadOnlyList<LocalNetworkInterfaceView> networkInterfaces = [];
    private IReadOnlyList<LinuxShareUser> localLinuxUsers = [];
    private TrustedNetworkAccessResult currentAccess = new("unknown", "unknown", false, null, false, false, false, false, false);
    private TrustedNetworkEntryEditor networkEditor = new();
    private SecurityUserEditor userEditor = new();
    private SecurityMessagingSettingsEditor messagingEditor = new();
    private SecurityUserProvisioningViewModel? provisioningResult;
    private bool isLoaded;
    private bool isSavingNetwork;
    private bool isSavingUser;
    private bool isSavingMessaging;
    private bool isSendingMessagingTest;
    private string? networkMessage;
    private bool networkMessageIsError;
    private string? userMessage;
    private bool userMessageIsError;
    private string? messagingMessage;
    private bool messagingMessageIsError;
    private string messagingTestRecipient = string.Empty;
    private readonly Dictionary<Guid, int> sessionLifetimeEditors = new();
    private readonly Dictionary<Guid, string> linuxUsernameEditors = new();
    private readonly HashSet<Guid> savingSessionLifetimes = [];
    private readonly HashSet<Guid> savingLinuxUsernames = [];
    private string activeTab = TrustedNetworksTabValue;
    private bool showNetworkRiskModal;
    private bool showGraphHelpModal;
    private string networkRiskModalTitle = "Confirm security change";
    private string networkRiskModalMessage = string.Empty;
    private string networkRiskCurrentAccessWarning = string.Empty;
    private string networkRiskRecoveryWarning = string.Empty;
    private Func<Task>? pendingNetworkRiskAction;
    private bool networkRiskRequiresTypedConfirmation;
    private bool networkRiskAcknowledged;
    private string networkRiskConfirmationInput = string.Empty;

    private const string TrustedNetworksTabValue = "trusted-networks";
    private const string RemoteAccessUsersTabValue = "remote-access-users";
    private const string MessagingTabValue = "messaging";
    private const int MinutesPerHour = 60;
    private const int MinutesPerDay = 24 * MinutesPerHour;
    private const int MaxSessionLifetimeDays = SecuritySessionPolicy.MaximumSessionLifetimeMinutes / MinutesPerDay;

    private bool IsNetworkRiskConfirmationSatisfied =>
        !networkRiskRequiresTypedConfirmation ||
        (networkRiskAcknowledged &&
         string.Equals(networkRiskConfirmationInput?.Trim(), "UNLOCK", StringComparison.Ordinal));

    private bool IsNetworkEditorOpen =>
        networkEditor.Id.HasValue || page.TrustedNetworks.Count == 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        isLoaded = true;
    }

    private async Task LoadAsync()
    {
        page = await SecuritySettingsService.GetPageAsync();
        messagingEditor = await SecuritySettingsService.GetMessagingEditorAsync();
        localLinuxUsers = await LoadLocalLinuxUsersAsync();
        SyncSessionLifetimeEditors();
        SyncLinuxUsernameEditors();
        networkInterfaces = LoadNetworkInterfaces();
        currentAccess = await TrustedNetworkAccessService.EvaluateAsync(
            HttpContext?.Connection.RemoteIpAddress,
            HttpContext?.Request.Host.Host);
    }

    private async Task<IReadOnlyList<LinuxShareUser>> LoadLocalLinuxUsersAsync()
    {
        try
        {
            var identities = await ShareService.GetUsersGroupsManagerAsync();
            return identities.Users;
        }
        catch
        {
            return [];
        }
    }

    private void SyncSessionLifetimeEditors()
    {
        var currentUserIds = page.Users.Select(user => user.Id).ToHashSet();
        foreach (var staleUserId in sessionLifetimeEditors.Keys.Where(userId => !currentUserIds.Contains(userId)).ToArray())
        {
            sessionLifetimeEditors.Remove(staleUserId);
        }

        foreach (var user in page.Users)
        {
            sessionLifetimeEditors[user.Id] = SecuritySessionPolicy.NormalizeSessionLifetimeMinutes(user.SessionLifetimeMinutes);
        }
    }

    private void SyncLinuxUsernameEditors()
    {
        var currentUserIds = page.Users.Select(user => user.Id).ToHashSet();
        foreach (var staleUserId in linuxUsernameEditors.Keys.Where(userId => !currentUserIds.Contains(userId)).ToArray())
        {
            linuxUsernameEditors.Remove(staleUserId);
        }

        foreach (var user in page.Users)
        {
            linuxUsernameEditors[user.Id] = user.LinuxUsername;
        }
    }

    private Task HandleTabChangedAsync(string? value)
    {
        activeTab = string.IsNullOrWhiteSpace(value) ? TrustedNetworksTabValue : value;
        return Task.CompletedTask;
    }

    private void OpenGraphHelpModal()
    {
        showGraphHelpModal = true;
    }

    private void CloseGraphHelpModal()
    {
        showGraphHelpModal = false;
    }

    private async Task SaveMessagingAsync()
    {
        isSavingMessaging = true;
        messagingMessage = null;
        messagingMessageIsError = false;
        try
        {
            await SecuritySettingsService.SaveMessagingSettingsAsync(messagingEditor);
            messagingMessage = "Messaging settings saved.";
            await LoadAsync();
        }
        catch (Exception exception)
        {
            messagingMessage = exception.Message;
            messagingMessageIsError = true;
        }
        finally
        {
            isSavingMessaging = false;
        }
    }

    private async Task SendMessagingTestAsync()
    {
        isSendingMessagingTest = true;
        messagingMessage = null;
        messagingMessageIsError = false;
        try
        {
            var result = await SecuritySettingsService.SendMessagingTestAsync(messagingTestRecipient);
            messagingMessage = result.Message;
            messagingMessageIsError = !result.Succeeded;
            if (result.Succeeded)
            {
                await LoadAsync();
            }
        }
        catch (Exception exception)
        {
            messagingMessage = exception.Message;
            messagingMessageIsError = true;
        }
        finally
        {
            isSendingMessagingTest = false;
        }
    }

    private async Task SaveNetworkAsync()
    {
        if (TryBuildRiskWarning(
                networkEditor.Id,
                networkEditor.Label,
                networkEditor.AddressOrCidr,
                networkEditor.IsEnabled,
                networkEditor.IsAuthenticationEnabled,
                out var warningTitle,
                out var warningMessage,
                out var currentAccessWarning,
                out var recoveryWarning,
                out var requiresTypedConfirmation))
        {
            ShowNetworkRiskModal(
                warningTitle,
                warningMessage,
                currentAccessWarning,
                recoveryWarning,
                requiresTypedConfirmation,
                SaveNetworkCoreAsync);
            return;
        }

        await SaveNetworkCoreAsync();
    }

    private async Task SaveNetworkCoreAsync()
    {
        isSavingNetwork = true;
        networkMessage = null;

        try
        {
            await SecuritySettingsService.SaveTrustedNetworkAsync(networkEditor);
            networkMessage = networkEditor.Id.HasValue ? "Access rule updated." : "Access rule added.";
            networkMessageIsError = false;
            networkEditor = new TrustedNetworkEntryEditor();
            await LoadAsync();
        }
        catch (Exception exception)
        {
            networkMessage = exception.Message;
            networkMessageIsError = true;
        }
        finally
        {
            isSavingNetwork = false;
        }
    }

    private Task CancelNetworkEditAsync()
    {
        networkEditor = new TrustedNetworkEntryEditor();
        return Task.CompletedTask;
    }

    private void BeginNetworkEdit(TrustedNetworkEntryViewModel entry)
    {
        networkEditor = new TrustedNetworkEntryEditor
        {
            Id = entry.Id,
            Label = entry.Label,
            AddressOrCidr = entry.AddressOrCidr,
            Description = entry.Description,
            IsEnabled = entry.IsEnabled,
            IsTrustedAccessEnabled = entry.IsTrustedAccessEnabled,
            IsAuthenticationEnabled = entry.IsAuthenticationEnabled
        };
    }

    private async Task ToggleTrustedNetworkAsync(TrustedNetworkEntryViewModel entry)
    {
        var targetEnabled = !entry.IsEnabled;
        if (TryBuildRiskWarning(
                entry.Id,
                entry.Label,
                entry.AddressOrCidr,
                targetEnabled,
                entry.IsAuthenticationEnabled,
                out var warningTitle,
                out var warningMessage,
                out var currentAccessWarning,
                out var recoveryWarning,
                out var requiresTypedConfirmation))
        {
            ShowNetworkRiskModal(
                warningTitle,
                warningMessage,
                currentAccessWarning,
                recoveryWarning,
                requiresTypedConfirmation,
                () => ToggleTrustedNetworkCoreAsync(entry));
            return;
        }

        await ToggleTrustedNetworkCoreAsync(entry);
    }

    private async Task ToggleTrustedNetworkCoreAsync(TrustedNetworkEntryViewModel entry)
    {
        try
        {
            await SecuritySettingsService.SetTrustedNetworkEnabledAsync(entry.Id, !entry.IsEnabled);
            networkMessage = entry.IsEnabled ? "Access rule disabled." : "Access rule enabled.";
            networkMessageIsError = false;
            await LoadAsync();
        }
        catch (Exception exception)
        {
            networkMessage = exception.Message;
            networkMessageIsError = true;
        }
    }

    private async Task ToggleAuthenticationAccessAsync(TrustedNetworkEntryViewModel entry)
    {
        var targetAuthenticationEnabled = !entry.IsAuthenticationEnabled;
        if (TryBuildRiskWarning(
                entry.Id,
                entry.Label,
                entry.AddressOrCidr,
                entry.IsEnabled,
                targetAuthenticationEnabled,
                out var warningTitle,
                out var warningMessage,
                out var currentAccessWarning,
                out var recoveryWarning,
                out var requiresTypedConfirmation))
        {
            ShowNetworkRiskModal(
                warningTitle,
                warningMessage,
                currentAccessWarning,
                recoveryWarning,
                requiresTypedConfirmation,
                () => ToggleAuthenticationAccessCoreAsync(entry));
            return;
        }

        await ToggleAuthenticationAccessCoreAsync(entry);
    }

    private async Task ToggleAuthenticationAccessCoreAsync(TrustedNetworkEntryViewModel entry)
    {
        try
        {
            await SecuritySettingsService.SetTrustedNetworkAuthenticationEnabledAsync(entry.Id, !entry.IsAuthenticationEnabled);
            networkMessage = entry.IsAuthenticationEnabled ? "Authenticated access disabled." : "Authenticated access enabled.";
            networkMessageIsError = false;
            await LoadAsync();
        }
        catch (Exception exception)
        {
            networkMessage = exception.Message;
            networkMessageIsError = true;
        }
    }

    private async Task DeleteTrustedNetworkAsync(TrustedNetworkEntryViewModel entry)
    {
        try
        {
            await SecuritySettingsService.DeleteTrustedNetworkAsync(entry.Id);
            networkMessage = "Access rule deleted.";
            networkMessageIsError = false;
            if (networkEditor.Id == entry.Id)
            {
                networkEditor = new TrustedNetworkEntryEditor();
            }

            await LoadAsync();
        }
        catch (Exception exception)
        {
            networkMessage = exception.Message;
            networkMessageIsError = true;
        }
    }

    private IReadOnlyList<TrustedNetworkEntryViewModel> GetTrustedNetworksForInterface(LocalNetworkInterfaceView networkInterface) =>
        page.TrustedNetworks
            .Where(entry => NetworkEntryMatchesInterface(entry, networkInterface))
            .ToArray();

    private static bool NetworkEntryMatchesInterface(TrustedNetworkEntryViewModel entry, LocalNetworkInterfaceView networkInterface) =>
        networkInterface.Addresses.Any(address => TrustedNetworkContainsAddress(entry.AddressOrCidr, address.Address));

    private static IReadOnlyList<NetworkAddressView> GetPrimaryAddresses(LocalNetworkInterfaceView networkInterface) =>
        networkInterface.Addresses
            .OrderBy(address => address.Family == "IPv4" ? 0 : 1)
            .ThenBy(address => address.Address.ToString(), StringComparer.OrdinalIgnoreCase)
            .Take(4)
            .ToArray();

    private static IReadOnlyList<LocalNetworkInterfaceView> LoadNetworkInterfaces()
    {
        try
        {
            return NetworkInterface.GetAllNetworkInterfaces()
                .Select(BuildNetworkInterfaceView)
                .OrderByDescending(networkInterface => networkInterface.IsUp)
                .ThenBy(networkInterface => networkInterface.Type == "Loopback" ? 1 : 0)
                .ThenBy(networkInterface => networkInterface.Name, StringComparer.OrdinalIgnoreCase)
                .ToArray();
        }
        catch
        {
            return [];
        }
    }

    private static LocalNetworkInterfaceView BuildNetworkInterfaceView(NetworkInterface networkInterface)
    {
        var properties = GetIPProperties(networkInterface);
        var addresses = properties?.UnicastAddresses
            .Select(address => new NetworkAddressView(NormalizeAddress(address.Address), GetAddressFamilyLabel(address.Address), address.PrefixLength))
            .Where(address => IsUsefulAddress(address.Address))
            .ToArray() ?? [];

        var gateways = properties?.GatewayAddresses
            .Select(address => NormalizeAddress(address.Address).ToString())
            .Where(static value => !string.IsNullOrWhiteSpace(value))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray() ?? [];

        var dnsServers = properties?.DnsAddresses
            .Select(address => NormalizeAddress(address).ToString())
            .Where(static value => !string.IsNullOrWhiteSpace(value))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray() ?? [];

        return new LocalNetworkInterfaceView(
            networkInterface.Id,
            networkInterface.Name,
            string.IsNullOrWhiteSpace(networkInterface.Description) ? networkInterface.Name : networkInterface.Description,
            networkInterface.NetworkInterfaceType.ToString(),
            networkInterface.OperationalStatus.ToString(),
            FormatMacAddress(networkInterface.GetPhysicalAddress()),
            FormatLinkSpeed(networkInterface.Speed),
            addresses,
            gateways,
            dnsServers);
    }

    private static IPInterfaceProperties? GetIPProperties(NetworkInterface networkInterface)
    {
        try
        {
            return networkInterface.GetIPProperties();
        }
        catch
        {
            return null;
        }
    }

    private static bool TrustedNetworkContainsAddress(string addressOrCidr, IPAddress address)
    {
        if (TryParseNetwork(addressOrCidr, out var network))
        {
            return NetworkContainsAddress(network.Address, network.PrefixLength, NormalizeAddress(address));
        }

        return false;
    }

    private static bool TryParseNetwork(string addressOrCidr, out (IPAddress Address, int PrefixLength) network)
    {
        try
        {
            var normalized = addressOrCidr.Trim();
            var slashIndex = normalized.IndexOf('/');
            if (slashIndex < 0)
            {
                var address = NormalizeAddress(IPAddress.Parse(normalized));
                network = (address, address.GetAddressBytes().Length * 8);
                return true;
            }

            var addressPart = normalized[..slashIndex];
            var prefixPart = normalized[(slashIndex + 1)..];
            var parsedAddress = NormalizeAddress(IPAddress.Parse(addressPart));
            var maxPrefix = parsedAddress.GetAddressBytes().Length * 8;
            if (!int.TryParse(prefixPart, out var prefixLength) || prefixLength < 0 || prefixLength > maxPrefix)
            {
                network = default;
                return false;
            }

            network = (parsedAddress, prefixLength);
            return true;
        }
        catch
        {
            network = default;
            return false;
        }
    }

    private static bool NetworkContainsAddress(IPAddress networkAddress, int prefixLength, IPAddress address)
    {
        if (networkAddress.AddressFamily != address.AddressFamily)
        {
            return false;
        }

        var networkBytes = networkAddress.GetAddressBytes();
        var addressBytes = address.GetAddressBytes();
        var fullBytes = prefixLength / 8;
        var remainingBits = prefixLength % 8;

        for (var index = 0; index < fullBytes; index++)
        {
            if (networkBytes[index] != addressBytes[index])
            {
                return false;
            }
        }

        if (remainingBits == 0)
        {
            return true;
        }

        var mask = 0xff << (8 - remainingBits);
        return (networkBytes[fullBytes] & mask) == (addressBytes[fullBytes] & mask);
    }

    private static IPAddress NormalizeAddress(IPAddress address) =>
        address.IsIPv4MappedToIPv6 ? address.MapToIPv4() : address;

    private static bool IsUsefulAddress(IPAddress address) =>
        !Equals(address, IPAddress.Any) &&
        !Equals(address, IPAddress.IPv6Any) &&
        !Equals(address, IPAddress.None) &&
        !Equals(address, IPAddress.IPv6None);

