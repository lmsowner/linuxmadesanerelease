    }

    private static string FormatLinkSpeed(long bitsPerSecond)
    {
        if (bitsPerSecond <= 0)
        {
            return "-";
        }

        string[] units = ["bps", "Kbps", "Mbps", "Gbps"];
        double value = bitsPerSecond;
        var index = 0;
        while (value >= 1000 && index < units.Length - 1)
        {
            value /= 1000;
            index++;
        }

        return $"{value:0.#} {units[index]}";
    }

