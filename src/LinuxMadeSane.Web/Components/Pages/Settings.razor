@page "/settings"
@rendermode InteractiveServer
@using System.Net
@using System.Net.NetworkInformation
@using System.Net.Sockets
@using LinuxMadeSane.Application.Interfaces
@using LinuxMadeSane.Application.Services
@using LinuxMadeSane.Core.Abstractions
@using LinuxMadeSane.Core.Models
@using LinuxMadeSane.Core.Models.Shares
@using Microsoft.AspNetCore.Components.Forms
@inject ISecuritySettingsService SecuritySettingsService
@inject IShareManagementService ShareService
@inject ITrustedNetworkAccessService TrustedNetworkAccessService
@inject NavigationManager Navigation

<PageTitle>LMS Security | Linux Made Sane</PageTitle>

<div class="page-shell">
    <UiHeroPanel Title="LMS Security" Compact="true" />

    @if (!isLoaded)
    {
        <section class="surface-card">
            <p class="meta-text">Loading LMS account settings...</p>
        </section>
    }
    else
    {
        <TabControl ActiveValue="@activeTab"
                    ActiveValueChanged="HandleTabChangedAsync"
                    Class="page-tab-control security-tab-control"
                    PanelClass="page-tab-panel security-tab-panel">
            <ChildContent>
                <TabPage Value="@TrustedNetworksTabValue" Title="Network Interfaces">
                    <Header>
                        <div class="security-tab-header">
                            <span class="security-tab-title">Network Interfaces</span>
                            <span class="security-tab-count">@networkInterfaces.Count</span>
                        </div>
                    </Header>
                    <ChildContent>
                        <div class="security-tab-content network-interface-content">
                            <div class="section-heading">
                                <div>
                                    <p class="eyebrow">Interface access</p>
                                    <h2>Grouped by NIC</h2>
                                    <p class="meta-text">Each local network interface shows the access rules covering its addresses. A rule can allow direct access, require sign-in, or be disabled.</p>
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(networkMessage))
                            {
                                <p class="callout @(networkMessageIsError ? "error" : "success")">@networkMessage</p>
                            }

                            <details class="surface-subcard security-network-editor" open="@IsNetworkEditorOpen">
                                <summary>
                                    <span>
                                        <strong>@(networkEditor.Id.HasValue ? "Edit access rule" : "Add access rule")</strong>
                                        <span class="meta-text">CIDR rules control direct access, email + OTP, or no access for matching networks.</span>
                                    </span>
                                    <span class="status-pill neutral">@(page.TrustedNetworks.Count) rules</span>
                                </summary>

                                <EditForm Model="@networkEditor" OnValidSubmit="SaveNetworkAsync" class="stack-form security-network-editor-form">
                                    <DataAnnotationsValidator />

                                    <div class="field-row">
                                        <UiTextField @bind-Value="networkEditor.Label" Label="Label" />
                                        <UiTextField @bind-Value="networkEditor.AddressOrCidr" Label="Address or CIDR" />
                                    </div>

                                    <UiTextField @bind-Value="networkEditor.Description" Label="Description" />

                                    <div class="field-row">
                                        <UiCheckboxField @bind-Value="networkEditor.IsEnabled" Label="Rule enabled" />
                                        <UiCheckboxField @bind-Value="networkEditor.IsAuthenticationEnabled" Label="Authentication enabled" Helper="Require email plus OTP before allowing access." />
                                    </div>

                                    <div class="toolbar-row">
                                        <UiCommandButton Label="@(isSavingNetwork ? "Saving..." : networkEditor.Id.HasValue ? "Save rule" : "Add rule")"
                                                         Glyph="@(networkEditor.Id.HasValue ? UiIconGlyph.Connect : UiIconGlyph.Plus)"
                                                         Type="submit"
                                                         Disabled="@isSavingNetwork" />
                                        @if (networkEditor.Id.HasValue)
                                        {
                                            <UiCommandButton Label="Cancel edit" Glyph="UiIconGlyph.Clear" Variant="UiButtonVariant.Ghost" OnClick="CancelNetworkEditAsync" />
                                        }
                                    </div>
                                </EditForm>
                            </details>

                            @if (networkInterfaces.Count == 0)
                            {
                                <div class="empty-state">
                                    <h3>No network interfaces were reported</h3>
                                    <p>The saved access rule list is still available in the additional ranges section below.</p>
                                </div>
                            }
                            else
                            {
                                <div class="network-interface-list">
                                    @foreach (var networkInterface in networkInterfaces)
                                    {
                                        var interfaceRanges = GetTrustedNetworksForInterface(networkInterface);

                                        <article class="surface-subcard network-interface-card">
                                            <div class="network-interface-header">
                                                <div class="network-interface-heading">
                                                    <span class="network-interface-status-dot @(networkInterface.IsUp ? "up" : "down")" aria-hidden="true"></span>
                                                    <div>
                                                        <h3>@networkInterface.Name</h3>
                                                        <p>@networkInterface.Description</p>
                                                    </div>
                                                </div>

                                                <div class="token-row compact-token-row">
                                                    <span class="status-pill @(networkInterface.IsUp ? "success" : "neutral")">@networkInterface.Status</span>
                                                    <span class="status-pill neutral">@networkInterface.Type</span>
                                                    <span class="status-pill neutral">@interfaceRanges.Count rule(s)</span>
                                                </div>
                                            </div>

                                            <div class="network-address-strip">
                                                @foreach (var address in GetPrimaryAddresses(networkInterface))
                                                {
                                                    <code>@address.Display</code>
                                                }
                                            </div>

                                            @if (interfaceRanges.Count == 0)
                                            {
                                                <p class="meta-text">No access rules currently match this NIC address.</p>
                                            }
                                            else
                                            {
                                                <div class="trusted-range-list">
                                                    @foreach (var entry in interfaceRanges)
                                                    {
                                                        <div class="trusted-range-row @(!entry.IsEnabled ? "trusted-range-row-disabled" : string.Empty)">
                                                            <div class="trusted-range-main">
                                                                <strong>@entry.Label</strong>
                                                                <code>@entry.AddressOrCidr</code>
                                                                @if (!string.IsNullOrWhiteSpace(entry.Description))
                                                                {
                                                                    <span class="meta-text">@entry.Description</span>
                                                                }
                                                            </div>
                                                            <div class="trusted-range-access">
                                                                @if (entry.IsEnabled)
                                                                {
                                                                    <div class="trusted-range-pill-row">
                                                                        <span class="status-pill @GetTrustedNetworkAccessPillClass(entry)">@GetTrustedNetworkAccessSummary(entry)</span>
                                                                        <span class="status-pill success">@GetTrustedNetworkAuthPillText(entry)</span>
                                                                    </div>
                                                                }
                                                                else
                                                                {
                                                                    <span class="status-pill @GetTrustedNetworkAccessPillClass(entry)">@GetTrustedNetworkAccessSummary(entry)</span>
                                                                }
                                                                @if (!string.IsNullOrWhiteSpace(GetTrustedNetworkAccessMeta(entry)))
                                                                {
                                                                    <span class="meta-text">@GetTrustedNetworkAccessMeta(entry)</span>
                                                                }
                                                            </div>
                                                            @if (entry.IsEnabled)
                                                            {
                                                                <div class="trusted-range-meta">
                                                                    <span class="status-pill neutral">@(entry.IsBuiltIn ? "Built-in" : "Custom")</span>
                                                                </div>
                                                            }
                                                            <div class="trusted-range-actions">
                                                                @if (!entry.IsBuiltIn && entry.IsEnabled)
                                                                {
                                                                    <UiCommandButton Label="Edit"
                                                                                     Glyph="UiIconGlyph.Edit"
                                                                                     Variant="UiButtonVariant.Action"
                                                                                     OnClick="@(() => BeginNetworkEdit(entry))"
                                                                                     Disabled="@(!entry.IsEnabled)" />
                                                                }
                                                                @if (entry.IsEnabled)
                                                                {
                                                                    <UiCommandButton Label="@(entry.IsAuthenticationEnabled ? "Auth off" : "Auth on")"
                                                                                     Glyph="@(entry.IsAuthenticationEnabled ? UiIconGlyph.Disconnect : UiIconGlyph.Connect)"
                                                                                     Variant="UiButtonVariant.Action"
                                                                                     OnClick="@(() => ToggleAuthenticationAccessAsync(entry))"
                                                                                     Disabled="@(!entry.IsEnabled)" />
                                                                }
                                                                <UiCommandButton Label="@(entry.IsEnabled ? "Disable" : "Enable")"
                                                                                 Glyph="@(entry.IsEnabled ? UiIconGlyph.Disconnect : UiIconGlyph.Connect)"
                                                                                 Variant="UiButtonVariant.Action"
                                                                                 OnClick="@(() => ToggleTrustedNetworkAsync(entry))" />
                                                                @if (!entry.IsBuiltIn && entry.IsEnabled)
                                                                {
                                                                    <UiCommandButton Label="Delete"
                                                                                     Glyph="UiIconGlyph.Delete"
                                                                                     Variant="UiButtonVariant.Danger"
                                                                                     OnClick="@(() => DeleteTrustedNetworkAsync(entry))"
                                                                                     Disabled="@(!entry.IsEnabled)" />
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }

                                            <details class="network-interface-details">
                                                <summary>
                                                    <span>Interface details</span>
                                                    <span class="meta-text">addresses, DNS, gateway, MAC, speed</span>
                                                </summary>

                                                <dl class="network-interface-detail-grid">
                                                    <div>
                                                        <dt>Interface ID</dt>
                                                        <dd>@networkInterface.Id</dd>
                                                    </div>
                                                    <div>
                                                        <dt>MAC</dt>
                                                        <dd>@networkInterface.MacAddress</dd>
                                                    </div>
                                                    <div>
                                                        <dt>Speed</dt>
                                                        <dd>@networkInterface.Speed</dd>
                                                    </div>
                                                    <div>
                                                        <dt>Addresses</dt>
                                                        <dd>@FormatAddressList(networkInterface.Addresses)</dd>
                                                    </div>
                                                    <div>
                                                        <dt>Gateways</dt>
                                                        <dd>@FormatStringList(networkInterface.Gateways)</dd>
                                                    </div>
                                                    <div>
                                                        <dt>DNS</dt>
                                                        <dd>@FormatStringList(networkInterface.DnsServers)</dd>
                                                    </div>
                                                </dl>
                                            </details>
                                        </article>
                                    }
                                </div>
                            }

                        </div>
                    </ChildContent>
                </TabPage>

                <TabPage Value="@RemoteAccessUsersTabValue" Title="LMS Accounts">
                    <Header>
                        <div class="security-tab-header">
                            <span class="security-tab-title">LMS Accounts</span>
                            <span class="security-tab-count">@(page.Users.Count)</span>
                        </div>
                    </Header>
                    <ChildContent>
                        <div class="security-tab-content remote-access-content">
                            <div class="section-heading">
                                <div>
                                    <p class="eyebrow">LMS accounts</p>
                                    <h2>Accounts and authenticator access</h2>
                                    <p class="meta-text">Create LMS accounts with email-based sign-in and authenticator OTP. These accounts identify the operator; dedicated runner access controls what LMS can execute on a machine.</p>
                                </div>
                            </div>

                            <section class="surface-subcard security-runner-access-panel">
                                <div class="security-runner-access-copy">
                                    <p class="eyebrow">Automation trust model</p>
                                    <h3>Privileged automation is explicit</h3>
                                    <p>LMS is a control plane. If you want terminals, runbooks, patching, service management, and repair workflows to run without password prompts, the target machine needs a dedicated LMS runner account with key-based login and passwordless sudo.</p>
                                    <p>LMS treats that as an intentional grant of elevated control. Secrets are stored through the protected secret store, sudo automation is non-interactive, and privileged workflows should be traceable back to the signed-in LMS account that requested them.</p>
                                </div>

                                <div class="security-runner-access-pills">
                                    <span class="status-pill neutral">Dedicated runner</span>
                                    <span class="status-pill neutral">Public key login</span>
                                    <span class="status-pill warning">sudo -n</span>
                                    <span class="status-pill neutral">Operator traceability</span>
                                </div>
                            </section>

                            @if (!string.IsNullOrWhiteSpace(userMessage))
                            {
                                <p class="callout @(userMessageIsError ? "error" : "success")">@userMessage</p>
                            }

                            <section class="surface-subcard remote-access-create-panel">
                                <div class="remote-access-panel-heading">
                                    <div>
                                        <h3>Create LMS account</h3>
                                        <p>Create an LMS account and issue the authenticator QR for app access.</p>
                                    </div>
                                    <span class="status-pill @(page.Messaging.CanSendLoginSetupEmail ? "success" : "neutral")">
                                        @(page.Messaging.CanSendLoginSetupEmail ? "Email + OTP" : "OTP only")
                                    </span>
                                </div>

                                <EditForm Model="@userEditor" OnValidSubmit="CreateUserAsync" class="stack-form">
                                    <DataAnnotationsValidator />

                                    <UiTextField @bind-Value="userEditor.Email"
                                                 Label="Email"
                                                 Type="email"
                                                 Helper="Used for Linux Made Sane sign-in and OTP verification." />

                                    <UiComboboxField TValue="string"
                                                     Label="Associated Linux user"
                                                     Value="@userEditor.LinuxUsername"
                                                     ValueChanged="SetNewUserLinuxUsernameAsync"
                                                     ValueExpression="@(() => userEditor.LinuxUsername)"
                                                     Helper="Choose an existing local account, or leave this blank so LMS creates a managed Linux user from the email address.">
                                        <option value="">Create LMS-managed Linux user</option>
                                        @if (ShouldRenderCurrentLinuxUserOption(userEditor.LinuxUsername))
                                        {
                                            <option value="@userEditor.LinuxUsername">@FormatSavedLinuxUserOptionLabel(userEditor.LinuxUsername)</option>
                                        }
                                        @if (GetInteractiveLinuxUsers().Count > 0)
                                        {
                                            <optgroup label="Interactive users">
                                                @foreach (var linuxUser in GetInteractiveLinuxUsers())
                                                {
                                                    <option value="@linuxUser.UserName">@FormatLinuxUserOptionLabel(linuxUser)</option>
                                                }
                                            </optgroup>
                                        }
                                        @if (GetSystemLinuxUsers().Count > 0)
                                        {
                                            <optgroup label="System users">
                                                @foreach (var linuxUser in GetSystemLinuxUsers())
                                                {
                                                    <option value="@linuxUser.UserName">@FormatLinuxUserOptionLabel(linuxUser)</option>
                                                }
                                            </optgroup>
                                        }
                                    </UiComboboxField>

                                    @if (page.Messaging.CanSendLoginSetupEmail)
                                    {
                                        <p class="callout success">Verified Messaging is available. LMS will email the setup QR code and login link to the account email.</p>
                                    }
                                    else
                                    {
                                        <p class="meta-text">Messaging must be saved and pass a test email before LMS can email login setup QR codes. The QR code will still be shown here.</p>
                                    }

                                    <div class="remote-access-session-duration">
                                        <span class="ui-field-label">Login session</span>
                                        <span class="meta-text">How long this LMS account stays signed in before OTP is required again.</span>
                                        <div class="remote-access-session-duration-grid">
                                            <UiNumberField TValue="int"
                                                           Value="@GetSessionLifetimePart(userEditor.SessionLifetimeMinutes, SessionLifetimePart.Days)"
                                                           ValueChanged="@((int value) => SetNewUserSessionLifetimePart(SessionLifetimePart.Days, value))"
                                                           ValueExpression="@(() => userEditor.SessionLifetimeMinutes)"
                                                           Label="Days"
                                                           min="0"
                                                           max="@MaxSessionLifetimeDays"
                                                           step="1"
                                                           Compact="true" />
                                            <UiNumberField TValue="int"
                                                           Value="@GetSessionLifetimePart(userEditor.SessionLifetimeMinutes, SessionLifetimePart.Hours)"
                                                           ValueChanged="@((int value) => SetNewUserSessionLifetimePart(SessionLifetimePart.Hours, value))"
                                                           ValueExpression="@(() => userEditor.SessionLifetimeMinutes)"
                                                           Label="Hours"
                                                           min="0"
                                                           max="23"
                                                           step="1"
                                                           Compact="true" />
                                            <UiNumberField TValue="int"
                                                           Value="@GetSessionLifetimePart(userEditor.SessionLifetimeMinutes, SessionLifetimePart.Minutes)"
                                                           ValueChanged="@((int value) => SetNewUserSessionLifetimePart(SessionLifetimePart.Minutes, value))"
                                                           ValueExpression="@(() => userEditor.SessionLifetimeMinutes)"
                                                           Label="Minutes"
                                                           min="0"
                                                           max="59"
                                                           step="5"
                                                           Compact="true" />
                                        </div>
                                        <span class="meta-text">@FormatSessionLifetimeMinutes(userEditor.SessionLifetimeMinutes)</span>
                                    </div>

                                    <div class="toolbar-row">
                                        <UiCommandButton Label="@(isSavingUser ? "Registering..." : "Register account")"
                                                         Glyph="UiIconGlyph.Plus"
                                                         Type="submit"
                                                         Disabled="@isSavingUser" />
                                    </div>
                                </EditForm>
                            </section>

                            @if (provisioningResult is not null)
                            {
                                <div class="surface-subcard otp-provisioning-panel remote-access-provisioning-panel">
                                    <UiQrCode Payload="@provisioningResult.OtpUri"
                                              Class="otp-provisioning-qr"
                                              Title="Authenticator setup QR"
                                              AriaLabel="Authenticator setup QR"
                                              Caption="Scan this in your authenticator app" />

                                    <div class="stack-list">
                                        <ServiceMetricComponent TagName="div" Label="Provisioned email" Value="@provisioningResult.Email" />
                                        <ServiceMetricComponent TagName="div" Label="Manual key" Value="@provisioningResult.ManualEntryKey" />
                                        <ServiceMetricComponent TagName="div" Label="OTP URI" Value="@provisioningResult.OtpUri" />
                                        @if (provisioningResult.EmailSucceeded)
                                        {
                                            <p class="callout success">Setup email sent to @provisioningResult.Email.</p>
                                        }
                                        else if (provisioningResult.EmailAttempted)
                                        {
                                            <p class="callout warning">Account setup succeeded, but the setup email was not sent. @provisioningResult.EmailMessage</p>
                                        }
                                        else if (!page.Messaging.CanSendLoginSetupEmail)
                                        {
                                            <p class="callout warning">Setup email was not sent because Messaging is not verified. Send a successful test email from the Messaging tab to enable this.</p>
                                        }
                                        <p class="meta-text">Scan the QR code or enter the manual key in your authenticator app. If you reset OTP, the new QR is shown here again.</p>
                                    </div>
                                </div>
                            }

                            @if (page.Users.Count == 0)
                            {
                                <div class="empty-state">
                                    <h3>No LMS accounts</h3>
                                    <p>Create at least one LMS account before enabling authenticated access on interfaces that should require sign-in.</p>
                                </div>
                            }
                            else
                            {
                                <table class="remote-access-user-table">
                                    <thead>
                                        <tr>
                                            <th>Account</th>
                                            <th>Linux user</th>
                                            <th>Status</th>
                                            <th>Login session</th>
                                            <th>Last login</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var user in page.Users)
                                        {
                                            <tr>
                                                <td class="remote-access-account-cell">
                                                    <strong>@user.Email</strong>
                                                    @if (!user.HasOtpSecret)
                                                    {
                                                        <div class="meta-text">Authenticator secret missing</div>
                                                    }
                                                </td>
                                                <td>
                                                    <div class="remote-access-linux-editor">
                                                        <div class="ui-combobox-shell ui-select-shell remote-access-linux-combobox">
                                                            <select class="ui-combobox-input ui-select-input"
                                                                    value="@GetLinuxUsernameEditor(user)"
                                                                    aria-label="@($"Associated Linux user for {user.Email}")"
                                                                    @onchange="@((ChangeEventArgs args) => SetLinuxUsernameEditor(user.Id, args))">
                                                                @if (ShouldRenderCurrentLinuxUserOption(GetLinuxUsernameEditor(user)))
                                                                {
                                                                    <option value="@GetLinuxUsernameEditor(user)">@FormatSavedLinuxUserOptionLabel(GetLinuxUsernameEditor(user))</option>
                                                                }
                                                                @if (GetInteractiveLinuxUsers().Count > 0)
                                                                {
                                                                    <optgroup label="Interactive users">
                                                                        @foreach (var linuxUser in GetInteractiveLinuxUsers())
                                                                        {
                                                                            <option value="@linuxUser.UserName">@FormatLinuxUserOptionLabel(linuxUser)</option>
                                                                        }
                                                                    </optgroup>
                                                                }
                                                                @if (GetSystemLinuxUsers().Count > 0)
                                                                {
                                                                    <optgroup label="System users">
                                                                        @foreach (var linuxUser in GetSystemLinuxUsers())
                                                                        {
                                                                            <option value="@linuxUser.UserName">@FormatLinuxUserOptionLabel(linuxUser)</option>
                                                                        }
                                                                    </optgroup>
                                                                }
                                                            </select>
                                                            <span class="ui-combobox-indicator ui-select-indicator" aria-hidden="true">
                                                                <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                                                                    <path d="m2.5 4.5 3.5 3 3.5-3" />
                                                                </svg>
                                                            </span>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>
                                                    <div class="remote-access-status-text">
                                                        <span>@(user.IsEnabled ? "Enabled" : "Disabled")</span>
                                                        <span>@(user.HasOtpSecret ? "OTP ready" : "OTP missing")</span>
                                                    </div>
                                                </td>
                                                <td>
                                                    <div class="remote-access-session-editor">
                                                        <label class="remote-access-session-part">
                                                            <span>Days</span>
                                                            <input class="remote-access-session-input"
                                                                   type="number"
                                                                   min="0"
                                                                   max="@MaxSessionLifetimeDays"
                                                                   step="1"
                                                                   value="@GetSessionLifetimePart(GetSessionLifetimeEditor(user), SessionLifetimePart.Days)"
                                                                   @onchange="@((ChangeEventArgs args) => SetSessionLifetimeEditorPart(user.Id, SessionLifetimePart.Days, args))" />
                                                        </label>
                                                        <label class="remote-access-session-part">
                                                            <span>Hours</span>
                                                            <input class="remote-access-session-input"
                                                                   type="number"
                                                                   min="0"
                                                                   max="23"
                                                                   step="1"
                                                                   value="@GetSessionLifetimePart(GetSessionLifetimeEditor(user), SessionLifetimePart.Hours)"
                                                                   @onchange="@((ChangeEventArgs args) => SetSessionLifetimeEditorPart(user.Id, SessionLifetimePart.Hours, args))" />
                                                        </label>
                                                        <label class="remote-access-session-part">
                                                            <span>Minutes</span>
                                                            <input class="remote-access-session-input"
                                                                   type="number"
                                                                   min="0"
                                                                   max="59"
                                                                   step="5"
                                                                   value="@GetSessionLifetimePart(GetSessionLifetimeEditor(user), SessionLifetimePart.Minutes)"
                                                                   @onchange="@((ChangeEventArgs args) => SetSessionLifetimeEditorPart(user.Id, SessionLifetimePart.Minutes, args))" />
                                                        </label>
                                                        <span class="meta-text">@FormatSessionLifetimeMinutes(GetSessionLifetimeEditor(user))</span>
                                                    </div>
                                                </td>
                                                <td>@FormatTimestamp(user.LastLoginAtUtc, "Never")</td>
                                                <td class="actions-cell">
                                                    <UiCommandButton Label="@(IsSavingUserSettings(user.Id) ? "Saving..." : "Save")"
                                                                     Glyph="UiIconGlyph.Save"
                                                                     Variant="UiButtonVariant.Action"
                                                                     Disabled="@IsSavingUserSettings(user.Id)"
                                                                     OnClick="@(() => SaveUserSettingsAsync(user))" />
                                                    <UiCommandButton Label="@(user.IsEnabled ? "Disable" : "Enable")"
                                                                     Glyph="@(user.IsEnabled ? UiIconGlyph.Disconnect : UiIconGlyph.Connect)"
                                                                     Variant="UiButtonVariant.Action"
                                                                     OnClick="@(() => ToggleUserAsync(user))" />
                                                    <UiCommandButton Label="Reset OTP" Glyph="UiIconGlyph.Refresh" Variant="UiButtonVariant.Action" OnClick="@(() => ResetUserOtpAsync(user))" />
                                                    <UiCommandButton Label="Delete" Glyph="UiIconGlyph.Delete" Variant="UiButtonVariant.Danger" OnClick="@(() => DeleteUserAsync(user))" />
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </ChildContent>
                </TabPage>

                <TabPage Value="@MessagingTabValue" Title="Messaging">
                    <Header>
                        <div class="security-tab-header">
                            <span class="security-tab-title">Messaging</span>
                            <span class="security-tab-count">@FormatMessagingProvider(page.Messaging.Provider)</span>
                        </div>
                    </Header>
                    <ChildContent>
                        <div class="security-tab-content remote-access-content">
                            <div class="section-heading">
                                <div>
                                    <p class="eyebrow">Email delivery</p>
                                    <h2>SMTP or Microsoft Graph</h2>
                                    <p class="meta-text">Configure local LMS email for passkey setup, account workflows, and future notifications. Secrets are stored in the protected LMS secret store, not appsettings.</p>
                                </div>
                                <UiCommandButton Label="Graph setup help"
                                                 Glyph="UiIconGlyph.Info"
                                                 Variant="UiButtonVariant.Action"
                                                 OnClick="OpenGraphHelpModal" />
                            </div>

                            @if (!string.IsNullOrWhiteSpace(messagingMessage))
                            {
                                <p class="callout @(messagingMessageIsError ? "error" : "success")">@messagingMessage</p>
                            }

                            <section class="surface-subcard remote-access-create-panel">
                                <EditForm Model="@messagingEditor" OnValidSubmit="SaveMessagingAsync" class="stack-form">
                                    <DataAnnotationsValidator />

                                    <div class="field-row">
                                        <UiCheckboxField @bind-Value="messagingEditor.IsEnabled"
                                                         Label="Email enabled"
                                                         Helper="Turn this on after the provider details are saved and tested." />
                                        <UiSelectField TValue="MessagingEmailProvider"
                                                       @bind-Value="messagingEditor.Provider"
                                                       Label="Provider">
                                            <option value="@MessagingEmailProvider.Disabled">Disabled</option>
