    private static string FormatSessionLifetimeMinutes(int minutes)
    {
        var normalizedMinutes = NormalizeSessionLifetimeEditorMinutes(minutes);
        var days = normalizedMinutes / MinutesPerDay;
        var remainder = normalizedMinutes % MinutesPerDay;
        var hours = remainder / MinutesPerHour;
        var remainingMinutes = remainder % MinutesPerHour;
        var parts = new List<string>(3);

        if (days > 0)
        {
            parts.Add(days == 1 ? "1 day" : $"{days} days");
        }

        if (hours > 0)
        {
            parts.Add(hours == 1 ? "1 hour" : $"{hours} hours");
        }

        if (remainingMinutes > 0 || parts.Count == 0)
        {
            parts.Add(remainingMinutes == 1 ? "1 minute" : $"{remainingMinutes} minutes");
        }

        return string.Join(" ", parts);
    }

    private static int GetSessionLifetimePart(int minutes, SessionLifetimePart part)
    {
        var clampedMinutes = NormalizeSessionLifetimeEditorMinutes(minutes);
        return part switch
        {
            SessionLifetimePart.Days => clampedMinutes / MinutesPerDay,
            SessionLifetimePart.Hours => clampedMinutes % MinutesPerDay / MinutesPerHour,
            SessionLifetimePart.Minutes => clampedMinutes % MinutesPerHour,
            _ => 0
        };
    }

    private static int BuildSessionLifetimeMinutes(
        int currentMinutes,
        SessionLifetimePart part,
        int value)
    {
        var clampedCurrent = NormalizeSessionLifetimeEditorMinutes(currentMinutes);
        var days = clampedCurrent / MinutesPerDay;
        var remainder = clampedCurrent % MinutesPerDay;
        var hours = remainder / MinutesPerHour;
        var minutes = remainder % MinutesPerHour;

        switch (part)
        {
            case SessionLifetimePart.Days:
                days = Math.Clamp(value, 0, MaxSessionLifetimeDays);
                break;
            case SessionLifetimePart.Hours:
                hours = Math.Clamp(value, 0, 23);
                break;
            case SessionLifetimePart.Minutes:
                minutes = Math.Clamp(value, 0, 59);
                break;
        }

        return ClampBuiltSessionLifetimeMinutes(days * MinutesPerDay + hours * MinutesPerHour + minutes);
    }

    private static int NormalizeSessionLifetimeEditorMinutes(int minutes) =>
        minutes <= 0
            ? SecuritySessionPolicy.DefaultSessionLifetimeMinutes
            : ClampBuiltSessionLifetimeMinutes(minutes);

    private static int ClampBuiltSessionLifetimeMinutes(int minutes) =>
        Math.Clamp(
            minutes,
            SecuritySessionPolicy.MinimumSessionLifetimeMinutes,
            SecuritySessionPolicy.MaximumSessionLifetimeMinutes);

