    private async Task ApplyPendingUserActionAsync()
    {
        if (pendingUserAction is null)
        {
            return;
        }

        isUserActionBusy = true;
        try
        {
            if (pendingUserAction.Value is not UserActionKind.Disable and not UserActionKind.Delete)
            {
                userActionMessage = "That SFTP action is no longer available.";
                userActionTone = "error";
                return;
            }

            var result = pendingUserAction.Value == UserActionKind.Disable
                ? await SftpService.DisableUserAsync(pendingUserActionUserName, approved: true)
                : await SftpService.DeleteUserAsync(pendingUserActionUserName, approved: true);

            userActionMessage = result.Summary;
            userActionTone = result.Success ? "success" : "error";
            statusMessage = result.Summary;
            statusTone = result.Success ? "success" : "error";

            if (result.Success)
            {
                if (pendingUserAction == UserActionKind.Delete &&
                    string.Equals(selectedUserName, pendingUserActionUserName, StringComparison.OrdinalIgnoreCase))
                {
                    selectedUserName = null;
                }

                await CloseUserActionModalAsync();
                await LoadAsync();
            }
        }
        catch (Exception exception)
        {
            userActionMessage = exception.Message;
            userActionTone = "error";
        }
        finally
        {
            isUserActionBusy = false;
        }
    }

