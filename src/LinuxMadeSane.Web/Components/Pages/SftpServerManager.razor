    private async Task ApplyUserAsync()
    {
        if (userEditor is null || userEditContext is null)
        {
            return;
        }

        if (!userEditContext.Validate())
        {
            userModalMessage = "Fix the SFTP user fields before applying the user.";
            userModalTone = "error";
            return;
        }

        if (userPlan is null)
        {
            await RefreshUserPlanAsync(resetApproval: false, announceReadyState: true);
            if (userPlan is null)
            {
                return;
            }
        }

        isUserBusy = true;
        try
        {
            var result = await SftpService.SaveUserAsync(userEditor, userEditorPassword, approved: true);
            userModalMessage = result.Summary;
            userModalTone = result.Success ? "success" : "error";
            statusMessage = result.Summary;
            statusTone = result.Success ? "success" : "error";
            if (result.Success)
            {
                selectedUserName = userEditor.UserName.Trim().ToLowerInvariant();
                await CloseUserEditorModalAsync();
                await LoadAsync();
            }
        }
        catch (Exception exception)
        {
            userModalMessage = exception.Message;
            userModalTone = "error";
        }
        finally
        {
            isUserBusy = false;
        }
    }

