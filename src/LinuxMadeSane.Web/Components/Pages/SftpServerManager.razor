    private RenderFragment RenderPlan(SftpConfigurationPlan plan, string heading, string helpText) => @<section class="surface-subcard sftp-plan-card">
        <div class="table-header">
            <div>
                <p class="eyebrow">Preview</p>
                <h3>@heading</h3>
                <p class="meta-text">@helpText</p>
            </div>
            <UiPill Tone="@(plan.Validation.IsValid ? UiPillTone.Success : UiPillTone.Failure)">
                @(plan.Validation.IsValid ? "Validated" : "Invalid")
            </UiPill>
        </div>

        @if (!string.IsNullOrWhiteSpace(plan.BackupSummary))
        {
            <div class="sftp-plan-summary">@plan.BackupSummary</div>
        }

        @if (plan.Warnings.Count > 0)
        {
            <div class="sftp-warning-list">
                @foreach (var warning in plan.Warnings)
                {
                    <div class="sftp-warning-item">@warning</div>
                }
            </div>
        }

        <div class="sftp-plan-validation">
            <strong>@plan.Validation.Summary</strong>
            @if (plan.Validation.Errors.Count > 0)
            {
                <ul>
                    @foreach (var error in plan.Validation.Errors)
                    {
                        <li>@error</li>
                    }
                </ul>
            }
        </div>

        <div class="sftp-plan-action-list">
            @foreach (var action in plan.Actions.OrderBy(item => item.Order))
            {
                <article class="sftp-plan-action">
                    <div class="sftp-plan-action-header">
                        <strong>@action.Order. @action.Title</strong>
                        <UiPill Tone="@(action.MutatesSystem ? UiPillTone.Warning : UiPillTone.Neutral)">
                            @(action.MutatesSystem ? "Mutates system" : "Read / validate")
                        </UiPill>
                    </div>
                    <p>@action.Summary</p>
                    <pre class="sftp-plan-code"><code>@action.CommandText</code></pre>
                    @if (!string.IsNullOrWhiteSpace(action.TargetPath))
                    {
                        <span class="meta-text">Target: @action.TargetPath</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(action.ProposedContent))
                    {
                        <details class="sftp-plan-content">
                            <summary>Preview generated content</summary>
                            <pre class="sftp-plan-code"><code>@action.ProposedContent</code></pre>
                        </details>
                    }
                </article>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(plan.ProposedSshdConfig))
        {
            <details class="sftp-plan-content">
                <summary>Full generated sshd configuration</summary>
                <pre class="sftp-plan-code"><code>@plan.ProposedSshdConfig</code></pre>
            </details>
        }
    </section>;

