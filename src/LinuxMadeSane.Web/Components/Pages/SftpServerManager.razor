    private async Task ImportPublicKeysAsync(InputFileChangeEventArgs args)
    {
        if (userEditor is null)
        {
            return;
        }

        const long maxImportBytes = 128 * 1024;
        foreach (var file in args.GetMultipleFiles())
        {
            await using var stream = file.OpenReadStream(maxImportBytes);
            using var reader = new StreamReader(stream);
            var content = await reader.ReadToEndAsync();

            foreach (var importedKey in ExtractImportedPublicKeys(content))
            {
                if (userEditor.PublicKeys.Any(existing => existing.PublicKeyText.Equals(importedKey, StringComparison.Ordinal)))
                {
                    continue;
                }

                userEditor.PublicKeys.Add(new SftpPublicKeyEditor
                {
                    Label = BuildImportedKeyLabel(importedKey),
                    PublicKeyText = importedKey
                });
            }
        }

        await RefreshUserPlanAsync(resetApproval: true, announceReadyState: false);
    }

    private async Task PreviewUserPlanAsync()
    {
        await RefreshUserPlanAsync(resetApproval: true, announceReadyState: true);
    }

    private async Task RefreshUserPlanAsync(bool resetApproval, bool announceReadyState)
    {
        if (userEditor is null || userEditContext is null)
        {
            return;
        }

        if (!userEditContext.Validate())
        {
            userPlan = null;
            if (resetApproval)
            {
                userPlanApproved = false;
            }

            if (announceReadyState)
            {
                userModalMessage = "Fix the SFTP user fields before previewing the plan.";
                userModalTone = "error";
            }
            return;
        }

        isUserBusy = true;
        try
        {
            userPlan = await SftpService.PreviewUserAsync(userEditor, userEditorPassword);
            if (resetApproval)
            {
                userPlanApproved = false;
            }

            if (announceReadyState)
            {
                userModalMessage = "Review the Linux account, chroot, and auth changes before you approve this user update.";
                userModalTone = userPlan.Validation.IsValid ? "info" : "error";
            }
        }
        catch (Exception exception)
        {
            userPlan = null;
            if (resetApproval)
            {
                userPlanApproved = false;
            }
            userModalMessage = exception.Message;
            userModalTone = "error";
        }
        finally
        {
            isUserBusy = false;
        }
    }

