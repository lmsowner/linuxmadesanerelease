@page "/file-search-window/{SearchId:guid}"
@layout PopupLayout
@rendermode InteractiveServer
@using LinuxMadeSane.Web.Components.Ui

<PageTitle>Find Files | Linux Made Sane</PageTitle>

<div class="page-shell file-browser-popup-page">
    <HostFileBrowserWorkspace DetachedSearchId="@SearchId"
                              WorkspaceId="@WorkspaceId"
                              RootPath="@RootPath"
                              Title="@ResolvedTitle"
                              AllowPopout="false" />
</div>

@code {
    [Parameter]
    public Guid SearchId { get; set; }

    [SupplyParameterFromQuery]
    public string? RootPath { get; set; }

    [SupplyParameterFromQuery]
    public string? Title { get; set; }

    [SupplyParameterFromQuery(Name = "workspaceId")]
    public string? WorkspaceId { get; set; }

    private string ResolvedTitle => string.IsNullOrWhiteSpace(Title) ? "Find files" : Title.Trim();
}
