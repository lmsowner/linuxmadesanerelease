    private string GetPassword(TerminalTabState tab) =>
        ConnectionSecretStore.Get(tab.SecretHandle).Password;

    private string GetPrivateKey(TerminalTabState tab) =>
        ConnectionSecretStore.Get(tab.SecretHandle).PrivateKey;

    private string GetPrivateKeyPassphrase(TerminalTabState tab) =>
        ConnectionSecretStore.Get(tab.SecretHandle).PrivateKeyPassphrase;

    private void SetPassword(TerminalTabState tab, string? value)
    {
        var existing = ConnectionSecretStore.Get(tab.SecretHandle);
        tab.SecretHandle = ConnectionSecretStore.Save(tab.SecretHandle, value, existing.PrivateKey, existing.PrivateKeyPassphrase);
    }

    private void SetPrivateKey(TerminalTabState tab, string? value)
    {
        var existing = ConnectionSecretStore.Get(tab.SecretHandle);
        tab.SecretHandle = ConnectionSecretStore.Save(tab.SecretHandle, existing.Password, value, existing.PrivateKeyPassphrase);
    }

    private void SetPrivateKeyPassphrase(TerminalTabState tab, string? value)
    {
        var existing = ConnectionSecretStore.Get(tab.SecretHandle);
        tab.SecretHandle = ConnectionSecretStore.Save(tab.SecretHandle, existing.Password, existing.PrivateKey, value);
    }

    private string BuildDetachedTerminalUrl(Guid tabId) =>
        NavigationManager.ToAbsoluteUri($"/terminal-window/{tabId}").ToString();

    private async Task DisposeTerminalClientAsync()
    {
        if (!terminalInitialized)
        {
            return;
        }

        try
        {
            await JSRuntime.InvokeVoidAsync("lmsTerminal.disposeTerminal", terminalClientId);
        }
        catch (JSDisconnectedException)
        {
        }
        finally
        {
            terminalInitialized = false;
            renderedTabId = null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        pollingCts?.Cancel();
        pollingCts?.Dispose();
        TerminalSessionService.OutputAppended -= HandleTerminalOutputAppended;

        await DisposeTerminalClientAsync();

        dotNetReference?.Dispose();
    }
}
