    private static bool RequiresUiRefresh(TerminalSessionSnapshot? previous, TerminalSessionSnapshot current)
    {
        if (previous is null)
        {
            return true;
        }

        return previous.Status != current.Status
               || !string.Equals(previous.WorkingDirectory, current.WorkingDirectory, StringComparison.Ordinal);
    }

    private void HandleTerminalOutputAppended(TerminalSessionOutputAppended update)
    {
        if (TerminalWorkspace is null || TerminalWorkspace.Tabs.All(tab => tab.SessionId != update.SessionId))
        {
            return;
        }

        _ = InvokeAsync(() => ApplyTerminalOutputUpdateAsync(update));
    }

    private async Task ApplyTerminalOutputUpdateAsync(TerminalSessionOutputAppended update)
    {
        if (TerminalWorkspace is null)
        {
            return;
        }

        TerminalTabState? renderedMatch = null;

        foreach (var tab in TerminalWorkspace.Tabs.Where(tab => tab.SessionId == update.SessionId))
        {
            tab.Snapshot = MergeTerminalSnapshot(tab, tab.Snapshot, update);
            if (RenderedTab?.Id == tab.Id)
            {
                renderedMatch = tab;
            }
        }

        if (renderedMatch is not null && terminalInitialized)
        {
            await JSRuntime.InvokeVoidAsync("lmsTerminal.appendChunk", terminalClientId, update.Chunk, update.OutputRevision);
            renderedOutputRevisions[renderedMatch.Id] = update.OutputRevision;
        }
    }

    private static TerminalSessionSnapshot MergeTerminalSnapshot(
        TerminalTabState tab,
        TerminalSessionSnapshot? previous,
        TerminalSessionOutputAppended update)
    {
        var nextOutput = (previous?.Output ?? string.Empty) + update.Chunk;
        if (nextOutput.Length > 120_000)
        {
            nextOutput = nextOutput[^120_000..];
        }

        return previous is null
            ? new TerminalSessionSnapshot(
                update.SessionId,
                update.Status,
                tab.WorkingDirectory,
                nextOutput,
                update.OutputRevision,
                update.LastActivityUtc,
                update.LastActivityUtc)
            : previous with
            {
                Status = update.Status,
                Output = nextOutput,
                OutputRevision = update.OutputRevision,
                LastActivityUtc = update.LastActivityUtc
            };
    }

    private string GetTabTitle(TerminalTabState tab)
    {
        var siblings = OrderedTabs.Where(item => item.HostId == tab.HostId).ToArray();
        if (siblings.Length <= 1)
        {
            return tab.HostName;
        }

        var index = Array.FindIndex(siblings, item => item.Id == tab.Id) + 1;
        return $"{tab.HostName} {index}";
    }

    private string GetTabTooltip(TerminalTabState tab) =>
        $"{tab.HostName} · {GetSessionLabel(tab)}{(tab.IsDetached ? " · Popped out" : string.Empty)}";

    private static string BuildTerminalTitleHostLabel(TerminalTabState tab)
    {
        var name = string.IsNullOrWhiteSpace(tab.HostName) ? tab.HostAddress : tab.HostName.Trim();
        var address = tab.HostAddress.Trim();
        return string.IsNullOrWhiteSpace(address) || string.Equals(name, address, StringComparison.OrdinalIgnoreCase)
            ? name
            : $"{name} ({address})";
    }

    private string GetTabStatusClass(TerminalTabState tab) =>
        tab.IsDetached
            ? "detached"
            : tab.Snapshot?.Status switch
        {
            TerminalSessionStatus.Active => "active",
            TerminalSessionStatus.Faulted => "faulted",
            _ => "idle"
        };

    private static UiPillTone GetSessionTone(TerminalTabState tab) =>
        tab.Snapshot?.Status switch
        {
            TerminalSessionStatus.Active => UiPillTone.Success,
            TerminalSessionStatus.Faulted => UiPillTone.Failure,
            _ => UiPillTone.Neutral
        };

    private static string GetSessionLabel(TerminalTabState tab) =>
        tab.Snapshot?.Status switch
        {
            TerminalSessionStatus.Active => "Connected",
            TerminalSessionStatus.Faulted => "Faulted",
            TerminalSessionStatus.Closed => "Closed",
            _ => tab.SessionId.HasValue ? "Opening" : "Ready"
        };

