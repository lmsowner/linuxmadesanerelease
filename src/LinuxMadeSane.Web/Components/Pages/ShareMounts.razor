    private async Task RefreshDiscoveryAsync(NetworkShareDiscoveryScope? scope = null, bool runDiscovery = true)
    {
        activeDiscoveryScope = scope ?? activeDiscoveryScope;
        isDiscovering = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            explorer = await ShareWorkspace.GetNetworkShareMountExplorerAsync(activeDiscoveryScope, runDiscovery);
            explorerLoadError = null;
            isNetworkMountStateLoading = false;
            if (explorer.Tooling.HasAllRequiredPackages)
            {
                showInstallPrompt = false;
            }
        }
        finally
        {
            isDiscovering = false;
            await InvokeAsync(StateHasChanged);
