    private async Task ConfirmDeleteMountAsync()
    {
        if (pendingManagedMountDeletion is null && pendingCurrentMountDeletion is null)
        {
            return;
        }

        isDeletingMount = true;

        try
        {
            var deleted = false;

            if (pendingManagedMountDeletion is not null)
            {
                deleted = await DeleteManagedMountAsync(pendingManagedMountDeletion.Id, pendingManagedMountDeletion.LocalMountPath);
            }
            else if (pendingCurrentMountDeletion is not null)
            {
                deleted = await DisconnectCurrentMountAsync(pendingCurrentMountDeletion.LocalMountPath);
            }

            if (deleted)
            {
                showDeleteMountPanel = false;
                pendingManagedMountDeletion = null;
                pendingCurrentMountDeletion = null;
            }
        }
        finally
        {
            isDeletingMount = false;
        }
    }

    private async Task ConfirmDeleteSshfsMountAsync()
    {
        if (pendingSshfsMountDeletion is null)
        {
            return;
        }

        isDeletingSshfsMount = true;

        try
        {
            await ShareWorkspace.DeleteManagedSshfsMountAsync(pendingSshfsMountDeletion.Id);
            expandedCurrentMountBrowsers.Remove(pendingSshfsMountDeletion.LocalMountPath);
            await RefreshSshfsAsync();
            sshfsStatusMessage = "SSHFS mount deleted.";
            sshfsStatusTone = "success";
            showDeleteSshfsMountPanel = false;
            pendingSshfsMountDeletion = null;
        }
        catch (Exception exception)
        {
            sshfsStatusMessage = exception.Message;
            sshfsStatusTone = "error";
        }
        finally
        {
            isDeletingSshfsMount = false;
        }
    }

