    private IReadOnlyList<CurrentSystemMount> GetVisibleCurrentMounts()
    {
        if (explorer is null)
        {
            return [];
        }

        return explorer.CurrentMounts
            .Where(mount =>
                string.IsNullOrWhiteSpace(currentMountSearchTerm) ||
                mount.LocalMountPath.Contains(currentMountSearchTerm, StringComparison.OrdinalIgnoreCase) ||
                mount.SourcePath.Contains(currentMountSearchTerm, StringComparison.OrdinalIgnoreCase) ||
                mount.FileSystemType.Contains(currentMountSearchTerm, StringComparison.OrdinalIgnoreCase) ||
                mount.MountOptions.Contains(currentMountSearchTerm, StringComparison.OrdinalIgnoreCase))
            .ToArray();
    }

    private async Task ToggleCurrentMountBrowserAsync(string mountPath)
    {
        if (expandedCurrentMountBrowsers.Add(mountPath))
        {
            return;
        }

        expandedCurrentMountBrowsers.Remove(mountPath);
        if (await ShareWorkspace.ReleaseTemporaryRemoteMountAsync(mountPath))
        {
            mountStatusMessage = "Temporary LMS mount released.";
            mountStatusTone = "success";
            await RefreshMountStateAsync();
        }
    }

    private bool IsCurrentMountBrowserExpanded(string mountPath) =>
        expandedCurrentMountBrowsers.Contains(mountPath);

    private bool IsSelectedMachine(NetworkShareMachine machine) =>
        selectedMachine?.Id == machine.Id ||
        connectionEditor.Target.Equals(machine.Target, StringComparison.OrdinalIgnoreCase);

    private static string GetMachineAddressSummary(NetworkShareMachine machine)
    {
        if (string.IsNullOrWhiteSpace(machine.IpAddress) ||
            machine.Target.Equals(machine.IpAddress, StringComparison.OrdinalIgnoreCase))
        {
            return machine.Target;
        }

        return $"{machine.Target} · {machine.IpAddress}";
    }

    private bool CanScanNetwork() =>
        explorer?.Tooling.CanScanNetwork ?? false;

    private bool CanScanTailnet() =>
        explorer?.Discovery.CanDiscoverTailnet ?? false;

    private bool CanBrowseRemoteShares() =>
        explorer?.Tooling.CanBrowseRemoteShares ?? false;

    private bool CanCreateRemoteMounts() =>
        explorer?.Tooling.CanCreateRemoteMounts ?? false;

    private bool CanCreateSshfsMounts() =>
        sshfsExplorer?.Tooling.CanCreateSshfsMounts == true &&
        GetMountableSshfsHostCandidates().Count > 0;

    private bool CanSubmitSshfsMount() =>
        CanCreateSshfsMounts() &&
        !isCreatingSshfsMount &&
        sshfsEditor.HostId != Guid.Empty &&
        !string.IsNullOrWhiteSpace(sshfsEditor.RemotePath) &&
        !string.IsNullOrWhiteSpace(sshfsEditor.LocalMountPath) &&
        Path.IsPathRooted(sshfsEditor.LocalMountPath);

    private IReadOnlyList<SshfsMountHostCandidate> GetMountableSshfsHostCandidates() =>
        sshfsExplorer?.HostCandidates
            .Where(candidate => candidate.CanMountWithSshfs)
            .ToArray() ?? [];

    private SshfsMountHostCandidate? SelectedSshfsHostCandidate =>
        sshfsExplorer?.HostCandidates.FirstOrDefault(candidate => candidate.HostId == sshfsEditor.HostId);

    private CurrentSystemMount? FindCurrentMount(string localMountPath) =>
        explorer?.CurrentMounts.FirstOrDefault(mount =>
            mount.LocalMountPath.Equals(localMountPath, StringComparison.OrdinalIgnoreCase));

    private bool CanExposeManagedMountBrowser(ManagedRemoteShareMount mount)
    {
        if (!mount.IsMounted)
        {
            return false;
        }

        var currentMount = FindCurrentMount(mount.LocalMountPath);
        if (currentMount is not null)
        {
            return CanExposeMountBrowser(currentMount);
        }

        return Path.IsPathRooted(mount.LocalMountPath) &&
               Directory.Exists(mount.LocalMountPath);
    }

    private bool CanExposeSshfsMountBrowser(ManagedSshfsMount mount)
    {
        if (!mount.IsMounted)
        {
            return false;
        }

        return Path.IsPathRooted(mount.LocalMountPath) &&
               Directory.Exists(mount.LocalMountPath);
    }

    private Task HandleSshfsHostChangedAsync(ChangeEventArgs args)
    {
        if (Guid.TryParse(args.Value?.ToString(), out var hostId))
        {
            var candidate = sshfsExplorer?.HostCandidates.FirstOrDefault(item => item.HostId == hostId);
            if (candidate is not null)
            {
                ApplySshfsHostCandidate(candidate);
            }
        }

        return Task.CompletedTask;
    }

    private void ApplySshfsHostCandidate(SshfsMountHostCandidate candidate)
    {
        sshfsEditor.HostId = candidate.HostId;
        sshfsEditor.RemotePath = string.IsNullOrWhiteSpace(candidate.DefaultRemotePath)
            ? "/"
            : candidate.DefaultRemotePath;
        sshfsEditor.LocalMountPath = BuildDefaultSshfsMountPath(candidate, sshfsEditor.RemotePath);
        sshfsEditor.PersistOnServer = true;
    }

    private Task SetSshfsRemotePathAsync(string? value)
    {
        sshfsEditor.RemotePath = string.IsNullOrWhiteSpace(value) ? "/" : value.Trim();
        var candidate = SelectedSshfsHostCandidate;
        if (candidate is not null)
        {
            sshfsEditor.LocalMountPath = BuildDefaultSshfsMountPath(candidate, sshfsEditor.RemotePath);
        }

        return Task.CompletedTask;
    }

    private Task SetSshfsLocalMountPathAsync(string? value)
    {
        sshfsEditor.LocalMountPath = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task ApplySshfsMountPathSuggestionAsync(string path)
    {
        sshfsEditor.LocalMountPath = path;
        return Task.CompletedTask;
    }

    private IReadOnlyList<SshfsMountPathSuggestion> BuildSshfsMountPathSuggestions()
    {
        var candidate = SelectedSshfsHostCandidate;
        if (candidate is null)
        {
            return [];
        }

        var remoteLeaf = GetRemotePathLeaf(sshfsEditor.RemotePath);
        return
        [
            new(
                "LMS default",
                BuildDefaultSshfsMountPath(candidate, sshfsEditor.RemotePath),
                "Recommended LMS-managed SSHFS mount location."),
            new(
                "Standard /mnt",
                $"/mnt/{ShareMountPathSuggestions.SlugifyPathSegment(candidate.Name, "host")}/{ShareMountPathSuggestions.SlugifyPathSegment(remoteLeaf, "remote")}",
                "Standard Linux mount area for temporary or admin-created mounts.")
        ];
    }

    private static string BuildDefaultSshfsMountPath(SshfsMountHostCandidate candidate, string remotePath) =>
        $"/mnt/lms/ssh/{ShareMountPathSuggestions.SlugifyPathSegment(candidate.Name, "host")}/{ShareMountPathSuggestions.SlugifyPathSegment(GetRemotePathLeaf(remotePath), "remote")}";

    private static string GetRemotePathLeaf(string? remotePath)
    {
        var trimmed = string.IsNullOrWhiteSpace(remotePath) ? "root" : remotePath.Trim().TrimEnd('/');
        if (string.IsNullOrWhiteSpace(trimmed) || trimmed == "/")
        {
            return "root";
        }

        var separatorIndex = trimmed.LastIndexOf('/');
        return separatorIndex < 0
            ? trimmed
            : trimmed[(separatorIndex + 1)..];
    }

    private static string BuildSshfsSourceSummary(ManagedSshfsMount mount) =>
        $"{mount.UserName}@{mount.Hostname}:{mount.RemotePath}";

    private static string BuildSshfsHostOptionLabel(SshfsMountHostCandidate host) =>
        $"{host.Name} ({host.UserName}@{host.Hostname}:{host.Port})";

    private static string GetManagedSshfsMountSummary(ManagedSshfsMount mount)
    {
        var parts = new List<string>
        {
            mount.IsMounted ? "Mounted" : "Saved only",
            "Managed by LMS",
            $"Port {mount.Port}"
        };

        return string.Join(" • ", parts);
    }

    private static bool CanExposeMountBrowser(CurrentSystemMount mount) =>
        (mount.IsNetworkMount || mount.IsManagedByLms) &&
        Path.IsPathRooted(mount.LocalMountPath) &&
        Directory.Exists(mount.LocalMountPath);

    private static string FormatLog(OperationLogEntry log)
    {
        var parts = new List<string> { $"[{log.Timestamp.ToLocalTime():u}] {log.Level}: {log.Message}" };
        if (!string.IsNullOrWhiteSpace(log.CommandText))
        {
            parts.Add($"$ {log.CommandText}");
        }

        if (!string.IsNullOrWhiteSpace(log.StandardOutput))
        {
            parts.Add(log.StandardOutput.Trim());
        }

        if (!string.IsNullOrWhiteSpace(log.StandardError))
        {
            parts.Add(log.StandardError.Trim());
        }

        return string.Join(Environment.NewLine, parts);
    }

    private sealed record SshfsMountPathSuggestion(string Label, string Path, string Help);

    private static string GetMachineSummary(NetworkShareMachine machine)
    {
        var details = new List<string>();
        if (!string.IsNullOrWhiteSpace(machine.OperatingSystem))
        {
            details.Add(machine.OperatingSystem);
        }

        if (!string.IsNullOrWhiteSpace(machine.ServerVersion))
        {
            details.Add(machine.ServerVersion);
        }

        return details.Count == 0
            ? machine.DiscoveryMethod.Contains("Tailscale", StringComparison.OrdinalIgnoreCase)
                ? "Tailnet peer. Click to interrogate this machine's shares."
                : "Click to interrogate this machine's shares."
            : string.Join(" • ", details);
    }

    private static string GetManagedMountSummary(ManagedRemoteShareMount mount)
    {
        var parts = new List<string>
        {
            mount.IsMounted ? "Mounted" : "Saved only",
            "Managed by LMS"
        };

        if (!string.IsNullOrWhiteSpace(mount.UserName))
        {
            parts.Add($"User {mount.UserName}");
        }

        if (mount.HasSavedPassword)
        {
            parts.Add("Saved credentials");
        }

        return string.Join(" • ", parts);
    }

    private static string GetCurrentMountSummary(CurrentSystemMount mount)
    {
        var parts = new List<string>
        {
            mount.FileSystemType,
            mount.IsReadOnly ? "Read-only" : "Read-write"
        };

        if (mount.IsManagedByLms)
        {
            parts.Add("Managed by LMS");
        }

        return string.Join(" • ", parts);
    }

}
