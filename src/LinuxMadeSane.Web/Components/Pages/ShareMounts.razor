                !string.IsNullOrWhiteSpace(machine.IpAddress) &&
                machine.IpAddress.Contains(machineSearchTerm, StringComparison.OrdinalIgnoreCase) ||
                !string.IsNullOrWhiteSpace(machine.Workgroup) &&
                machine.Workgroup.Contains(machineSearchTerm, StringComparison.OrdinalIgnoreCase))
            .ToArray();
    }

