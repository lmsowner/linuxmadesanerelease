    private int GetRemoteShareTotalCount()
    {
        if (explorer is null)
        {
            return 0;
        }

        return explorer.ManagedMounts.Count +
               explorer.CurrentMounts.Count(mount => mount.IsNetworkMount && !mount.IsManagedByLms);
    }

    private int GetSshfsMountTotalCount()
    {
        if (sshfsExplorer is null)
        {
            return 0;
        }

        return sshfsExplorer.ManagedMounts.Count +
               sshfsExplorer.CurrentMounts.Count(mount => !mount.IsManagedByLms);
    }

    private string GetRemoteShareListSummary()
    {
        var totalCount = GetRemoteShareTotalCount();
        if (string.IsNullOrWhiteSpace(shareMountSearchTerm))
        {
            return $"{totalCount} share(s)";
        }

        return $"{GetRemoteShareListCount()} of {totalCount} share(s)";
    }

    private string GetSshfsMountListSummary()
    {
        var totalCount = GetSshfsMountTotalCount();
        if (string.IsNullOrWhiteSpace(sshfsMountSearchTerm))
        {
            return $"{totalCount} SSH mount(s)";
        }

        return $"{GetSshfsMountListCount()} of {totalCount} SSH mount(s)";
    }

    private IReadOnlyList<ManagedRemoteShareMount> GetVisibleManagedMounts()
    {
        if (explorer is null)
        {
            return [];
        }

        return explorer.ManagedMounts
            .Where(MatchesShareMountFilter)
            .ToArray();
    }

    private IReadOnlyList<ManagedSshfsMount> GetVisibleManagedSshfsMounts()
    {
        if (sshfsExplorer is null)
        {
            return [];
        }

        return sshfsExplorer.ManagedMounts
            .Where(MatchesSshfsMountFilter)
            .ToArray();
    }

    private IReadOnlyList<CurrentSystemMount> GetVisibleUnmanagedNetworkMounts()
    {
        if (explorer is null)
        {
            return [];
        }

        return explorer.CurrentMounts
            .Where(mount => mount.IsNetworkMount && !mount.IsManagedByLms)
            .Where(MatchesShareMountFilter)
            .ToArray();
    }

    private IReadOnlyList<CurrentSystemMount> GetVisibleUnmanagedSshfsMounts()
    {
        if (sshfsExplorer is null)
        {
            return [];
        }

        return sshfsExplorer.CurrentMounts
            .Where(mount => !mount.IsManagedByLms)
            .Where(MatchesSshfsMountFilter)
            .ToArray();
    }

    private bool MatchesShareMountFilter(ManagedRemoteShareMount mount)
    {
        if (string.IsNullOrWhiteSpace(shareMountSearchTerm))
        {
            return true;
        }

        return ContainsShareMountSearch(mount.RemoteHost) ||
               ContainsShareMountSearch(mount.RemoteAddress) ||
               ContainsShareMountSearch(mount.ShareName) ||
               ContainsShareMountSearch(mount.LocalMountPath) ||
               ContainsShareMountSearch(mount.UserName) ||
               ContainsShareMountSearch(mount.Domain) ||
               ContainsShareMountSearch(mount.StatusMessage);
    }

    private bool MatchesShareMountFilter(CurrentSystemMount mount)
    {
        if (string.IsNullOrWhiteSpace(shareMountSearchTerm))
        {
            return true;
        }

        return ContainsShareMountSearch(mount.SourcePath) ||
               ContainsShareMountSearch(mount.LocalMountPath) ||
               ContainsShareMountSearch(mount.FileSystemType) ||
               ContainsShareMountSearch(mount.MountOptions);
    }

    private bool MatchesSshfsMountFilter(ManagedSshfsMount mount)
    {
        if (string.IsNullOrWhiteSpace(sshfsMountSearchTerm))
        {
            return true;
        }

        return ContainsSshfsMountSearch(mount.HostName) ||
               ContainsSshfsMountSearch(mount.Hostname) ||
               ContainsSshfsMountSearch(mount.UserName) ||
               ContainsSshfsMountSearch(mount.RemotePath) ||
               ContainsSshfsMountSearch(mount.LocalMountPath) ||
               ContainsSshfsMountSearch(mount.StatusMessage);
    }

    private bool MatchesSshfsMountFilter(CurrentSystemMount mount)
    {
        if (string.IsNullOrWhiteSpace(sshfsMountSearchTerm))
        {
            return true;
        }

        return ContainsSshfsMountSearch(mount.SourcePath) ||
               ContainsSshfsMountSearch(mount.LocalMountPath) ||
               ContainsSshfsMountSearch(mount.FileSystemType) ||
               ContainsSshfsMountSearch(mount.MountOptions);
    }

    private bool ContainsShareMountSearch(string? value) =>
        !string.IsNullOrWhiteSpace(value) &&
        value.Contains(shareMountSearchTerm, StringComparison.OrdinalIgnoreCase);

    private bool ContainsSshfsMountSearch(string? value) =>
        !string.IsNullOrWhiteSpace(value) &&
        value.Contains(sshfsMountSearchTerm, StringComparison.OrdinalIgnoreCase);

    private IReadOnlyList<NetworkShareMachine> GetVisibleMachines()
