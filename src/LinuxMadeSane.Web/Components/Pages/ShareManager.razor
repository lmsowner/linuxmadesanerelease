@page "/shares/manager"
@rendermode InteractiveServer
<PageTitle>Share Manager | Linux Made Sane</PageTitle>

<div class="page-shell">
    <section class="surface-card page-header-toolbar share-manager-header">
        <div class="page-header-copy">
            <p class="eyebrow">Share manager</p>
            <h1 class="section-title-compact">Current LMS shares</h1>
            <p class="meta-text share-manager-header-copy">The same LMS share-management workspace used inside Shares and Mounts lives here too.</p>
        </div>
        <div class="page-header-actions share-manager-header-actions">
            <UiCommandButton Label="Current shares" Glyph="UiIconGlyph.FolderOpen" Variant="UiButtonVariant.Ghost" Href="/shares" />
            <UiCommandButton Label="Network shares and mounts" Glyph="UiIconGlyph.Connect" Variant="UiButtonVariant.Ghost" Href="/shares/mounts" />
            <UiCommandButton Label="Users and groups" Glyph="UiIconGlyph.Info" Variant="UiButtonVariant.Ghost" Href="/shares/identities" />
        </div>
    </section>

    <ShareManagerWorkspace InitialShareId="@ShareId" />
</div>

@code {
    [SupplyParameterFromQuery(Name = "shareId")]
    public Guid? ShareId { get; set; }
}
