@page "/ai"
@rendermode InteractiveServer

<PageTitle>AI Services | Linux Made Sane</PageTitle>

<div class="page-shell">
    <UiHeroPanel Title="AI Services"
                 Compact="true">
    </UiHeroPanel>

    <TabControl ActiveValue="@activeAiTab"
                ActiveValueChanged="HandleAiTabChangedAsync"
                Class="page-tab-control ai-services-tab-control"
                PanelClass="page-tab-panel ai-services-tab-panel">
            <TabPage Value="@ProvidersTabValue" Title="Providers">
                <AiProviderSettings Embedded="true" />
            </TabPage>

            <TabPage Value="@LocalEngineTabValue" Title="Local Engine">
                <LocalAiEngine Embedded="true" />
            </TabPage>
    </TabControl>
</div>

@code {
    private const string ProvidersTabValue = "providers";
    private const string LocalEngineTabValue = "engine";

    private string activeAiTab = ProvidersTabValue;

    private Task HandleAiTabChangedAsync(string? value)
    {
        activeAiTab = value switch
        {
            LocalEngineTabValue => LocalEngineTabValue,
            ProvidersTabValue => ProvidersTabValue,
            _ => ProvidersTabValue
        };

        return Task.CompletedTask;
    }
}
