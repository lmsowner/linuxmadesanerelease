@page "/hosts/{HostId:guid}"
@rendermode InteractiveServer
@using LinuxMadeSane.Application.Interfaces
@using LinuxMadeSane.Core.Models
@inject IManagedHostService HostService
@inject IServiceScopeFactory ServiceScopeFactory
@inject TerminalWorkspaceRegistry TerminalWorkspaceRegistry
@inject LmsHostUpdateAvailabilityService LmsUpdateAvailabilityService
@inject RemoteLmsSshTunnelService RemoteLmsSshTunnelService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Host Details | Linux Made Sane</PageTitle>

@if (details is null)
{
    <div class="page-shell">
        <section class="surface-card">
            <h1>Host not found</h1>
            <UiCommandButton Label="Return to inventory" Glyph="UiIconGlyph.FolderOpen" Href="/hosts" />
        </section>
    </div>
}
else
{
    <div class="page-shell host-details-shell">
        <section class="hero-panel compact">
            <div>
                <p class="eyebrow">Host details</p>
                <h1 class="page-title-compact">@details.Host.Name</h1>
                <p class="hero-copy">@details.Host.Description</p>
                <ManagedHostKindIndicator Profile="@details.Capabilities" />
            </div>
            <div class="hero-actions">
                @if (CanConnectToRemoteLmsHost)
                {
                    @if (CanOpenRemoteLmsDirectly)
                    {
                        <UiCommandButton Label="Connect"
                                         Glyph="UiIconGlyph.Connect"
                                         Variant="UiButtonVariant.PrimaryMuted"
                                         Title="@RemoteLmsConnectTitle"
                                         Href="@BuildDirectLmsRootUrl(details.Host)"
                                         Target="_blank"
                                         Rel="noreferrer" />
                    }
                    else
                    {
                        <UiCommandButton Label="Connect"
                                         Glyph="UiIconGlyph.Connect"
                                         Variant="UiButtonVariant.PrimaryMuted"
                                         Title="@RemoteLmsConnectTitle"
                                         Disabled="@(!CanRunRemoteLmsTunnel || isRemoteLmsConnectBusy)"
                                         OnClick="@(() => ConnectToRemoteLmsAsync("/"))" />
                    }
                }
                @if (CanRegisterLmsHost)
                {
                    <UiCommandButton Label="@LmsRegisterButtonLabel"
                                     Glyph="UiIconGlyph.Plus"
                                     Variant="UiButtonVariant.PrimaryMuted"
                                     Title="@LmsRegisterButtonTitle"
                                     OnClick="ShowLmsRegisterPrompt"
                                     Disabled="@(!CanRunLmsRegistration || isInstallingLms)" />
                }
                @if (CanUpdateLmsHost)
                {
                    <UiCommandButton Label="@LmsUpdateButtonLabel"
                                     Glyph="UiIconGlyph.Download"
                                     Variant="UiButtonVariant.PrimaryMuted"
                                     OnClick="StartLmsUpdateAsync"
                                     Disabled="@isInstallingLms" />
                    <UiCommandButton Label="Uninstall LMS"
                                     Glyph="UiIconGlyph.Delete"
                                     Variant="UiButtonVariant.Ghost"
                                     OnClick="ShowLmsUninstallPrompt"
                                     Disabled="@isInstallingLms" />
                }
                <UiCommandButton Label="Open terminal"
                                 Glyph="UiIconGlyph.Run"
                                 Href="@($"/hosts/{details.Host.Id}/terminal")"
                                 SuperscriptText="@GetTerminalSessionBadge(details.Host.Id)" />
                <UiCommandButton Label="Browse files" Glyph="UiIconGlyph.FolderOpen" Variant="UiButtonVariant.PrimaryMuted" Href="@($"/hosts/{details.Host.Id}/files")" />
                <UiCommandButton Label="Edit host" Glyph="UiIconGlyph.Edit" Variant="UiButtonVariant.Ghost" Href="@($"/hosts/{details.Host.Id}/edit")" />
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(remoteLmsConnectStatus))
        {
            <p class="@($"callout {remoteLmsConnectTone}")">@remoteLmsConnectStatus</p>
        }
        @if (!string.IsNullOrWhiteSpace(lmsBackgroundUpdateStatus))
        {
            <p class="@($"callout {lmsBackgroundUpdateTone}")">@lmsBackgroundUpdateStatus</p>
        }
        @if (ShouldShowLmsInstallUnavailableNote)
        {
            <p class="callout warning">@LmsInstallUnavailableMessage</p>
        }

        <TabControl ActiveValue="@activeTab"
                    ActiveValueChanged="HandleTabChangedAsync"
                    Class="page-tab-control host-details-tab-control"
                    PanelClass="page-tab-panel host-details-tab-panel">
            <ChildContent>
                <TabPage Value="@OverviewTabValue" Title="Overview">
                    <ChildContent>
                        <div class="overview-grid">
                            <section class="surface-card">
                                <p class="eyebrow">Connectivity</p>
                                <h2>@details.ConnectionTest.Summary</h2>
                                <p class="meta-text">@details.ConnectionTest.Detail</p>
                                <p class="meta-text">Current live checks use the stored SSH credentials and verify that Linux Made Sane can open a real shell session.</p>
                                @if (ShouldShowRemoteLmsWebAccessNote)
                                {
                                    <p class="callout info">Direct port 5080 is not reachable from this LMS session. Connect uses the saved SSH login to open a local tunnel.</p>
                                }
                                <p class="meta-text">Checked @details.ConnectionTest.CheckedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</p>
                            </section>

                            <section class="surface-card">
                                <p class="eyebrow">Server health</p>
                                <div class="stack-tight">
                                    <span>CPU: <strong>@FormatPercent(details.HealthSnapshot.CpuUsagePercent)</strong></span>
                                    <span>Memory free: <strong>@FormatMemorySummary(details.HealthSnapshot)</strong></span>
                                    <span>Disk used: <strong>@FormatPercent(details.HealthSnapshot.DiskUsagePercent)</strong></span>
                                    <span>Disk free: <strong>@FormatDiskAvailable(details.HealthSnapshot.RootDiskAvailable)</strong></span>
                                    <span>Load: <strong>@details.HealthSnapshot.LoadAverage</strong></span>
                                    <span>Uptime: <strong>@details.HealthSnapshot.Uptime</strong></span>
                                </div>
                            </section>
                        </div>

                        <section class="surface-card">
                            <div class="table-header">
                                <h2>Host profile</h2>
                                <span>@FormatPlatform(details.Host.Platform)</span>
                            </div>
                            <div class="details-grid">
                                <ServiceMetricComponent TagName="div" Label="Host type" Value="@details.Capabilities.KindLabel" />
                                <ServiceMetricComponent TagName="div" Label="Endpoint" Value="@($"{details.Host.Hostname}:{details.Host.Port}")" />
                                <ServiceMetricComponent TagName="div" Label="Primary auth" Value="@ManagedHostAuthenticationPolicy.GetDisplayLabel(details.Host.PrimaryAuthenticationType)" />
                                <ServiceMetricComponent TagName="div" Label="Working directory" Value="@details.Host.DefaultWorkingDirectory" />
                            </div>
                            <div class="details-grid details-grid-secondary">
                                <ServiceMetricComponent TagName="div" Label="Fallback auth" Value="@(details.Host.FallbackAuthenticationType.HasValue ? ManagedHostAuthenticationPolicy.GetDisplayLabel(details.Host.FallbackAuthenticationType.Value) : "None")" />
                                <ServiceMetricComponent TagName="div" Label="Stored credentials" Value="@(HasStoredCredentials(details.Host) ? "Yes" : "No")" />
                                <ServiceMetricComponent TagName="div" Label="Protected storage" Value="Encrypted secret storage" />
                            </div>
                            @if (HasLegacyAuthentication(details.Host))
                            {
                                <p class="callout warning">This host is still using a legacy SSH auth mode. Edit it and move it to `Password`, `Password + public key`, or `Public key`.</p>
                            }
                        </section>

                        @if (ShouldShowLmsInstallPanel)
                        {
                            <section class="surface-card lms-install-panel">
                                <div class="table-header">
                                    <div>
                                        <p class="eyebrow">@LmsOperationEyebrow</p>
                                        <h2>@LmsInstallPanelTitle</h2>
                                    </div>
                                </div>

                                <p class="meta-text">
                                    @LmsInstallPanelDescription
                                </p>
                                <p class="callout warning">@LmsInstallPanelWarning</p>

                                @if ((CanRegisterLmsHost || CanInstallLmsHost || CanUpdateLmsHost || CanUninstallLmsHost) && showLmsInstallPrompt)
                                {
                                    @if (details is not null && !HasStoredCredentials(details.Host))
                                    {
                                        <p class="callout warning">Save SSH credentials for this host before running this remote operation.</p>
                                    }

                                    @if (isLmsRegisterMode)
                                    {
                                        <p class="meta-text">No installer will be run. This checks the saved SSH connection for an existing LMS service, app directory, config, or data store, then registers the host when one is found.</p>
                                    }
                                    else if (isLmsUninstallMode)
                                    {
                                        <div class="lms-install-options">
                                            <UiCheckboxField @bind-Value="lmsUninstallOptions.RemoveData"
                                                             Label="Remove LMS data and config"
                                                             Helper="Also removes the remote LMS data and config directories. Leave this off when testing reinstall or update behaviour."
                                                             Card="true"
                                                             Disabled="@isInstallingLms" />
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="lms-install-options">
                                            <UiCheckboxField @bind-Value="lmsInstallOptions.StartService"
                                                             Label="Start service after install"
                                                             Helper="Leaves the remote LMS web service running when the installer finishes."
                                                             Card="true"
                                                             Disabled="@isInstallingLms" />
                                            <UiCheckboxField @bind-Value="lmsInstallOptions.ConfigureLocalSshRunner"
                                                             Label="Prepare local SSH runner"
                                                             Helper="Creates the key-only localhost runner used by terminals, runbooks, and scheduled jobs."
                                                             Card="true"
                                                             Disabled="@isInstallingLms" />
                                            <UiCheckboxField @bind-Value="lmsInstallOptions.EnableLocalSudo"
                                                             Label="Allow runner sudo"
                                                             Helper="Lets the LMS runner perform local admin tasks without password prompts."
                                                             Card="true"
                                                             Disabled="@(!lmsInstallOptions.ConfigureLocalSshRunner || isInstallingLms)" />
                                        </div>
                                    }

                                    <div class="lms-install-actions">
                                        <UiCommandButton Label="Cancel"
                                                         Glyph="UiIconGlyph.Clear"
                                                         Variant="UiButtonVariant.Ghost"
                                                         OnClick="HideLmsInstallPrompt"
                                                         Disabled="@isInstallingLms" />
                                        <UiCommandButton Label="@GetLmsInstallRunButtonLabel()"
                                                         Glyph="UiIconGlyph.Run"
                                                         Variant="UiButtonVariant.Primary"
                                                         OnClick="RunLmsHostOperationAsync"
                                                         Disabled="@(!CanRunLmsHostOperation || isInstallingLms)" />
                                    </div>
                                }

                                @if (lmsInstallResult is not null)
                                {
                                    <p class="@GetLmsInstallResultClass()">
                                        <strong>@lmsInstallResult.Summary</strong>
                                        @lmsInstallResult.Detail
                                    </p>
                                }

                                @if (lmsInstallResult is { Success: false } && isLmsRegisterMode && CanInstallLmsHost)
                                {
                                    <div class="lms-install-actions">
                                        <UiCommandButton Label="Run installer"
                                                         Glyph="UiIconGlyph.Download"
                                                         Variant="UiButtonVariant.Ghost"
                                                         OnClick="ShowLmsInstallPrompt"
                                                         Disabled="@isInstallingLms" />
                                    </div>
                                }

                                @if (lmsInstallResult?.Success == true && details is not null && !isLmsUninstallMode)
                                {
                                    <div class="lms-install-actions">
                                        @if (CanOpenRemoteLmsDirectly)
                                        {
                                            <UiCommandButton Label="Open remote LMS"
                                                             Glyph="UiIconGlyph.Connect"
                                                             Variant="UiButtonVariant.PrimaryMuted"
                                                             Href="@BuildDirectLmsRootUrl(details.Host)"
                                                             Target="_blank"
                                                             Rel="noreferrer" />
                                            <UiCommandButton Label="Local AI setup"
                                                             Glyph="UiIconGlyph.Ai"
                                                             Variant="UiButtonVariant.Ghost"
                                                             Href="@BuildDirectLmsAiSetupUrl(details.Host)"
                                                             Target="_blank"
                                                             Rel="noreferrer" />
                                        }
                                        else
                                        {
                                            <UiCommandButton Label="Open remote LMS"
                                                             Glyph="UiIconGlyph.Connect"
                                                             Variant="UiButtonVariant.PrimaryMuted"
                                                             Disabled="@(!CanRunRemoteLmsTunnel || isRemoteLmsConnectBusy)"
                                                             OnClick="@(() => ConnectToRemoteLmsAsync("/"))" />
                                            <UiCommandButton Label="Local AI setup"
                                                             Glyph="UiIconGlyph.Ai"
                                                             Variant="UiButtonVariant.Ghost"
                                                             Disabled="@(!CanRunRemoteLmsTunnel || isRemoteLmsConnectBusy)"
                                                             OnClick="@(() => ConnectToRemoteLmsAsync("/ai/engine"))" />
                                        }
                                    </div>
                                }

                                @if (lmsInstallProgress.Count > 0)
                                {
                                    <pre class="lms-install-log">@GetLmsInstallProgressLog()</pre>
                                }
                            </section>
                        }

                    </ChildContent>
                </TabPage>
                <TabPage Value="@IntegrationsTabValue" Title="Integrations">
                    <ChildContent>
                        <section class="surface-card integrations-shell">
                            <div class="table-header">
                                <div>
                                    <p class="eyebrow">Integrations</p>
                                    <h2>Edge Gateway publishing</h2>
                                    <p class="meta-text">@BuildHostIntegrationsSummary()</p>
                                </div>
                            </div>

                            <div class="host-edge-gateway-card">
                                <div>
                                    <p class="eyebrow">Managed edge runtime</p>
                                    <h3>Caddy and Cloudflare are configured from Edge Gateway</h3>
                                    <p class="meta-text">LMS owns the Cloudflare token, relay namespace, tunnel connector, Caddy routes, and published app records from one place.</p>
                                </div>
                                <div class="host-edge-gateway-actions">
                                    @if (details.Capabilities.IsLocalLmsHost)
                                    {
                                        <UiCommandButton Label="Open Edge Gateway"
                                                         Glyph="UiIconGlyph.Connect"
                                                         Href="/edge-gateway" />
                                    }
                                    else if (CanConnectToRemoteLmsHost)
                                    {
                                        @if (CanOpenRemoteLmsDirectly)
                                        {
                                            <UiCommandButton Label="Open remote Edge Gateway"
                                                             Glyph="UiIconGlyph.Connect"
                                                             Href="@BuildDirectLmsEdgeGatewayUrl(details.Host)"
                                                             Target="_blank"
                                                             Rel="noreferrer" />
                                        }
                                        else
                                        {
                                            <UiCommandButton Label="Open remote Edge Gateway"
                                                             Glyph="UiIconGlyph.Connect"
                                                             Disabled="@(!CanRunRemoteLmsTunnel || isRemoteLmsConnectBusy)"
                                                             OnClick="@(() => ConnectToRemoteLmsAsync("/edge-gateway"))" />
                                        }
                                    }
                                    else
                                    {
                                        <UiCommandButton Label="Open local Edge Gateway"
                                                         Glyph="UiIconGlyph.Connect"
                                                         Href="/edge-gateway" />
                                    }
                                </div>
                            </div>
                        </section>
                    </ChildContent>
                </TabPage>
            </ChildContent>
        </TabControl>
    </div>
}

@code {
    private const string OverviewTabValue = "overview";
    private const string IntegrationsTabValue = "integrations";

    [Parameter]
    public Guid HostId { get; set; }

    [SupplyParameterFromQuery(Name = "install")]
    public string? InstallAction { get; set; }

    [SupplyParameterFromQuery(Name = "update")]
    public string? UpdateAction { get; set; }

    [SupplyParameterFromQuery(Name = "uninstall")]
    public string? UninstallAction { get; set; }

    private ManagedHostDetailsViewModel? details;
    private string activeTab = OverviewTabValue;
    private ManagedHostLmsInstallOptions lmsInstallOptions = new();
    private ManagedHostLmsUninstallOptions lmsUninstallOptions = new();
    private ManagedHostLmsInstallResult? lmsInstallResult;
    private readonly List<ManagedHostLmsInstallProgressUpdate> lmsInstallProgress = [];
    private bool showLmsInstallPrompt;
    private bool isLmsRegisterMode;
    private bool isLmsUpdateMode;
    private bool isLmsUninstallMode;
    private bool isInstallingLms;
    private bool isBackgroundLmsUpdate;
    private Guid? installQueryHandledForHostId;
    private Guid? updateQueryHandledForHostId;
    private Guid? uninstallQueryHandledForHostId;
    private LmsHostWebAccessStatus? remoteLmsWebAccess;
    private bool isRemoteLmsConnectBusy;
    private string remoteLmsConnectStatus = string.Empty;
    private string remoteLmsConnectTone = "info";
    private string lmsBackgroundUpdateStatus = string.Empty;
    private string lmsBackgroundUpdateTone = "info";

    private bool CanRegisterLmsHost =>
        details is { Capabilities.IsLmsHost: false } &&
        !IsCurrentLmsEndpoint(details.Host);

    private bool CanInstallLmsHost => details is { Capabilities.SupportsLmsInstall: true };

    private bool ShouldShowLmsInstallUnavailableNote =>
        details is { Capabilities.IsLmsHost: false, Capabilities.SupportsLmsInstall: false };

    private string LmsInstallUnavailableMessage =>
        details?.Capabilities.LmsInstallSupportMessage ?? "LMS cannot be installed on this host.";

    private bool CanUpdateLmsHost =>
        details is { Capabilities.IsLmsHost: true, Capabilities.IsLocalLmsHost: false } &&
        !IsCurrentLmsEndpoint(details.Host);

    private bool CanUninstallLmsHost =>
        details is { Capabilities.IsLmsHost: true, Capabilities.IsLocalLmsHost: false } &&
        !IsCurrentLmsEndpoint(details.Host);

    private bool CanConnectToRemoteLmsHost =>
        details is { Capabilities.IsLmsHost: true, Capabilities.IsLocalLmsHost: false };

    private bool ShouldShowRemoteLmsWebAccessNote =>
        details is { Capabilities.IsLmsHost: true, Capabilities.IsLocalLmsHost: false } &&
        remoteLmsWebAccess is { IsDirectWebAvailable: false };

    private bool CanOpenRemoteLmsDirectly =>
        remoteLmsWebAccess?.IsDirectWebAvailable == true;

    private bool CanRunRemoteLmsTunnel =>
        details is not null && HasStoredCredentials(details.Host);

    private bool CanRunLmsRegistration => details is not null && HasStoredCredentials(details.Host);

    private string RemoteLmsConnectTitle =>
        CanOpenRemoteLmsDirectly
            ? "Open the directly reachable LMS web UI on port 5080."
            : CanRunRemoteLmsTunnel
                ? "Port 5080 is not directly reachable. Use saved SSH credentials to open the remote LMS through the Caddy relay."
                : "Save SSH credentials for this host before opening its LMS UI through the relay.";

    private bool CanRunLmsInstaller => details is not null && HasStoredCredentials(details.Host);

    private bool CanRunLmsHostOperation => isLmsRegisterMode ? CanRunLmsRegistration : CanRunLmsInstaller;

    private string LmsRegisterButtonLabel =>
        isInstallingLms && isLmsRegisterMode ? "Checking..." : "Add LMS Server";

    private string LmsRegisterButtonTitle =>
        CanRunLmsRegistration
            ? "Check this SSH host for an existing LMS install and add it to the LMS hosts list."
            : "Save SSH credentials for this host before adding it as an LMS server.";

    private string LmsUpdateButtonLabel =>
        isInstallingLms && isBackgroundLmsUpdate ? "Updating..." : "Update LMS";

    private static string BuildDirectLmsRootUrl(ManagedHost host) =>
        BuildDirectLmsUrl(host, "/");

    private static string BuildDirectLmsAiSetupUrl(ManagedHost host) =>
        BuildDirectLmsUrl(host, "/ai/engine");

    private static string BuildDirectLmsEdgeGatewayUrl(ManagedHost host) =>
        BuildDirectLmsUrl(host, "/edge-gateway");

    private static string BuildDirectLmsUrl(ManagedHost host, string path)
    {
        var endpoint = host.Hostname.Trim();
        var scheme = Uri.UriSchemeHttp;
        if (Uri.TryCreate(endpoint, UriKind.Absolute, out var uri))
        {
            endpoint = uri.Host;
            scheme = uri.Scheme.Equals(Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase)
                ? Uri.UriSchemeHttps
                : Uri.UriSchemeHttp;
        }

        return new UriBuilder(scheme, endpoint, 5080, path.TrimStart('/')).Uri.ToString();
    }

    private bool ShouldShowLmsInstallPanel =>
        !isBackgroundLmsUpdate && (showLmsInstallPrompt || isInstallingLms || lmsInstallResult is not null);

    private string BuildHostIntegrationsSummary()
    {
        if (details is null)
        {
            return string.Empty;
        }

        if (details.Capabilities.IsLocalLmsHost)
        {
            return "Configure the local Cloudflare token, relay namespace, Caddy routing, and published apps in Edge Gateway.";
        }

        if (details.Capabilities.IsLmsHost)
        {
            return "Open this remote LMS instance and configure its Cloudflare token, relay namespace, Caddy routing, and published apps there.";
        }

        return "Use the LMS Edge Gateway page to publish services from this SSH host. Caddy and Cloudflare are no longer configured separately here.";
    }

    private string LmsOperationEyebrow => isLmsRegisterMode
        ? "Host registration"
        : isLmsUninstallMode
        ? "Host uninstall"
        : isLmsUpdateMode
            ? "Host update"
            : "Host conversion";

    private string LmsInstallPanelTitle => isLmsRegisterMode
        ? "Add existing LMS server"
        : isLmsUninstallMode
        ? "Uninstall Linux Made Sane from this LMS host"
        : isLmsUpdateMode
            ? "Update Linux Made Sane on this LMS host"
            : "Install Linux Made Sane on this SSH host";

    private string LmsInstallPanelDescription => isLmsRegisterMode
        ? "Checks the saved SSH connection for an existing Linux Made Sane service, application files, config, or data store, then adds the host to the LMS hosts list when detected."
        : isLmsUninstallMode
        ? "Runs the public Community Edition installer over the saved SSH connection with uninstall mode. The remote account must be root or have non-interactive sudo."
        : isLmsUpdateMode
            ? "Runs the public Community Edition installer over the saved SSH connection, updates the existing remote LMS install, and restarts the service. The remote account must be root or have non-interactive sudo."
            : "Runs the public Community Edition installer over the saved SSH connection, updates an existing install when one is present, and marks the host as an LMS host after a successful run. The remote account must be root or have non-interactive sudo.";

    private string LmsInstallPanelWarning => isLmsRegisterMode
        ? "This operation is read-only on the remote host. If no LMS install is found, the host stays registered as an SSH host."
        : isLmsUninstallMode
        ? "This stops and removes the remote LMS service and application files. Data and config are kept unless you explicitly choose to remove them."
        : isLmsUpdateMode
            ? "This updates the remote LMS service over SSH. The UI on that remote host may restart while the installer swaps the release."
            : "Community Edition can install and convert this SSH host. Once installed, Connect opens that LMS through an SSH tunnel even when port 5080 is not directly reachable.";

    private string GetLmsInstallRunButtonLabel()
    {
        if (isInstallingLms)
        {
            return isLmsRegisterMode
                ? "Checking..."
                : isLmsUninstallMode
                ? "Uninstalling..."
                : isLmsUpdateMode ? "Updating..." : "Installing...";
        }

        return isLmsRegisterMode
            ? "Add LMS Server"
            : isLmsUninstallMode
            ? "Run uninstall"
            : isLmsUpdateMode ? "Run update" : "Run installer";
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadDetailsAsync();
        if (details is not null &&
            !isInstallingLms &&
            !showLmsInstallPrompt &&
            installQueryHandledForHostId != HostId &&
            string.Equals(InstallAction, "lms", StringComparison.OrdinalIgnoreCase))
        {
            installQueryHandledForHostId = HostId;
            if (CanRegisterLmsHost)
            {
                ShowLmsRegisterPrompt();
            }
        }

        if (details is not null &&
            !isInstallingLms &&
            !showLmsInstallPrompt &&
            updateQueryHandledForHostId != HostId &&
            string.Equals(UpdateAction, "lms", StringComparison.OrdinalIgnoreCase) &&
            CanUpdateLmsHost)
        {
            updateQueryHandledForHostId = HostId;
            await StartLmsUpdateAsync();
        }

        if (details is not null &&
            !isInstallingLms &&
            !showLmsInstallPrompt &&
            uninstallQueryHandledForHostId != HostId &&
            string.Equals(UninstallAction, "lms", StringComparison.OrdinalIgnoreCase) &&
            CanUninstallLmsHost)
        {
            uninstallQueryHandledForHostId = HostId;
            ShowLmsUninstallPrompt();
        }
    }

    private async Task LoadDetailsAsync()
    {
        remoteLmsWebAccess = null;
        details = await HostService.GetDetailsAsync(HostId);
        if (details is null)
        {
            return;
        }

        remoteLmsWebAccess = details.Capabilities is { IsLmsHost: true, IsLocalLmsHost: false }
            ? await LmsUpdateAvailabilityService.CheckDirectWebAccessAsync(details.Host)
            : null;
    }

    private void ShowLmsInstallPrompt()
    {
        lmsInstallOptions = new ManagedHostLmsInstallOptions();
        lmsUninstallOptions = new ManagedHostLmsUninstallOptions();
        lmsInstallResult = null;
        lmsInstallProgress.Clear();
        isLmsRegisterMode = false;
        isLmsUpdateMode = false;
        isLmsUninstallMode = false;
        isBackgroundLmsUpdate = false;
        showLmsInstallPrompt = true;
        activeTab = OverviewTabValue;
    }

    private void ShowLmsRegisterPrompt()
    {
        lmsInstallOptions = new ManagedHostLmsInstallOptions();
        lmsUninstallOptions = new ManagedHostLmsUninstallOptions();
        lmsInstallResult = null;
        lmsInstallProgress.Clear();
        isLmsRegisterMode = true;
        isLmsUpdateMode = false;
        isLmsUninstallMode = false;
        isBackgroundLmsUpdate = false;
        showLmsInstallPrompt = true;
        activeTab = OverviewTabValue;
    }

    private void ShowLmsUpdatePrompt()
    {
        lmsInstallOptions = new ManagedHostLmsInstallOptions
        {
            StartService = true,
            ConfigureLocalSshRunner = true,
            EnableLocalSudo = true,
            UpdateExistingInstall = true,
            MarkAsLmsHostOnSuccess = true
        };
        lmsUninstallOptions = new ManagedHostLmsUninstallOptions();
        lmsInstallResult = null;
        lmsInstallProgress.Clear();
        isLmsRegisterMode = false;
        isLmsUpdateMode = true;
        isLmsUninstallMode = false;
        isBackgroundLmsUpdate = false;
        showLmsInstallPrompt = true;
        activeTab = OverviewTabValue;
    }

    private void ShowLmsUninstallPrompt()
    {
        lmsInstallOptions = new ManagedHostLmsInstallOptions();
        lmsUninstallOptions = new ManagedHostLmsUninstallOptions
        {
            RemoveData = false,
            MarkAsSshHostOnSuccess = true
        };
        lmsInstallResult = null;
        lmsInstallProgress.Clear();
        isLmsRegisterMode = false;
        isLmsUpdateMode = false;
        isLmsUninstallMode = true;
        isBackgroundLmsUpdate = false;
        showLmsInstallPrompt = true;
        activeTab = OverviewTabValue;
    }

    private void HideLmsInstallPrompt()
    {
        if (isInstallingLms)
        {
            return;
        }

        showLmsInstallPrompt = false;
        isLmsRegisterMode = false;
        isLmsUpdateMode = false;
        isLmsUninstallMode = false;
        isBackgroundLmsUpdate = false;
    }

    private Task StartLmsUpdateAsync()
    {
        if (details is null || isInstallingLms)
        {
            return Task.CompletedTask;
        }

        if (IsCurrentLmsEndpoint(details.Host))
        {
            NavigationManager.NavigateTo("/updates");
            return Task.CompletedTask;
        }

        isInstallingLms = true;
        isBackgroundLmsUpdate = true;
        isLmsRegisterMode = false;
        isLmsUpdateMode = true;
        isLmsUninstallMode = false;
        showLmsInstallPrompt = false;
        lmsInstallResult = null;
        lmsInstallProgress.Clear();
        lmsBackgroundUpdateStatus = $"Update started for {details.Host.Name}.";
        lmsBackgroundUpdateTone = "info";

        _ = RunLmsUpdateInBackgroundAsync(details.Host.Id, details.Host.Name);
        return Task.CompletedTask;
    }

    private async Task RunLmsUpdateInBackgroundAsync(Guid hostId, string hostName)
    {
        var progress = new Progress<ManagedHostLmsInstallProgressUpdate>(update =>
        {
            _ = ApplyBackgroundLmsUpdateProgressAsync(hostName, update);
        });

        try
        {
            await using var scope = ServiceScopeFactory.CreateAsyncScope();
            var hostService = scope.ServiceProvider.GetRequiredService<IManagedHostService>();
            var result = await hostService.InstallLmsAsync(
                hostId,
                BuildLmsUpdateOptions(),
                progress,
                CancellationToken.None);

            await InvokeIfAliveAsync(async () =>
            {
                lmsBackgroundUpdateStatus = result.Success
                    ? $"Update finished for {hostName}."
                    : $"Update failed for {hostName}: {FirstNonBlank(result.Detail, result.Summary, "remote installer failed")}";
                lmsBackgroundUpdateTone = result.Success ? "success" : "error";
                isInstallingLms = false;
                isBackgroundLmsUpdate = false;

                if (result.Success && details?.Host.Id == hostId)
                {
                    await LoadDetailsAsync();
                }
            });
        }
        catch (Exception ex)
        {
            await InvokeIfAliveAsync(() =>
            {
                lmsBackgroundUpdateStatus = $"Update failed for {hostName}: {ex.Message}";
                lmsBackgroundUpdateTone = "error";
                isInstallingLms = false;
                isBackgroundLmsUpdate = false;
            });
        }
    }

    private Task ApplyBackgroundLmsUpdateProgressAsync(string hostName, ManagedHostLmsInstallProgressUpdate update) =>
        InvokeIfAliveAsync(() =>
        {
            lmsBackgroundUpdateStatus = update.State switch
            {
                ManagedHostLmsInstallProgressState.Starting => $"Update started for {hostName}.",
                ManagedHostLmsInstallProgressState.Completed => $"Update finished for {hostName}.",
                ManagedHostLmsInstallProgressState.Failed => $"Update failed for {hostName}: {FirstNonBlank(update.Message, "remote installer failed")}",
                _ => $"Applying update on {hostName}."
            };
            lmsBackgroundUpdateTone = update.State switch
            {
                ManagedHostLmsInstallProgressState.Completed => "success",
                ManagedHostLmsInstallProgressState.Failed => "error",
                _ => "info"
            };
        });

    private async Task InvokeIfAliveAsync(Action action)
    {
        try
        {
            await InvokeAsync(() =>
            {
                action();
                StateHasChanged();
            });
        }
        catch (ObjectDisposedException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }

    private async Task InvokeIfAliveAsync(Func<Task> action)
    {
        try
        {
            await InvokeAsync(async () =>
            {
                await action();
                StateHasChanged();
            });
        }
        catch (ObjectDisposedException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }

    private static ManagedHostLmsInstallOptions BuildLmsUpdateOptions() =>
        new()
        {
            StartService = true,
            ConfigureLocalSshRunner = true,
            EnableLocalSudo = true,
            UpdateExistingInstall = true,
            MarkAsLmsHostOnSuccess = true
        };

    private async Task RunLmsHostOperationAsync()
    {
        if (details is null || isInstallingLms)
        {
            return;
        }

        isInstallingLms = true;
        isBackgroundLmsUpdate = false;
        lmsInstallResult = null;
        lmsInstallProgress.Clear();

        var progress = new Progress<ManagedHostLmsInstallProgressUpdate>(update =>
        {
            lmsInstallProgress.Add(update);
            _ = InvokeAsync(StateHasChanged);
        });

        try
        {
            lmsInstallResult = isLmsRegisterMode
                ? await HostService.RegisterLmsHostAsync(details.Host.Id, progress)
                : isLmsUninstallMode
                    ? await HostService.UninstallLmsAsync(details.Host.Id, lmsUninstallOptions, progress)
                    : await HostService.InstallLmsAsync(details.Host.Id, lmsInstallOptions, progress);
            if (lmsInstallResult.Success)
            {
                showLmsInstallPrompt = false;
                await LoadDetailsAsync();
            }
        }
        catch (Exception ex)
        {
            var now = DateTimeOffset.UtcNow;
            lmsInstallProgress.Add(new ManagedHostLmsInstallProgressUpdate(
                ManagedHostLmsInstallProgressState.Failed,
                ex.Message,
                now));
            lmsInstallResult = new ManagedHostLmsInstallResult(
                false,
                isLmsRegisterMode
                    ? "Add LMS Server failed."
                    : isLmsUninstallMode
                    ? "Linux Made Sane uninstall failed."
                    : "Linux Made Sane install failed.",
                ex.Message,
                string.Empty,
                null,
                string.Empty,
                ex.ToString(),
                now,
                now);
        }
        finally
        {
            isInstallingLms = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string? GetTerminalSessionBadge(Guid hostId)
    {
        var count = TerminalWorkspaceRegistry.GetOpenSessionCount(hostId);
        return count > 0 ? count.ToString() : null;
    }

    private Task HandleTabChangedAsync(string? value)
    {
        activeTab = string.IsNullOrWhiteSpace(value) ? OverviewTabValue : value;
        return Task.CompletedTask;
    }

    private async Task ConnectToRemoteLmsAsync(string path)
    {
        if (details is null || !CanRunRemoteLmsTunnel || isRemoteLmsConnectBusy)
        {
            return;
        }

        isRemoteLmsConnectBusy = true;
        remoteLmsConnectStatus = $"Opening an SSH tunnel to {details.Host.Name}...";
        remoteLmsConnectTone = "info";
        var popupName = BuildRemoteLmsPopupName(details.Host);
        var popupPrepared = await JSRuntime.InvokeAsync<bool>("lmsTerminalWindow.preparePopup", popupName, 1280, 900);
        if (popupPrepared)
        {
            _ = await JSRuntime.InvokeAsync<bool>(
                "lmsTerminalWindow.setPreparedPopupStatus",
                popupName,
                $"Connecting to {details.Host.Name}",
                "Opening the SSH tunnel and preparing the Caddy relay.");
        }

        try
        {
            var connection = await RemoteLmsSshTunnelService.ConnectAsync(details.Host.Id, path);
            if (popupPrepared)
            {
                _ = await JSRuntime.InvokeAsync<bool>(
                    "lmsTerminalWindow.setPreparedPopupStatus",
                    popupName,
                    $"Opening {details.Host.Name}",
                    "Caddy relay is ready. Opening the remote LMS.");
            }

            var opened = await JSRuntime.InvokeAsync<bool>(
                "lmsTerminalWindow.openPopupAfterDelay",
                connection.Url,
                popupName,
                1280,
                900,
                1200);
            if (!opened)
            {
                NavigationManager.NavigateTo(connection.Url, forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            remoteLmsConnectStatus = $"Could not connect to {details.Host.Name} through SSH: {ex.Message}";
            remoteLmsConnectTone = "error";
            if (popupPrepared)
            {
                _ = await JSRuntime.InvokeAsync<bool>(
                    "lmsTerminalWindow.setPreparedPopupStatus",
                    popupName,
                    $"Could not open {details.Host.Name}",
                    ex.Message,
                    "error");
            }
        }
        finally
        {
            isRemoteLmsConnectBusy = false;
        }
    }

    private static string BuildRemoteLmsPopupName(ManagedHost host) =>
        $"lms-remote-{host.Id:N}-{Guid.NewGuid():N}";

    private static string FormatPlatform(string? platform) =>
        string.IsNullOrWhiteSpace(platform) ? "Platform not set" : platform;

    private static string FormatPercent(double? value) =>
        value.HasValue ? $"{value.Value:0.#}%" : "Unavailable";

    private static string FormatDiskAvailable(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "Unavailable" : value;

    private static bool HasStoredCredentials(ManagedHost host) =>
        !string.IsNullOrWhiteSpace(host.PasswordSecretReference) ||
        !string.IsNullOrWhiteSpace(host.PrivateKeySecretReference);

    private static bool IsCurrentLmsEndpoint(ManagedHost host) =>
        ManagedHostCapabilities.Describe(host).IsLocalLmsHost ||
        AiLocalMachine.IsLoopbackHostname(host.Hostname);

    private static string? FirstNonBlank(params string?[] values) =>
        values.FirstOrDefault(value => !string.IsNullOrWhiteSpace(value))?.Trim();

    private static bool HasLegacyAuthentication(ManagedHost host) =>
        !ManagedHostAuthenticationPolicy.IsOperatorSelectable(host.PrimaryAuthenticationType) ||
        (host.FallbackAuthenticationType.HasValue && !ManagedHostAuthenticationPolicy.IsOperatorSelectable(host.FallbackAuthenticationType.Value));

    private string GetLmsInstallProgressLog() =>
        string.Join(Environment.NewLine, lmsInstallProgress.Select(FormatLmsInstallProgressUpdate));

    private static string FormatLmsInstallProgressUpdate(ManagedHostLmsInstallProgressUpdate update)
    {
        var channel = update.Channel switch
        {
            CommandExecutionOutputChannel.StandardError => "stderr",
            CommandExecutionOutputChannel.StandardOutput => "stdout",
            _ => update.State.ToString().ToLowerInvariant()
        };

        return $"[{update.OccurredAtUtc.ToLocalTime():HH:mm:ss}] {channel}: {update.Message}";
    }

    private string GetLmsInstallResultClass() =>
        lmsInstallResult?.Success == true ? "callout success" : "callout error";

    private static string FormatMemorySummary(ServerHealthSnapshot snapshot)
    {
        var memory = FormatCompactBytes(snapshot.MemoryAvailableBytes);
        var swap = FormatCompactBytes(snapshot.SwapFreeBytes);
        var percent = snapshot.MemoryFreePercent.HasValue
            ? $" ({snapshot.MemoryFreePercent.Value:0.#}% free)"
            : string.Empty;

        if (string.IsNullOrWhiteSpace(memory))
        {
            if (string.IsNullOrWhiteSpace(swap))
            {
                return "Unavailable";
            }

            return $"{swap} swap{percent}";
        }

        return string.IsNullOrWhiteSpace(swap)
            ? $"{memory}{percent}"
            : $"{memory} + {swap} swap{percent}";
    }

    private static string? FormatCompactBytes(long? bytes)
    {
        if (!bytes.HasValue)
        {
            return null;
        }

        string[] units = ["B", "K", "M", "G", "T", "P"];
        double value = bytes.Value;
        var unitIndex = 0;

        while (value >= 1024 && unitIndex < units.Length - 1)
        {
            value /= 1024;
            unitIndex++;
        }

        var format = value >= 10 || unitIndex == 0 ? "0" : "0.#";
        return $"{value.ToString(format, System.Globalization.CultureInfo.InvariantCulture)}{units[unitIndex]}";
    }
}
