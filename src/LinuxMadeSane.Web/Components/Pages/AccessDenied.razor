@page "/access-denied"
@layout AuthLayout
@inject IHttpContextAccessor HttpContextAccessor
@inject LinuxMadeSane.Core.Abstractions.ITrustedNetworkAccessService TrustedNetworkAccessService

<PageTitle>Access Denied | Linux Made Sane</PageTitle>

<div class="page-shell">
    <section class="surface-card">
        <p class="eyebrow">403</p>
        <h1>Access denied</h1>
        @if (accessRequiresAuthentication)
        {
            <p>This network interface requires authenticated access before Linux Made Sane can be used.</p>
            <p class="meta-text">Sign in with your username or email plus OTP, or switch to an interface that allows direct access.</p>

            <div class="toolbar-row">
                <UiCommandButton Label="Go to login" Glyph="UiIconGlyph.Connect" Href="/login" />
            </div>
        }
        else
        {
            <p>This network interface is not allowed to reach Linux Made Sane right now.</p>
            <p class="meta-text">This matching network rule is disabled. Use a different interface or change the rule in <strong>LMS Accounts</strong>.</p>
        }
    </section>
</div>

@code {
    private bool accessRequiresAuthentication;

    protected override async Task OnInitializedAsync()
    {
        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext is null)
        {
            return;
        }

        if (httpContext.Items.TryGetValue("LmsTrustedNetworkAccess", out var cached) &&
            cached is TrustedNetworkAccessResult cachedResult)
        {
            accessRequiresAuthentication = cachedResult.RequiresAuthentication;
            return;
        }

        var accessResult = await TrustedNetworkAccessService.EvaluateAsync(
            httpContext.Connection.RemoteIpAddress,
            httpContext.Request.Host.Host,
            httpContext.RequestAborted);
        accessRequiresAuthentication = accessResult.RequiresAuthentication;
    }
}
