@page "/ai/providers/new"
@page "/ai/providers/{ProviderKey}"
@rendermode InteractiveServer
@using LinuxMadeSane.Application.Contracts.LocalAi
@using LinuxMadeSane.Application.Interfaces
@using LinuxMadeSane.Core.Models.Ai
@using LinuxMadeSane.Core.Models.LocalAi
@inject IAiProviderSettingsService ProviderSettingsService
@inject ILocalAiEngineManagerService LocalAiService
@inject NavigationManager NavigationManager

<PageTitle>@(IsEditMode ? "Edit AI Provider" : "New AI Provider") | Linux Made Sane</PageTitle>

<div class="page-shell ai-chat-shell">
    @if (!isLoaded)
    {
        <section class="surface-card">
            <p class="meta-text">Loading provider editor...</p>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(loadError))
    {
        <section class="surface-card">
            <div class="callout error">@loadError</div>
        </section>
    }
    else if (IsEditMode && (providerContext is null || !providerContext.ProviderExists))
    {
        <section class="surface-card">
            <div class="empty-state">
                That provider record could not be found.
            </div>
        </section>
    }
    else if (providerContext is not null)
    {
        <div class="dashboard-columns">
            <section class="surface-card">
                @if (!string.IsNullOrWhiteSpace(saveError))
                {
                    <div class="callout warning">@saveError</div>
                }

                @if (!string.IsNullOrWhiteSpace(providerTestMessage))
                {
                    <div class="callout @providerTestTone">@providerTestMessage</div>
                }

                @if (!SelectedProviderTypeDefinition.IsRuntimeImplemented)
                {
                    <div class="callout warning">
                        @SelectedProviderTypeDefinition.RuntimeNotes
                    </div>
                }

                <EditForm Model="@providerContext.Editor" OnValidSubmit="SaveAsync" class="stack-form">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="field-row">
                        @if (IsEditMode)
                        {
                            <div class="provider-type-label">
                                <div class="ui-field-copy">
                                    <span class="ui-field-label">Provider</span>
                                </div>
                                <div class="ui-field-input-region">
                                    <div class="provider-type-value">@SelectedProviderTypeDefinition.DisplayName</div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <UiComboboxField TValue="AiProviderType"
                                           @bind-Value="providerContext.Editor.ProviderType"
                                           @bind-Value:after="OnProviderTypeChanged"
                                           Label="Provider">
                                @foreach (var provider in providerContext.SupportedProviders.OrderBy(provider => provider.DisplayName, StringComparer.OrdinalIgnoreCase))
                                {
                                    <option value="@provider.ProviderType">@provider.DisplayName</option>
                                }
                            </UiComboboxField>
                        }

                        <UiTextField @bind-Value="providerContext.Editor.DisplayName"
                                     Label="Display name" />
                    </div>

                    @if (providerContext.Editor.ProviderType == AiProviderType.Custom ||
                         !string.IsNullOrWhiteSpace(providerContext.Editor.BaseUrl))
                    {
                        <section class="ai-provider-docker-api-panel">
                            @if (!string.IsNullOrWhiteSpace(dockerDiscoveryMessage))
                            {
                                <div class="callout warning">@dockerDiscoveryMessage</div>
                            }

                            <div class="field-row ai-provider-docker-source-row">
                                <UiComboboxField TValue="string"
                                                 Value="@SelectedDockerEngineBaseUrl"
                                                 ValueChanged="SetDockerHostedEngineAsync"
                                                 ValueExpression="@(() => SelectedDockerEngineBaseUrl)"
                                                 Label="Docker-hosted AI"
                                                 Helper="@DockerHostedAiHelper">
                                    <option value="">Manual / external OpenAI-compatible endpoint</option>
                                    @foreach (var engine in ReadyDockerCompatibleEngines)
                                    {
                                        <option value="@NormalizeBaseUrl(engine.BaseUrl)">@FormatDockerEngineOption(engine)</option>
                                    }
                                </UiComboboxField>

                                <UiTextField @bind-Value="providerContext.Editor.BaseUrl"
                                             Label="Base URL"
                                             Helper="OpenAI-compatible API root, for example http://127.0.0.1:8000/v1." />
                            </div>
                        </section>
                    }

                    <div class="field-row ai-provider-model-row">
                        <UiComboboxField TValue="string"
                                       @bind-Value="providerContext.Editor.DefaultModelId"
                                       Label="Default model"
                                       Helper="@DefaultModelFieldHelper">
                            @if (CurrentModelOptions.Count == 0)
                            {
                                <option value="">Select an engine or refresh models</option>
                            }
                            @foreach (var model in CurrentModelOptions)
                            {
                                <option value="@model.ModelId">@model.DisplayName</option>
                            }
                        </UiComboboxField>
                        <UiCommandButton Label="@(isRefreshingModels ? "Refreshing..." : "Refresh models")"
                                         Glyph="UiIconGlyph.Refresh"
                                         Variant="UiButtonVariant.Toolbar"
                                         Class="ai-provider-refresh-models-button"
                                         Disabled="@(isSaving || isTestingProvider || isRefreshingModels)"
                                         OnClick="HandleRefreshModelsAsync" />
                    </div>

                    @if (!string.IsNullOrWhiteSpace(modelRefreshMessage))
                    {
                        <div class="callout @modelRefreshTone">@modelRefreshMessage</div>
                    }

                    <details class="identity-advanced" open>
                        <summary>Capability flags</summary>
                        <div class="advanced-fields">
                            <div class="field-row">
                                <UiCheckboxField @bind-Value="providerContext.Editor.IsEnabled"
                                                 Label="Enabled" />

                                <UiCheckboxField @bind-Value="providerContext.Editor.IsDefault"
                                                 Label="Default provider" />
                            </div>

                            <div class="field-row">
                                <UiCheckboxField @bind-Value="providerContext.Editor.StreamingEnabled"
                                                 Label="Streaming enabled" />

                                <UiCheckboxField @bind-Value="providerContext.Editor.ToolUseEnabled"
                                                 Label="Tool use enabled" />
                            </div>
                        </div>
                    </details>

                    @if (providerContext.Editor.RequiresApiKey)
                    {
                        <details class="identity-advanced" open>
                            <summary>Protected API key</summary>
                            <div class="advanced-fields">
                                <UiTextField @bind-Value="providerContext.Editor.ApiKeyInput"
                                             Label="@(providerContext.Editor.HasApiKeyConfigured ? "Replacement API key" : "API key")"
                                             Type="password"
                                             Autocomplete="new-password" />

                                <p class="helper-text">
                                    @(providerContext.Editor.HasApiKeyConfigured
                                        ? "A key is already stored. Enter a new one to replace it, or clear it."
                                        : "No key stored yet.")
                                </p>

                                @if (providerContext.Editor.HasApiKeyConfigured)
                                {
                                    <UiCheckboxField @bind-Value="providerContext.Editor.ClearStoredApiKey"
                                                     Label="Clear stored API key" />
                                }
                            </div>
                        </details>
                    }
                    else
                    {
                        <details class="identity-advanced" open>
                            <summary>Provider runtime</summary>
                            <div class="advanced-fields">
                                <p class="helper-text">This provider is managed by Linux Made Sane and does not require a directly stored API key.</p>
                            </div>
                        </details>
                    }

                    <div class="hero-actions">
                        <UiCommandButton Label="@(isTestingProvider ? "Testing..." : "Test provider")"
                                         Glyph="UiIconGlyph.Search"
                                         Variant="UiButtonVariant.ActionSubtle"
                                         Disabled="@(isSaving || isTestingProvider)"
                                         OnClick="HandleTestProviderAsync" />
                        <UiCommandButton Label="@(isSaving ? "Saving..." : IsEditMode ? "Save provider" : "Create provider")"
                                         Glyph="UiIconGlyph.Connect"
                                         Type="submit"
                                         Disabled="@(isSaving || isTestingProvider)" />
                        <UiCommandButton Label="Cancel" Glyph="UiIconGlyph.Clear" Href="/ai/providers" Variant="UiButtonVariant.Secondary" />
                    </div>
                </EditForm>
            </section>

            <section class="surface-card">
                <div class="table-header">
                    <h2>Existing provider records</h2>
                    <span>@providerContext.ExistingProviders.Count item(s)</span>
                </div>

                @if (providerContext.ExistingProviders.Count == 0)
                {
                    <div class="empty-state">
                        This will be the first provider record.
                    </div>
                }
                else
                {
                    <div class="stack-list">
                        @foreach (var provider in providerContext.ExistingProviders)
                        {
                            <a class="list-row" href="@($"/ai/providers/{provider.ProviderKey}")">
                                <div class="stack-tight">
                                    <strong>@provider.DisplayName</strong>
                                    <span class="meta-text">@provider.ProviderType | @provider.DefaultModelId</span>
                                </div>
                                <div class="row-action-cluster">
                                    @if (provider.IsDefault)
                                    {
                                        <span class="status-pill neutral">Default</span>
                                    }
                                    <span class="status-pill @((provider.RequiresApiKey ? provider.HasApiKeyConfigured : true) ? "success" : "warning")">
                                        @(provider.RequiresApiKey
                                            ? provider.HasApiKeyConfigured ? "API key set" : "API key missing"
                                            : "Managed locally")
                                    </span>
                                    <span class="status-pill @(provider.StreamingEnabled ? "success" : "neutral")">
                                        @(provider.StreamingEnabled ? "Streaming" : "No streaming")
                                    </span>
                                </div>
                            </a>
                        }
                    </div>
                }
            </section>
        </div>
    }
</div>

@code {
    [Parameter]
    public string? ProviderKey { get; set; }

    private AiProviderSettingsEditorContextViewModel? providerContext;
    private LocalAiEngineWorkspaceViewModel? localAiWorkspace;
    private bool isLoaded;
    private bool isSaving;
    private bool isTestingProvider;
    private bool isRefreshingModels;
    private string loadError = string.Empty;
    private string saveError = string.Empty;
    private string? providerTestMessage;
    private string providerTestTone = "success";
    private string? modelRefreshMessage;
    private string modelRefreshTone = "success";
    private string dockerDiscoveryMessage = string.Empty;
    private AiProviderType? lastProviderType;
    private bool IsEditMode => !string.IsNullOrWhiteSpace(ProviderKey);
    private AiProviderDefinition SelectedProviderTypeDefinition =>
        providerContext?.SupportedProviders.FirstOrDefault(provider => provider.ProviderType == providerContext.Editor.ProviderType)
        ?? new AiProviderDefinition("unknown", AiProviderType.Unknown, "Unknown", "Unknown provider type.", false, false);
    private IReadOnlyList<DockerAiDiscoveredEngine> ReadyDockerCompatibleEngines =>
        localAiWorkspace?.DockerEngines.DiscoveredEngines
            .Where(engine => engine.IsRunning &&
                             engine.IsReachable &&
                             !string.IsNullOrWhiteSpace(engine.BaseUrl) &&
                             engine.ModelIds.Any(IsSelectableChatModelId))
            .OrderBy(engine => engine.ContainerName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(engine => engine.BaseUrl, StringComparer.OrdinalIgnoreCase)
            .ToArray()
        ?? [];

    private string SelectedDockerEngineBaseUrl
    {
        get
        {
            var baseUrl = providerContext?.Editor.BaseUrl ?? string.Empty;
            return ReadyDockerCompatibleEngines
                       .FirstOrDefault(engine => SameBaseUrl(engine.BaseUrl, baseUrl))
                       ?.BaseUrl
                       .Trim()
                       .TrimEnd('/') ??
                   string.Empty;
        }
    }

    private string DockerHostedAiHelper =>
        ReadyDockerCompatibleEngines.Count == 0
            ? "No running Docker model endpoint was found. Use a manual endpoint below, or start one in Local AI."
            : "Choose a Docker engine LMS has already found, then pick the model below.";

    private string? DefaultModelFieldHelper =>
        CurrentModelOptions.Count > 0
            ? "Used for new chats that pick this provider."
            : providerContext?.Editor.ProviderType == AiProviderType.Custom
                ? "Select a Docker-hosted AI endpoint, or enter a Base URL and refresh models."
                : null;

    private IReadOnlyList<AiProviderModelOption> CurrentModelOptions
    {
        get
        {
            if (providerContext is null)
            {
                return [];
            }

            var options = providerContext.AvailableModelOptions
                .Where(model => model.ProviderType == providerContext.Editor.ProviderType)
                .Concat(GetDockerModelOptionsForCurrentProvider())
                .Where(IsSelectableModelOption)
                .GroupBy(model => model.ModelId, StringComparer.OrdinalIgnoreCase)
                .Select(group => group.First())
                .OrderByDescending(model => model.IsRecommendedDefault)
                .ThenBy(model => model.DisplayName, StringComparer.OrdinalIgnoreCase)
                .ToArray();

            return options;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoaded = false;
        loadError = string.Empty;
        saveError = string.Empty;
        ClearProviderTestMessage();
        ClearModelRefreshMessage();

        try
        {
            providerContext = await ProviderSettingsService.GetEditorAsync(ProviderKey);
            lastProviderType = providerContext.Editor.ProviderType;
            providerContext.Editor.RequiresApiKey = SelectedProviderTypeDefinition.RequiresApiKey;
            try
            {
                localAiWorkspace = await LocalAiService.GetWorkspaceAsync();
                dockerDiscoveryMessage = string.Empty;
            }
            catch (Exception exception)
            {
                localAiWorkspace = null;
                dockerDiscoveryMessage = $"Docker API-compatible engine discovery is unavailable: {exception.Message}";
            }

            EnsureSelectedDefaultModelIsSelectable();
        }
        catch (Exception exception)
        {
            providerContext = null;
            loadError = exception.Message;
        }
        finally
        {
            isLoaded = true;
        }
    }

    private Task OnProviderTypeChanged()
    {
        if (providerContext is null)
        {
            return Task.CompletedTask;
        }

        ClearProviderTestMessage();
        ClearModelRefreshMessage();

        var previousDefinition = lastProviderType.HasValue
            ? providerContext.SupportedProviders.FirstOrDefault(provider => provider.ProviderType == lastProviderType.Value)
            : null;
        var selectedDefinition = SelectedProviderTypeDefinition;

        if (string.IsNullOrWhiteSpace(providerContext.Editor.DisplayName) ||
            (!string.IsNullOrWhiteSpace(previousDefinition?.DisplayName) &&
             providerContext.Editor.DisplayName.Equals(previousDefinition.DisplayName, StringComparison.OrdinalIgnoreCase)))
        {
            providerContext.Editor.DisplayName = selectedDefinition.DisplayName;
        }

        if (providerContext.Editor.ProviderType == AiProviderType.Custom &&
            string.IsNullOrWhiteSpace(providerContext.Editor.BaseUrl) &&
            ReadyDockerCompatibleEngines.Count == 1)
        {
            ApplyDockerCompatibleEngine(ReadyDockerCompatibleEngines[0], updateDisplayName: true);
        }
        else
        {
            EnsureSelectedDefaultModelIsSelectable();
        }

        lastProviderType = providerContext.Editor.ProviderType;
        providerContext.Editor.RequiresApiKey = selectedDefinition.RequiresApiKey;

        return Task.CompletedTask;
    }

    private async Task SaveAsync()
    {
        if (providerContext is null)
        {
            return;
        }

        isSaving = true;
        saveError = string.Empty;
        ClearProviderTestMessage();

        try
        {
            var providerKey = await ProviderSettingsService.SaveAsync(providerContext.Editor);
            var targetPath = $"/ai/providers/{providerKey}";
            var currentPath = "/" + NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Trim('/');

            if (string.Equals(currentPath, targetPath, StringComparison.OrdinalIgnoreCase))
            {
                providerContext = await ProviderSettingsService.GetEditorAsync(providerKey);
            }
            else
            {
                NavigationManager.NavigateTo(targetPath);
            }
        }
        catch (Exception exception)
        {
            saveError = exception.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task HandleTestProviderAsync()
    {
        if (providerContext is null)
        {
            return;
        }

        isTestingProvider = true;
        saveError = string.Empty;
        providerTestTone = "warning";
        providerTestMessage = "Testing provider...";

        try
        {
            var result = await ProviderSettingsService.TestAsync(providerContext.Editor);
            providerTestTone = result.Succeeded ? "success" : "warning";
            providerTestMessage = string.IsNullOrWhiteSpace(result.Detail)
                ? result.Summary
                : $"{result.Summary} {result.Detail}";
        }
        catch (Exception exception)
        {
            providerTestTone = "error";
            providerTestMessage = exception.Message;
        }
        finally
        {
            isTestingProvider = false;
        }
    }

    private async Task HandleRefreshModelsAsync()
    {
        if (providerContext is null)
        {
            return;
        }

        isRefreshingModels = true;
        saveError = string.Empty;
        modelRefreshTone = "warning";
        modelRefreshMessage = "Refreshing model list...";

        try
        {
            var refreshedCatalog = await ProviderSettingsService.RefreshModelCatalogAsync(providerContext.Editor);
            providerContext = providerContext with { AvailableModelOptions = refreshedCatalog };

            EnsureSelectedDefaultModelIsSelectable();

            modelRefreshTone = "success";
            modelRefreshMessage = $"Model list refreshed. {CurrentModelOptions.Count} option(s) available for {SelectedProviderTypeDefinition.DisplayName}.";
        }
        catch (Exception exception)
        {
            modelRefreshTone = "error";
            modelRefreshMessage = exception.Message;
        }
        finally
        {
            isRefreshingModels = false;
        }
    }

    private Task SetDockerHostedEngineAsync(string baseUrl)
    {
        if (providerContext is null)
        {
            return Task.CompletedTask;
        }

        ClearProviderTestMessage();
        ClearModelRefreshMessage();

        if (string.IsNullOrWhiteSpace(baseUrl))
        {
            if (ReadyDockerCompatibleEngines.Any(engine => SameBaseUrl(engine.BaseUrl, providerContext.Editor.BaseUrl)))
            {
                providerContext.Editor.BaseUrl = string.Empty;
                providerContext.Editor.DefaultModelId = string.Empty;
            }

            return Task.CompletedTask;
        }

        var selectedEngine = ReadyDockerCompatibleEngines.FirstOrDefault(engine => SameBaseUrl(engine.BaseUrl, baseUrl));
        if (selectedEngine is null)
        {
            return Task.CompletedTask;
        }

        ApplyDockerCompatibleEngine(selectedEngine, updateDisplayName: true);
        modelRefreshTone = "success";
        modelRefreshMessage = $"Selected {selectedEngine.ContainerName}. Pick the model below and save the provider.";
        return Task.CompletedTask;
    }

    private void ApplyDockerCompatibleEngine(DockerAiDiscoveredEngine engine, bool updateDisplayName)
    {
        if (providerContext is null)
        {
            return;
        }

        providerContext.Editor.ProviderType = AiProviderType.Custom;
        if (updateDisplayName &&
            (string.IsNullOrWhiteSpace(providerContext.Editor.DisplayName) ||
             providerContext.Editor.DisplayName.Equals(SelectedProviderTypeDefinition.DisplayName, StringComparison.OrdinalIgnoreCase) ||
             providerContext.Editor.DisplayName.Equals("OpenAI / Docker-compatible API", StringComparison.OrdinalIgnoreCase)))
        {
            providerContext.Editor.DisplayName = $"Docker {engine.ContainerName}";
        }

        providerContext.Editor.BaseUrl = NormalizeBaseUrl(engine.BaseUrl);
        providerContext.Editor.DefaultModelId = SelectDefaultDockerModelId(engine);
        providerContext.Editor.StreamingEnabled = true;
        providerContext.Editor.ToolUseEnabled = false;
        providerContext.Editor.RequiresApiKey = false;
    }

    private IReadOnlyList<AiProviderModelOption> GetDockerModelOptionsForCurrentProvider()
    {
        if (providerContext?.Editor.ProviderType != AiProviderType.Custom)
        {
            return [];
        }

        var selectedBaseUrl = NormalizeBaseUrl(providerContext.Editor.BaseUrl);
        var selectedEngine = ReadyDockerCompatibleEngines.FirstOrDefault(engine =>
            SameBaseUrl(engine.BaseUrl, selectedBaseUrl));

        if (selectedEngine is null)
        {
            return [];
        }

        return selectedEngine.ModelIds
            .Where(IsSelectableChatModelId)
            .Select((modelId, index) => new AiProviderModelOption(
                AiProviderType.Custom,
                modelId,
                modelId,
                $"Docker API-compatible model from {selectedEngine.ContainerName}.",
                false,
                index == 0))
            .ToArray();
    }

    private static string FormatDockerProviderModelList(IReadOnlyList<string> modelIds)
    {
        var selectable = modelIds.Where(IsSelectableChatModelId).ToArray();
        var visible = selectable.Take(3).ToArray();
        var suffix = selectable.Length > visible.Length ? $" +{selectable.Length - visible.Length} more" : string.Empty;
        return $"{string.Join(", ", visible)}{suffix}";
    }

    private static string FormatDockerEngineOption(DockerAiDiscoveredEngine engine) =>
        $"{engine.ContainerName} - {FormatDockerProviderModelList(engine.ModelIds)}";

    private static string NormalizeBaseUrl(string? baseUrl) =>
        string.IsNullOrWhiteSpace(baseUrl) ? string.Empty : baseUrl.Trim().TrimEnd('/');

    private static bool SameBaseUrl(string? left, string? right) =>
        NormalizeBaseUrl(left).Equals(NormalizeBaseUrl(right), StringComparison.OrdinalIgnoreCase);

    private void EnsureSelectedDefaultModelIsSelectable()
    {
        if (providerContext is null)
        {
            return;
        }

        var selectedModel = CurrentModelOptions.FirstOrDefault(model =>
            model.ModelId.Equals(providerContext.Editor.DefaultModelId, StringComparison.OrdinalIgnoreCase));

        if (selectedModel is null || !IsSelectableChatModelId(selectedModel.ModelId))
        {
            providerContext.Editor.DefaultModelId = CurrentModelOptions.FirstOrDefault(IsSelectableModelOption)?.ModelId ?? string.Empty;
        }
    }

    private static string SelectDefaultDockerModelId(DockerAiDiscoveredEngine engine)
    {
        if (IsSelectableChatModelId(engine.DefaultModelId))
        {
            return engine.DefaultModelId;
        }

        return engine.ModelIds.FirstOrDefault(IsSelectableChatModelId) ?? string.Empty;
    }

    private static bool IsSelectableModelOption(AiProviderModelOption model) =>
        IsSelectableChatModelId(model.ModelId);

    private static bool IsSelectableChatModelId(string modelId)
    {
        if (string.IsNullOrWhiteSpace(modelId))
        {
            return false;
        }

        var normalized = modelId.Trim().Replace('\\', '/').ToLowerInvariant();
        var fileName = normalized.Split('/').LastOrDefault() ?? normalized;
        return !fileName.StartsWith("mmproj", StringComparison.Ordinal) &&
               !fileName.Contains("-mmproj", StringComparison.Ordinal) &&
               !fileName.Contains("_mmproj", StringComparison.Ordinal) &&
               !fileName.EndsWith(".mmproj", StringComparison.Ordinal) &&
               !(fileName.Contains("projector", StringComparison.Ordinal) &&
                 fileName.EndsWith(".gguf", StringComparison.Ordinal));
    }

    private void ClearProviderTestMessage()
    {
        providerTestMessage = null;
        providerTestTone = "success";
    }

    private void ClearModelRefreshMessage()
    {
        modelRefreshMessage = null;
        modelRefreshTone = "success";
    }
}
