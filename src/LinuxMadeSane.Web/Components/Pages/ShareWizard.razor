@page "/shares/wizard"
@using LinuxMadeSane.Application.Contracts.Shares
@using LinuxMadeSane.Application.Interfaces
@inject IShareManagementService ShareService

<PageTitle>Ownership Wizard | Linux Made Sane</PageTitle>

<div class="page-shell">
    <section class="hero-panel compact">
        <div>
            <p class="eyebrow">Ownership and inheritance wizard</p>
            <h1>Choose the outcome you want, then apply the right permission pattern</h1>
            <p class="hero-copy">These presets are deliberately opinionated. They translate collaborative intent into the chmod, group ownership, setgid, ACL, and Samba choices people usually forget under pressure.</p>
        </div>
    </section>

    @if (viewModel is null)
    {
        <section class="surface-card">
            <p class="meta-text">Loading presets...</p>
        </section>
    }
    else
    {
        <section class="feature-grid">
            @foreach (var preset in viewModel.Presets)
            {
                <article class="surface-card module-card active">
                    <p class="eyebrow">@preset.Name</p>
                    <h2>@preset.Summary</h2>
                    <p>@preset.Outcome</p>

                    <div class="decision-list">
                        @foreach (var step in preset.RecommendedSteps)
                        {
                            <InfoPill Eyebrow="Recommended step" Text="@step" />
                        }
                    </div>
                </article>
            }
        </section>
    }
</div>

@code {
    private OwnershipWizardViewModel? viewModel;

    protected override async Task OnInitializedAsync()
    {
        viewModel = await ShareService.GetWizardAsync();
    }
}
