    private string BuildPublishHeadline()
    {
        var externalUrl = ResolvePreviewExternalUrl();
        return string.IsNullOrWhiteSpace(externalUrl)
            ? "Enter a hostname and target to preview the route."
            : $"{externalUrl} -> {BuildPreviewTarget()}";
    }

    private string BuildPublishDetail()
    {
        var auth = routeEditor.AuthMode == EdgeGatewayAuthMode.PassThrough
            ? "Caddy will proxy this straight to the backend with no LMS auth check."
            : $"Caddy will call LMS forward_auth first. Policy: {FormatAuthMode(routeEditor.AuthMode)}.";
        var cloudflare = CloudflareDomains.Count > 0
            ? $"LMS will publish DNS as {ResolvePreviewHostname()} -> {ResolvePreviewRelayHostname()}."
            : "Domain is manual because no saved Cloudflare token is available.";
        var path = NormalizeRoutePathPrefix(routeEditor.TargetPathPrefix);
        var routing = string.IsNullOrWhiteSpace(path)
            ? "This is the default route for the hostname."
            : $"Only {path} and anything under it will route here; Caddy strips that prefix before proxying.";
        return $"{auth} {routing} {cloudflare}";
    }

    private string ResolvePreviewHostname()
    {
        var host = routeEditor.Hostname.Trim();
        var domain = routeEditor.DomainName.Trim();
        if (string.IsNullOrWhiteSpace(host))
        {
            return string.Empty;
        }

        return host.Contains('.', StringComparison.Ordinal) || string.IsNullOrWhiteSpace(domain)
            ? host
            : $"{host}.{domain}";
    }

    private string ResolvePreviewExternalUrl()
    {
        var hostname = ResolvePreviewHostname();
        if (string.IsNullOrWhiteSpace(hostname))
        {
            return string.Empty;
        }

        var path = NormalizeRoutePathPrefix(routeEditor.TargetPathPrefix);
        return string.IsNullOrWhiteSpace(path)
            ? $"https://{hostname}"
            : $"https://{hostname}{path}";
    }

    private string ResolvePreviewRelayHostname()
    {
        var hostname = ResolvePreviewHostname();
        var domain = routeEditor.DomainName.Trim();
        var gatewayDomain = CloudflareDomains.FirstOrDefault(item =>
            item.DomainName.Equals(domain, StringComparison.OrdinalIgnoreCase))?.GatewayDomainName;
        if (string.IsNullOrWhiteSpace(hostname) || string.IsNullOrWhiteSpace(domain) || string.IsNullOrWhiteSpace(gatewayDomain))
        {
            return "relay target";
        }

        var suffix = $".{domain}";
        var relative = hostname.Equals(domain, StringComparison.OrdinalIgnoreCase)
            ? "root"
            : hostname.EndsWith(suffix, StringComparison.OrdinalIgnoreCase)
                ? hostname[..^suffix.Length]
                : hostname;
        return $"{relative}.{gatewayDomain}";
    }

    private string BuildRouteRelayHostname(EdgeGatewayRouteListItem route)
    {
        var gatewayDomain = CloudflareDomains.FirstOrDefault(item =>
            item.DomainName.Equals(route.DomainName, StringComparison.OrdinalIgnoreCase))?.GatewayDomainName;
        if (string.IsNullOrWhiteSpace(gatewayDomain))
        {
            return "relay target";
        }

        var suffix = $".{route.DomainName}";
        var relative = route.Hostname.Equals(route.DomainName, StringComparison.OrdinalIgnoreCase)
            ? "root"
            : route.Hostname.EndsWith(suffix, StringComparison.OrdinalIgnoreCase)
                ? route.Hostname[..^suffix.Length]
                : route.Hostname;
        return $"{relative}.{gatewayDomain}";
    }

    private static string NormalizeRouteDomainName(string? domainName)
    {
        var normalized = domainName?.Trim().TrimEnd('.') ?? string.Empty;
        return string.IsNullOrWhiteSpace(normalized) ? "Unassigned domain" : normalized;
    }

    private static string BuildExternalRouteUrl(EdgeGatewayRouteListItem route)
    {
        var path = NormalizeRoutePathPrefix(route.TargetPathPrefix);
        return string.IsNullOrWhiteSpace(path)
            ? $"https://{route.Hostname}"
            : $"https://{route.Hostname}{path}";
    }

    private static string BuildDomainOptionLabel(EdgeGatewayCloudflareDomainOption domain)
    {
        var status = domain.RelayConfigured
            ? domain.RelayUsesCloudflareTunnel ? "relay ready" : "relay check"
            : "no relay";
        return $"{domain.DomainName} - {status}";
    }

    private static string BuildRelayButtonLabel(EdgeGatewayCloudflareDomainOption? domain)
    {
        if (domain is null)
        {
            return "Set up relay";
        }

        return domain.RelayConfigured ? "Check relay" : "Set up relay";
    }

    private string BuildRouteEditorDomainHelper()
    {
        var domain = CloudflareDomains.FirstOrDefault(item =>
            item.DomainName.Equals(routeEditor.DomainName, StringComparison.OrdinalIgnoreCase));
        if (domain is null)
        {
            return routeEditor.Id.HasValue
                ? "Existing route domain."
                : "Selected from the Edge Gateway domain picker.";
        }

        var relay = domain.RelayConfigured && domain.RelayUsesCloudflareTunnel
            ? $"Relay ready: {domain.GatewayDomainName}."
            : $"Relay is not ready for {domain.GatewayDomainName}.";
        return routeEditor.Id.HasValue
            ? $"{relay} Create a new route to change domains."
            : relay;
    }

    private static string BuildDomainRelayLabel(EdgeGatewayCloudflareDomainOption domain)
    {
        if (domain.Paused)
        {
            return "Zone paused";
        }

        if (!domain.RelayConfigured)
        {
            return "No relay";
        }

        return domain.RelayUsesCloudflareTunnel ? "Relay ready" : "Check relay";
    }

    private static string BuildDomainRelayDetail(EdgeGatewayCloudflareDomainOption domain)
    {
        if (domain.Paused)
        {
            return "Cloudflare reports this zone as paused.";
        }

        if (!domain.RelayConfigured)
        {
            return $"No wildcard DNS record found for *.{domain.GatewayDomainName}.";
        }

        return domain.RelayUsesCloudflareTunnel
            ? $"*.{domain.GatewayDomainName} points to {domain.RelayDnsTarget}."
            : $"*.{domain.GatewayDomainName} exists but points to {domain.RelayDnsTarget}.";
    }

    private string BuildCloudflareSummary()
    {
        if (dashboard?.Cloudflare.IsAvailable != true)
        {
            return "needs token";
        }

        var relayCount = CloudflareDomains.Count(domain => domain.RelayConfigured && domain.RelayUsesCloudflareTunnel);
        return relayCount == 0
            ? "no relays yet"
            : relayCount == 1 ? "1 relay ready" : $"{relayCount} relays ready";
    }

    private string BuildPreviewTarget()
    {
        var scheme = routeEditor.TargetScheme == EdgeGatewayTargetScheme.Https ? "https" : "http";
        return string.IsNullOrWhiteSpace(routeEditor.TargetHost)
            ? $"{scheme}://target:{routeEditor.TargetPort}"
            : $"{scheme}://{routeEditor.TargetHost.Trim()}:{routeEditor.TargetPort}";
    }

    private static string NormalizeRoutePathPrefix(string? value)
    {
        var normalized = (value ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(normalized) || normalized == "/")
        {
            return string.Empty;
        }

        return normalized.StartsWith("/", StringComparison.Ordinal)
            ? normalized.TrimEnd('/')
            : $"/{normalized.TrimEnd('/')}";
    }

    private static string BuildCloudflareDomainTitle(EdgeGatewayCloudflareDomainOption domain) =>
        string.IsNullOrWhiteSpace(domain.AccountName)
            ? $"{domain.DomainName} -> {domain.GatewayDomainName}"
            : $"{domain.DomainName} -> {domain.GatewayDomainName} in {domain.AccountName}";

    private string BuildRelayNamespaceHelper()
    {
        if (!relayNamespaceUnlocked)
        {
            return "Locked to prevent accidental DNS changes. Unlock only when deliberately renaming this LMS relay namespace.";
        }

        return "Use a single DNS label such as relay, edge, lms-relay, or office-relay. It must be unique across your LMS landscape.";
    }

    private string BuildRelayNamespaceExampleHelper()
    {
        var appCount = dashboard?.Routes.Count ?? 0;
        var relayCount = CloudflareDomains.Count(domain => domain.RelayConfigured);
        if (appCount > 0 || relayCount > 0)
        {
            return "Changing this now will break exposed app URLs until the relay and affected routes are republished.";
        }

        return "Choose a unique namespace before setting up your first relay.";
    }

    private string BuildGatewaySubdomainExample()
    {
        var label = string.IsNullOrWhiteSpace(edgeSettingsEditor.GatewaySubdomain)
            ? dashboard?.Settings.GatewaySubdomain ?? "relay"
            : edgeSettingsEditor.GatewaySubdomain.Trim().Trim('.');
        return $"*.{label}.example.com";
    }

