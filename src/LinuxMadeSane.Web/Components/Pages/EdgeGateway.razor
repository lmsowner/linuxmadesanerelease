    private static IReadOnlyList<LocalHttpServiceEndpoint> SortHttpServiceSuggestions(IEnumerable<LocalHttpServiceEndpoint> services) =>
        services
            .DistinctBy(BuildHttpServiceKey, StringComparer.OrdinalIgnoreCase)
            .OrderBy(service => service.Scope switch
            {
                "Localhost" => 0,
                "LAN" => 1,
                "Tailnet" => 2,
                _ => 3
            })
            .ThenBy(service => service.Host, StringComparer.OrdinalIgnoreCase)
            .ThenBy(service => service.Port)
            .ThenBy(service => service.Scheme.Equals(Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase) ? 0 : 1)
            .ToArray();

    private static string BuildHttpServiceKey(LocalHttpServiceEndpoint service) =>
        $"{service.Scope}|{service.Scheme}|{service.Host}|{service.Port}";

    private static async Task<IReadOnlyList<RouteTargetProbeResult>> ProbeRouteTargetSchemesAsync(string host, int port)
    {
        using var handler = new HttpClientHandler
        {
            AllowAutoRedirect = false,
            UseProxy = false,
            ServerCertificateCustomValidationCallback = HttpClientHandler.DangerousAcceptAnyServerCertificateValidator
        };
        using var client = new HttpClient(handler)
        {
            Timeout = TimeSpan.FromSeconds(5)
        };

        var probes = new[]
        {
            ProbeRouteTargetAsync(client, host, port, EdgeGatewayTargetScheme.Https),
            ProbeRouteTargetAsync(client, host, port, EdgeGatewayTargetScheme.Http)
        };
        return await Task.WhenAll(probes);
    }

    private static async Task<RouteTargetProbeResult> ProbeRouteTargetAsync(
        HttpClient client,
        string host,
        int port,
        EdgeGatewayTargetScheme scheme)
    {
        var targetUrl = BuildRouteTargetProbeUrl(host, port, scheme);
        using var timeout = new CancellationTokenSource(TimeSpan.FromSeconds(5));

        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, $"{targetUrl}/");
            request.Headers.UserAgent.ParseAdd("LinuxMadeSane-edge-target-check");

            using var response = await client.SendAsync(
                request,
                HttpCompletionOption.ResponseHeadersRead,
                timeout.Token);
            var snippet = await TryReadProbeSnippetAsync(response, timeout.Token);
            if (scheme == EdgeGatewayTargetScheme.Http && IsLikelyHttpsRequiredResponse(snippet))
            {
                return new RouteTargetProbeResult(
                    scheme,
                    false,
                    $"{FormatTargetScheme(scheme)} reached the port, but the response says this endpoint expects https.");
            }

            var reason = string.IsNullOrWhiteSpace(response.ReasonPhrase)
                ? string.Empty
                : $" {response.ReasonPhrase.Trim()}";
            return new RouteTargetProbeResult(
                scheme,
                true,
                $"{FormatTargetScheme(scheme)} responded with HTTP {(int)response.StatusCode}{reason}.");
        }
        catch (TaskCanceledException)
        {
            return new RouteTargetProbeResult(scheme, false, $"{FormatTargetScheme(scheme)} timed out.");
        }
        catch (Exception exception) when (exception is HttpRequestException or OperationCanceledException or InvalidOperationException)
        {
            return new RouteTargetProbeResult(scheme, false, $"{FormatTargetScheme(scheme)} failed: {exception.Message}");
        }
    }

    private static async Task<string> TryReadProbeSnippetAsync(HttpResponseMessage response, CancellationToken cancellationToken)
    {
        if ((int)response.StatusCode is not 400 and not 421 and not 426)
        {
            return string.Empty;
        }

        try
        {
            await using var stream = await response.Content.ReadAsStreamAsync(cancellationToken);
            var buffer = new byte[4096];
            var read = await stream.ReadAsync(buffer.AsMemory(0, buffer.Length), cancellationToken);
            return read <= 0 ? string.Empty : Encoding.UTF8.GetString(buffer, 0, read);
        }
        catch
        {
            return string.Empty;
        }
    }

    private static bool IsLikelyHttpsRequiredResponse(string snippet)
    {
        if (string.IsNullOrWhiteSpace(snippet))
        {
            return false;
        }

        var text = snippet.ToLowerInvariant();
        return text.Contains("plain http request was sent to https port", StringComparison.Ordinal) ||
               text.Contains("client sent an http request to an https server", StringComparison.Ordinal) ||
               text.Contains("requires tls", StringComparison.Ordinal) ||
               text.Contains("requires https", StringComparison.Ordinal);
    }

    private static string BuildRouteTargetProbeUrl(string host, int port, EdgeGatewayTargetScheme scheme)
    {
        var hostPart = host.Contains(':', StringComparison.Ordinal) &&
                       IPAddress.TryParse(host, out var address) &&
                       address.AddressFamily == System.Net.Sockets.AddressFamily.InterNetworkV6
            ? $"[{host}]"
            : host;
        return $"{FormatTargetScheme(scheme)}://{hostPart}:{port}";
    }

    private static string BuildRouteTargetProbeFailureSummary(IEnumerable<RouteTargetProbeResult> probes) =>
        string.Join(" ", probes.Select(static probe => probe.Summary));

    private static string FormatTargetScheme(EdgeGatewayTargetScheme scheme) =>
        scheme == EdgeGatewayTargetScheme.Https ? "https" : "http";

    private sealed record RouteTargetProbeResult(
        EdgeGatewayTargetScheme Scheme,
        bool Success,
        string Summary);

    private static UiPillTone GetDomainRelayTone(EdgeGatewayCloudflareDomainOption domain)
    {
        if (domain.Paused)
        {
            return UiPillTone.Warning;
        }

        if (!domain.RelayConfigured)
        {
            return UiPillTone.Neutral;
        }

        return domain.RelayUsesCloudflareTunnel && domain.RelayOwnedByThisLms
            ? UiPillTone.Success
            : UiPillTone.Warning;
    }

    private static string FormatAuthMode(EdgeGatewayAuthMode mode) => mode switch
    {
        EdgeGatewayAuthMode.PassThrough => "Pass through",
        EdgeGatewayAuthMode.RequireLogin => "MFA/Passkey",
        EdgeGatewayAuthMode.RequireMfa => "MFA/Passkey",
        EdgeGatewayAuthMode.RequirePasskey => "MFA/Passkey",
        EdgeGatewayAuthMode.Blocked => "Blocked",
        _ => mode.ToString()
    };

    private static string BuildRouteAccessLabel(EdgeGatewayAuthMode mode) => mode switch
    {
        EdgeGatewayAuthMode.PassThrough => "Straight through",
        EdgeGatewayAuthMode.RequireLogin => "MFA/Passkey",
        EdgeGatewayAuthMode.RequireMfa => "MFA/Passkey",
        EdgeGatewayAuthMode.RequirePasskey => "MFA/Passkey",
        EdgeGatewayAuthMode.Blocked => "Blocked",
        _ => mode.ToString()
    };

    private static string DescribeAuthMode(EdgeGatewayAuthMode mode) => mode switch
    {
        EdgeGatewayAuthMode.PassThrough => "Caddy proxies straight to the backend. Use only for intentionally public services.",
        EdgeGatewayAuthMode.RequireLogin => "The user must pass LMS MFA using an authenticator code or a registered passkey.",
        EdgeGatewayAuthMode.RequireMfa => "The user must pass LMS MFA using an authenticator code or a registered passkey.",
        EdgeGatewayAuthMode.RequirePasskey => "The user must pass LMS MFA using an authenticator code or a registered passkey.",
        EdgeGatewayAuthMode.Blocked => "Caddy still has the hostname, but LMS rejects all access.",
        _ => string.Empty
    };

    private static string DescribeAuthModeUse(EdgeGatewayAuthMode mode) => mode switch
    {
        EdgeGatewayAuthMode.PassThrough => "Use for deliberately public apps only. Anyone who can reach the hostname reaches the backend.",
        EdgeGatewayAuthMode.RequireLogin => "Use for internal tools, admin surfaces, dashboards, and anything that should require LMS MFA. This is the default.",
        EdgeGatewayAuthMode.RequireMfa => "Use for internal tools, admin surfaces, dashboards, and anything that should require LMS MFA. This is the default.",
        EdgeGatewayAuthMode.RequirePasskey => "Use for internal tools, admin surfaces, dashboards, and anything that should require LMS MFA. This is the default.",
        EdgeGatewayAuthMode.Blocked => "Use as an emergency stop or placeholder while keeping the route record.",
        _ => string.Empty
    };

    private static UiPillTone GetAuthModeTone(EdgeGatewayAuthMode mode) => mode switch
    {
        EdgeGatewayAuthMode.PassThrough => UiPillTone.Warning,
        EdgeGatewayAuthMode.Blocked => UiPillTone.Failure,
        _ => UiPillTone.Success
    };

    private string BuildPublishHeadline()
    {
        var externalUrl = ResolvePreviewExternalUrl();
        return string.IsNullOrWhiteSpace(externalUrl)
            ? "Enter a hostname and target to preview the route."
            : $"{externalUrl} -> {BuildPreviewTarget()}";
    }

    private string BuildPublishDetail()
    {
        var auth = routeEditor.AuthMode == EdgeGatewayAuthMode.PassThrough
            ? "Caddy will proxy this straight to the backend with no LMS auth check."
            : $"Caddy will call LMS forward_auth first. Policy: {FormatAuthMode(routeEditor.AuthMode)}.";
        var cloudflare = CloudflareDomains.Count > 0
            ? $"LMS will publish DNS as {ResolvePreviewHostname()} -> {ResolvePreviewRelayHostname()}."
            : "Domain is manual because no saved Cloudflare token is available.";
        var path = NormalizeRoutePathPrefix(routeEditor.TargetPathPrefix);
        var routing = string.IsNullOrWhiteSpace(path)
            ? "This is the default route for the hostname."
            : $"Only {path} and anything under it will route here; Caddy strips that prefix before proxying.";
        return $"{auth} {routing} {cloudflare}";
    }

    private string ResolvePreviewHostname()
    {
        var host = routeEditor.Hostname.Trim();
        var domain = routeEditor.DomainName.Trim();
        if (string.IsNullOrWhiteSpace(host))
        {
            return string.Empty;
        }

        return host.Contains('.', StringComparison.Ordinal) || string.IsNullOrWhiteSpace(domain)
            ? host
            : $"{host}.{domain}";
    }

    private string ResolvePreviewExternalUrl()
    {
        var hostname = ResolvePreviewHostname();
        if (string.IsNullOrWhiteSpace(hostname))
        {
            return string.Empty;
        }

        var path = NormalizeRoutePathPrefix(routeEditor.TargetPathPrefix);
        return string.IsNullOrWhiteSpace(path)
            ? $"https://{hostname}"
            : $"https://{hostname}{path}";
    }

    private string ResolvePreviewRelayHostname()
    {
        var hostname = ResolvePreviewHostname();
        var domain = routeEditor.DomainName.Trim();
        var gatewayDomain = CloudflareDomains.FirstOrDefault(item =>
            item.DomainName.Equals(domain, StringComparison.OrdinalIgnoreCase))?.GatewayDomainName;
        if (string.IsNullOrWhiteSpace(hostname) || string.IsNullOrWhiteSpace(domain) || string.IsNullOrWhiteSpace(gatewayDomain))
        {
            return "relay target";
        }

        var suffix = $".{domain}";
        var relative = hostname.Equals(domain, StringComparison.OrdinalIgnoreCase)
            ? "root"
            : hostname.EndsWith(suffix, StringComparison.OrdinalIgnoreCase)
                ? hostname[..^suffix.Length]
                : hostname;
        return $"{relative}.{gatewayDomain}";
    }

    private string BuildRouteRelayHostname(EdgeGatewayRouteListItem route)
    {
        var gatewayDomain = CloudflareDomains.FirstOrDefault(item =>
            item.DomainName.Equals(route.DomainName, StringComparison.OrdinalIgnoreCase))?.GatewayDomainName;
        if (string.IsNullOrWhiteSpace(gatewayDomain))
        {
            return "relay target";
        }

        var suffix = $".{route.DomainName}";
        var relative = route.Hostname.Equals(route.DomainName, StringComparison.OrdinalIgnoreCase)
            ? "root"
            : route.Hostname.EndsWith(suffix, StringComparison.OrdinalIgnoreCase)
                ? route.Hostname[..^suffix.Length]
                : route.Hostname;
        return $"{relative}.{gatewayDomain}";
    }

    private static string NormalizeRouteDomainName(string? domainName)
    {
        var normalized = domainName?.Trim().TrimEnd('.') ?? string.Empty;
        return string.IsNullOrWhiteSpace(normalized) ? "Unassigned domain" : normalized;
    }

    private static string BuildExternalRouteUrl(EdgeGatewayRouteListItem route)
    {
        var path = NormalizeRoutePathPrefix(route.TargetPathPrefix);
        return string.IsNullOrWhiteSpace(path)
            ? $"https://{route.Hostname}"
            : $"https://{route.Hostname}{path}";
    }

    private static string BuildDomainOptionLabel(EdgeGatewayCloudflareDomainOption domain)
        => $"{domain.DomainName} (*.{domain.GatewayDomainName})";

    private string BuildRouteEditorDomainHelper()
    {
        var domain = CloudflareDomains.FirstOrDefault(item =>
            item.DomainName.Equals(routeEditor.DomainName, StringComparison.OrdinalIgnoreCase));
        if (domain is null)
        {
            return routeEditor.Id.HasValue
                ? "Existing route domain."
                : "Selected from the Edge Gateway domain picker.";
        }

        var relay = domain.RelayConfigured && domain.RelayUsesCloudflareTunnel && domain.RelayOwnedByThisLms
            ? $"Relay ready: {domain.GatewayDomainName}."
            : $"Relay is not ready for {domain.GatewayDomainName}.";
        return routeEditor.Id.HasValue
            ? $"{relay} Create a new route to change domains."
            : relay;
    }

    private static string BuildDomainRelayLabel(EdgeGatewayCloudflareDomainOption domain)
    {
        if (domain.Paused)
        {
            return "Zone paused";
        }

        if (!domain.RelayConfigured)
        {
            return "No relay";
        }

        if (!domain.RelayUsesCloudflareTunnel)
        {
            return "Check relay";
        }

        return domain.RelayOwnedByThisLms ? "Local relay" : "Other LMS";
    }

    private static string BuildDomainRelayDetail(EdgeGatewayCloudflareDomainOption domain)
    {
        if (domain.Paused)
        {
            return "Cloudflare reports this zone as paused.";
        }

        if (!domain.RelayConfigured)
        {
            return $"No wildcard DNS record found for *.{domain.GatewayDomainName}.";
        }

        if (!domain.RelayUsesCloudflareTunnel)
        {
            return $"*.{domain.GatewayDomainName} exists but points to {domain.RelayDnsTarget}.";
        }

        return string.IsNullOrWhiteSpace(domain.RelayOwnershipSummary)
            ? $"*.{domain.GatewayDomainName} points to {domain.RelayDnsTarget}."
            : domain.RelayOwnershipSummary;
    }

    private string BuildCloudflareSummary()
    {
        if (dashboard?.Cloudflare.IsAvailable != true)
        {
            return "needs token";
        }

        var relayCount = CloudflareDomains.Count(domain => domain.RelayConfigured);
        return relayCount == 0
            ? "no relays"
            : relayCount == 1 ? "1 relay" : $"{relayCount} relays";
    }

    private string BuildConfiguredRelayCountLabel() =>
        ConfiguredCloudflareRelays.Count == 0
            ? "None"
            : ConfiguredCloudflareRelays.Count == 1 ? "1 zone" : $"{ConfiguredCloudflareRelays.Count} zones";

    private int CountRoutesForDomain(string domainName) =>
        dashboard?.Routes.Count(route => route.DomainName.Equals(domainName, StringComparison.OrdinalIgnoreCase)) ?? 0;

    private IReadOnlyList<EdgeGatewayRouteListItem> GetRoutesForDomain(string domainName) =>
        dashboard?.Routes
            .Where(route => route.DomainName.Equals(domainName, StringComparison.OrdinalIgnoreCase))
            .OrderBy(route => route.DisplayName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(route => route.Hostname, StringComparer.OrdinalIgnoreCase)
            .ToArray()
        ?? [];

    private string BuildPreviewTarget()
    {
        var scheme = routeEditor.TargetScheme == EdgeGatewayTargetScheme.Https ? "https" : "http";
        return string.IsNullOrWhiteSpace(routeEditor.TargetHost)
            ? $"{scheme}://target:{routeEditor.TargetPort}"
            : $"{scheme}://{routeEditor.TargetHost.Trim()}:{routeEditor.TargetPort}";
    }

    private static string NormalizeRoutePathPrefix(string? value)
    {
        var normalized = (value ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(normalized) || normalized == "/")
        {
            return string.Empty;
        }

        return normalized.StartsWith("/", StringComparison.Ordinal)
            ? normalized.TrimEnd('/')
            : $"/{normalized.TrimEnd('/')}";
    }

    private static string BuildCloudflareDomainTitle(EdgeGatewayCloudflareDomainOption domain)
    {
        var account = string.IsNullOrWhiteSpace(domain.AccountName)
            ? string.Empty
            : $" in {domain.AccountName}";
        var ownership = string.IsNullOrWhiteSpace(domain.RelayOwnershipSummary)
            ? string.Empty
            : $" - {domain.RelayOwnershipSummary}";
        return $"{domain.DomainName} -> {domain.GatewayDomainName}{account}{ownership}";
    }

    private string BuildRelayNamespaceHelper()
    {
        if (!relayNamespaceUnlocked)
        {
            return "Locked to prevent accidental DNS changes. Unlock only when deliberately renaming this LMS relay namespace.";
        }

        return "Use a DNS label such as relay, or a full namespace such as linuxmintrelay.example.com. It must be unique across your LMS landscape.";
    }

    private string BuildRelayNamespaceExampleHelper()
    {
        var appCount = dashboard?.Routes.Count ?? 0;
        var relayCount = CloudflareDomains.Count(domain => domain.RelayConfigured);
        if (appCount > 0 || relayCount > 0)
        {
            return "Changing this now will break exposed app URLs until the relay and affected routes are republished.";
        }

        return "Choose a unique namespace before setting up your first relay.";
    }

    private string BuildGatewaySubdomainExample()
    {
        var value = string.IsNullOrWhiteSpace(edgeSettingsEditor.GatewaySubdomain)
            ? dashboard?.Settings.GatewaySubdomain ?? EdgeGatewayOptions.GatewaySubdomain
            : edgeSettingsEditor.GatewaySubdomain;
        var normalized = (value ?? string.Empty).Trim().TrimEnd('.');
        if (normalized.StartsWith("*.", StringComparison.Ordinal))
        {
            normalized = normalized[2..];
        }

        if (string.IsNullOrWhiteSpace(normalized))
        {
            normalized = "relay";
        }

        return normalized.Contains('.', StringComparison.Ordinal)
            ? $"*.{normalized}"
            : $"*.{normalized}.example.com";
    }

    private sealed record EdgeGatewayRouteDomainGroup(
        string DomainName,
        IReadOnlyList<EdgeGatewayRouteListItem> Routes)
    {
        public int EnabledCount => Routes.Count(route => route.Enabled);
    }

    private sealed record EdgeGatewayDashboardSnapshot(
        EdgeGatewayDashboardViewModel Dashboard,
        EdgeGatewaySettingsEditor SettingsEditor);
}
