    private async Task CheckRouteTargetAsync()
    {
        if (isCheckingRouteTarget)
        {
            return;
        }

        isCheckingRouteTarget = true;
        routeTargetCheckIsError = false;
        routeTargetCheckMessage = "Checking target with http and https...";
        await InvokeAsync(StateHasChanged);

        try
        {
            var host = EdgeGatewayRouteValidator.NormalizeTargetHost(routeEditor.TargetHost);
            var port = EdgeGatewayRouteValidator.NormalizeTargetPort(routeEditor.TargetPort);
            var currentScheme = routeEditor.TargetScheme;
            var probes = await ProbeRouteTargetSchemesAsync(host, port);
            var workingProbes = probes.Where(static probe => probe.Success).ToArray();

            if (workingProbes.Length == 0)
            {
                routeTargetCheckIsError = true;
                routeTargetCheckMessage = $"No HTTP/S response from {host}:{port}. {BuildRouteTargetProbeFailureSummary(probes)}";
                return;
            }

            var selectedProbe = workingProbes.FirstOrDefault(probe => probe.Scheme == currentScheme) ??
                                workingProbes.First();
            routeEditor.TargetScheme = selectedProbe.Scheme;

            routeTargetCheckMessage = selectedProbe.Scheme == currentScheme
                ? $"Target OK using {FormatTargetScheme(selectedProbe.Scheme)}. {selectedProbe.Summary}"
                : $"Switched scheme to {FormatTargetScheme(selectedProbe.Scheme)}. {selectedProbe.Summary}";
        }
        catch (Exception exception)
        {
            routeTargetCheckIsError = true;
            routeTargetCheckMessage = exception.Message;
        }
        finally
        {
            isCheckingRouteTarget = false;
        }
    }

    private void ResetRouteTargetCheckMessage()
    {
