@page "/edge-gateway"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IDisposable
@using System.Net
@using System.Net.Http
@using System.Text
@using LinuxMadeSane.Application.Contracts.EdgeGateway
@using LinuxMadeSane.Application.Interfaces
@using LinuxMadeSane.Application.Services.EdgeGateway
@using LinuxMadeSane.Core.Abstractions
@using LinuxMadeSane.Core.Models.Cloudflare
@using LinuxMadeSane.Core.Models.EdgeGateway
@inject IEdgeGatewayService EdgeGatewayService
@inject EdgeGatewayOptions EdgeGatewayOptions
@inject ILocalHttpServiceDiscoveryService HttpServiceDiscovery

<PageTitle>Edge Gateway | Linux Made Sane</PageTitle>

<div class="page-shell edge-gateway-page">
    <UiHeroPanel Title="Edge Gateway"
                 Description="Expose internal HTTP services through Cloudflare Tunnel and Caddy while LMS makes the authentication decision."
                 Compact="true" />

    @if (!string.IsNullOrWhiteSpace(userMessage))
    {
        <section class="surface-subcard edge-message">
            <span>@userMessage</span>
        </section>
    }

    @if (dashboard is null)
    {
        <section class="surface-card edge-loading-card" aria-busy="@isDashboardLoading">
            @if (isDashboardLoading)
            {
                <span class="edge-loading-progress">
                    <span class="edge-loading-progress-fill"></span>
                </span>
            }
            <p class="meta-text">
                @(string.IsNullOrWhiteSpace(dashboardLoadError)
                    ? "Loading Edge Gateway..."
                    : $"Edge Gateway could not load: {dashboardLoadError}")
            </p>
        </section>
    }
    else
    {
        <TabControl ActiveValue="@activeTab"
                    ActiveValueChanged="HandleTabChangedAsync"
                    Class="page-tab-control edge-tabs"
                    PanelClass="page-tab-panel edge-tab-panel">
            <ChildContent>
                <TabPage Value="@PublishedAppsTabValue" Title="@($"Published Apps ({dashboard.Routes.Count})")">
                    <section class="surface-card edge-card">
                        <div class="table-header">
                            <div>
                                <p class="eyebrow">Services</p>
                                <h2>Apps and hosts exposed through Edge Gateway</h2>
                                <p class="meta-text">Saving a service adds it to LMS. Press Publish on the service card to create Cloudflare DNS, tunnel ingress, and Caddy routing.</p>
                            </div>
                        </div>

                        @if (dashboard.Routes.Count == 0)
                        {
                            <p class="meta-text">No services yet. Use Setup to prepare a relay, add a service, then press Publish on the service card to make it live.</p>
                        }
                        else
                        {
                            <div class="edge-route-list">
                                @foreach (var domainGroup in RouteDomainGroups)
                                {
                                    var isDomainExpanded = IsRouteDomainExpanded(domainGroup.DomainName);
                                    <section class="edge-route-domain-group">
                                        <div class="edge-route-domain-header" aria-expanded="@isDomainExpanded">
                                            <button class="edge-route-domain-toggle"
                                                    type="button"
                                                    @onclick="@(() => ToggleRouteDomain(domainGroup.DomainName))">
                                                <span class="edge-route-domain-chevron @(isDomainExpanded ? "expanded" : string.Empty)" aria-hidden="true"></span>
                                                <span class="edge-route-domain-copy">
                                                    <strong>@domainGroup.DomainName</strong>
                                                    <span>@BuildRouteDomainSummary(domainGroup)</span>
                                                </span>
                                            </button>
                                            <span class="edge-route-domain-pills">
                                                <span class="edge-route-domain-pill">@domainGroup.Routes.Count app@(domainGroup.Routes.Count == 1 ? string.Empty : "s")</span>
                                                <span class="edge-route-domain-pill">@domainGroup.EnabledCount enabled</span>
                                                <UiCommandButton Label="Add App"
                                                                 Glyph="UiIconGlyph.Plus"
                                                                 Variant="UiButtonVariant.Primary"
                                                                 Class="edge-route-domain-add"
                                                                 Disabled="@(!CanCreateAppForDomain(domainGroup.DomainName))"
                                                                 OnClick="@(() => UseCloudflareDomain(domainGroup.DomainName))" />
                                            </span>
                                        </div>

                                        @if (isDomainExpanded)
                                        {
                                            <div class="edge-route-domain-apps">
                                                @foreach (var route in domainGroup.Routes)
                                                {
                                                    <article class="surface-subcard edge-route-card">
                                                        <div class="edge-route-card-header">
                                                            <div class="edge-route-title">
                                                                <h3>@route.DisplayName</h3>
                                                                <UiPill Tone="@(route.Enabled ? UiPillTone.Success : UiPillTone.Neutral)">
                                                                    @(route.Enabled ? "Enabled" : "Disabled")
                                                                </UiPill>
                                                                <UiPill Tone="@GetAuthModeTone(route.AuthMode)">
                                                                    @BuildRouteAccessLabel(route.AuthMode)
                                                                </UiPill>
                                                                <UiPill Tone="@GetStatusTone(route.LastTestStatus)">@BuildRouteTestStatusLabel(route.LastTestStatus)</UiPill>
                                                            </div>
                                                            <div class="edge-route-actions">
                                                                <UiCommandButton Label="@(IsPublishingRoute(route.Id) ? "Publishing..." : "Publish")"
                                                                                 Glyph="UiIconGlyph.Connection"
                                                                                 Variant="UiButtonVariant.Primary"
                                                                                 Disabled="@(IsRouteActionBusy || !route.Enabled || !dashboard.Runtime.CanAttemptPublish)"
                                                                                 OnClick="@(() => ProvisionCloudflareRouteAsync(route.Id))" />
                                                                <UiCommandButton Label="@BuildRouteToggleLabel(route)"
                                                                                 Glyph="@(route.Enabled ? UiIconGlyph.Stop : UiIconGlyph.Run)"
                                                                                 Variant="@(route.Enabled ? UiButtonVariant.Danger : UiButtonVariant.Primary)"
                                                                                 Disabled="@IsRouteActionBusy"
                                                                                 OnClick="@(() => ToggleRouteAccessAsync(route.Id, route.Enabled))" />
                                                                <UiCommandButton Label="Test" Glyph="UiIconGlyph.Analyze" Disabled="@IsRouteActionBusy" OnClick="@(() => TestRouteAsync(route.Id))" />
                                                                <UiCommandButton Label="Edit" Glyph="UiIconGlyph.Edit" Variant="UiButtonVariant.Ghost" Disabled="@IsRouteActionBusy" OnClick="@(() => OpenEditRouteAsync(route.Id))" />
                                                                <UiCommandButton Label="Delete" Glyph="UiIconGlyph.Delete" Variant="UiButtonVariant.Danger" Disabled="@IsRouteActionBusy" OnClick="@(() => OpenRouteDeleteDialog(route))" />
                                                            </div>
                                                        </div>
                                                        <div class="edge-route-links">
                                                            <span class="edge-route-link">
                                                                <span>External</span>
                                                                <a href="@BuildExternalRouteUrl(route)" target="_blank" rel="noopener noreferrer">@BuildExternalRouteUrl(route)</a>
                                                            </span>
                                                            <span class="edge-route-link">
                                                                <span>Internal</span>
                                                                <a href="@route.TargetUrl" target="_blank" rel="noopener noreferrer">@route.TargetUrl</a>
                                                            </span>
                                                        </div>
                                                        @if (routeActionMessageRouteId == route.Id && !string.IsNullOrWhiteSpace(routeActionMessage))
                                                        {
                                                            <div class="edge-route-status @(routeActionIsError ? "error" : "success")">
                                                                @routeActionMessage
                                                            </div>
                                                        }
                                                        @if (cloudflareRouteSetupResult is { } publishResult && publishResult.RouteId == route.Id)
                                                        {
                                                            <details class="edge-route-publish-details">
                                                                <summary>
                                                                    <span>Publishing details</span>
                                                                    <UiPill Tone="@(publishResult.Success ? UiPillTone.Success : UiPillTone.Warning)">
                                                                        @(publishResult.Success ? "Published" : "Needs confirmation")
                                                                    </UiPill>
                                                                </summary>
                                                                <div class="edge-route-publish-body">
                                                                    <p class="meta-text">@publishResult.Summary</p>
                                                                    <div class="edge-setup-result-grid">
                                                                        <div class="surface-subcard">
                                                                            <h3>Public DNS</h3>
                                                                            <p class="meta-text"><code>@publishResult.Hostname</code> -> <code>@publishResult.RelayHostname</code></p>
                                                                        </div>
                                                                        <div class="surface-subcard">
                                                                            <h3>Relay wildcard</h3>
                                                                            <p class="meta-text"><code>@publishResult.RelayHostname</code> is covered by <code>@publishResult.DnsTarget</code></p>
                                                                        </div>
                                                                        <div class="surface-subcard">
                                                                            <h3>Caddy match</h3>
                                                                            <p class="meta-text">Caddy matches <code>@publishResult.Hostname</code> and proxies to the route target.</p>
                                                                        </div>
                                                                    </div>
                                                                    @if (publishResult.RequiresDnsReplacement)
                                                                    {
                                                                        <div class="edge-confirm-row">
                                                                            <UiCheckboxField @bind-Value="confirmRouteDnsReplacement"
                                                                                             Label="Replace the existing DNS record for this route"
                                                                                             Helper="Use this when the public hostname is currently pointing somewhere else."
                                                                                             Compact="true" />
                                                                            <UiCommandButton Label="Replace and publish"
                                                                                             Glyph="UiIconGlyph.Save"
                                                                                             Variant="UiButtonVariant.Danger"
                                                                                             OnClick="@(() => ProvisionCloudflareRouteAsync(publishResult.RouteId))" />
                                                                        </div>
                                                                    }
                                                                    @if (publishResult.Steps.Count > 0)
                                                                    {
                                                                        <ul class="edge-setup-list">
                                                                            @foreach (var step in publishResult.Steps)
                                                                            {
                                                                                <li>@step</li>
                                                                            }
                                                                        </ul>
                                                                    }
                                                                    @if (publishResult.Warnings.Count > 0)
                                                                    {
                                                                        <ul class="edge-setup-list edge-warning-list">
                                                                            @foreach (var warning in publishResult.Warnings)
                                                                            {
                                                                                <li>@warning</li>
                                                                            }
                                                                        </ul>
                                                                    }
                                                                </div>
                                                            </details>
                                                        }
                                                    </article>
                                                }
                                            </div>
                                        }
                                    </section>
                                }
                            </div>
                        }
                    </section>
                </TabPage>

                <TabPage Value="@SetupTabValue" Title="Setup">
                    @if (cloudflareSetupResult is not null)
                    {
                        <section class="surface-card edge-card">
                            <div class="table-header">
                                <div>
                                    <p class="eyebrow">Cloudflare tunnel setup</p>
                                    <h2>@cloudflareSetupResult.GatewayDomainName</h2>
                                    <p class="meta-text">@cloudflareSetupResult.Summary</p>
                                </div>
                                <UiPill Tone="@(cloudflareSetupResult.Success ? UiPillTone.Success : UiPillTone.Warning)">
                                    @(cloudflareSetupResult.Success ? "Configured" : "Needs confirmation")
                                </UiPill>
                            </div>
                            <div class="edge-setup-result-grid">
                                <div class="surface-subcard">
                                    <h3>Wildcard DNS</h3>
                                    <p class="meta-text"><code>@cloudflareSetupResult.WildcardHostname</code> -> <code>@cloudflareSetupResult.DnsTarget</code></p>
                                </div>
                                <div class="surface-subcard">
                                    <h3>Tunnel ingress</h3>
                                    <p class="meta-text"><code>@cloudflareSetupResult.WildcardHostname</code> -> <code>@cloudflareSetupResult.CaddyServiceUrl</code></p>
                                </div>
                                <div class="surface-subcard">
                                    <h3>Connector</h3>
                                    <p class="meta-text">@cloudflareSetupResult.ConnectorInstallSummary</p>
                                </div>
                            </div>
                            @if (cloudflareSetupResult.RequiresDnsReplacement)
                            {
                                <div class="edge-confirm-row">
                                    <UiCheckboxField @bind-Value="confirmWildcardDnsReplacement"
                                                     Label="Replace the existing wildcard DNS record for this Edge Gateway namespace"
                                                     Helper="LMS will delete the existing wildcard record and recreate it pointing at this host's Edge Gateway tunnel."
                                                     Compact="true" />
                                    <UiCommandButton Label="Replace and set up"
                                                     Glyph="UiIconGlyph.Save"
                                                     Variant="UiButtonVariant.Danger"
                                                     OnClick="@(() => ProvisionCloudflareDomainAsync(cloudflareSetupResult.DomainName))" />
                                </div>
                            }
                            @if (cloudflareSetupResult.Steps.Count > 0)
                            {
                                <ul class="edge-setup-list">
                                    @foreach (var step in cloudflareSetupResult.Steps)
                                    {
                                        <li>@step</li>
                                    }
                                </ul>
                            }
                            @if (cloudflareSetupResult.Warnings.Count > 0)
                            {
                                <ul class="edge-setup-list edge-warning-list">
                                    @foreach (var warning in cloudflareSetupResult.Warnings)
                                    {
                                        <li>@warning</li>
                                    }
                                </ul>
                            }
                        </section>
                    }

                    @if (cloudflareRelayRemovalResult is not null)
                    {
                        <section class="surface-card edge-card">
                            <div class="table-header">
                                <div>
                                    <p class="eyebrow">Relay removal</p>
                                    <h2>@cloudflareRelayRemovalResult.GatewayDomainName</h2>
                                    <p class="meta-text">@cloudflareRelayRemovalResult.Summary</p>
                                </div>
                                <UiPill Tone="@(cloudflareRelayRemovalResult.Success ? UiPillTone.Success : UiPillTone.Warning)">
                                    @(cloudflareRelayRemovalResult.Success ? "Removed" : "Needs confirmation")
                                </UiPill>
                            </div>
                            @if (cloudflareRelayRemovalResult.Steps.Count > 0)
                            {
                                <ul class="edge-setup-list">
                                    @foreach (var step in cloudflareRelayRemovalResult.Steps)
                                    {
                                        <li>@step</li>
                                    }
                                </ul>
                            }
                            @if (cloudflareRelayRemovalResult.Warnings.Count > 0)
                            {
                                <ul class="edge-setup-list edge-warning-list">
                                    @foreach (var warning in cloudflareRelayRemovalResult.Warnings)
                                    {
                                        <li>@warning</li>
                                    }
                                </ul>
                            }
                        </section>
                    }

                    <section class="edge-card edge-setup-section edge-cloudflare-token-card">
                        <div class="table-header">
                            <div>
                                <p class="eyebrow">Cloudflare token</p>
                                <h2>Connect Cloudflare to Edge Gateway</h2>
                                <p class="meta-text">Validate a scoped token here before publishing. Edge Gateway will then list the Cloudflare zones that token can manage.</p>
                            </div>
                            @if (dashboard.Cloudflare.HasSavedToken)
                            {
                                <div class="edge-token-header-actions">
                                    <UiPill Tone="UiPillTone.Success">Token saved</UiPill>
                                    <UiCommandButton Label="Setup Guide"
                                                     Glyph="UiIconGlyph.Info"
                                                     Variant="UiButtonVariant.Ghost"
                                                     OnClick="OpenCloudflareSetupGuide" />
                                </div>
                            }
                        </div>

                        @if (dashboard.Cloudflare.HasSavedToken)
                        {
                            <div class="edge-token-ready">
                                <div>
                                    <strong>Cloudflare is connected.</strong>
                                    <span>Use the domain section below to set up this LMS host's relay namespace and prepare Caddy/cloudflared automatically.</span>
                                </div>
                                <UiCommandButton Label="Reset settings"
                                                 Glyph="UiIconGlyph.Delete"
                                                 Variant="UiButtonVariant.Danger"
                                                 OnClick="OpenResetSetupModal" />
                            </div>
                        }
                        else
                        {
                            <div class="edge-token-grid">
                                <UiTextField @bind-Value="cloudflareTokenInput"
                                             Label="Paste Cloudflare token"
                                             Type="password"
                                             Autocomplete="off"
                                             Placeholder="Paste Cloudflare token"
                                             Disabled="@isValidatingCloudflareToken"
                                             Compact="true" />
                                <UiCommandButton Label="@(isValidatingCloudflareToken ? "Validating and saving..." : "Validate and Save token")"
                                                 Glyph="UiIconGlyph.Save"
                                                 Variant="UiButtonVariant.Primary"
                                                 Disabled="@(isValidatingCloudflareToken || string.IsNullOrWhiteSpace(cloudflareTokenInput))"
                                                 OnClick="ValidateCloudflareTokenAsync" />
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(cloudflareTokenMessage))
                        {
                            <p class="edge-token-message @(cloudflareTokenIsError ? "error" : "success")">@cloudflareTokenMessage</p>
                        }
                    </section>

                    @if (ShouldShowRuntimeSetupDetails)
                    {
                        <section class="edge-card edge-setup-section edge-runtime-card">
                            <div class="table-header">
                                <div>
                                    <p class="eyebrow">Local edge runtime</p>
                                    <h2>Managed runtime readiness</h2>
                                    <p class="meta-text">@dashboard.Runtime.Summary</p>
                                </div>
                            </div>
                            <div class="edge-runtime-grid">
                                <div class="surface-subcard edge-runtime-item">
                                    <UiPill Tone="@GetStatusTone(dashboard.Runtime.Caddy.Status)">@BuildRuntimeStatusLabel(dashboard.Runtime.Caddy.Status)</UiPill>
                                    <div>
                                        <strong>@dashboard.Runtime.Caddy.Label</strong>
                                        <span>@dashboard.Runtime.Caddy.Message</span>
                                    </div>
                                </div>
                                <div class="surface-subcard edge-runtime-item">
                                    <UiPill Tone="@GetStatusTone(dashboard.Runtime.Cloudflared.Status)">@BuildRuntimeStatusLabel(dashboard.Runtime.Cloudflared.Status)</UiPill>
                                    <div>
                                        <strong>@dashboard.Runtime.Cloudflared.Label</strong>
                                        <span>@dashboard.Runtime.Cloudflared.Message</span>
                                    </div>
                                </div>
                            </div>
                            @if (!dashboard.Cloudflare.IsAvailable)
                            {
                                <p class="callout warning edge-runtime-warning">@dashboard.Cloudflare.Message</p>
                            }
                        </section>
                    }

                    <section class="edge-card edge-setup-section edge-local-relays-card">
                        <div class="table-header">
                            <div>
                                <p class="eyebrow">Configured zones</p>
                                <h2>Configured relay zones</h2>
                                <p class="meta-text">Shows every relay wildcard LMS can see, including whether it appears to belong to this host.</p>
                            </div>
                            <UiPill Tone="@(ConfiguredCloudflareRelays.Count > 0 ? UiPillTone.Success : UiPillTone.Neutral)">
                                @BuildConfiguredRelayCountLabel()
                            </UiPill>
                        </div>

                        @if (CloudflareDomains.Count == 0)
                        {
                            <p class="meta-text">No Cloudflare zones are available from the saved token.</p>
                        }
                        else if (ConfiguredCloudflareRelays.Count == 0)
                        {
                            <p class="meta-text">No relay wildcard is currently configured for these Cloudflare zones.</p>
                        }
                        else
                        {
                            <div class="edge-local-relay-list">
                                @foreach (var domain in ConfiguredCloudflareRelays)
                                {
                                    var routeCount = CountRoutesForDomain(domain.DomainName);
                                    var relayRoutes = GetRoutesForDomain(domain.DomainName);
                                    <div class="edge-local-relay-row">
                                        <div class="edge-local-relay-main">
                                            <strong>@domain.DomainName</strong>
                                            <span><code>@domain.GatewayDomainName</code></span>
                                            <CompactUIButton Label="Add"
                                                             Glyph="UiIconGlyph.Plus"
                                                             Disabled="@isProvisioningCloudflareDomain"
                                                             OnClick="@(() => UseCloudflareDomain(domain.DomainName))" />
                                        </div>
                                        <div class="edge-local-relay-meta">
                                            <span>@BuildDomainRelayLabel(domain)</span>
                                            <span>@BuildDomainRelayDetail(domain)</span>
                                            <span>@routeCount app@(routeCount == 1 ? string.Empty : "s")</span>
                                            @if (relayRoutes.Count > 0)
                                            {
                                                <div class="edge-local-relay-routes">
                                                    @foreach (var route in relayRoutes.Take(3))
                                                    {
                                                        <span><strong>@route.DisplayName</strong> <code>@BuildExternalRouteUrl(route)</code></span>
                                                    }
                                                    @if (relayRoutes.Count > 3)
                                                    {
                                                        <span>+@(relayRoutes.Count - 3) more</span>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <span>No published app routes on this zone yet.</span>
                                            }
                                        </div>
                                        <div class="edge-local-relay-actions">
                                            <CompactUIButton Label="Delete"
                                                             Glyph="UiIconGlyph.Delete"
                                                             Disabled="@(isProvisioningCloudflareDomain || isDeletingRelay)"
                                                             OnClick="@(() => OpenRelayDeleteDialog(domain))" />
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </section>

                    <details class="edge-setup-section edge-relay-settings @(relayNamespaceUnlocked ? "unlocked" : "locked")" open="@relayNamespaceExpanded">
                        <summary class="edge-relay-settings-summary" @onclick="ToggleRelayNamespaceExpanded" @onclick:preventDefault="true">
                            <div>
                                <span class="eyebrow">Relay namespace</span>
                                <strong>@edgeSettingsEditor.GatewaySubdomain</strong>
                                <span class="meta-text">Example: <code>@BuildGatewaySubdomainExample()</code></span>
                            </div>
                            <span class="edge-relay-summary-actions">
                                <UiPill Tone="@(relayNamespaceUnlocked ? UiPillTone.Warning : UiPillTone.Success)">
                                    @(relayNamespaceUnlocked ? "Unlocked" : "Locked")
                                </UiPill>
                                <span class="edge-relay-toggle-text edge-relay-toggle-expand">Expand</span>
                                <span class="edge-relay-toggle-text edge-relay-toggle-collapse">Collapse</span>
                            </span>
                        </summary>

                        <div class="edge-relay-settings-body">
                            <p class="callout warning edge-relay-warning">
                                The relay namespace must be unique across your LMS landscape. Do not change it after apps are published unless you intentionally want to break those external app URLs and then republish the affected relay/routes.
                            </p>

                            <EditForm Model="@edgeSettingsEditor" OnValidSubmit="SaveEdgeGatewaySettingsAsync" class="edge-relay-settings-form">
                                <div class="edge-relay-settings-form-line">
                                    <UiLockedTextField @bind-Value="edgeSettingsEditor.GatewaySubdomain"
                                                       Label="Relay namespace"
                                                       Helper="@BuildRelayNamespaceHelper()"
                                                       Placeholder="relay or relay.example.com"
                                                       Locked="@(!relayNamespaceUnlocked)"
                                                       LockTitle='@(relayNamespaceUnlocked ? "Lock namespace" : "Unlock namespace")'
                                                       SaveTitle="Save relay namespace"
                                                       Compact="true"
                                                       Class="edge-relay-lock-field"
                                                       OnLockClick="ToggleRelayNamespaceLockAsync" />
                                    <div class="edge-readonly-field">
                                        <span class="ui-field-label">Example</span>
                                        <strong>@BuildGatewaySubdomainExample()</strong>
                                        <span>@BuildRelayNamespaceExampleHelper()</span>
                                    </div>
                                </div>
                            </EditForm>
                        </div>
                    </details>

                    <section class="edge-card edge-setup-section edge-new-app-card">
                        <div class="table-header">
                            <div>
                                <p class="eyebrow">Setup Relay</p>
                                <h2>Setup Relay</h2>
                                <p class="meta-text">@dashboard.Cloudflare.Message</p>
                            </div>
                        </div>

                        @if (dashboard.Cloudflare.Domains.Count == 0)
                        {
                            <p class="meta-text">Validate a Cloudflare token above first. Edge Gateway will then list the domains that token can manage.</p>
                        }
                        else if (RelaySetupCloudflareDomains.Count == 0)
                        {
                            <p class="meta-text">Every available Cloudflare zone already has this LMS relay namespace configured. Use Configured zones above to add services or delete a relay before setting it up again.</p>
                        }
                        else
                        {
                            <div class="edge-domain-picker-grid">
                                <UiSelectField TValue="string"
                                               @bind-Value="selectedRelaySetupDomainName"
                                               Label="Cloudflare domain"
                                               Helper="Only domains that still need this LMS relay namespace are listed."
                                               Compact="true">
                                    @foreach (var domain in RelaySetupCloudflareDomains)
                                    {
                                        <option value="@domain.DomainName">@BuildDomainOptionLabel(domain)</option>
                                    }
                                </UiSelectField>
                                <div class="edge-domain-actions">
                                    <UiCommandButton Label="@(IsProvisioningSelectedRelaySetupDomain ? "Setting up Relay..." : "Setup Relay")"
                                                     Glyph="UiIconGlyph.Connection"
                                                     Variant="UiButtonVariant.Primary"
                                                     Disabled="@(SelectedRelaySetupCloudflareDomain is null || !dashboard.Runtime.CanAttemptPublish || isProvisioningCloudflareDomain)"
                                                     OnClick="@(() => ProvisionSelectedRelaySetupDomainAsync())" />
                                </div>
                            </div>
                            @if (isProvisioningCloudflareDomain)
                            {
                                <p class="edge-domain-progress">
                                    Setting up Relay for <code>@provisioningCloudflareDomainName</code>. Updating Cloudflare tunnel, DNS, local cloudflared, and Caddy...
                                </p>
                            }

                            @if (SelectedRelaySetupCloudflareDomain is { } selectedDomain)
                            {
                                <p class="edge-domain-relay-preview">
                                    Setup Relay will create <code>@selectedDomain.GatewayDomainName</code> with wildcard <code>*.@selectedDomain.GatewayDomainName</code>.
                                </p>
                            }
                        }
                    </section>
                </TabPage>

                <TabPage Value="@DiagnosticsTabValue" Title="Diagnostics">
                    <section class="surface-card edge-card edge-advanced-card">
                        <div class="table-header">
                            <div>
                                <p class="eyebrow">Diagnostics</p>
                                <h2>Route checks and access log</h2>
                                <p class="meta-text">Run Test on a published app to show route checks here. The log shows recent auth decisions.</p>
                            </div>
                        </div>

                        @if (lastDiagnostic is not null)
                        {
                            <div class="edge-diagnostic">
                                <UiPill Tone="@GetStatusTone(lastDiagnostic.Status)">@BuildRuntimeStatusLabel(lastDiagnostic.Status)</UiPill>
                                <strong>@lastDiagnostic.Summary</strong>
                                <ul>
                                    @foreach (var check in lastDiagnostic.Checks)
                                    {
                                        <li>@check</li>
                                    }
                                </ul>
                            </div>
                        }

                        @if (dashboard.AuditEntries.Count > 0)
                        {
                            <div class="edge-audit-table">
                                <div class="edge-audit-row edge-audit-heading">
                                    <span>Time</span>
                                    <span>Host</span>
                                    <span>User</span>
                                    <span>Decision</span>
                                    <span>Reason</span>
                                </div>
                                @foreach (var entry in dashboard.AuditEntries.Take(40))
                                {
                                    <div class="edge-audit-row">
                                        <span>@entry.TimestampUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                        <span>@entry.Hostname</span>
                                        <span>@(string.IsNullOrWhiteSpace(entry.UserEmail) ? "-" : entry.UserEmail)</span>
                                        <span>@entry.Decision</span>
                                        <span>@entry.Reason</span>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="meta-text">No Edge Gateway access decisions have been logged yet.</p>
                        }
                    </section>
                </TabPage>
            </ChildContent>
        </TabControl>
    }

    <UiModal IsOpen="@showRouteModal"
             Title="@routeModalTitle"
             Subtitle="Save creates a local LMS service record."
             Class="edge-route-modal"
             OnClose="CloseRouteModal">
        <ChildContent>
            <EditForm id="@routeEditorFormId" Model="@routeEditor" OnValidSubmit="SaveRouteAsync">
                <DataAnnotationsValidator />
                <div class="edge-route-form">
                    @if (!string.IsNullOrWhiteSpace(routeEditorMessage))
                    {
                        <p class="edge-editor-message @(routeEditorIsError ? "error" : "success")">@routeEditorMessage</p>
                    }

                    <div class="edge-form-grid edge-route-main-grid">
                        <UiTextField @bind-Value="routeEditor.DisplayName" Label="Display name" Compact="true" />
                        <UiTextField @bind-Value="routeEditor.Hostname" Label="Hostname / subdomain" Helper="Use nas or a full hostname inside the selected Edge Gateway namespace." Placeholder="nas" Compact="true" />
                        <UiSelectField TValue="EdgeGatewayAuthMode" @bind-Value="routeEditor.AuthMode" Label="Auth mode" Compact="true">
                            @foreach (var mode in AuthModeOptions)
                            {
                                <option value="@mode">@FormatAuthMode(mode)</option>
                            }
                        </UiSelectField>
                    </div>

                    <div class="edge-form-grid edge-form-grid-target">
                        <UiTextField @bind-Value="routeEditor.TargetPathPrefix"
                                     Label="URL path prefix"
                                     Helper="Optional. /plex makes only hostname/plex route to this backend. LMS strips the prefix before proxying."
                                     Placeholder="/plex"
                                     Compact="true" />
                        <UiSelectField TValue="EdgeGatewayTargetScheme" @bind-Value="routeEditor.TargetScheme" Label="Scheme" Compact="true">
                            <option value="@EdgeGatewayTargetScheme.Http">http</option>
                            <option value="@EdgeGatewayTargetScheme.Https">https</option>
                        </UiSelectField>
                        <UiTextField @bind-Value="routeEditor.TargetHost" Label="Target host" Placeholder="192.168.1.20" Compact="true" />
                        <UiNumberField TValue="int" @bind-Value="routeEditor.TargetPort" Label="Port" Compact="true" />
                        <div class="edge-target-actions">
                            <UiCommandButton Label="@(isCheckingRouteTarget ? "Checking..." : "Check Target")"
                                             Glyph="UiIconGlyph.Analyze"
                                             Variant="UiButtonVariant.Primary"
                                             Class="edge-target-check-button"
                                             Disabled="@isCheckingRouteTarget"
                                             OnClick="CheckRouteTargetAsync" />
                            <UiCommandButton Label="Find HTTP/S"
                                             Glyph="UiIconGlyph.Search"
                                             Variant="UiButtonVariant.Ghost"
                                             Class="edge-service-find-button"
                                             Disabled="@isCheckingRouteTarget"
                                             OnClick="OpenHttpServicePickerAsync" />
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(routeTargetCheckMessage))
                    {
                        <p class="edge-target-check-message @(routeTargetCheckIsError ? "error" : "success")">@routeTargetCheckMessage</p>
                    }

                    <details class="edge-advanced-settings edge-publish-details">
                        <summary>
                            <span>Publishing</span>
                            <small>Public URL and DNS preview</small>
                        </summary>
                        <div class="edge-publish-details-body">
                            <div class="edge-publish-preview">
                                <div>
                                    <strong>@BuildPublishHeadline()</strong>
                                    <span>@BuildPublishDetail()</span>
                                </div>
                                <UiPill Tone="@GetAuthModeTone(routeEditor.AuthMode)">
                                    @BuildRouteAccessLabel(routeEditor.AuthMode)
                                </UiPill>
                            </div>

                            <p class="callout warning edge-publish-required">
                                Save creates the service record only. Press Publish on the service card when you want the public hostname to go live.
                            </p>
                        </div>
                    </details>

                    <div class="edge-form-flags">
                        <UiCheckboxField @bind-Value="routeEditor.Enabled" Label="Enabled" Compact="true" />
                    </div>

                    <details class="edge-advanced-settings">
                        <summary>
                            <span>Advanced settings</span>
                            <small>Allow-lists, source filtering and notes</small>
                        </summary>
                        <div class="edge-form-grid edge-form-grid-two">
                            <UiTextAreaField @bind-Value="routeEditor.AllowKnownIps" Label="Known IP allow-list" Helper="Optional IP/CIDR list. Leave blank to allow any source after auth." Rows="3" Compact="true" />
                            <UiTextAreaField @bind-Value="routeEditor.AllowedUsers" Label="Allowed users" Helper="Optional comma or line separated email allow-list." Rows="3" Compact="true" />
                            <UiTextAreaField @bind-Value="routeEditor.AllowedGroups" Label="Allowed groups" Helper="Optional group claims for future SSO/passkey policies." Rows="3" Compact="true" />
                            <UiTextAreaField @bind-Value="routeEditor.Notes" Label="Notes" Rows="3" Compact="true" />
                            <div class="edge-advanced-checkboxes">
                                <UiCheckboxField @bind-Value="routeEditor.AllowLanOnly" Label="LAN sources only" Helper="Reject public source IPs before auth policy checks." Compact="true" />
                            </div>
                        </div>
                    </details>

                    <ValidationSummary />
                </div>
            </EditForm>
        </ChildContent>
        <Footer>
            <UiCommandButton Label="Save service" Glyph="UiIconGlyph.Save" Variant="UiButtonVariant.Primary" Type="submit" form="@routeEditorFormId" />
            <UiCommandButton Label="Cancel" Glyph="UiIconGlyph.Clear" Variant="UiButtonVariant.Ghost" OnClick="CloseRouteModal" />
        </Footer>
    </UiModal>

    <UiModal IsOpen="@isHttpServicePickerOpen"
             Title="HTTP/S service lookup"
             Subtitle="Cached internal services from localhost, Docker, LAN, and optional Tailscale peers."
             Class="edge-http-service-modal"
             OnClose="CloseHttpServicePicker">
        <ChildContent>
            <div class="edge-http-service-picker">
                <div class="table-header edge-http-service-picker-header">
                    <div>
                        <strong>Available origins</strong>
                        <p class="meta-text">Cached results are shown first. Run a scan to refresh localhost, exposed Docker containers, private LAN and optional Tailscale services.</p>
                    </div>
                    <div class="edge-http-service-actions">
                        <UiCheckboxField @bind-Value="includeDockerHttpScan" Label="Docker" Compact="true" />
                        <UiCheckboxField @bind-Value="includeLanHttpScan" Label="LAN" Compact="true" />
                        <UiCheckboxField @bind-Value="includeTailnetHttpScan" Label="Tailscale" Compact="true" />
                        <UiCommandButton Label="@(isDiscoveringHttpServices ? "Scanning..." : "Scan")"
                                         Glyph="UiIconGlyph.Search"
                                         Variant="UiButtonVariant.Primary"
                                         Disabled="@isDiscoveringHttpServices"
                                         OnClick="ScanHttpServicesAsync" />
                    </div>
                </div>

                @if (isDiscoveringHttpServices)
                {
                    <section class="surface-subcard edge-http-service-scanning" role="status" aria-live="polite">
                        <span class="edge-http-service-progress">
                            <span class="edge-http-service-progress-fill"></span>
                        </span>
                        <span>@BuildHttpScanSummary()</span>
                    </section>
                }

                @if (httpServiceSuggestions.Count == 0)
                {
                    <section class="empty-state edge-http-service-empty">
                        <h3>No cached HTTP/S services</h3>
                        <p>@(httpServiceDiscoveryMessage ?? "Click Scan to search localhost, exposed Docker containers, and the private LAN. Enable Tailscale if you want tailnet peers included.")</p>
                    </section>
                }
                else
                {
                    <div class="edge-http-service-list" role="list">
                        @foreach (var service in httpServiceSuggestions)
                        {
                            <HttpServiceLookupRow Service="service" OnUse="SelectHttpServiceAsync" />
                        }
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(httpServiceDiscoveryMessage) && httpServiceSuggestions.Count > 0)
                {
                    <p class="meta-text edge-http-service-message">@httpServiceDiscoveryMessage</p>
                }
            </div>
        </ChildContent>
        <Footer>
            <UiCommandButton Label="Close"
                             Glyph="UiIconGlyph.Clear"
                             Variant="UiButtonVariant.Ghost"
                             OnClick="CloseHttpServicePicker" />
        </Footer>
    </UiModal>

    <UiModal IsOpen="@showCloudflareSetupGuide"
             Title="Cloudflare token setup"
             Subtitle="Create a scoped token for Edge Gateway publishing."
             Class="edge-setup-guide-modal"
             OnClose="CloseCloudflareSetupGuide">
        <ChildContent>
            <div class="edge-setup-guide-body">
                <section class="surface-subcard edge-setup-guide-section">
                    <h3>Create the token</h3>
                    <ol>
                        <li>Open <a href="@CloudflareUserTokenUrl" target="_blank" rel="noreferrer">Cloudflare API Tokens</a>.</li>
                        <li>Create a custom token named something obvious, for example <strong>Linux Made Sane</strong>.</li>
                        <li>Scope it to the account and zones you want this LMS host to manage.</li>
                        <li>Paste it into Edge Gateway and validate it. Cloudflare only shows the full token once.</li>
                    </ol>
                </section>
                <section class="surface-subcard edge-setup-guide-section">
                    <h3>Required permissions</h3>
                    <div class="edge-token-permissions">
                        <span><strong>Required</strong> <code>Account - Cloudflare Tunnel - Edit</code></span>
                        <span><strong>Required</strong> <code>Zone - DNS - Edit</code></span>
                        <span><strong>Optional</strong> <code>Account - Access: Apps and Policies - Edit</code></span>
                    </div>
                    <p class="meta-text">If a token validates but no zones appear, the zone scope is wrong. If tunnel setup fails, check the account scope and Tunnel permission.</p>
                </section>
                <p class="callout warning edge-ownership-warning">
                    Warning: once a relay is set up, LMS manages the local Caddy configuration, the local cloudflared service, the Cloudflare tunnel ingress, and the scoped wildcard DNS record for this LMS host.
                </p>
            </div>
        </ChildContent>
        <Footer>
            <UiCommandButton Label="Close"
                             Glyph="UiIconGlyph.Clear"
                             Variant="UiButtonVariant.Ghost"
                             OnClick="CloseCloudflareSetupGuide" />
        </Footer>
    </UiModal>

    <UiModal IsOpen="@showResetSetupModal"
             Title="Reset Edge Gateway settings"
             Subtitle="Remove the live Cloudflare footprint, local routes, token, and relay setup for this LMS host."
             Class="edge-reset-modal"
             CloseOnBackdrop="@(!isResettingEdgeGatewaySetup)"
             OnClose="CloseResetSetupModal">
        <ChildContent>
            <div class="edge-reset-body">
                <p class="callout warning">
                    @BuildResetSetupWarning()
                </p>
                <p class="meta-text">
                    If Cloudflare cleanup cannot complete, reset will stop before the token is forgotten so the live resources can still be cleaned up safely.
                </p>
                @if (!string.IsNullOrWhiteSpace(resetSetupMessage))
                {
                    <p class="edge-token-message error">@resetSetupMessage</p>
                }
            </div>
        </ChildContent>
        <Footer>
            <UiCommandButton Label="Cancel"
                             Glyph="UiIconGlyph.Clear"
                             Variant="UiButtonVariant.Ghost"
                             Disabled="@isResettingEdgeGatewaySetup"
                             OnClick="CloseResetSetupModal" />
            <UiCommandButton Label="@(isResettingEdgeGatewaySetup ? "Resetting..." : "Reset settings")"
                             Glyph="UiIconGlyph.Delete"
                             Variant="UiButtonVariant.Danger"
                             Disabled="@isResettingEdgeGatewaySetup"
                             OnClick="ConfirmResetSetupAsync" />
        </Footer>
    </UiModal>

    <UiModal IsOpen="@(relayPendingDelete is not null)"
             Title="Delete relay"
             Subtitle="Remove the Cloudflare relay wildcard for this zone."
             Class="edge-delete-relay-modal"
             CloseOnBackdrop="@(!isDeletingRelay)"
             OnClose="CloseRelayDeleteDialog">
        <ChildContent>
            @if (relayPendingDelete is not null)
            {
                <div class="edge-delete-route-body">
                    <section class="surface-subcard edge-delete-route-summary">
                        <strong>@relayPendingDelete.DomainName</strong>
                        <span>@relayPendingDelete.GatewayDomainName</span>
                        <span>*.@relayPendingDelete.GatewayDomainName</span>
                    </section>
                    <p class="callout warning">
                        This deletes the scoped wildcard DNS record and removes the wildcard tunnel ingress. Route records are kept, but apps using this relay will stop working until the relay is set up again.
                    </p>
                    @if (relayPendingDelete is { RelayOwnedByThisLms: false })
                    {
                        <p class="callout warning">
                            LMS does not think this relay belongs to the current host. Confirm only if you intentionally want LMS to remove this relay wildcard and matching tunnel ingress.
                        </p>
                    }
                    @if (!string.IsNullOrWhiteSpace(relayDeleteMessage))
                    {
                        <p class="edge-route-status error">@relayDeleteMessage</p>
                    }
                </div>
            }
        </ChildContent>
        <Footer>
            <UiCommandButton Label="Cancel"
                             Glyph="UiIconGlyph.Clear"
                             Variant="UiButtonVariant.Ghost"
                             Disabled="@isDeletingRelay"
                             OnClick="CloseRelayDeleteDialog" />
            <UiCommandButton Label="@(isDeletingRelay ? "Deleting..." : "Delete relay")"
                             Glyph="UiIconGlyph.Delete"
                             Variant="UiButtonVariant.Danger"
                             Disabled="@isDeletingRelay"
                             OnClick="ConfirmDeleteRelayAsync" />
        </Footer>
    </UiModal>

    <UiModal IsOpen="@(routePendingDelete is not null)"
             Title="Delete published service"
             Subtitle="Remove this Edge Gateway route and regenerate the local Caddy config."
             Class="edge-delete-route-modal"
             CloseOnBackdrop="@(!isDeletingRoute)"
             OnClose="CloseRouteDeleteDialog">
        <ChildContent>
            @if (routePendingDelete is not null)
            {
                <div class="edge-delete-route-body">
                    <section class="surface-subcard edge-delete-route-summary">
                        <strong>@routePendingDelete.DisplayName</strong>
                        <span>@BuildExternalRouteUrl(routePendingDelete)</span>
                        <span>@routePendingDelete.TargetUrl</span>
                    </section>
                    <p class="meta-text">
                        This removes the published service route from LMS and reloads Caddy. It does not uninstall the backend application.
                    </p>
                    @if (!string.IsNullOrWhiteSpace(routeDeleteMessage))
                    {
                        <p class="edge-route-status error">@routeDeleteMessage</p>
                    }
                </div>
            }
        </ChildContent>
        <Footer>
            <UiCommandButton Label="Cancel"
                             Glyph="UiIconGlyph.Clear"
                             Variant="UiButtonVariant.Ghost"
                             Disabled="@isDeletingRoute"
                             OnClick="CloseRouteDeleteDialog" />
            <UiCommandButton Label="@(isDeletingRoute ? "Deleting..." : "Delete service")"
                             Glyph="UiIconGlyph.Delete"
                             Variant="UiButtonVariant.Danger"
                             Disabled="@isDeletingRoute"
                             OnClick="ConfirmDeleteRouteAsync" />
        </Footer>
    </UiModal>
</div>

@code {
    private const string PublishedAppsTabValue = "published";
    private const string SetupTabValue = "setup";
    private const string DiagnosticsTabValue = "diagnostics";
    private const string CloudflareUserTokenUrl = "https://dash.cloudflare.com/profile/api-tokens";
    private readonly string routeEditorFormId = $"edge-route-editor-form-{Guid.NewGuid():N}";
    private static readonly IReadOnlyList<EdgeGatewayAuthMode> AuthModeOptions =
    [
        EdgeGatewayAuthMode.PassThrough,
        EdgeGatewayAuthMode.RequireMfa,
        EdgeGatewayAuthMode.Blocked
    ];

    private readonly HashSet<string> expandedRouteDomains = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> knownRouteDomains = new(StringComparer.OrdinalIgnoreCase);
    private EdgeGatewayDashboardViewModel? dashboard;
    private EdgeGatewayRouteEditor routeEditor = new();
    private EdgeGatewayDiagnosticResult? lastDiagnostic;
    private EdgeGatewayCloudflareSetupResult? cloudflareSetupResult;
    private EdgeGatewayCloudflareRouteSetupResult? cloudflareRouteSetupResult;
    private EdgeGatewayCloudflareRelayRemovalResult? cloudflareRelayRemovalResult;
    private EdgeGatewaySettingsEditor edgeSettingsEditor = new();
    private IReadOnlyList<LocalHttpServiceEndpoint> httpServiceSuggestions = [];
    private CancellationTokenSource? dashboardLoadCancellation;
    private string activeTab = PublishedAppsTabValue;
    private string userMessage = string.Empty;
    private string dashboardLoadError = string.Empty;
    private string? httpServiceDiscoveryMessage;
    private string httpServiceDiscoveryStatus = string.Empty;
    private int httpServiceScanFoundCount;
    private int httpServiceScanProbedCount;
    private int httpServiceScanTotalCount;
    private bool isDisposed;
    private bool isDashboardLoading;
    private bool showRouteModal;
    private bool isHttpServicePickerOpen;
    private bool isDiscoveringHttpServices;
    private bool showCloudflareSetupGuide;
    private bool showResetSetupModal;
    private bool relayNamespaceExpanded;
    private bool relayNamespaceUnlocked;
    private bool confirmWildcardDnsReplacement;
    private bool confirmRouteDnsReplacement;
    private bool isValidatingCloudflareToken;
    private bool cloudflareTokenIsError;
    private bool isResettingEdgeGatewaySetup;
    private bool isProvisioningCloudflareDomain;
    private bool isDeletingRelay;
    private bool isCheckingRouteTarget;
    private bool includeDockerHttpScan = true;
    private bool includeLanHttpScan = true;
    private bool includeTailnetHttpScan;
    private bool routeEditorIsError;
    private bool routeTargetCheckIsError;
    private bool routeActionIsError;
    private Guid? publishingRouteId;
    private Guid? togglingRouteId;
    private bool isDeletingRoute;
    private EdgeGatewayCloudflareDomainOption? relayPendingDelete;
    private EdgeGatewayRouteListItem? routePendingDelete;
    private Guid? routeActionMessageRouteId;
    private string routeActionMessage = string.Empty;
    private string routeDeleteMessage = string.Empty;
    private string routeEditorMessage = string.Empty;
    private string routeTargetCheckMessage = string.Empty;
    private string routeModalTitle = "New route";
    private string cloudflareTokenInput = string.Empty;
    private string cloudflareTokenMessage = string.Empty;
    private string resetSetupMessage = string.Empty;
    private string provisioningCloudflareDomainName = string.Empty;
    private string relayDeleteMessage = string.Empty;
    private string selectedDomainNameValue = string.Empty;
    private string selectedRelaySetupDomainNameValue = string.Empty;
    private string selectedDomainName
    {
        get => selectedDomainNameValue;
        set
        {
            selectedDomainNameValue = value;
        }
    }
    private string selectedRelaySetupDomainName
    {
        get => selectedRelaySetupDomainNameValue;
        set
        {
            selectedRelaySetupDomainNameValue = value;
        }
    }
    private bool IsRouteActionBusy => publishingRouteId.HasValue || togglingRouteId.HasValue || isDeletingRoute;
    private bool IsCaddyReady => dashboard?.Runtime.Caddy.Status == EdgeGatewayDiagnosticStatus.Good;
    private bool IsCloudflareReady =>
        dashboard?.Cloudflare.IsAvailable == true &&
        dashboard.Runtime.Cloudflared.Status == EdgeGatewayDiagnosticStatus.Good;
    private bool ShouldShowRuntimeSetupDetails => !IsCaddyReady || !IsCloudflareReady;
    private EdgeGatewayRouteListItem? LocalLmsRoute =>
        dashboard?.Routes.FirstOrDefault(IsLocalLmsRoute);
    private IReadOnlyList<EdgeGatewayRouteDomainGroup> RouteDomainGroups =>
        dashboard?.Routes
            .GroupBy(route => NormalizeRouteDomainName(route.DomainName), StringComparer.OrdinalIgnoreCase)
            .Select(group => new EdgeGatewayRouteDomainGroup(
                group.Key,
                group
                    .OrderBy(route => route.DisplayName, StringComparer.OrdinalIgnoreCase)
                    .ThenBy(route => route.Hostname, StringComparer.OrdinalIgnoreCase)
                    .ToArray()))
            .OrderBy(group => group.DomainName, StringComparer.OrdinalIgnoreCase)
            .ToArray()
        ?? [];
    private IReadOnlyList<EdgeGatewayCloudflareDomainOption> CloudflareDomains =>
        dashboard?.Cloudflare.Domains ?? [];

    private IReadOnlyList<EdgeGatewayCloudflareDomainOption> ConfiguredCloudflareRelays =>
        CloudflareDomains
            .Where(static domain => domain.RelayConfigured)
            .OrderBy(static domain => domain.DomainName, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private IReadOnlyList<EdgeGatewayCloudflareDomainOption> RelaySetupCloudflareDomains =>
        CloudflareDomains
            .Where(static domain => !domain.RelayConfigured)
            .OrderBy(static domain => domain.DomainName, StringComparer.OrdinalIgnoreCase)
            .ToArray();

    private EdgeGatewayCloudflareDomainOption? SelectedCloudflareDomain =>
        CloudflareDomains.FirstOrDefault(domain => domain.DomainName.Equals(selectedDomainName, StringComparison.OrdinalIgnoreCase)) ??
        CloudflareDomains.FirstOrDefault();

    private EdgeGatewayCloudflareDomainOption? SelectedRelaySetupCloudflareDomain =>
        RelaySetupCloudflareDomains.FirstOrDefault(domain => domain.DomainName.Equals(selectedRelaySetupDomainName, StringComparison.OrdinalIgnoreCase)) ??
        RelaySetupCloudflareDomains.FirstOrDefault();

    private bool CanCreateAppOnSelectedDomain =>
        SelectedCloudflareDomain is { Paused: false, RelayConfigured: true, RelayUsesCloudflareTunnel: true, RelayOwnedByThisLms: true };

    private bool CanCreateAppForDomain(string domainName) =>
        CloudflareDomains.Any(domain =>
            domain.DomainName.Equals(domainName, StringComparison.OrdinalIgnoreCase) &&
            domain is { Paused: false, RelayConfigured: true, RelayUsesCloudflareTunnel: true, RelayOwnedByThisLms: true });

    private bool IsProvisioningSelectedRelaySetupDomain =>
        isProvisioningCloudflareDomain &&
        SelectedRelaySetupCloudflareDomain is { } domain &&
        domain.DomainName.Equals(provisioningCloudflareDomainName, StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized() => BeginDashboardLoad();

    public void Dispose()
    {
        isDisposed = true;
        dashboardLoadCancellation?.Cancel();
        dashboardLoadCancellation?.Dispose();
    }

    private void BeginDashboardLoad()
    {
        dashboardLoadCancellation?.Cancel();
        dashboardLoadCancellation?.Dispose();
        dashboardLoadCancellation = new CancellationTokenSource();
        isDashboardLoading = true;
        dashboardLoadError = string.Empty;
        _ = LoadDashboardInBackgroundAsync(dashboardLoadCancellation.Token);
    }

    private async Task LoadDashboardInBackgroundAsync(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Yield();
            var snapshot = await LoadDashboardSnapshotAsync(cancellationToken);
            await InvokeAsync(() =>
            {
                if (isDisposed || cancellationToken.IsCancellationRequested)
                {
                    return;
                }

                ApplyDashboardSnapshot(snapshot);
                isDashboardLoading = false;
                StateHasChanged();
            });
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
        catch (Exception exception)
        {
            await InvokeAsync(() =>
            {
                if (isDisposed)
                {
                    return;
                }

                dashboardLoadError = exception.Message;
                userMessage = exception.Message;
                isDashboardLoading = false;
                StateHasChanged();
            });
        }
    }

    private async Task LoadAsync()
    {
        isDashboardLoading = true;
        dashboardLoadError = string.Empty;
        await InvokeAsync(StateHasChanged);

        try
        {
            var snapshot = await LoadDashboardSnapshotAsync();
            ApplyDashboardSnapshot(snapshot);
        }
        finally
        {
            isDashboardLoading = false;
        }
    }

    private async Task<EdgeGatewayDashboardSnapshot> LoadDashboardSnapshotAsync(CancellationToken cancellationToken = default)
    {
        var dashboardTask = EdgeGatewayService.GetDashboardAsync(cancellationToken);
        var settingsTask = EdgeGatewayService.GetSettingsEditorAsync(cancellationToken);
        await Task.WhenAll(dashboardTask, settingsTask);
        return new EdgeGatewayDashboardSnapshot(await dashboardTask, await settingsTask);
    }

    private void ApplyDashboardSnapshot(EdgeGatewayDashboardSnapshot snapshot)
    {
        dashboard = snapshot.Dashboard;
        edgeSettingsEditor = snapshot.SettingsEditor;
        relayNamespaceUnlocked = false;
        if (CloudflareDomains.Count > 0 &&
            !CloudflareDomains.Any(domain => domain.DomainName.Equals(selectedDomainName, StringComparison.OrdinalIgnoreCase)))
        {
            selectedDomainName = CloudflareDomains.FirstOrDefault(domain => domain.RelayOwnedByThisLms)?.DomainName ??
                                 CloudflareDomains.FirstOrDefault(domain => domain.RelayConfigured)?.DomainName ??
                                 CloudflareDomains[0].DomainName;
        }

        if (RelaySetupCloudflareDomains.Count == 0)
        {
            selectedRelaySetupDomainName = string.Empty;
        }
        else if (!RelaySetupCloudflareDomains.Any(domain => domain.DomainName.Equals(selectedRelaySetupDomainName, StringComparison.OrdinalIgnoreCase)))
        {
            selectedRelaySetupDomainName = RelaySetupCloudflareDomains[0].DomainName;
        }

        SyncRouteDomainExpansionState();
    }

    private async Task SaveEdgeGatewaySettingsAsync()
    {
        try
        {
            await EdgeGatewayService.SaveSettingsAsync(edgeSettingsEditor);
            userMessage = "Edge Gateway relay namespace saved.";
            relayNamespaceExpanded = true;
            relayNamespaceUnlocked = false;
            cloudflareSetupResult = null;
            cloudflareRouteSetupResult = null;
            cloudflareRelayRemovalResult = null;
            await LoadAsync();
        }
