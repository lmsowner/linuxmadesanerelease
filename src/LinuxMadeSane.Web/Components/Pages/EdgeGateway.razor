    private async Task ValidateCloudflareTokenAsync()
    {
        if (isValidatingCloudflareToken)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(cloudflareTokenInput))
        {
            cloudflareTokenIsError = true;
            cloudflareTokenMessage = "Paste a Cloudflare API token before validating.";
            return;
        }

        isValidatingCloudflareToken = true;
        cloudflareTokenIsError = false;
        cloudflareTokenMessage = "Validating Cloudflare token...";
        userMessage = cloudflareTokenMessage;
        await InvokeAsync(StateHasChanged);

        try
        {
            var validation = await EdgeGatewayService.ValidateCloudflareTokenAsync(
                cloudflareTokenInput,
                saveToken: true);
            var autoSetupDomainName = validation.Zones.Count == 1
                ? validation.Zones[0].Name
                : string.Empty;
            cloudflareTokenInput = string.Empty;
            selectedDomainName = string.Empty;
            selectedRelaySetupDomainName = string.Empty;
            cloudflareTokenMessage = validation.Zones.Count == 0
                ? "Token saved, but Cloudflare did not return any zones. Check the token zone scope."
                : validation.Zones.Count == 1
                    ? $"Token saved. Setting up Edge Gateway for {autoSetupDomainName}."
                    : $"Token saved. Choose one of the {validation.Zones.Count} Cloudflare zones below to set up Edge Gateway.";
            cloudflareTokenIsError = validation.Zones.Count == 0;
            userMessage = cloudflareTokenMessage;
            await LoadAsync();

            if (!string.IsNullOrWhiteSpace(autoSetupDomainName))
            {
                selectedDomainName = autoSetupDomainName;
                selectedRelaySetupDomainName = autoSetupDomainName;
                await ProvisionCloudflareDomainAsync(autoSetupDomainName);
            }
        }
        catch (Exception exception)
        {
            cloudflareTokenIsError = true;
            cloudflareTokenMessage = exception.Message;
            userMessage = exception.Message;
        }
        finally
        {
            isValidatingCloudflareToken = false;
        }
    }

