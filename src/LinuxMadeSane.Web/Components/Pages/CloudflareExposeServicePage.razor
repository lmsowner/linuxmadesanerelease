        );

    protected override async Task OnParametersSetAsync()
    {
        ResetInitialLoadProgress();
        await SetInitialLoadProgressAsync(
            LoadingSettingsPhase,
            "Opening Cloudflare integration",
            "Loading the local connector, saved settings, and existing applications for this LMS host.");
        ResetEditContext();
        currentUserEmail = await ResolveCurrentUserEmailAsync();
        await LoadWorkspaceAsync(validateSavedToken: false);
        await SetInitialLoadProgressAsync(
            LoadingReadyPhase,
            "Cloudflare ready",
            "The Cloudflare integration is ready.");
        isLoaded = true;

        if (hasSavedToken)
        {
            QueueBackgroundValidation();
        }
    }

    private async Task LoadWorkspaceAsync(bool preserveUiState = false, bool validateSavedToken = true)
    {
        if (ShowBlockingLoad)
        {
            await SetInitialLoadProgressAsync(
                LoadingSettingsPhase,
                "Loading saved Cloudflare settings",
                "Checking saved token state, local connector details, and configured applications.");
        }

        workspace = await ExposedServiceManager.GetWorkspaceAsync(HostId);
        hasSavedToken = !string.IsNullOrWhiteSpace(workspace.SavedSettings?.ApiTokenSecretReference);

        if (!hasInitializedActiveTab)
        {
            activeCloudflareTab = hasSavedToken && HostHasInstalledConnector ? ApplicationsTabValue : SetupTabValue;
            hasInitializedActiveTab = true;
        }

        editor.ServiceName = string.IsNullOrWhiteSpace(editor.ServiceName)
            ? workspace.HostName
            : editor.ServiceName;
        editor.AccountId = string.IsNullOrWhiteSpace(editor.AccountId)
            ? workspace.SavedSettings?.AccountId ?? string.Empty
            : editor.AccountId;
        editor.ZoneId = string.IsNullOrWhiteSpace(editor.ZoneId)
            ? workspace.SavedSettings?.ZoneId ?? string.Empty
            : editor.ZoneId;

        if (hasSavedToken)
        {
            if (validateSavedToken)
            {
                if (ShowBlockingLoad)
                {
                    await SetInitialLoadProgressAsync(
                    LoadingTokenPhase,
                    "Validating saved token",
                    "Checking the saved Cloudflare token and loading the available account context.");
                }

                await ValidateTokenAsync(preserveUiState, suppressStatus: !ShowBlockingLoad);
            }
            else
            {
                validation = null;
                availableTunnels = [];
            }
        }
        else
        {
            validation = null;
            availableTunnels = [];

            if (ShowBlockingLoad)
            {
                await SetInitialLoadProgressAsync(
                    LoadingSettingsPhase,
                    "Ready for Cloudflare setup",
                    "No saved token was found. Add a token in Setup to continue.");
            }
        }
    }

    private async Task ReloadWorkspaceSnapshotAsync()
    {
        workspace = await ExposedServiceManager.GetWorkspaceAsync(HostId);
        hasSavedToken = !string.IsNullOrWhiteSpace(workspace.SavedSettings?.ApiTokenSecretReference);
    }

    private void QueueBackgroundValidation()
    {
        if (isDisposed || !hasSavedToken || isBackgroundRefreshing || isRefreshingWorkspace)
        {
            return;
        }

        _ = RunBackgroundValidationAsync();
    }

    private async Task RunBackgroundValidationAsync()
    {
        if (isDisposed || !hasSavedToken || isBackgroundRefreshing || isRefreshingWorkspace)
        {
            return;
        }

        isBackgroundRefreshing = true;

        if (!isDisposed)
        {
            await InvokeAsync(StateHasChanged);
        }

        try
        {
            await ValidateTokenAsync(preserveUiState: true, suppressStatus: true);
        }
        finally
        {
            isBackgroundRefreshing = false;

            if (!isDisposed)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task RefreshWorkspaceAsync()
    {
        if (isRefreshingWorkspace || isBackgroundRefreshing)
        {
            return;
        }

        isRefreshingWorkspace = true;
        ClearStatus();
        connectorSetupResult = null;
        ResetInitialLoadProgress();
        await SetInitialLoadProgressAsync(
            LoadingSettingsPhase,
            "Refreshing Cloudflare integration",
            "Reloading saved settings, token state, and connector context for this LMS host.");

        try
        {
            await LoadWorkspaceAsync(preserveUiState: true);
            await SetInitialLoadProgressAsync(
                LoadingReadyPhase,
                "Cloudflare ready",
                "The Cloudflare integration is ready.");

            if (string.IsNullOrWhiteSpace(statusMessage))
            {
                SetStatus("Cloudflare workspace refreshed.", isError: false, autoHide: true);
            }
        }
        finally
        {
            isRefreshingWorkspace = false;
        }
    }

    private Task HandleCloudflareTabChangedAsync(string? value)
    {
        activeCloudflareTab = value switch
        {
            ApplicationsTabValue => ApplicationsTabValue,
            SetupTabValue => SetupTabValue,
            _ => SetupTabValue
        };

        return Task.CompletedTask;
    }

    private async Task ValidateTokenAsync(bool preserveUiState = false, bool suppressStatus = false)
    {
        if (!preserveUiState)
        {
            ClearStatus();
            previewPlan = null;
            applyResult = null;
            connectorSetupResult = null;
        }

        isValidating = true;
        if (!suppressStatus)
        {
            SetStatus("Validating Cloudflare token...", isError: false);
        }

        try
        {
            if (ShowBlockingLoad)
            {
                await SetInitialLoadProgressAsync(
                    LoadingTokenPhase,
                    "Validating saved token",
                    "Cloudflare is checking the saved token and returning accounts and domains.");
            }

            validation = await ExposedServiceManager.ValidateTokenAsync(HostId, editor.ApiTokenInput);
            hasSavedToken = validation.HasSavedToken;

            if (string.IsNullOrWhiteSpace(editor.AccountId))
            {
                editor.AccountId = workspace?.SavedSettings?.AccountId
                    ?? validation.Accounts.FirstOrDefault()?.Id
                    ?? validation.Zones.FirstOrDefault()?.AccountId
                    ?? string.Empty;
            }

            if (string.IsNullOrWhiteSpace(editor.ZoneId))
            {
                editor.ZoneId = workspace?.SavedSettings?.ZoneId
                    ?? FilteredZones.FirstOrDefault()?.Id
                    ?? string.Empty;
            }

            NormalizeSelectedAccountAndZone();

            if (ShowBlockingLoad)
            {
                await SetInitialLoadProgressAsync(
                    LoadingTunnelPhase,
                    "Loading tunnel context",
                    "Checking reusable tunnels and matching them to the local cloudflared connector.");
            }

            await LoadAvailableTunnelsAsync();

            if (!preserveUiState && !suppressStatus && !HostHasInstalledConnector)
            {
                await EnsureConnectorAsync(switchToApplicationsOnSuccess: true, clearStatus: false);
                return;
            }

            if (!preserveUiState)
            {
                activeCloudflareTab = ApplicationsTabValue;
                if (!suppressStatus)
                {
                    SetStatus("Cloudflare token validated.", isError: false, autoHide: true);
                }
            }

            if (ShowBlockingLoad)
            {
                await SetInitialLoadProgressAsync(
                    LoadingTunnelPhase,
                    "Preparing Cloudflare workspace",
                    "Finalising validated settings and local connector choices.");
            }
        }
        catch (Exception exception)
        {
            availableTunnels = [];
            if (suppressStatus)
            {
                statusMessage = BuildStatusMessage(exception, isTokenValidation: true);
                statusIsError = true;
            }
            else
            {
                SetStatus(BuildStatusMessage(exception, isTokenValidation: true), isError: true);
            }

            if (ShowBlockingLoad)
            {
                await SetInitialLoadProgressAsync(
                    LoadingTokenPhase,
                    "Cloudflare setup needs attention",
                    "The saved token could not be validated. Open Setup to fix the token or connector.");
            }
        }
        finally
        {
            isValidating = false;
        }
    }

    private async Task EnsureConnectorAsync(
        bool switchToApplicationsOnSuccess = false,
        bool clearStatus = true)
    {
        if (isEnsuringConnector)
        {
            return;
        }

        if (validation is null)
        {
            activeCloudflareTab = SetupTabValue;
            SetStatus("Validate a Cloudflare token before setting up the connector.", isError: true);
            return;
        }

        isEnsuringConnector = true;
        if (clearStatus)
        {
            ClearStatus();
            previewPlan = null;
            applyResult = null;
            connectorSetupResult = null;
        }

        SetStatus("Setting up the local Cloudflare connector...", isError: false);

        try
        {
            connectorSetupResult = await ExposedServiceManager.EnsureConnectorAsync(HostId, editor);
            await ReloadWorkspaceSnapshotAsync();
            await LoadAvailableTunnelsAsync();

            SetStatus(
                connectorSetupResult.Status,
                isError: !connectorSetupResult.Succeeded);

            if (connectorSetupResult.Succeeded && switchToApplicationsOnSuccess)
            {
                activeCloudflareTab = ApplicationsTabValue;
            }
        }
        catch (Exception exception)
        {
            SetStatus(exception.Message, isError: true);
        }
        finally
        {
            isEnsuringConnector = false;
        }
    }

    private async Task HandleAccountChangedAsync(string value)
    {
        editor.AccountId = value;
        editor.ConfirmDnsRecordReplacement = false;
        previewPlan = null;
        applyResult = null;

        if (!FilteredZones.Any(zone => zone.Id == editor.ZoneId))
        {
            editor.ZoneId = FilteredZones.FirstOrDefault()?.Id ?? string.Empty;
        }

        await LoadAvailableTunnelsAsync();
    }

    private async Task HandleZoneChangedAsync(string value)
    {
        editor.ZoneId = value;
        editor.ConfirmDnsRecordReplacement = false;
        previewPlan = null;
        applyResult = null;
        AlignAccountToSelectedZone();
        NormalizeSelectedAccountAndZone();
        await LoadAvailableTunnelsAsync();
    }

    private Task HandleTunnelSelectionChangedAsync(string value)
    {
        editor.CreateNewTunnel = value == CreateNewTunnelOptionValue;
        editor.TunnelId = editor.CreateNewTunnel ? string.Empty : value;
        editor.ConfirmDnsRecordReplacement = false;
        ApplySuggestedConnectorInstallDefault();
        previewPlan = null;
        applyResult = null;
        return Task.CompletedTask;
    }

