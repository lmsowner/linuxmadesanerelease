    private static string FormatTunnelOptionLabel(CloudflareTunnel tunnel)
    {
        var managedLabel = tunnel.IsManagedByLinuxMadeSane ? "LMS managed" : "existing";
        var statusLabel = string.IsNullOrWhiteSpace(tunnel.Status) ? "unknown" : tunnel.Status;
        return $"{tunnel.Name} ({managedLabel}, {statusLabel})";
    }

