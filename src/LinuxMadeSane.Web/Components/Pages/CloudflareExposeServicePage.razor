        mode switch
        {
            ExposedServiceAccessMode.OnlyMe => "Only me",
            ExposedServiceAccessMode.EmailAllowList => "Email list",
            ExposedServiceAccessMode.EmailDomainAllowList => "Email domains",
            _ => "DNS / tunnel only"
        };

    private async Task<string?> ResolveCurrentUserEmailAsync()
    {
        var authenticationState = AuthenticationStateTask is null
            ? null
            : await AuthenticationStateTask;

        return authenticationState?.User.FindFirstValue(ClaimTypes.Email);
    }

    private void ClearStatus()
    {
        CancelStatusTimer();
        statusMessage = string.Empty;
        statusIsError = false;
        validationMessages = [];
    }

    private void ResetInitialLoadProgress()
    {
        initialLoadPhase = LoadingSettingsPhase;
        initialLoadStep = "Opening Cloudflare integration";
        initialLoadDetail = "Loading this LMS host configuration.";
    }

    private void SetInitialLoadProgress(string phase, string step, string detail)
    {
        initialLoadPhase = phase;
        initialLoadStep = step;
        initialLoadDetail = detail;
    }

    private async Task SetInitialLoadProgressAsync(string phase, string step, string detail)
    {
        SetInitialLoadProgress(phase, step, detail);

        if (!ShowBlockingLoad)
        {
            return;
        }

        await InvokeAsync(StateHasChanged);
        await Task.Yield();
    }

    private string GetInitialLoadStepClass(string stepPhase)
    {
        var current = GetInitialLoadStepOrder(initialLoadPhase);
        var target = GetInitialLoadStepOrder(stepPhase);

        if (current > target)
        {
            return "complete";
        }

        return current == target ? "current" : string.Empty;
    }

    private static int GetInitialLoadStepOrder(string phase) =>
        phase switch
        {
            LoadingSettingsPhase => 0,
            LoadingTokenPhase => 1,
            LoadingTunnelPhase => 2,
            LoadingReadyPhase => 3,
            _ => 0
        };

    private void ResetEditContext()
    {
        editContext = new EditContext(editor);
    }

    private void SetStatus(string message, bool isError, bool autoHide = false)
    {
        CancelStatusTimer();
        statusMessage = message;
        statusIsError = isError;

        if (!autoHide || isError || string.IsNullOrWhiteSpace(message))
        {
            return;
        }

        statusMessageCts = new CancellationTokenSource();
        _ = AutoHideStatusAsync(statusMessageCts.Token);
    }

    private async Task AutoHideStatusAsync(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(TimeSpan.FromSeconds(10), cancellationToken);

            if (cancellationToken.IsCancellationRequested || isDisposed)
            {
                return;
            }

            await InvokeAsync(() =>
            {
                if (cancellationToken.IsCancellationRequested || isDisposed)
                {
                    return;
                }

                statusMessage = string.Empty;
                statusIsError = false;
                StateHasChanged();
            });
        }
        catch (TaskCanceledException)
        {
        }
    }

    private void CancelStatusTimer()
    {
        if (statusMessageCts is null)
        {
            return;
        }

        statusMessageCts.Cancel();
        statusMessageCts.Dispose();
        statusMessageCts = null;
    }

    private bool CanSubmitCloudflareForm()
    {
        if (validation is null)
        {
            validationMessages =
            [
                "Validate a Cloudflare API token first so Linux Made Sane can load the available zones."
            ];
            return false;
        }

        if (validation.Zones.Count == 0)
        {
            validationMessages =
            [
                "The validated token did not return any Cloudflare zones. Check the token's Zone Resources scope."
            ];
            return false;
        }

        return true;
    }

    private void CaptureValidationMessages()
    {
        validationMessages = editContext.GetValidationMessages()
            .Where(message => !string.IsNullOrWhiteSpace(message))
            .Distinct(StringComparer.Ordinal)
            .ToList();
    }

    private string BuildStatusMessage(Exception exception, bool isTokenValidation = false)
    {
        if (exception is CloudflareApiException apiException &&
            (apiException.StatusCode == 401 || apiException.StatusCode == 403))
        {
            var requiredPermissions = RequiresAccessPermission
                ? "Required permissions: Account -> Cloudflare Tunnel -> Edit, Account -> Access: Apps and Policies -> Edit, and Zone -> DNS -> Edit."
                : "Required permissions: Account -> Cloudflare Tunnel -> Edit and Zone -> DNS -> Edit.";

            return isTokenValidation
                ? $"Cloudflare rejected the token. Make sure you copied the full token, scoped it to the correct account and zone, and granted the expected permissions. {requiredPermissions}"
                : $"Cloudflare rejected the token or its permissions for this request. {requiredPermissions}";
        }

        return exception.Message;
    }

    public void Dispose()
    {
        isDisposed = true;
        CancelStatusTimer();
    }
}
