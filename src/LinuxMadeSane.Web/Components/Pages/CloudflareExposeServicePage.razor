    private void NormalizeSelectedAccountAndZone()
    {
        if (validation is null)
        {
            return;
        }

        if (!validation.Accounts.Any(item => item.Id == editor.AccountId))
        {
            var selectedZone = validation.Zones.FirstOrDefault(item => item.Id == editor.ZoneId);
            var selectedZoneAccountExists = selectedZone is not null &&
                !string.IsNullOrWhiteSpace(selectedZone.AccountId) &&
                validation.Accounts.Any(item => item.Id == selectedZone.AccountId);

            editor.AccountId = selectedZoneAccountExists
                ? selectedZone!.AccountId
                : validation.Accounts.FirstOrDefault()?.Id ?? string.Empty;
        }

        if (!FilteredZones.Any(item => item.Id == editor.ZoneId))
        {
            editor.ZoneId = FilteredZones.FirstOrDefault()?.Id
                ?? validation.Zones.FirstOrDefault()?.Id
                ?? string.Empty;
        }
    }

    private void NormalizeSelectedTunnel()
    {
        if (HostHasInstalledConnector &&
            !string.IsNullOrWhiteSpace(HostConnectorStatus?.TunnelId) &&
            availableTunnels.Any(item => item.Id == HostConnectorStatus.TunnelId))
        {
            editor.TunnelId = HostConnectorStatus.TunnelId!;
            editor.CreateNewTunnel = false;
            ApplySuggestedConnectorInstallDefault();
            return;
        }

        if (!editor.CreateNewTunnel &&
            !string.IsNullOrWhiteSpace(editor.TunnelId) &&
            availableTunnels.Any(item => item.Id == editor.TunnelId))
        {
            ApplySuggestedConnectorInstallDefault();
            return;
        }

        var preferredTunnelId = workspace?.ServiceEntries
            .OrderByDescending(item => item.Config.UpdatedAtUtc)
            .Select(item => item.Config.TunnelId)
            .FirstOrDefault(tunnelId => availableTunnels.Any(tunnel => tunnel.Id == tunnelId));

        if (!string.IsNullOrWhiteSpace(preferredTunnelId))
        {
            editor.TunnelId = preferredTunnelId;
            editor.CreateNewTunnel = false;
            ApplySuggestedConnectorInstallDefault();
            return;
        }

        var preferredManagedTunnel = availableTunnels.FirstOrDefault(item => item.IsManagedByLinuxMadeSane);
        if (preferredManagedTunnel is not null)
        {
            editor.TunnelId = preferredManagedTunnel.Id;
            editor.CreateNewTunnel = false;
            ApplySuggestedConnectorInstallDefault();
            return;
        }

        editor.TunnelId = string.Empty;
        editor.CreateNewTunnel = !HostHasInstalledConnector;
        ApplySuggestedConnectorInstallDefault();
    }

    private void PopulateEditorForNewApplication()
    {
        var accountId = !string.IsNullOrWhiteSpace(editor.AccountId)
            ? editor.AccountId
            : workspace?.SavedSettings?.AccountId
                ?? validation?.Accounts.FirstOrDefault()?.Id
                ?? string.Empty;
        var zoneId = !string.IsNullOrWhiteSpace(editor.ZoneId)
            ? editor.ZoneId
            : workspace?.SavedSettings?.ZoneId
                ?? FilteredZones.FirstOrDefault()?.Id
                ?? validation?.Zones.FirstOrDefault()?.Id
                ?? string.Empty;

        editor.ConfigId = null;
        editor.AccountId = accountId;
        editor.ZoneId = zoneId;
        editor.ServiceName = workspace?.HostName ?? string.Empty;
        editor.Subdomain = string.Empty;
        editor.LocalServiceUrl = "http://localhost:8080";
        editor.TunnelId = string.Empty;
        editor.CreateNewTunnel = !HostHasInstalledConnector;
        editor.AccessMode = ExposedServiceAccessMode.NoAccessProtection;
        editor.EmailAllowList = string.Empty;
        editor.EmailDomainAllowList = string.Empty;
        ApplyOriginRequestSettingsToEditor(CloudflareOriginRequestSettings.Default with { NoTlsVerify = true });
        editor.ConfirmDangerousExposure = false;
        editor.ConfirmDnsRecordReplacement = false;
        connectorInstallPreferenceTouched = false;
        noTlsVerifyPreferenceTouched = false;
        ApplySuggestedConnectorInstallDefault();
    }

    private void PopulateEditorForExistingApplication(ExposedServiceConfig config)
    {
        editor.ConfigId = config.Id;
        editor.AccountId = config.AccountId;
        editor.ZoneId = config.ZoneId;
        editor.ServiceName = config.ServiceName;
        editor.Subdomain = ExtractRelativeHostname(config.Hostname, config.ZoneName);
        editor.LocalServiceUrl = config.LocalServiceUrl;
        editor.TunnelId = config.TunnelId;
        editor.CreateNewTunnel = false;
        editor.AccessMode = config.AccessMode;
        editor.EmailAllowList = string.Join(Environment.NewLine, config.AllowedEmails);
        editor.EmailDomainAllowList = string.Join(Environment.NewLine, config.AllowedEmailDomains);
        ApplyOriginRequestSettingsToEditor(
            config.OriginRequestSettings
            ?? (CloudflareOriginRequestSettings.Default with { NoTlsVerify = IsHttpsLocalServiceUrl(config.LocalServiceUrl) }));
        editor.ConfirmDangerousExposure = false;
        editor.ConfirmDnsRecordReplacement = false;
        connectorInstallPreferenceTouched = false;
        noTlsVerifyPreferenceTouched = false;
        ApplySuggestedConnectorInstallDefault();
    }

    private void ApplyOriginRequestSettingsToEditor(CloudflareOriginRequestSettings settings)
    {
        editor.OriginServerName = settings.OriginServerName;
        editor.CertificateAuthorityPool = settings.CertificateAuthorityPool;
        editor.NoTlsVerify = settings.NoTlsVerify;
        editor.TlsTimeoutSeconds = settings.TlsTimeoutSeconds;
        editor.Http2Origin = settings.Http2Origin;
        editor.MatchSniToHost = settings.MatchSniToHost;
        editor.HttpHostHeader = settings.HttpHostHeader;
        editor.DisableChunkedEncoding = settings.DisableChunkedEncoding;
        editor.ConnectTimeoutSeconds = settings.ConnectTimeoutSeconds;
        editor.NoHappyEyeballs = settings.NoHappyEyeballs;
        editor.ProxyType = settings.ProxyType;
        editor.KeepAliveTimeoutSeconds = settings.KeepAliveTimeoutSeconds;
        editor.KeepAliveConnections = settings.KeepAliveConnections;
        editor.TcpKeepAliveSeconds = settings.TcpKeepAliveSeconds;
    }

    private static Uri? TryParseLocalServiceUri(string? value) =>
        Uri.TryCreate(value?.Trim(), UriKind.Absolute, out var uri)
            ? uri
            : null;

    private static bool IsHttpsLocalServiceUrl(string? value) =>
        TryParseLocalServiceUri(value)?.Scheme.Equals(Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase) == true;

    private static string BuildPublicServiceUrl(string hostname) =>
        hostname.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
        hostname.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
            ? hostname
            : $"https://{hostname}";

    private static string? BuildAbsoluteHref(string? value) =>
        Uri.TryCreate(value?.Trim(), UriKind.Absolute, out var uri)
            ? uri.ToString()
            : null;

    private static string ExtractRelativeHostname(string hostname, string zoneName)
    {
        if (!string.IsNullOrWhiteSpace(hostname) &&
            !string.IsNullOrWhiteSpace(zoneName) &&
            hostname.EndsWith($".{zoneName}", StringComparison.OrdinalIgnoreCase))
        {
            return hostname[..^(zoneName.Length + 1)];
        }

        return hostname;
    }

    private void BindEditorToSavedService()
    {
        if (workspace is null)
        {
            return;
        }

        if (editor.ConfigId.HasValue &&
            workspace.ServiceEntries.Any(item => item.Config.Id == editor.ConfigId.Value))
        {
            return;
        }

        var zone = FilteredZones.FirstOrDefault(item => item.Id == editor.ZoneId);
        if (zone is null || string.IsNullOrWhiteSpace(editor.Subdomain))
        {
            return;
        }

        var hostname = $"{editor.Subdomain.Trim()}.{zone.Name}".Trim();
        var matchingEntry = workspace.ServiceEntries.FirstOrDefault(item =>
            item.Config.Hostname.Equals(hostname, StringComparison.OrdinalIgnoreCase));

        if (matchingEntry is null)
        {
            return;
        }

        editor.ConfigId = matchingEntry.Config.Id;
    }

    private void AlignAccountToSelectedZone()
    {
        if (validation is null)
        {
            return;
        }

        var selectedZone = validation.Zones.FirstOrDefault(item => item.Id == editor.ZoneId);
        if (selectedZone is null || string.IsNullOrWhiteSpace(selectedZone.AccountId))
        {
            return;
        }

        if (validation.Accounts.Any(item => item.Id == selectedZone.AccountId))
        {
            editor.AccountId = selectedZone.AccountId;
        }
    }

