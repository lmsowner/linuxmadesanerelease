    }

    private Task DiscoverLocalServicesAsync()
    {
        if (isDiscoveringLocalServices)
        {
            return Task.CompletedTask;
        }

        isDiscoveringLocalServices = true;
        localServiceDiscoveryMessage = "Scan running in the background. Cached services stay visible while new services are added.";
        localServiceDiscoveryStatus = "Starting HTTP/S discovery...";
        localServiceScanFoundCount = 0;
        localServiceScanProbedCount = 0;
        localServiceScanTotalCount = 0;

        var request = new LocalHttpServiceDiscoveryRequest(
            IncludeLocalhost: true,
            IncludeLan: includeLanLocalServiceScan,
            IncludeTailnet: includeTailnetLocalServiceScan);
        _ = RunLocalServicesScanAsync(request);
        return Task.CompletedTask;
    }

    private async Task RunLocalServicesScanAsync(LocalHttpServiceDiscoveryRequest request)
    {
        try
        {
            await Task.Yield();
            var progress = new Progress<LocalHttpServiceDiscoveryProgressUpdate>(update =>
            {
                _ = InvokeAsync(() =>
                {
                    ApplyLocalServiceProgress(update);
                    StateHasChanged();
                });
            });

            var results = await LocalHttpServiceDiscovery.DiscoverAsync(request, progress);
            await InvokeAsync(() =>
            {
                localServiceSuggestions = SortLocalServiceSuggestions(results);
                localServiceDiscoveryMessage = localServiceSuggestions.Count == 0
                    ? "No HTTP/S services responded. Cached results were updated for the selected scan scopes."
                    : $"{localServiceSuggestions.Count} HTTP/S service(s) available from cache and the latest scan.";
                isDiscoveringLocalServices = false;
                StateHasChanged();
            });
        }
        catch (Exception exception)
        {
            await InvokeAsync(() =>
            {
                localServiceDiscoveryMessage = $"Local service lookup failed: {exception.Message}";
                localServiceDiscoveryStatus = "HTTP/S lookup failed.";
                isDiscoveringLocalServices = false;
                StateHasChanged();
            });
        }
    }

    private void ApplyLocalServiceProgress(LocalHttpServiceDiscoveryProgressUpdate update)
    {
        localServiceDiscoveryStatus = update.Message;
        localServiceScanProbedCount = update.ProbedCount;
        localServiceScanTotalCount = update.TotalProbeCount;
        localServiceScanFoundCount = update.FoundCount;

        if (update.FoundEndpoint is not null)
        {
            MergeLocalServiceSuggestion(update.FoundEndpoint);
        }

        if (update.IsCompleted)
        {
            isDiscoveringLocalServices = false;
        }
    }

    private void MergeLocalServiceSuggestion(LocalHttpServiceEndpoint endpoint)
    {
        localServiceSuggestions = SortLocalServiceSuggestions(
            localServiceSuggestions
                .Where(service => !BuildLocalServiceKey(service).Equals(BuildLocalServiceKey(endpoint), StringComparison.OrdinalIgnoreCase))
                .Append(endpoint));
    }

    private async Task SelectLocalServiceAsync(LocalHttpServiceEndpoint service)
    {
