        isLocalServicePickerOpen = false;
    }

    private async Task LoadCachedLocalServicesAsync()
    {
        localServiceSuggestions = await LocalHttpServiceDiscovery.GetCachedAsync();
        localServiceDiscoveryMessage = localServiceSuggestions.Count == 0
            ? "No cached HTTP/S services yet. Run Scan to search localhost and private LAN services."
            : $"Showing {localServiceSuggestions.Count} cached HTTP/S service(s). Run Scan to refresh.";
        localServiceDiscoveryStatus = string.Empty;
        localServiceScanFoundCount = 0;
        localServiceScanProbedCount = 0;
        localServiceScanTotalCount = 0;
    }

