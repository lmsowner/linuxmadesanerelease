    private void ClearApplicationPreviewState()
    {
        previewPlan = null;
        applyResult = null;
    }

    private async Task LoadAvailableTunnelsAsync()
    {
        availableTunnels = [];

        if (validation is null || string.IsNullOrWhiteSpace(editor.ZoneId))
        {
            editor.TunnelId = string.Empty;
            editor.CreateNewTunnel = !HostHasInstalledConnector;
            ApplySuggestedConnectorInstallDefault();
            return;
        }

        try
        {
            availableTunnels = (await ExposedServiceManager.ListTunnelsAsync(
                    HostId,
                    editor.ZoneId,
                    editor.AccountId,
                    editor.ApiTokenInput))
                .ToList();
            NormalizeSelectedTunnel();
        }
        catch (Exception exception)
        {
            editor.TunnelId = string.Empty;
            editor.CreateNewTunnel = !HostHasInstalledConnector;
            ApplySuggestedConnectorInstallDefault();
            statusMessage = BuildStatusMessage(exception);
            statusIsError = true;
        }
    }

    private async Task PreviewAsync()
    {
        ClearStatus();

        if (!CanSubmitCloudflareForm())
        {
            SetStatus(
                validationMessages.Count == 1
                    ? validationMessages[0]
                    : "Fix the listed fields before previewing the Cloudflare plan.",
                isError: true);
            return;
        }

        if (!editContext.Validate())
        {
            CaptureValidationMessages();
            SetStatus("Fix the listed fields before previewing the Cloudflare plan.", isError: true);
            return;
        }

        isPreviewing = true;
        previewPlan = null;
        applyResult = null;

        try
        {
            previewPlan = await ExposedServiceManager.PreviewAsync(HostId, editor, currentUserEmail);
            previewPanelExpanded = true;
            SetStatus("Dry-run preview generated.", isError: false);
        }
        catch (Exception exception)
        {
            if (IsDnsReplacementConfirmationError(exception))
            {
                await TryLoadPreviewForDnsReplacementPromptAsync();
            }

            SetStatus(exception.Message, isError: true);
        }
        finally
        {
            isPreviewing = false;
        }
    }

    private async Task ApplyAsync()
    {
        ClearStatus();

        if (!CanSubmitCloudflareForm())
        {
            SetStatus(
                validationMessages.Count == 1
                    ? validationMessages[0]
                    : "Fix the listed fields before applying Cloudflare changes.",
                isError: true);
            return;
        }

        if (!editContext.Validate())
        {
            CaptureValidationMessages();
            SetStatus("Fix the listed fields before applying Cloudflare changes.", isError: true);
            return;
        }

        isApplying = true;
        applyResult = null;

        try
        {
            applyResult = await ExposedServiceManager.ApplyAsync(HostId, editor, currentUserEmail);
            previewPanelExpanded = true;
            previewPlan = null;
            await LoadWorkspaceAsync(preserveUiState: true);
            BindEditorToSavedService();
            SetStatus(
                applyResult.Status,
                isError: applyResult.ConnectorDeployment is { Succeeded: false });
        }
        catch (Exception exception)
        {
            if (IsDnsReplacementConfirmationError(exception))
            {
                await TryLoadPreviewForDnsReplacementPromptAsync();
            }

            SetStatus(exception.Message, isError: true);
        }
        finally
        {
            isApplying = false;
        }
    }

    private async Task TryLoadPreviewForDnsReplacementPromptAsync()
    {
        try
        {
            previewPlan = await ExposedServiceManager.PreviewAsync(HostId, editor, currentUserEmail);
            previewPanelExpanded = true;
        }
        catch
        {
        }
    }

    private static bool IsDnsReplacementConfirmationError(Exception exception) =>
        exception is InvalidOperationException &&
        exception.Message.Contains("DNS conflict", StringComparison.OrdinalIgnoreCase) &&
        exception.Message.Contains("deleting/replacing", StringComparison.OrdinalIgnoreCase);

    private async Task RemoveServiceAsync(CloudflareExposedServiceListItemViewModel serviceEntry)
    {
        ClearStatus();
        removingServiceId = serviceEntry.Config.Id;

        try
        {
            await ExposedServiceManager.RemoveServiceAsync(
                HostId,
                serviceEntry.Config,
                serviceEntry.ExistsInLmsStore,
                editor.ApiTokenInput);
            await LoadWorkspaceAsync(preserveUiState: true);

            if (editor.ConfigId == serviceEntry.Config.Id)
            {
                CloseApplicationEditor();
            }

            SetStatus(
                serviceEntry.ExistsInLmsStore
                    ? "Saved exposed service removed from Cloudflare and Linux Made Sane."
                    : "Cloudflare-only exposed service removed.",
                isError: false);
        }
        catch (Exception exception)
        {
            SetStatus(exception.Message, isError: true);
        }
        finally
        {
            removingServiceId = null;
        }
    }

