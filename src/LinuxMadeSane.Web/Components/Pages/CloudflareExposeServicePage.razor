@using System.Security.Claims
@using System.Threading
@using LinuxMadeSane.Core.Abstractions
@using LinuxMadeSane.Core.Models.Cloudflare
@using LinuxMadeSane.Application.Contracts.Cloudflare
@using LinuxMadeSane.Application.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@inject IExposedServiceManager ExposedServiceManager
@inject ILocalHttpServiceDiscoveryService LocalHttpServiceDiscovery
@implements IDisposable

@if (ShowBlockingLoad)
{
    <section class="surface-card cloudflare-loading-card">
        <div class="cloudflare-loading-header">
            <div>
                <strong>@initialLoadStep</strong>
                <p class="meta-text">@initialLoadDetail</p>
            </div>
        </div>
        <div class="cloudflare-loading-progress" role="progressbar" aria-label="Cloudflare load progress" aria-valuetext="@initialLoadStep">
            <div class="cloudflare-loading-progress-fill"></div>
        </div>
        <div class="cloudflare-loading-steps">
            <span class="cloudflare-loading-step @GetInitialLoadStepClass(LoadingSettingsPhase)">Local settings</span>
            <span class="cloudflare-loading-step @GetInitialLoadStepClass(LoadingTokenPhase)">Token validation</span>
            <span class="cloudflare-loading-step @GetInitialLoadStepClass(LoadingTunnelPhase)">Connector context</span>
        </div>
    </section>
}
else
{
    <div class="cloudflare-expose-shell">
        <section class="surface-card">
            <TabControl ActiveValue="@activeCloudflareTab"
                        ActiveValueChanged="HandleCloudflareTabChangedAsync"
                        Class="cloudflare-page-tab-control"
                        PanelClass="cloudflare-page-tab-panel">
                <HeaderActions>
                    <UiCommandButton Label="Setup guide"
                                     Glyph="UiIconGlyph.Info"
                                     Variant="UiButtonVariant.Ghost"
                                     OnClick="OnOpenSetupGuide" />
                    <UiCommandButton Label="@(IsRefreshBusy ? "Refreshing..." : "Refresh")"
                                     Glyph="UiIconGlyph.Refresh"
                                     Variant="UiButtonVariant.Ghost"
                                     Disabled="@IsRefreshBusy"
                                     OnClick="RefreshWorkspaceAsync" />
                </HeaderActions>
                <ChildContent>
                    <TabPage Value="@SetupTabValue" Title="Setup">
                        <div class="cloudflare-tab-section">
                        @if (ShowSetupSummary)
                        {
                            <section class="surface-subcard cloudflare-setup-summary">
                                <div class="cloudflare-setup-summary-item">
                                    <span class="meta-text">Connector</span>
                                    <strong>@ConnectorSummary</strong>
                                </div>
                                <div class="cloudflare-setup-summary-item">
                                    <span class="meta-text">Token</span>
                                    <strong>@TokenSummary</strong>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(SelectedAccountName))
                                {
                                    <div class="cloudflare-setup-summary-item">
                                        <span class="meta-text">Account</span>
                                        <strong>@SelectedAccountName</strong>
                                    </div>
                                }
                                <div class="cloudflare-setup-summary-item">
                                    <span class="meta-text">Apps on connector</span>
                                    <strong>@ConnectedApplicationCount</strong>
                                </div>
                            </section>
                        }

                        @if (!HostHasInstalledConnector)
                        {
                            <section class="surface-subcard cloudflare-mode-note">
                                <strong>Set up this box as the Cloudflare connector</strong>
                                <span>Validate a Cloudflare token and LMS will create or reuse a tunnel, then attach cloudflared on this host before you add applications.</span>
                                <UiCheckboxField Value="@editor.RunConnectorInstallOnHost"
                                                 ValueChanged="HandleRunConnectorInstallOnHostChangedAsync"
                                                 ValueExpression="@(() => editor.RunConnectorInstallOnHost)"
                                                 Label="Install or attach cloudflared automatically"
                                                 Helper="@ConnectorInstallHelper" />
                                @if (validation is not null)
                                {
                                    <div class="cloudflare-token-actions">
                                        <UiCommandButton Label="@(isEnsuringConnector ? "Setting up connector..." : "Set up connector")"
                                                         Glyph="UiIconGlyph.Connect"
                                                         Disabled="@isEnsuringConnector"
                                                         OnClick="@(() => EnsureConnectorAsync(switchToApplicationsOnSuccess: true))" />
                                    </div>
                                }
                            </section>
                        }

                        @if (HasValidatedSavedToken)
                        {
                            <div class="cloudflare-token-actions cloudflare-token-actions-standalone">
                                <UiCommandButton Label="Forget saved token"
                                                 Glyph="UiIconGlyph.Delete"
                                                 Variant="UiButtonVariant.Ghost"
                                                 OnClick="ForgetSavedTokenAsync" />
                            </div>
                        }
                        else
                        {
                            <div class="cloudflare-token-row">
                                <UiTextField @bind-Value="editor.ApiTokenInput"
                                             Label="Cloudflare API token"
                                             Type="password"
                                             Autocomplete="off"
                                             Helper="Keep the save option enabled so Edge Gateway and future app publishing can reuse this token."
                                             Placeholder="Paste a scoped Bearer API token" />
                                <div class="cloudflare-token-actions">
                                    <UiCommandButton Label="@CloudflareTokenActionLabel"
                                                     Glyph="UiIconGlyph.Connect"
                                                     Disabled="@(isValidating || isEnsuringConnector)"
                                                     OnClick="@(() => ValidateTokenAsync())" />
                                    @if (hasSavedToken)
                                    {
                                        <UiCommandButton Label="Forget saved token"
                                                         Glyph="UiIconGlyph.Delete"
                                                         Variant="UiButtonVariant.Ghost"
                                                         OnClick="ForgetSavedTokenAsync" />
                                    }
                                </div>
                            </div>

                            <UiCheckboxField @bind-Value="editor.SaveApiToken"
                                             Label="Save this token securely for this host"
                                             Helper="Uses the existing encrypted secret store." />
                        }

                        @if (!string.IsNullOrWhiteSpace(statusMessage) && activeCloudflareTab == SetupTabValue)
                        {
                            <p class="callout @(statusIsError ? "error" : "success")">@statusMessage</p>
                        }

                        @if (connectorSetupResult is not null && activeCloudflareTab == SetupTabValue)
                        {
                            <p class="callout @(connectorSetupResult.Succeeded ? "success" : "warning")">@connectorSetupResult.NextStep</p>
                        }
                        </div>
                    </TabPage>

                    <TabPage Value="@ApplicationsTabValue" Title="@($"Applications ({ServiceEntries.Count})")">
                        <div class="cloudflare-tab-section">
                        <section class="surface-subcard">
                            <div class="table-header">
                                <div>
                                    <h3>Applications</h3>
                                    <p class="meta-text">Configured public hostnames for this local LMS instance.</p>
                                </div>
                                <div class="cloudflare-saved-actions">
                                    <UiCommandButton Label="Add application"
                                                     Glyph="UiIconGlyph.Plus"
                                                     Disabled="@(!CanManageApplications)"
                                                     OnClick="BeginAddApplication" />
                                </div>
                            </div>

                            @if (workspace?.SyncWarnings.Count > 0)
                            {
                                <div class="cloudflare-warning-list">
                                    @foreach (var warning in workspace.SyncWarnings)
                                    {
                                        <p class="callout warning">@warning</p>
                                    }
                                </div>
                            }

                            @if (ServiceEntries.Count == 0)
                            {
                                <p class="meta-text">No Cloudflare applications are configured yet.</p>
                            }
                            else
                            {
                                <div class="cloudflare-saved-list">
                                    @foreach (var serviceEntry in ServiceEntries)
                                    {
                                        var service = serviceEntry.Config;
                                        var publicHref = BuildPublicServiceUrl(service.Hostname);
                                        var localHref = BuildAbsoluteHref(service.LocalServiceUrl);
                                        <div class="cloudflare-saved-row">
                                            <div>
                                                <strong>@service.ServiceName</strong>
                                                <div class="meta-text cloudflare-saved-mapping">
                                                    <a href="@publicHref" target="_blank" rel="noreferrer">@publicHref</a>
                                                    <span aria-hidden="true">-&gt;</span>
                                                    @if (localHref is null)
                                                    {
                                                        <span>@service.LocalServiceUrl</span>
                                                    }
                                                    else
                                                    {
                                                        <a href="@localHref" target="_blank" rel="noreferrer">@service.LocalServiceUrl</a>
                                                    }
                                                </div>
                                            </div>
                                            <div class="cloudflare-saved-actions">
                                                <span class="status-pill neutral">@FormatAccessMode(service.AccessMode)</span>
                                                <span class="status-pill @(serviceEntry.ExistsInCloudflare ? "success" : "warning")">@GetSyncLabel(serviceEntry)</span>
                                                @if (CanManageApplications)
                                                {
                                                    <UiCommandButton Label="Edit"
                                                                     Glyph="UiIconGlyph.Edit"
                                                                     Variant="UiButtonVariant.Action"
                                                                     OnClick="@(() => BeginEditApplicationAsync(serviceEntry))" />
                                                }
                                                <UiCommandButton Label="@(removingServiceId == service.Id ? "Removing..." : "Remove")"
                                                                 Glyph="UiIconGlyph.Delete"
                                                                 Variant="UiButtonVariant.Danger"
                                                                 Disabled="@(removingServiceId == service.Id)"
                                         OnClick="@(() => RemoveServiceAsync(serviceEntry))" />
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </section>

                        @if (!CanManageApplications)
                        {
                            <section class="surface-subcard cloudflare-mode-note">
                                <strong>Setup required</strong>
                                <span>Validate a Cloudflare API token and set up this host as the connector before adding or editing applications.</span>
                            </section>
                        }
                        else if (isApplicationEditorOpen)
                        {
                            <section class="surface-subcard cloudflare-application-editor-card">
                                <div class="table-header">
                                    <div>
                                        <h3>@ApplicationEditorHeading</h3>
                                        <p class="meta-text">@ApplicationEditorSummary</p>
                                    </div>
                                    <div class="cloudflare-saved-actions">
                                        <UiCommandButton Label="Close"
                                                         Glyph="UiIconGlyph.Clear"
                                                         Variant="UiButtonVariant.Ghost"
                                                         OnClick="CloseApplicationEditor" />
                                    </div>
                                </div>

                                <EditForm EditContext="@editContext" class="stack-form cloudflare-form">
                                    <DataAnnotationsValidator />

                                    @if (validationMessages.Count > 0)
                                    {
                                        <div class="callout error">
                                            <strong>Cloudflare form errors</strong>
                                            <ul class="cloudflare-validation-list">
                                                @foreach (var message in validationMessages)
                                                {
                                                    <li>@message</li>
                                                }
                                            </ul>
                                        </div>
                                    }

                                    @if (validation is not null && validation.Accounts.Count > 1)
                                    {
                                        <div class="field-row">
                                            <UiComboboxField TValue="string"
                                                           Label="Cloudflare account"
                                                           Value="@editor.AccountId"
                                                           ValueChanged="HandleAccountChangedAsync"
                                                           ValueExpression="@(() => editor.AccountId)"
                                                           Helper="Choose which Zero Trust account to use.">
                                                @foreach (var account in validation.Accounts)
                                                {
                                                    <option value="@account.Id">@account.Name</option>
                                                }
                                            </UiComboboxField>
                                        </div>
                                    }

                                    @if (!HostHasInstalledConnector)
                                    {
                                        <div class="field-row">
                                            <UiComboboxField TValue="string"
                                                           Label="Tunnel"
                                                           Value="@SelectedTunnelOptionValue"
                                                           ValueChanged="HandleTunnelSelectionChangedAsync"
                                                           ValueExpression="@(() => editor.TunnelId)"
                                                           Helper="@TunnelSelectionFieldHelper">
                                                <option value="@CreateNewTunnelOptionValue">Create new LMS tunnel</option>
                                                @foreach (var tunnel in availableTunnels)
                                                {
                                                    <option value="@tunnel.Id">@FormatTunnelOptionLabel(tunnel)</option>
                                                }
                                            </UiComboboxField>
                                        </div>
                                    }

                                    <section class="surface-subcard cloudflare-route-options">
                                        <div class="cloudflare-config-options-heading">
                                            <strong>Route mapping</strong>
                                            <span>Public hostname and local origin for this application.</span>
                                        </div>

                                        <div class="field-row cloudflare-primary-grid cloudflare-route-grid">
                                            <UiTextField Value="@editor.Subdomain"
                                                         ValueChanged="HandleSubdomainChangedAsync"
                                                         ValueExpression="@(() => editor.Subdomain)"
                                                         Label="Subdomain"
                                                         Helper="@SubdomainHelperText"
                                                         Placeholder="myapp"
                                                         Class="cloudflare-route-field" />

                                            <UiComboboxField TValue="string"
                                                           Label="Zone / domain"
                                                           Value="@editor.ZoneId"
                                                           ValueChanged="HandleZoneChangedAsync"
                                                           ValueExpression="@(() => editor.ZoneId)"
                                                           Helper="Pick the Cloudflare zone that will hold the public hostname."
                                                           Class="cloudflare-route-field">
                                                @if (FilteredZones.Count == 0)
                                                {
                                                    <option value="">Validate a token first</option>
                                                }
                                                else
                                                {
                                                    @foreach (var zone in FilteredZones)
                                                    {
                                                        <option value="@zone.Id">@zone.Name</option>
                                                    }
                                                }
                                            </UiComboboxField>

                                            <div class="cloudflare-local-service-field">
                                                <UiTextField Value="@editor.LocalServiceUrl"
                                                             ValueChanged="HandleLocalServiceUrlChangedAsync"
                                                             ValueExpression="@(() => editor.LocalServiceUrl)"
                                                             Label="Local service URL"
                                                             Helper="Origin URL only. Use Find to pick from cached localhost, LAN, or Tailscale services."
                                                             Placeholder="http://localhost:5080"
                                                             Class="cloudflare-route-field" />
                                                <UiCommandButton Label="Find"
                                                                 Title="Find cached or scanned internal HTTP and HTTPS services"
                                                                 Glyph="UiIconGlyph.Search"
                                                                 Variant="UiButtonVariant.Ghost"
                                                                 Class="cloudflare-local-service-find-button"
                                                                 OnClick="OpenLocalServicePickerAsync" />
                                            </div>
                                        </div>
                                    </section>

                                    <section class="surface-subcard cloudflare-config-options">
                                        <div class="cloudflare-config-options-heading">
                                            <strong>Configuration options</strong>
                                            <span>Access and origin settings for this hostname.</span>
                                        </div>

                                        <div class="field-row cloudflare-config-grid cloudflare-config-main-grid">
                                            <UiTextField @bind-Value="editor.ServiceName"
                                                         Label="Service name"
                                                         Helper="Friendly label shown in Linux Made Sane and Cloudflare Access."
                                                         Class="cloudflare-config-field" />

                                            <UiComboboxField TValue="ExposedServiceAccessMode"
                                                          Label="Access mode"
                                                          Value="@editor.AccessMode"
                                                          ValueChanged="HandleAccessModeChangedAsync"
                                                          ValueExpression="@(() => editor.AccessMode)"
                                                           Helper="Default is DNS/tunnel only; LMS handles app login."
                                                           Class="cloudflare-config-field">
                                                @foreach (var option in accessModes)
                                                {
                                                    <option value="@option.Value">@option.Label</option>
                                                }
                                            </UiComboboxField>

                                            @if (editor.AccessMode == ExposedServiceAccessMode.EmailAllowList)
                                            {
                                                <UiTextField @bind-Value="editor.EmailAllowList"
                                                             Label="Email allow list"
                                                             Helper="Comma or newline separated email addresses."
                                                             Class="cloudflare-config-field" />
                                            }
                                            else if (editor.AccessMode == ExposedServiceAccessMode.EmailDomainAllowList)
                                            {
                                                <UiTextField @bind-Value="editor.EmailDomainAllowList"
                                                             Label="Email domain allow list"
                                                             Helper="Comma or newline separated email domains such as example.com."
                                                             Class="cloudflare-config-field" />
                                            }
                                            else if (editor.AccessMode == ExposedServiceAccessMode.OnlyMe)
                                            {
                                                <div class="surface-subcard cloudflare-mode-note cloudflare-config-mode-note">
                                                    <strong>Only me</strong>
                                                    <span>@(string.IsNullOrWhiteSpace(currentUserEmail) ? "This login does not expose an email claim." : currentUserEmail)</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="surface-subcard cloudflare-mode-note cloudflare-config-mode-note">
                                                    <strong>DNS / tunnel only</strong>
                                                    <span>No Cloudflare Access app or policy will be created for this hostname.</span>
                                                </div>
                                            }

                                        </div>

                                        <div class="cloudflare-origin-quick-row">
                                            <UiCheckboxField Value="@NoTlsVerifyFieldValue"
                                                             ValueChanged="HandleNoTlsVerifyChangedAsync"
                                                             ValueExpression="@(() => editor.NoTlsVerify)"
                                                             Label="No TLS Verify"
                                                             Helper="@NoTlsVerifyHelperText"
                                                             Compact="true"
                                                             Disabled="@(!LocalServiceUsesHttps)"
                                                             Class="cloudflare-config-checkbox" />
                                        </div>

                                        <details class="cloudflare-origin-advanced">
                                            <summary>Advanced origin request settings</summary>

                                            <div class="cloudflare-origin-settings">
                                                <section class="cloudflare-origin-settings-group">
                                                    <div class="cloudflare-origin-settings-heading">
                                                        <strong>TLS</strong>
                                                        <span>Certificate and HTTPS handshake behaviour.</span>
                                                    </div>
                                                    <div class="field-row cloudflare-origin-grid">
                                                        <UiTextField @bind-Value="editor.OriginServerName"
                                                                     Label="Origin server name"
                                                                     Helper="Hostname cloudflared expects on the origin certificate."
                                                                     Disabled="@(!LocalServiceUsesHttps)" />
                                                        <UiTextField @bind-Value="editor.CertificateAuthorityPool"
                                                                     Label="Certificate authority pool"
                                                                     Helper="Local CA bundle path for non-Cloudflare-signed origin certificates."
                                                                     Disabled="@(!LocalServiceUsesHttps)" />
                                                        <UiNumberField TValue="int"
                                                                       @bind-Value="editor.TlsTimeoutSeconds"
                                                                       Label="TLS timeout"
                                                                       Helper="Seconds allowed for TLS handshake."
                                                                       Disabled="@(!LocalServiceUsesHttps)"
                                                                       min="1" />
                                                        <UiCheckboxField @bind-Value="editor.Http2Origin"
                                                                         Label="HTTP2 connection"
                                                                         Helper="Use HTTP/2 from cloudflared to an HTTPS origin."
                                                                         Compact="true"
                                                                         Disabled="@(!LocalServiceUsesHttps)"
                                                                         Class="cloudflare-config-checkbox" />
                                                        <UiCheckboxField @bind-Value="editor.MatchSniToHost"
                                                                         Label="Match SNI to host"
                                                                         Helper="Use the incoming hostname as the TLS SNI."
                                                                         Compact="true"
                                                                         Disabled="@(!LocalServiceUsesHttps)"
                                                                         Class="cloudflare-config-checkbox" />
                                                    </div>
                                                </section>

                                                <section class="cloudflare-origin-settings-group">
                                                    <div class="cloudflare-origin-settings-heading">
                                                        <strong>HTTP Settings</strong>
                                                        <span>Headers and transfer behaviour.</span>
                                                    </div>
                                                    <div class="field-row cloudflare-origin-grid">
                                                        <UiTextField @bind-Value="editor.HttpHostHeader"
                                                                     Label="HTTP host header"
                                                                     Helper="Host header sent to the local service." />
                                                        <UiCheckboxField @bind-Value="editor.DisableChunkedEncoding"
                                                                         Label="Disable chunked encoding"
                                                                         Helper="Useful for some WSGI servers."
                                                                         Compact="true"
                                                                         Class="cloudflare-config-checkbox" />
                                                    </div>
                                                </section>

                                                <section class="cloudflare-origin-settings-group">
                                                    <div class="cloudflare-origin-settings-heading">
                                                        <strong>Connection</strong>
                                                        <span>Timeouts, connection reuse, and proxy behaviour.</span>
                                                    </div>
                                                    <div class="field-row cloudflare-origin-grid">
                                                        <UiNumberField TValue="int"
                                                                       @bind-Value="editor.ConnectTimeoutSeconds"
                                                                       Label="Connect timeout"
                                                                       Helper="Seconds allowed for establishing a TCP connection."
                                                                       min="1" />
                                                        <UiNumberField TValue="int"
                                                                       @bind-Value="editor.KeepAliveTimeoutSeconds"
                                                                       Label="Idle connection expiration"
                                                                       Helper="Seconds before idle keep-alive connections can be discarded."
                                                                       min="1" />
                                                        <UiNumberField TValue="int"
                                                                       @bind-Value="editor.KeepAliveConnections"
                                                                       Label="Keep alive connections"
                                                                       Helper="Maximum idle keep-alive connections."
                                                                       min="0" />
                                                        <UiNumberField TValue="int"
                                                                       @bind-Value="editor.TcpKeepAliveSeconds"
                                                                       Label="TCP keep alive interval"
                                                                       Helper="Seconds between TCP keep-alive packets."
                                                                       min="1" />
                                                        <UiComboboxField TValue="string"
                                                                         Label="Proxy type"
                                                                         @bind-Value="editor.ProxyType"
                                                                         Helper="Use SOCKS only for TCP-style proxy translation. Leave blank for normal HTTP proxying.">
                                                            <option value="">Regular</option>
                                                            <option value="socks">SOCKS5</option>
                                                        </UiComboboxField>
                                                        <UiCheckboxField @bind-Value="editor.NoHappyEyeballs"
                                                                         Label="No Happy Eyeballs"
                                                                         Helper="Disable IPv4/IPv6 fallback selection."
                                                                         Compact="true"
                                                                         Class="cloudflare-config-checkbox" />
                                                    </div>
                                                </section>
                                            </div>
                                        </details>
                                    </section>

                                    <div class="toolbar-row cloudflare-form-actions">
                                        <UiCommandButton Label="@(isPreviewing ? "Building preview..." : "Dry-run preview")"
                                                         Glyph="UiIconGlyph.Analyze"
                                                         Disabled="@isPreviewing"
                                                         OnClick="PreviewAsync" />
                                        <UiCommandButton Label="@(isApplying ? "Applying..." : editor.ConfigId.HasValue ? "Update application" : "Add application")"
                                                         Glyph="UiIconGlyph.Save"
                                                         Variant="UiButtonVariant.Primary"
                                                         Disabled="@isApplying"
                                                         OnClick="ApplyAsync" />
                                    </div>

                                    @if (previewPlan is not null && previewPlan.Warnings.Count > 0)
                                    {
                                        <div class="cloudflare-warning-list">
                                            @foreach (var warning in previewPlan.Warnings)
                                            {
                                                <p class="callout @(warning.RequiresConfirmation ? "warning" : "info")">@warning.Message</p>
                                            }
                                        </div>

                                        @if (previewPlan.RequiresConfirmation)
                                        {
                                            @if (PreviewRequiresDnsReplacementConfirmation)
                                            {
                                                <UiCheckboxField @bind-Value="editor.ConfirmDnsRecordReplacement"
                                                                 Label="Delete and replace the existing Cloudflare DNS record"
                                                                 Helper="Required when Cloudflare already has a DNS record for this hostname. LMS will remove that record and create a proxied CNAME for the selected tunnel." />
                                            }

                                            @if (PreviewRequiresDangerousExposureConfirmation)
                                            {
                                                <UiCheckboxField @bind-Value="editor.ConfirmDangerousExposure"
                                                                 Label="I understand the exposure warnings and want to continue"
                                                                 Helper="Required before applying dangerous or ambiguous targets." />
                                            }
                                        }
                                    }
                                </EditForm>
                            </section>

                            @if (!string.IsNullOrWhiteSpace(statusMessage) && activeCloudflareTab == ApplicationsTabValue)
                            {
                                <p class="callout @(statusIsError ? "error" : "success")">@statusMessage</p>
                            }

                            <div class="cloudflare-panel-stack">
                                <section class="surface-card cloudflare-collapsible-card">
                                    <button type="button"
                                            class="cloudflare-panel-toggle @(previewPanelExpanded ? "expanded" : string.Empty)"
                                            @onclick="TogglePreviewPanel">
                                        <div class="cloudflare-panel-heading">
                                            <h3>Preview / status</h3>
                                            <p class="meta-text">@PreviewPanelSummary</p>
                                        </div>
                                        <span class="cloudflare-panel-badge">@PreviewPanelBadge</span>
                                    </button>

                                    @if (previewPanelExpanded)
                                    {
                                        <div class="cloudflare-panel-body">
                                            @if (applyResult is not null)
                                            {
                                                <div class="cloudflare-result-block">
                                                    <p><strong>Public URL:</strong> <a href="@applyResult.PublicUrl" target="_blank" rel="noreferrer">@applyResult.PublicUrl</a></p>
                                                    <p><strong>Status:</strong> @applyResult.Status</p>
                                                    @if (!string.IsNullOrWhiteSpace(applyResult.NextStep))
                                                    {
                                                        <p class="meta-text">@applyResult.NextStep</p>
                                                    }

                                                    @if (ShouldShowConnectorRecoveryDetails)
                                                    {
                                                        <div class="surface-subcard cloudflare-connector-runbook">
                                                            <strong>Connector steps</strong>
                                                            <span class="meta-text">Review these only if the local connector still needs attention.</span>
                                                            @if (applyResult.ConnectorDeployment is not null)
                                                            {
                                                                <div class="surface-subcard cloudflare-connector-result">
                                                                    <strong>@(applyResult.ConnectorDeployment.Succeeded ? "Connector deployment succeeded" : "Connector deployment failed")</strong>
                                                                    <span class="meta-text">@applyResult.ConnectorDeployment.Summary</span>
                                                                    @if (applyResult.ConnectorDeployment.ExitCode.HasValue)
                                                                    {
                                                                        <span class="meta-text">Exit code: @applyResult.ConnectorDeployment.ExitCode.Value</span>
                                                                    }
                                                                    @if (!string.IsNullOrWhiteSpace(applyResult.ConnectorDeployment.StandardOutput))
                                                                    {
                                                                        <div>
                                                                            <p class="meta-text">Output</p>
                                                                            <pre class="block-code">@applyResult.ConnectorDeployment.StandardOutput</pre>
                                                                        </div>
                                                                    }
                                                                    @if (!string.IsNullOrWhiteSpace(applyResult.ConnectorDeployment.StandardError))
                                                                    {
                                                                        <div>
                                                                            <p class="meta-text">Errors</p>
                                                                            <pre class="block-code">@applyResult.ConnectorDeployment.StandardError</pre>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            }
                                                            @if (!string.IsNullOrWhiteSpace(applyResult.ConnectorInstallCommand))
                                                            {
                                                                <div>
                                                                    <p class="meta-text">Install or reattach the local connector:</p>
                                                                    <code class="block-code">@applyResult.ConnectorInstallCommand</code>
                                                                </div>
                                                            }
                                                            else if (!HostHasInstalledConnector)
                                                            {
                                                                <p class="callout warning">Linux Made Sane could not fetch the tunnel token automatically. Open this tunnel in the Cloudflare dashboard, choose the host operating system, and copy the <code>cloudflared service install ...</code> command from there.</p>
                                                            }

                                                            @if (!string.IsNullOrWhiteSpace(applyResult.ConnectorStatusCommand))
                                                            {
                                                                <div>
                                                                    <p class="meta-text">Check the local connector service:</p>
                                                                    <code class="block-code">@applyResult.ConnectorStatusCommand</code>
                                                                </div>
                                                            }
                                                            @if (!string.IsNullOrWhiteSpace(applyResult.ConnectorLogsCommand))
                                                            {
                                                                <div>
                                                                    <p class="meta-text">Inspect local connector logs:</p>
                                                                    <code class="block-code">@applyResult.ConnectorLogsCommand</code>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            else if (previewPlan is not null)
                                            {
                                                <div class="cloudflare-result-block">
                                                    <p><strong>Public URL:</strong> @previewPlan.PublicUrl</p>
                                                    <p><strong>Tunnel:</strong> @previewPlan.TunnelName</p>
                                                    <div class="cloudflare-plan-list">
                                                        @foreach (var step in previewPlan.Steps)
                                                        {
                                                            <div class="cloudflare-plan-row">
                                                                <strong>@step.Action</strong>
                                                                <span>@step.Summary</span>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <p class="meta-text">Use dry-run preview before applying Cloudflare changes.</p>
                                            }
                                        </div>
                                    }
                                </section>
                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(statusMessage) && activeCloudflareTab == ApplicationsTabValue)
                        {
                            <p class="callout @(statusIsError ? "error" : "success")">@statusMessage</p>
                        }
                        </div>
                    </TabPage>
                </ChildContent>
            </TabControl>
        </section>

    </div>

    <UiModal IsOpen="@isLocalServicePickerOpen"
             Title="HTTP/S service lookup"
             Subtitle="Cached internal services from localhost, LAN, and optional Tailscale peers."
             Class="cloudflare-local-service-modal"
             OnClose="CloseLocalServicePickerAsync">
        <ChildContent>
            <div class="cloudflare-local-service-picker">
                <div class="table-header cloudflare-local-service-picker-header">
                    <div>
                        <strong>Available origins</strong>
                        <p class="meta-text">Cached results are shown first. Run a scan to refresh localhost, private LAN and optional Tailscale services.</p>
                    </div>
                    <div class="cloudflare-local-service-actions">
                        <UiCheckboxField @bind-Value="includeLanLocalServiceScan" Label="LAN" Compact="true" />
                        <UiCheckboxField @bind-Value="includeTailnetLocalServiceScan" Label="Tailscale" Compact="true" />
                        <UiCommandButton Label="@(isDiscoveringLocalServices ? "Scanning..." : "Scan")"
                                         Glyph="UiIconGlyph.Search"
                                         Variant="UiButtonVariant.Primary"
                                         Disabled="@isDiscoveringLocalServices"
                                         OnClick="DiscoverLocalServicesAsync" />
                    </div>
                </div>

                @if (isDiscoveringLocalServices)
                {
                    <section class="surface-subcard cloudflare-local-service-scanning" role="status" aria-live="polite">
                        <span class="cloudflare-loading-progress">
                            <span class="cloudflare-loading-progress-fill"></span>
                        </span>
                        <span>@BuildLocalServiceScanSummary()</span>
                    </section>
                }

                @if (localServiceSuggestions.Count == 0)
                {
                    <section class="empty-state cloudflare-local-service-empty">
                        <h3>No HTTP/S services found</h3>
                        <p>@(localServiceDiscoveryMessage ?? "No cached services yet. Click Scan to search localhost and the private LAN.")</p>
                    </section>
                }
                else
                {
                    <div class="cloudflare-local-service-list" role="list">
                        @foreach (var service in localServiceSuggestions)
                        {
                            <HttpServiceLookupRow Service="service" OnUse="SelectLocalServiceAsync" />
                        }
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(localServiceDiscoveryMessage) && localServiceSuggestions.Count > 0)
                {
                    <p class="meta-text cloudflare-local-service-message">@localServiceDiscoveryMessage</p>
                }
            </div>
        </ChildContent>
        <Footer>
            <UiCommandButton Label="Close"
                             Glyph="UiIconGlyph.Clear"
                             Variant="UiButtonVariant.Ghost"
                             OnClick="CloseLocalServicePickerAsync" />
        </Footer>
    </UiModal>
}

@code {
