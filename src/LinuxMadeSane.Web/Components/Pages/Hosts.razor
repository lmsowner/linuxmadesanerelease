    private async Task CopyPublicKeySetupTextAsync(string text, string successMessage)
    {
        var copied = await JSRuntime.InvokeAsync<bool>("lmsClipboard.writeText", text);
        publicKeySetupStatus = copied
            ? successMessage
            : "Clipboard copy was blocked by the browser. Select the text manually.";
