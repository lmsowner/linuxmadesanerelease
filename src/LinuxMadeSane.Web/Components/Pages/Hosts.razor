    private async Task OpenPublicKeySetupAsync(ManagedHost host)
    {
        publicKeySetupHost = host;
        publicKeySetupEditor = null;
        publicKeySetupKeyPair = null;
        publicKeySetupCommandOutput = string.Empty;
        publicKeySetupStatus = "Loading host details...";
        publicKeySetupTone = "info";
        keepStoredPasswordFallback = true;
        isPublicKeySetupOpen = true;
        isPublicKeySetupBusy = true;

        try
        {
            publicKeySetupEditor = await HostService.GetEditorAsync(host.Id);
            if (publicKeySetupEditor is null)
            {
                throw new InvalidOperationException("Host not found.");
            }

            keepStoredPasswordFallback = publicKeySetupEditor.HasStoredPassword;
            await GeneratePublicKeySetupKeyCoreAsync();
            publicKeySetupStatus = HasStoredConnectionMaterial(host)
                ? "Ready. Click Install, test, and save to set up key authentication automatically."
                : "Save SSH credentials for this host first. LMS needs the current login once so it can install the public key.";
            publicKeySetupTone = HasStoredConnectionMaterial(host) ? "success" : "warning";
        }
        catch (Exception exception)
        {
            publicKeySetupStatus = exception.Message;
            publicKeySetupTone = "error";
        }
        finally
        {
            isPublicKeySetupBusy = false;
        }
    }

