    private async Task InstallAndSavePublicKeyAsync()
    {
        if (publicKeySetupHost is null || publicKeySetupEditor is null || publicKeySetupKeyPair is null)
        {
            publicKeySetupStatus = "Generate a key before saving.";
            publicKeySetupTone = "warning";
            return;
        }

        if (!HasStoredConnectionMaterial(publicKeySetupHost))
        {
            publicKeySetupStatus = "Save SSH credentials for this host first, then run public-key setup.";
            publicKeySetupTone = "warning";
            return;
        }

        isPublicKeySetupBusy = true;
        publicKeySetupStatus = "Installing the public key on the remote host...";
        publicKeySetupTone = "info";
        publicKeySetupCommandOutput = string.Empty;
        await InvokeAsync(StateHasChanged);

        try
        {
            var installResult = await CommandExecutionService.ExecuteAsync(
                publicKeySetupHost,
                PublicKeySetupInstallCommand);
            publicKeySetupCommandOutput = BuildCommandOutput(installResult);

            if (!installResult.IsSuccess)
            {
                publicKeySetupStatus = $"Public key install failed with exit code {installResult.ExitCode}.";
                publicKeySetupTone = "error";
                return;
            }

            publicKeySetupStatus = "Public key installed. Testing key authentication...";
            publicKeySetupTone = "info";
            await InvokeAsync(StateHasChanged);

            var editor = publicKeySetupEditor;
            editor.PrivateKey = publicKeySetupKeyPair.PrivateKey;
            editor.PrivateKeyPassphrase = string.Empty;
            editor.ClearStoredPrivateKey = false;
            editor.ClearStoredPrivateKeyPassphrase = editor.HasStoredPrivateKeyPassphrase;
            editor.PrimaryAuthenticationType = AuthenticationType.PrivateKey;
            editor.FallbackAuthenticationType =
                keepStoredPasswordFallback && editor.HasStoredPassword
                    ? AuthenticationType.Password
                    : null;
            editor.Password = string.Empty;
            editor.ClearStoredPassword = !keepStoredPasswordFallback && editor.HasStoredPassword;

            var testResult = await HostService.TestConnectionAsync(editor);
            if (testResult.Status != ConnectionTestStatus.Succeeded)
            {
                publicKeySetupStatus = BuildConnectionTestMessage(
                    testResult,
                    "Public key SSH did not connect after installation. Keep the existing host credentials and check authorized_keys on the remote account.");
                publicKeySetupTone = "error";
                return;
            }

            await HostService.SaveHostAsync(editor);
            await RefreshHostAfterPublicKeySetupAsync(editor.Id ?? publicKeySetupHost.Id, testResult);

            publicKeySetupStatus = "Public key auth is installed, tested, and saved.";
            publicKeySetupTone = "success";
        }
        catch (Exception exception)
        {
            publicKeySetupStatus = exception.Message;
            publicKeySetupTone = "error";
        }
        finally
        {
            isPublicKeySetupBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshHostAfterPublicKeySetupAsync(Guid hostId, HostConnectionTestResult testResult)
    {
        var updatedHosts = await HostService.ListHostsAsync();
        var updatedHost = updatedHosts.SingleOrDefault(host => host.Id == hostId);
        if (updatedHost is null)
        {
            return;
        }

        publicKeySetupHost = updatedHost;
        hostRows = hostRows
            .Select(row => row.Host.Id == hostId
                ? new HostRowState
                {
                    Host = ApplyConnectionResult(updatedHost, testResult),
                    ConnectionTest = testResult,
                    IsStatusLoading = false,
                    LmsUpdate = row.LmsUpdate
                }
                : row)
            .ToArray();
    }

    private string? BuildPublicKeyComment()
    {
        var username = publicKeySetupEditor?.Username.Trim();
        var hostname = publicKeySetupHost?.Hostname.Trim() ?? publicKeySetupEditor?.Hostname.Trim();

        if (!string.IsNullOrWhiteSpace(username) && !string.IsNullOrWhiteSpace(hostname))
        {
            return $"linux-made-sane:{username}@{hostname}";
        }

        if (!string.IsNullOrWhiteSpace(hostname))
        {
            return $"linux-made-sane:{hostname}";
        }

        return string.IsNullOrWhiteSpace(username)
            ? "linux-made-sane"
            : $"linux-made-sane:{username}";
    }

    private static bool HasStoredConnectionMaterial(ManagedHost host) =>
        !string.IsNullOrWhiteSpace(host.PasswordSecretReference) ||
        !string.IsNullOrWhiteSpace(host.PrivateKeySecretReference);

    private static string BuildCommandOutput(CommandExecutionResult result)
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(result.StandardOutput))
        {
            parts.Add(result.StandardOutput.Trim());
        }

        if (!string.IsNullOrWhiteSpace(result.StandardError))
        {
            parts.Add(result.StandardError.Trim());
        }

        return parts.Count == 0
            ? $"Command exited with code {result.ExitCode}."
            : string.Join(Environment.NewLine + Environment.NewLine, parts);
    }

    private static string BuildConnectionTestMessage(HostConnectionTestResult result, string fallback)
    {
        var summary = string.IsNullOrWhiteSpace(result.Summary) ? fallback : result.Summary.Trim();
        var message = string.IsNullOrWhiteSpace(result.Detail)
            ? summary
            : $"{summary} {result.Detail.Trim()}";

        return string.Equals(message, fallback, StringComparison.Ordinal)
            ? message
            : $"{message} {fallback}";
    }

    private ConnectionTestStatus ResolveConnectionStatus(HostRowState row)
    {
        if (HasActiveTerminalSession(row.Host.Id))
        {
            return ConnectionTestStatus.Succeeded;
        }

        return row.ConnectionTest?.Status ?? ConnectionTestStatus.NotRun;
    }

    private static string FormatLastSeen(HostRowState row)
    {
        var lastSeenUtc = ResolveLastSeenUtc(row);
        if (lastSeenUtc is null)
        {
            return "Never";
        }

        var elapsed = DateTimeOffset.UtcNow - lastSeenUtc.Value;
        if (elapsed < TimeSpan.Zero)
        {
            elapsed = TimeSpan.Zero;
        }

        if (elapsed < TimeSpan.FromMinutes(1))
        {
            return "Just now";
        }

        var days = (int)elapsed.TotalDays;
        var hours = elapsed.Hours;
        var minutes = elapsed.Minutes;

        if (days > 0)
        {
            return $"{days} {Pluralize(days, "day")} {hours} {Pluralize(hours, "hour")}";
        }

        if (hours > 0)
        {
            return $"{hours} {Pluralize(hours, "hour")} {minutes} mins";
        }

        return $"{minutes} mins";
    }

    private static string Pluralize(int value, string singular) =>
        value == 1 ? singular : $"{singular}s";

    private static DateTimeOffset? ResolveLastSeenUtc(HostRowState row)
    {
        if (row.ConnectionTest?.Status == ConnectionTestStatus.Succeeded)
        {
            return row.ConnectionTest.CheckedAtUtc;
        }

        return row.Host.LastSeenUtc;
    }

    private bool ShouldShowStatusSummary(HostRowState row) =>
        ResolveConnectionStatus(row) != ConnectionTestStatus.Succeeded;

    private static HostConnectionTestResult BuildTimedOutConnectionResult() =>
        new(
            ConnectionTestStatus.TimedOut,
            "Timed out establishing the SSH session.",
            $"Linux Made Sane did not get a live SSH result within {StatusCheckTimeout.TotalSeconds:0} seconds.",
            DateTimeOffset.UtcNow);

    private static HostConnectionTestResult BuildLiveSessionConnectionResult() =>
        new(
            ConnectionTestStatus.Succeeded,
            "Live SSH terminal session open.",
            "This host already has an active terminal session in Linux Made Sane.",
            DateTimeOffset.UtcNow);

    private static HostConnectionTestResult BuildCachedConnectionResult(ManagedHost host) =>
        host.LastConnectionTestStatus switch
        {
            ConnectionTestStatus.Succeeded => new HostConnectionTestResult(
                ConnectionTestStatus.Succeeded,
                "Last known check succeeded.",
                "Showing the previous successful SSH connection result until the live refresh completes.",
                host.LastSeenUtc ?? DateTimeOffset.UtcNow),
            ConnectionTestStatus.Failed => new HostConnectionTestResult(
                ConnectionTestStatus.Failed,
                "Last known check failed.",
                "Showing the previous failed SSH connection result until the live refresh completes.",
                host.LastSeenUtc ?? DateTimeOffset.UtcNow),
            ConnectionTestStatus.TimedOut => new HostConnectionTestResult(
                ConnectionTestStatus.TimedOut,
                "Last known check timed out.",
                "Showing the previous timed-out SSH connection result until the live refresh completes.",
                host.LastSeenUtc ?? DateTimeOffset.UtcNow),
            ConnectionTestStatus.InvalidConfiguration => new HostConnectionTestResult(
                ConnectionTestStatus.InvalidConfiguration,
                "Last known configuration issue.",
                "Showing the previous configuration issue until the live refresh completes.",
                host.LastSeenUtc ?? DateTimeOffset.UtcNow),
            _ => new HostConnectionTestResult(
                ConnectionTestStatus.NotRun,
                "No live check recorded yet.",
                "Linux Made Sane has not recorded a completed SSH connection result for this host yet.",
                host.LastSeenUtc ?? DateTimeOffset.UtcNow)
        };

    private static ManagedHost ApplyConnectionResult(
        ManagedHost host,
        HostConnectionTestResult connection)
    {
        var lastSeenUtc = connection.Status == ConnectionTestStatus.Succeeded
            ? connection.CheckedAtUtc
            : host.LastSeenUtc;

        return host with
        {
            LastSeenUtc = lastSeenUtc,
            LastConnectionTestStatus = connection.Status
        };
    }

    private bool HasActiveTerminalSession(Guid hostId) =>
        TerminalWorkspaceRegistry.HasActiveSession(hostId);

    private static async Task ObserveLateConnectionResultAsync(Task<HostConnectionTestResult> connectionTask)
    {
        try
        {
            await connectionTask;
        }
        catch
        {
        }
    }

    private sealed class HostRowState
    {
        public required ManagedHost Host { get; init; }
        public HostConnectionTestResult? ConnectionTest { get; set; }
        public bool IsStatusLoading { get; set; }
        public LmsHostUpdateAvailability? LmsUpdate { get; init; }
    }

    private sealed record HostStatusProbeResult(
        Guid HostId,
        HostConnectionTestResult Connection);

    private enum LmsHostUpdateOperationState
    {
        Started,
        Applying,
        Completed,
        Failed
    }

    private sealed record LmsHostUpdateOperation(
        LmsHostUpdateOperationState State,
        string Message,
        DateTimeOffset StartedAtUtc,
        DateTimeOffset? CompletedAtUtc = null);
}
