@page "/hosts"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IAsyncDisposable
@using LinuxMadeSane.Application.Interfaces
@using LinuxMadeSane.Core.Abstractions
@using LinuxMadeSane.Core.Enums
@using LinuxMadeSane.Core.Models
@using LinuxMadeSane.Core.Versioning
@inject IManagedHostService HostService
@inject ICommandExecutionService CommandExecutionService
@inject ISshKeyPairGenerator SshKeyPairGenerator
@inject IServiceScopeFactory ServiceScopeFactory
@inject TerminalWorkspaceRegistry TerminalWorkspaceRegistry
@inject LmsHostUpdateAvailabilityService LmsUpdateAvailabilityService
@inject RemoteLmsSshTunnelService RemoteLmsSshTunnelService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<PageTitle>Hosts | Linux Made Sane</PageTitle>

<div class="page-shell">
    <UiHeroPanel Title="Hosts"
                 Compact="true">
        <Actions>
            <UiCommandButton Label="Add host" Glyph="UiIconGlyph.Plus" Href="/hosts/new" />
        </Actions>
    </UiHeroPanel>

    <div class="summary-pill-row">
        <UiPill Tone="UiPillTone.Neutral">@($"{ActiveHostRows.Count} configured")</UiPill>
        <UiPill Tone="@(ActiveOnlineHostCount > 0 ? UiPillTone.Success : UiPillTone.Warning)">
            @(ActiveOnlineHostCount > 0 ? $"{ActiveOnlineHostCount} online" : "No online hosts")
        </UiPill>
        <UiPill Tone="@(ActiveCheckingHostCount > 0 ? UiPillTone.Warning : UiPillTone.Neutral)">
            @(ActiveCheckingHostCount > 0 ? $"{ActiveCheckingHostCount} checking" : "No hosts checking")
        </UiPill>
        <UiPill Tone="@(ActiveOfflineHostCount > 0 ? UiPillTone.Failure : UiPillTone.Neutral)">
            @(ActiveOfflineHostCount > 0 ? $"{ActiveOfflineHostCount} offline" : "No offline hosts")
        </UiPill>
    </div>

    @if (!string.IsNullOrWhiteSpace(lmsConnectStatus))
    {
        <p class="@($"callout {lmsConnectTone}")">@lmsConnectStatus</p>
    }

    <TabControl ActiveValue="@activeHostTab"
                ActiveValueChanged="HandleHostTabChangedAsync"
                Class="page-tab-control hosts-tab-control"
                PanelClass="page-tab-panel hosts-tab-panel">
            <TabPage Value="@LmsHostsTabValue" Title="@($"LMS Hosts ({LmsHostRows.Count})")">
                <table class="hosts-table hosts-table-lms">
                    <colgroup>
                        <col class="hosts-col-name" />
                        <col class="hosts-col-environment" />
                        <col class="hosts-col-status" />
                        <col class="hosts-col-auth" />
                        <col class="hosts-col-version" />
                        <col class="hosts-col-last-seen" />
                        <col class="hosts-col-actions" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th><span class="hosts-column-heading">Name</span></th>
                            <th><span class="hosts-column-heading">Environment</span></th>
                            <th><span class="hosts-column-heading">Status</span></th>
                            <th><span class="hosts-column-heading">Auth</span></th>
                            <th><span class="hosts-column-heading">Version</span></th>
                            <th><span class="hosts-column-heading">Last seen</span></th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (LmsHostRows.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="hosts-loading-cell">
                                    <span class="meta-text">No LMS hosts registered yet.</span>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var row in LmsHostRows)
                            {
                                <tr>
                                    <td>
                                        <div class="stack-tight hosts-name-stack">
                                            <div class="inventory-host-title">
                                                <strong class="hosts-name-text">@GetHostDisplayName(row.Host)</strong>
                                                <ManagedHostKindIndicator Host="@row.Host" Class="hosts-lms-indicator" ShowLabel="false" />
                                                @if (HasPublicKeyAuthenticationEnabled(row.Host))
                                                {
                                                    <span class="hosts-key-indicator" title="Public key authentication enabled" aria-label="Public key authentication enabled">
                                                        <UiGlyphIcon Glyph="UiIconGlyph.Key" />
                                                    </span>
                                                }
                                            </div>
                                            <span class="meta-text hosts-row-meta">@row.Host.Hostname:@row.Host.Port</span>
                                        </div>
                                    </td>
                                    <td><span class="hosts-row-value">@FormatEnvironment(row.Host.Environment)</span></td>
                                    <td class="hosts-status-cell">
                                        <div class="stack-tight hosts-status-stack">
                                            <UiPill Tone="@GetStatusTone(row)" Class="hosts-status-pill">@GetStatusLabel(row)</UiPill>
                                            @if (ShouldShowStatusSummary(row))
                                            {
                                                <span class="meta-text hosts-row-meta">@GetStatusSummary(row)</span>
                                            }
                                        </div>
                                    </td>
                                    <td><span class="hosts-row-value">@FormatAuthentication(row.Host.PrimaryAuthenticationType)</span></td>
                                    <td class="hosts-version-cell">
                                        <div class="stack-tight hosts-version-stack">
                                            <UiPill Tone="@GetLmsUpdateTone(row)" Class="hosts-version-pill">@GetLmsVersionLabel(row)</UiPill>
                                            <span class="meta-text hosts-row-meta" title="@GetLmsVersionTooltip(row)">@GetLmsVersionDetailWithOperation(row)</span>
                                        </div>
                                    </td>
                                    <td><span class="hosts-row-value hosts-last-seen-value">@FormatLastSeen(row)</span></td>
                                    <td class="actions-cell">
                                        <div class="row-action-cluster">
                                            @if (ShouldShowLmsConnectAction(row))
                                            {
                                                @if (CanOpenLmsDirectly(row))
                                                {
                                                    <UiCommandButton Label="Connect"
                                                                     Glyph="UiIconGlyph.Connect"
                                                                     Title="Open the directly reachable LMS web UI on port 5080."
                                                                     Variant="UiButtonVariant.Action"
                                                                     Href="@BuildDirectLmsRootUrl(row.Host)"
                                                                     Target="_blank"
                                                                     Rel="noreferrer" />
                                                }
                                                else
                                                {
                                                    <UiCommandButton Label="Connect"
                                                                     Glyph="UiIconGlyph.Connect"
                                                                     Title="@GetLmsTunnelConnectTitle(row.Host)"
                                                                     Variant="UiButtonVariant.Action"
                                                                     Disabled="@(!CanConnectRemoteLmsHostThroughSsh(row.Host) || IsLmsConnectBusyFor(row.Host))"
                                                                     OnClick="@(() => ConnectToRemoteLmsAsync(row.Host))" />
                                                }
                                            }
                                            @if (ShouldShowLmsUpdateAction(row))
                                            {
                                                <UiCommandButton Label="Update"
                                                                 Glyph="UiIconGlyph.Download"
                                                                 Variant="UiButtonVariant.Action"
                                                                 Disabled="@IsLmsUpdateActiveFor(row.Host)"
                                                                 OnClick="@(() => StartLmsHostUpdateAsync(row.Host))" />
                                            }
                                            @if (ShouldShowLmsUninstallAction(row))
                                            {
                                                <UiCommandButton Label="Uninstall"
                                                                 Glyph="UiIconGlyph.Delete"
                                                                 Href="@BuildLmsUninstallHref(row.Host)"
                                                                 Variant="UiButtonVariant.Action" />
                                            }
                                            @if (ShouldShowPublicKeySetupAction(row.Host))
                                            {
                                                <UiCommandButton Label="Setup key"
                                                                 Title="Set up public key SSH"
                                                                 Glyph="UiIconGlyph.Key"
                                                                 Variant="UiButtonVariant.Action"
                                                                 Disabled="@IsPublicKeySetupBusyFor(row.Host)"
                                                                 OnClick="@(() => OpenPublicKeySetupAsync(row.Host))" />
                                            }
                                            <UiCommandButton Label="Details" Glyph="UiIconGlyph.Info" Href="@($"/hosts/{row.Host.Id}")" Variant="UiButtonVariant.Action" />
                                            <UiCommandButton Label="Terminal"
                                                             Glyph="UiIconGlyph.Run"
                                                             Href="@($"/hosts/{row.Host.Id}/terminal")"
                                                             Variant="UiButtonVariant.Action"
                                                             SuperscriptText="@GetTerminalSessionBadge(row.Host.Id)" />
                                            <UiCommandButton Label="Files" Glyph="UiIconGlyph.FolderOpen" Href="@($"/hosts/{row.Host.Id}/files")" Variant="UiButtonVariant.Action" />
                                            <UiCommandButton Label="Edit" Glyph="UiIconGlyph.Edit" Href="@($"/hosts/{row.Host.Id}/edit")" Variant="UiButtonVariant.Action" />
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </TabPage>

            <TabPage Value="@SshHostsTabValue" Title="@($"SSH Hosts ({SshHostRows.Count})")">
                <table class="hosts-table hosts-table-ssh">
                    <colgroup>
                        <col class="hosts-col-name" />
                        <col class="hosts-col-environment" />
                        <col class="hosts-col-status" />
                        <col class="hosts-col-auth" />
                        <col class="hosts-col-last-seen" />
                        <col class="hosts-col-actions" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th><span class="hosts-column-heading">Name</span></th>
                            <th><span class="hosts-column-heading">Environment</span></th>
                            <th><span class="hosts-column-heading">Status</span></th>
                            <th><span class="hosts-column-heading">Auth</span></th>
                            <th><span class="hosts-column-heading">Last seen</span></th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (SshHostRows.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="hosts-loading-cell">
                                    <span class="meta-text">No SSH-only hosts registered yet.</span>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var row in SshHostRows)
                            {
                                <tr>
                                    <td>
                                        <div class="stack-tight hosts-name-stack">
                                            <div class="inventory-host-title">
                                                <strong class="hosts-name-text">@GetHostDisplayName(row.Host)</strong>
                                                @if (HasPublicKeyAuthenticationEnabled(row.Host))
                                                {
                                                    <span class="hosts-key-indicator" title="Public key authentication enabled" aria-label="Public key authentication enabled">
                                                        <UiGlyphIcon Glyph="UiIconGlyph.Key" />
                                                    </span>
                                                }
                                            </div>
                                            <span class="meta-text hosts-row-meta">@row.Host.Hostname:@row.Host.Port</span>
                                        </div>
                                    </td>
                                    <td><span class="hosts-row-value">@FormatEnvironment(row.Host.Environment)</span></td>
                                    <td class="hosts-status-cell">
                                        <div class="stack-tight hosts-status-stack">
                                            <UiPill Tone="@GetStatusTone(row)" Class="hosts-status-pill">@GetStatusLabel(row)</UiPill>
                                            @if (ShouldShowStatusSummary(row))
                                            {
                                                <span class="meta-text hosts-row-meta">@GetStatusSummary(row)</span>
                                            }
                                        </div>
                                    </td>
                                    <td><span class="hosts-row-value">@FormatAuthentication(row.Host.PrimaryAuthenticationType)</span></td>
                                    <td><span class="hosts-row-value hosts-last-seen-value">@FormatLastSeen(row)</span></td>
                                    <td class="actions-cell">
                                        <div class="row-action-cluster">
                                            @if (ShouldShowPublicKeySetupAction(row.Host))
                                            {
                                                <UiCommandButton Label="Setup key"
                                                                 Title="Set up public key SSH"
                                                                 Glyph="UiIconGlyph.Key"
                                                                 Variant="UiButtonVariant.Action"
                                                                 Disabled="@IsPublicKeySetupBusyFor(row.Host)"
                                                                 OnClick="@(() => OpenPublicKeySetupAsync(row.Host))" />
                                            }
                                            <UiCommandButton Label="Details" Glyph="UiIconGlyph.Info" Href="@($"/hosts/{row.Host.Id}")" Variant="UiButtonVariant.Action" />
                                            <UiCommandButton Label="Terminal"
                                                             Glyph="UiIconGlyph.Run"
                                                             Href="@($"/hosts/{row.Host.Id}/terminal")"
                                                             Variant="UiButtonVariant.Action"
                                                             SuperscriptText="@GetTerminalSessionBadge(row.Host.Id)" />
                                            <UiCommandButton Label="Files" Glyph="UiIconGlyph.FolderOpen" Href="@($"/hosts/{row.Host.Id}/files")" Variant="UiButtonVariant.Action" />
                                            <UiCommandButton Label="Install LMS" Glyph="UiIconGlyph.Download" Href="@($"/hosts/{row.Host.Id}?install=lms")" Variant="UiButtonVariant.Action" />
                                            <UiCommandButton Label="Edit" Glyph="UiIconGlyph.Edit" Href="@($"/hosts/{row.Host.Id}/edit")" Variant="UiButtonVariant.Action" />
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </TabPage>
    </TabControl>
</div>

<UiModal IsOpen="@isPublicKeySetupOpen"
         Title="Set up public key SSH"
         Subtitle="@PublicKeySetupSubtitle"
         Class="hosts-public-key-modal"
         CloseOnBackdrop="@(!isPublicKeySetupBusy)"
         OnClose="ClosePublicKeySetupAsync">
    <ChildContent>
        @if (publicKeySetupHost is null || publicKeySetupEditor is null || publicKeySetupKeyPair is null)
        {
            <p class="callout info hosts-public-key-status">Preparing public key setup...</p>
        }
        else
        {
            <div class="hosts-public-key-flow">
                <div class="hosts-public-key-steps">
                    <article class="surface-subcard hosts-public-key-step">
                        <strong>1. Generate</strong>
                        <span>LMS generated a key for @PublicKeySetupTargetLabel. The private key is only saved after a successful key-auth test.</span>
                    </article>
                    <article class="surface-subcard hosts-public-key-step">
                        <strong>2. Install</strong>
                        <span>LMS appends the public key to the remote account's authorized_keys file using the host's current saved SSH login.</span>
                    </article>
                    <article class="surface-subcard hosts-public-key-step">
                        <strong>3. Save</strong>
                        <span>LMS tests the new key and switches the host to Public key auth when the test passes.</span>
                    </article>
                </div>

                <label class="terminal-inline-field">
                    <span>Public key</span>
                    <textarea readonly class="ui-control-input hosts-public-key-textarea">@publicKeySetupKeyPair.PublicKey</textarea>
                </label>

                <span class="meta-text">Fingerprint: @publicKeySetupKeyPair.FingerprintSha256</span>

                <details class="hosts-public-key-command">
                    <summary>Install command</summary>
                    <pre class="command-preview-block command-display-block">@PublicKeySetupInstallCommand</pre>
                </details>

                <div class="toolbar-row hosts-public-key-actions">
                    <UiCommandButton Label="Copy public key"
                                     Glyph="UiIconGlyph.Copy"
                                     Variant="UiButtonVariant.ActionSubtle"
                                     Disabled="@isPublicKeySetupBusy"
                                     OnClick="CopyPublicKeySetupKeyAsync" />
                    <UiCommandButton Label="Copy command"
                                     Glyph="UiIconGlyph.Copy"
                                     Variant="UiButtonVariant.ActionSubtle"
                                     Disabled="@isPublicKeySetupBusy"
                                     OnClick="CopyPublicKeySetupCommandAsync" />
                    <UiCommandButton Label="Generate new key"
                                     Glyph="UiIconGlyph.Refresh"
                                     Variant="UiButtonVariant.Ghost"
                                     Disabled="@isPublicKeySetupBusy"
                                     OnClick="GeneratePublicKeySetupKeyAsync" />
                </div>

                <UiCheckboxField @bind-Value="keepStoredPasswordFallback"
                                 Label="Keep saved password as fallback"
                                 Helper="Recommended until the key has been used for a few normal connections. Disable it later if you want key-only SSH."
                                 Disabled="@(!publicKeySetupEditor.HasStoredPassword || isPublicKeySetupBusy)"
                                 Compact="true"
                                 Card="true" />

                @if (!string.IsNullOrWhiteSpace(publicKeySetupCommandOutput))
                {
                    <details class="hosts-public-key-command" open>
                        <summary>Last setup output</summary>
                        <pre class="command-preview-block command-display-block">@publicKeySetupCommandOutput</pre>
                    </details>
                }
            </div>
        }
    </ChildContent>

    <Footer>
        <div class="hosts-public-key-footer">
            @if (!string.IsNullOrWhiteSpace(publicKeySetupStatus))
            {
                <p class="callout @publicKeySetupTone hosts-public-key-status">@publicKeySetupStatus</p>
            }

            <div class="hosts-public-key-footer-actions">
                <UiCommandButton Label="Close"
                                 Glyph="UiIconGlyph.Clear"
                                 Variant="UiButtonVariant.Ghost"
                                 Disabled="@isPublicKeySetupBusy"
                                 OnClick="ClosePublicKeySetupAsync" />
                <UiCommandButton Label="@(isPublicKeySetupBusy ? "Working..." : "Install, test, and save")"
                                 Glyph="UiIconGlyph.Key"
                                 Disabled="@(!CanRunPublicKeySetup)"
                                 OnClick="InstallAndSavePublicKeyAsync" />
            </div>
        </div>
    </Footer>
</UiModal>

@code {
    private const string LmsHostsTabValue = "lms";
    private const string SshHostsTabValue = "ssh";
    private static readonly TimeSpan StatusCheckTimeout = TimeSpan.FromSeconds(8);
    private IReadOnlyList<HostRowState> hostRows = [];
    private CancellationTokenSource? statusRefreshCancellationTokenSource;
    private bool isStatusRefreshInProgress;
    private bool isLmsUpdateRefreshInProgress;
    private string activeHostTab = LmsHostsTabValue;
    private ManagedHost? publicKeySetupHost;
    private ManagedHostEditor? publicKeySetupEditor;
    private GeneratedSshKeyPair? publicKeySetupKeyPair;
    private bool isPublicKeySetupOpen;
    private bool isPublicKeySetupBusy;
    private bool keepStoredPasswordFallback = true;
    private string publicKeySetupStatus = string.Empty;
    private string publicKeySetupTone = "info";
    private string publicKeySetupCommandOutput = string.Empty;
    private Guid? lmsConnectHostId;
    private string lmsConnectStatus = string.Empty;
    private string lmsConnectTone = "info";
    private readonly Dictionary<Guid, LmsHostUpdateOperation> lmsUpdateOperations = [];

    private IReadOnlyList<HostRowState> LmsHostRows =>
        hostRows
            .Where(row => ManagedHostCapabilities.IsLmsHost(row.Host))
            .ToArray();

    private IReadOnlyList<HostRowState> SshHostRows =>
        hostRows
            .Where(row => !ManagedHostCapabilities.IsLmsHost(row.Host))
            .ToArray();

    private IReadOnlyList<HostRowState> ActiveHostRows =>
        string.Equals(activeHostTab, SshHostsTabValue, StringComparison.Ordinal)
            ? SshHostRows
            : LmsHostRows;

    private int ActiveOnlineHostCount => ActiveHostRows.Count(row => ResolveConnectionStatus(row) == ConnectionTestStatus.Succeeded);

    private int ActiveCheckingHostCount => isStatusRefreshInProgress
        ? ActiveHostRows.Count(row => !HasActiveTerminalSession(row.Host.Id))
        : 0;

    private int ActiveOfflineHostCount => ActiveHostRows.Count(row => !row.IsStatusLoading && ResolveConnectionStatus(row) != ConnectionTestStatus.Succeeded);

    protected override async Task OnInitializedAsync()
    {
        var hosts = await HostService.ListHostsAsync();
        hostRows = hosts
            .OrderBy(ManagedHostCapabilities.GetSortRank)
            .ThenBy(host => host.Name, StringComparer.OrdinalIgnoreCase)
            .Select(host =>
            {
                var hasActiveSession = TerminalWorkspaceRegistry.HasActiveSession(host.Id);

                return new HostRowState
                {
                    Host = host,
                    ConnectionTest = hasActiveSession
                        ? BuildLiveSessionConnectionResult()
                        : BuildCachedConnectionResult(host),
                    IsStatusLoading = false
                };
            })
            .ToArray();

        isStatusRefreshInProgress = hostRows.Any(row => !HasActiveTerminalSession(row.Host.Id));
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            statusRefreshCancellationTokenSource = new CancellationTokenSource();
            _ = RefreshStatusesAsync(statusRefreshCancellationTokenSource.Token);
            _ = RefreshLmsUpdateStatusesAsync(statusRefreshCancellationTokenSource.Token);
        }

        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        if (statusRefreshCancellationTokenSource is not null)
        {
            await statusRefreshCancellationTokenSource.CancelAsync();
            statusRefreshCancellationTokenSource.Dispose();
        }
    }

    private Task HandleHostTabChangedAsync(string? value)
    {
        activeHostTab = string.Equals(value, SshHostsTabValue, StringComparison.Ordinal)
            ? SshHostsTabValue
            : LmsHostsTabValue;
        return Task.CompletedTask;
    }

    private async Task RefreshStatusesAsync(CancellationToken cancellationToken)
    {
        var hostsToRefresh = hostRows
            .Where(row => !HasActiveTerminalSession(row.Host.Id))
            .Select(row => row.Host)
            .ToArray();

        if (hostsToRefresh.Length == 0)
        {
            isStatusRefreshInProgress = false;
            return;
        }

        try
        {
            var work = hostsToRefresh
                .Select(host => ProbeHostStatusAsync(host, cancellationToken))
                .ToList();

            while (work.Count > 0)
            {
                var completed = await Task.WhenAny(work);
                work.Remove(completed);
                var result = await completed;
                await ApplyHostStatusResultAsync(result);
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
        finally
        {
            isStatusRefreshInProgress = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshLmsUpdateStatusesAsync(CancellationToken cancellationToken)
    {
        var lmsHosts = hostRows
            .Where(row => ManagedHostCapabilities.IsLmsHost(row.Host))
            .Select(row => row.Host)
            .ToArray();

        if (lmsHosts.Length == 0)
        {
            return;
        }

        isLmsUpdateRefreshInProgress = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var latestVersionTask = LmsUpdateAvailabilityService.CheckLatestVersionAsync(cancellationToken);
            var localLatestVersion = LinuxMadeSaneBuildVersion.GetCurrent(typeof(Program).Assembly);
            var localLatestVersionCheck = new LmsLatestVersionCheck(localLatestVersion, string.Empty);
            var accessTasks = lmsHosts
                .Select(host => LmsUpdateAvailabilityService.CheckDirectWebAccessAsync(host, cancellationToken))
                .ToList();
            var installedVersionResults = new Dictionary<Guid, LmsHostWebAccessStatus>();

            while (accessTasks.Count > 0)
            {
                var completed = await Task.WhenAny(accessTasks);
                accessTasks.Remove(completed);
                var access = await completed;
                installedVersionResults[access.HostId] = access;

                if (latestVersionTask.IsCompletedSuccessfully)
                {
                    var effectiveLatestVersionCheck = ResolveEffectiveLatestVersion(
                        latestVersionTask.Result,
                        localLatestVersion);
                    await ApplyLmsUpdateResultAsync(LmsHostUpdateAvailabilityService.BuildAvailability(
                        access.HostId,
                        access.InstalledVersion,
                        effectiveLatestVersionCheck.Version,
                        effectiveLatestVersionCheck.Failure));
                    continue;
                }

                await ApplyLmsUpdateResultAsync(LmsHostUpdateAvailabilityService.BuildAvailability(
                    access.HostId,
                    access.InstalledVersion,
                    localLatestVersionCheck.Version,
                    localLatestVersionCheck.Failure));
            }

            var latestVersionCheck = ResolveEffectiveLatestVersion(await latestVersionTask, localLatestVersion);
            foreach (var access in installedVersionResults.Values)
            {
                await ApplyLmsUpdateResultAsync(LmsHostUpdateAvailabilityService.BuildAvailability(
                    access.HostId,
                    access.InstalledVersion,
                    latestVersionCheck.Version,
                    latestVersionCheck.Failure));
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            hostRows = hostRows
                .Select(row => new HostRowState
                {
                    Host = row.Host,
                    ConnectionTest = row.ConnectionTest,
                    IsStatusLoading = row.IsStatusLoading,
                    LmsUpdate = ManagedHostCapabilities.IsLmsHost(row.Host)
                        ? new LmsHostUpdateAvailability(
                            row.Host.Id,
                            LmsHostUpdateAvailabilityState.Unknown,
                            "Unknown",
                            "Unknown",
                            ex.Message)
                        : row.LmsUpdate
                })
                .ToArray();
        }
        finally
        {
            isLmsUpdateRefreshInProgress = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static LmsLatestVersionCheck ResolveEffectiveLatestVersion(
        LmsLatestVersionCheck publicManifestVersionCheck,
        string localLatestVersion)
    {
        if (string.IsNullOrWhiteSpace(localLatestVersion))
        {
            return publicManifestVersionCheck;
        }

        if (!publicManifestVersionCheck.HasVersion ||
            ApplicationUpdateVersionComparer.IsNewer(localLatestVersion, publicManifestVersionCheck.Version))
        {
            return new LmsLatestVersionCheck(localLatestVersion, publicManifestVersionCheck.Failure);
        }

        return publicManifestVersionCheck;
    }

    private Task ApplyHostStatusResultAsync(HostStatusProbeResult result) =>
        InvokeAsync(() =>
        {
            hostRows = hostRows
                .Select(row =>
                {
                    if (row.Host.Id != result.HostId)
                    {
                        return row;
                    }

                    if (HasActiveTerminalSession(row.Host.Id))
                    {
                        return new HostRowState
                        {
                            Host = row.Host,
                            ConnectionTest = BuildLiveSessionConnectionResult(),
                            IsStatusLoading = false,
                            LmsUpdate = row.LmsUpdate
                        };
                    }

                    return new HostRowState
                    {
                        Host = ApplyConnectionResult(row.Host, result.Connection),
                        ConnectionTest = result.Connection,
                        IsStatusLoading = false,
                        LmsUpdate = row.LmsUpdate
                    };
                })
                .ToArray();
            StateHasChanged();
        });

    private Task ApplyLmsUpdateResultAsync(LmsHostUpdateAvailability update) =>
        InvokeAsync(() =>
        {
            hostRows = hostRows
                .Select(row => row.Host.Id == update.HostId
                    ? new HostRowState
                    {
                        Host = row.Host,
                        ConnectionTest = row.ConnectionTest,
                        IsStatusLoading = row.IsStatusLoading,
                        LmsUpdate = update
                    }
                    : row)
                .ToArray();
            StateHasChanged();
        });


    private async Task<HostStatusProbeResult> ProbeHostStatusAsync(
        ManagedHost host,
        CancellationToken cancellationToken)
    {
        return await Task.Run(
            () => ProbeHostStatusCoreAsync(host, cancellationToken),
            cancellationToken);
    }

    private async Task<HostStatusProbeResult> ProbeHostStatusCoreAsync(
        ManagedHost host,
        CancellationToken cancellationToken)
    {
        try
        {
            await using var scope = ServiceScopeFactory.CreateAsyncScope();
            var hostService = scope.ServiceProvider.GetRequiredService<IManagedHostService>();
            using var probeCancellationTokenSource = CancellationTokenSource.CreateLinkedTokenSource(cancellationToken);
            probeCancellationTokenSource.CancelAfter(StatusCheckTimeout);

            var connectionTask = hostService.TestConnectionAsync(host, probeCancellationTokenSource.Token);

            try
            {
                return new HostStatusProbeResult(
                    host.Id,
                    await connectionTask.WaitAsync(StatusCheckTimeout, cancellationToken));
            }
            catch (TimeoutException)
            {
                probeCancellationTokenSource.Cancel();
                _ = ObserveLateConnectionResultAsync(connectionTask);
                return new HostStatusProbeResult(host.Id, BuildTimedOutConnectionResult());
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
            throw;
        }
        catch
        {
            return new HostStatusProbeResult(
                host.Id,
                new HostConnectionTestResult(
                    ConnectionTestStatus.Failed,
                    "Connection check failed.",
                    null,
                    DateTimeOffset.UtcNow));
        }
    }

