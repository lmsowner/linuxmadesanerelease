    private Task StartLmsHostUpdateAsync(ManagedHost host)
    {
        if (IsLmsUpdateActiveFor(host) || IsCurrentLmsEndpoint(host))
        {
            return Task.CompletedTask;
        }

        SetLmsUpdateOperation(
            host.Id,
            new LmsHostUpdateOperation(
                LmsHostUpdateOperationState.Started,
                "Update started.",
                DateTimeOffset.UtcNow));

        _ = RunLmsHostUpdateInBackgroundAsync(host.Id);
        return Task.CompletedTask;
    }

    private async Task RunLmsHostUpdateInBackgroundAsync(Guid hostId)
    {
        var progress = new Progress<ManagedHostLmsInstallProgressUpdate>(update =>
        {
            _ = ApplyLmsHostUpdateProgressAsync(hostId, update);
        });

        try
        {
            await using var scope = ServiceScopeFactory.CreateAsyncScope();
            var hostService = scope.ServiceProvider.GetRequiredService<IManagedHostService>();
            var result = await hostService.InstallLmsAsync(
                hostId,
                BuildLmsUpdateOptions(),
                progress,
                CancellationToken.None);

            await ApplyLmsHostUpdateResultAsync(hostId, result);
        }
        catch (Exception ex)
        {
            await ApplyLmsHostUpdateFailureAsync(hostId, ex.Message);
        }
    }

    private Task ApplyLmsHostUpdateProgressAsync(Guid hostId, ManagedHostLmsInstallProgressUpdate update) =>
        SafeInvokeAsync(() =>
        {
            var state = update.State switch
            {
                ManagedHostLmsInstallProgressState.Starting => LmsHostUpdateOperationState.Started,
                ManagedHostLmsInstallProgressState.Completed => LmsHostUpdateOperationState.Completed,
                ManagedHostLmsInstallProgressState.Failed => LmsHostUpdateOperationState.Failed,
                _ => LmsHostUpdateOperationState.Applying
            };

            var message = state switch
            {
                LmsHostUpdateOperationState.Started => "Update started.",
                LmsHostUpdateOperationState.Applying => "Applying update.",
                LmsHostUpdateOperationState.Completed => "Update finished.",
                LmsHostUpdateOperationState.Failed => FirstNonBlank(update.Message, "Update failed.")!,
                _ => FirstNonBlank(update.Message, "Update status changed.")!
            };

            SetLmsUpdateOperation(
                hostId,
                new LmsHostUpdateOperation(
                    state,
                    message,
                    update.OccurredAtUtc,
                    state is LmsHostUpdateOperationState.Completed or LmsHostUpdateOperationState.Failed
                        ? update.OccurredAtUtc
                        : null));
        });

    private Task ApplyLmsHostUpdateResultAsync(Guid hostId, ManagedHostLmsInstallResult result) =>
        SafeInvokeAsync(() =>
        {
            SetLmsUpdateOperation(
                hostId,
                new LmsHostUpdateOperation(
                    result.Success ? LmsHostUpdateOperationState.Completed : LmsHostUpdateOperationState.Failed,
                    result.Success ? "Update finished." : FirstNonBlank(result.Detail, result.Summary, "Update failed.")!,
                    result.StartedAtUtc,
                    result.CompletedAtUtc));
        });

    private Task ApplyLmsHostUpdateFailureAsync(Guid hostId, string message) =>
        SafeInvokeAsync(() =>
        {
            SetLmsUpdateOperation(
                hostId,
                new LmsHostUpdateOperation(
                    LmsHostUpdateOperationState.Failed,
                    FirstNonBlank(message, "Update failed.")!,
                    DateTimeOffset.UtcNow,
                    DateTimeOffset.UtcNow));
        });

    private static ManagedHostLmsInstallOptions BuildLmsUpdateOptions() =>
        new()
        {
            StartService = true,
            ConfigureLocalSshRunner = true,
            EnableLocalSudo = true,
            UpdateExistingInstall = true,
            MarkAsLmsHostOnSuccess = true
        };

    private async Task SafeInvokeAsync(Action action)
    {
        try
        {
            await InvokeAsync(() =>
            {
                action();
                StateHasChanged();
            });
        }
        catch (ObjectDisposedException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }

