<span class="@ResolvedClass">
    @ChildContent
</span>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }

    private string ResolvedClass => string.IsNullOrWhiteSpace(Class)
        ? "ui-label-text"
        : $"ui-label-text {Class}";
}
