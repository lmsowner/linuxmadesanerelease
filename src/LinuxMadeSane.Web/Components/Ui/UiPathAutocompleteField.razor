@using System.Linq.Expressions

<UiField Label="@Label"
         Helper="@Helper"
         Compact="@Compact"
         Inline="@Inline"
         Class="@Class">
    <ChildContent>
        <UiPathCombobox Value="@Value"
                        ValueChanged="@ValueChanged"
                        CommitRequested="@CommitRequested"
                        SuggestionSelected="@SuggestionSelected"
                        Suggestions="@Suggestions"
                        Placeholder="@Placeholder"
                        AriaLabel="@AriaLabel"
                        Title="@Title"
                        InputClass="@InputClass"
                        Disabled="@Disabled"
                        EscapeValue="@EscapeValue"
                        Glyph="@Glyph"
                        IsLoadingSuggestions="@IsLoadingSuggestions"
                        KeepSuggestionsOpenOnSelect="@KeepSuggestionsOpenOnSelect" />
    </ChildContent>
    <ValidationContent>
        @if (CurrentEditContext is not null && ValueExpression is not null)
        {
            <ValidationMessage For="ValueExpression" />
        }
    </ValidationContent>
</UiField>

@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Helper { get; set; }
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public Expression<Func<string?>>? ValueExpression { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? AriaLabel { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Compact { get; set; }
    [Parameter] public bool Inline { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? InputClass { get; set; }
    [Parameter] public IReadOnlyList<string> Suggestions { get; set; } = [];
    [Parameter] public string? EscapeValue { get; set; }
    [Parameter] public UiIconGlyph Glyph { get; set; } = UiIconGlyph.FolderOpen;
    [Parameter] public bool IsLoadingSuggestions { get; set; }
    [Parameter] public bool KeepSuggestionsOpenOnSelect { get; set; } = true;
    [Parameter] public EventCallback<string?> CommitRequested { get; set; }
    [Parameter] public EventCallback<string> SuggestionSelected { get; set; }

    [CascadingParameter] private EditContext? CurrentEditContext { get; set; }
}
