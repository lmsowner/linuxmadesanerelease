@using System.Linq

@if (ResolvedTagName == "div")
{
    <div class="@CssClass" title="@ResolvedTitle">
        @MetricPill
        @if (ChildContent is not null)
        {
            @ChildContent
        }
    </div>
}
else if (ResolvedTagName == "section")
{
    <section class="@CssClass" title="@ResolvedTitle">
        @MetricPill
        @if (ChildContent is not null)
        {
            @ChildContent
        }
    </section>
}
else
{
    <article class="@CssClass" title="@ResolvedTitle">
        @MetricPill
        @if (ChildContent is not null)
        {
            @ChildContent
        }
    </article>
}

@code {
    [Parameter] public string? Eyebrow { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public string? Meta { get; set; }
    [Parameter] public UiPillTone Tone { get; set; } = UiPillTone.Neutral;
    [Parameter] public string TagName { get; set; } = "article";
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string ResolvedTagName => TagName.Equals("div", StringComparison.OrdinalIgnoreCase)
        ? "div"
        : TagName.Equals("section", StringComparison.OrdinalIgnoreCase)
            ? "section"
            : "article";

    private string? ResolvedLabel => string.IsNullOrWhiteSpace(Label) ? Eyebrow : Label;

    private string CssClass => string.Join(" ", new[] { "service-metric-component", Class }
        .Where(static value => !string.IsNullOrWhiteSpace(value)));

    private string DisplayText =>
        string.IsNullOrWhiteSpace(ResolvedLabel)
            ? Value
            : $"{ResolvedLabel}: {Value}";

    private string? ResolvedTitle =>
        string.IsNullOrWhiteSpace(Meta)
            ? DisplayText
            : $"{DisplayText} | {Meta}";

    private RenderFragment MetricPill => @<UiPill Tone="@Tone" Class="service-metric-pill">@DisplayText</UiPill>;
}
