<div class="about-splash-modal"
     data-about-splash
     hidden
     aria-hidden="true"
     role="presentation">
    <section class="about-splash-panel"
             role="dialog"
             aria-modal="true"
             aria-labelledby="lms-about-title"
             aria-describedby="lms-about-summary">
        <button class="about-splash-close glass-button glass-button-toolbar"
                type="button"
                title="Close"
                aria-label="Close About"
                data-about-close>
            <UiGlyphIcon Glyph="UiIconGlyph.Clear" />
        </button>

        <div class="about-splash-content">
            <div class="about-splash-hero">
                <div class="about-splash-art">
                    <img src="/images/lms-splash.png" alt="Linux Made Sane" />
                </div>

                <div class="about-splash-copy">
                    <p class="about-splash-eyebrow">Linux Made Sane</p>
                    <h2 id="lms-about-title">Linux administration without the clutter.</h2>
                    <p id="lms-about-summary">
                        LMS is a local-first control surface for managing Linux hosts, terminals, files, shares,
                        services, identities, Desktop Assistant workflows, and AI-assisted operational work.
                    </p>

                    <div class="about-splash-highlights" aria-label="Linux Made Sane focus areas">
                        <span>Local network aware</span>
                        <span>Terminal and files</span>
                        <span>Desktop Assistant</span>
                        <span>Share mapping</span>
                    </div>

                    <div class="about-profile-links" aria-label="Linux Made Sane project links">
                        @foreach (var link in ProjectLinks)
                        {
                            <a class="about-profile-link"
                               href="@link.Url"
                               target="_blank"
                               rel="noopener noreferrer"
                               title="@link.Title"
                               aria-label="@link.Title">
                                <span class="about-profile-link-icon" aria-hidden="true">
                                    @if (!string.IsNullOrWhiteSpace(link.BrandIconPath))
                                    {
                                        <img src="@link.BrandIconPath" alt="" />
                                    }
                                    else if (link.Glyph is { } glyph)
                                    {
                                        <UiGlyphIcon Glyph="@glyph" />
                                    }
                                </span>
                                <span>@link.Label</span>
                            </a>
                        }
                    </div>
                </div>
            </div>

            <div class="about-splash-section about-notice-section" aria-label="Linux Made Sane copyright, license, and acknowledgements">
                <div class="about-splash-section-title">
                    <span>Copyright, License, and Acknowledgements</span>
                    <small>Notices to preserve with LMS distributions.</small>
                </div>

                <div class="about-notice-grid">
                    <section class="about-notice-card">
                        <strong>Copyright</strong>
                        <p>Copyright (c) Richard D. Kiernan. All rights reserved except where the LMS license grants specific rights.</p>
                    </section>
                    <section class="about-notice-card">
                        <strong>License</strong>
                        <p>Linux Made Sane Community Edition is licensed under the Business Source License 1.1 until the applicable Change Date, then Apache-2.0. Hosted, MSP, SaaS, white-label, resale, and third-party managed-service use requires a commercial license.</p>
                    </section>
                    <section class="about-notice-card">
                        <strong>Acknowledgements</strong>
                        <p>Third-party components remain under their own upstream licenses. Preserve <code>LICENSE</code>, <code>NOTICE</code>, <code>COMMERCIAL-LICENSE.md</code>, <code>THIRD-PARTY-NOTICES.md</code>, <code>TRADEMARKS.md</code>, and bundled vendor notices.</p>
                    </section>
                    <section class="about-notice-card">
                        <strong>Brand Marks</strong>
                        <p>GitHub and the Invertocat mark are trademarks of GitHub, Inc. The LinkedIn [in] logo is copyright LinkedIn Corporation. These links do not imply affiliation or endorsement.</p>
                    </section>
                </div>
            </div>

            <div class="about-splash-section">
                <div class="about-splash-section-title">
                    <span>Referenced GitHub Projects</span>
                    <small>Runtime packages and bundled client libraries used by LMS.</small>
                </div>

                <div class="about-license-grid">
                    @foreach (var project in RuntimeProjects)
                    {
                        <a class="about-license-card"
                           href="@project.Url"
                           target="_blank"
                           rel="noopener noreferrer">
                            <span class="about-license-card-top">
                                <strong>@project.Name</strong>
                                <span>@project.License</span>
                            </span>
                            <small>@project.Summary</small>
                            <em>@project.SourceLabel</em>
                        </a>
                    }
                </div>
            </div>

            <details class="about-splash-notes">
                <summary>Development and system tool notes</summary>
                <div class="about-splash-note-grid">
                    @foreach (var project in DevelopmentProjects)
                    {
                        <a href="@project.Url" target="_blank" rel="noopener noreferrer">
                            <strong>@project.Name</strong>
                            <span>@project.License</span>
                        </a>
                    }
                </div>
                <p>
                    Samba client tools and cifs-utils are invoked as optional LMS host packages for network share
                    discovery and mounting. They are not bundled with LMS; final license details should come from the
                    distro packages installed during deployment.
                </p>
                <p>
                    FFmpeg and FFprobe are invoked as optional host packages for media probing, remuxing, transcoding,
                    and preview generation. They are not bundled with LMS; final license details depend on the distro
                    package build and enabled codecs.
                </p>
                <p>
                    GtkSharp and its related binding packages are used by the Desktop Assistant helper for the Linux
                    tray icon. Native GTK runtime libraries are expected to come from the Linux distribution; final
                    license details should come from the distro packages installed on that machine.
                </p>
                <p>
                    h265web.js is listed under its project CYL_Free-1.0 usage agreement. Its bundled extension assets
                    also carry MIT and Apache-2.0 dependency notices in the shipped vendor files.
                </p>
                <p>
                    This screen is a compact attribution summary from package metadata and bundled client assets, not a
                    replacement for full release license notices.
                </p>
                <p>
                    PDF.js is bundled with viewer assets for LMS PDF preview. The core runtime is listed here under
                    Apache-2.0, while some shipped viewer assets also carry Mozilla notice headers in the bundled
                    files.
                </p>
            </details>
        </div>
    </section>
</div>

@code {
    private static readonly IReadOnlyList<ProjectLink> ProjectLinks =
    [
        new(
            "Website",
            "Open Linux Made Sane website",
            "https://www.linuxmadesane.com",
            Glyph: UiIconGlyph.Website),
        new(
            "GitHub",
            "Open Linux Made Sane Community Edition on GitHub",
            "https://github.com/lmsowner/linuxmadesanerelease",
            BrandIconPath: "/images/brand/github-invertocat-black.svg"),
        new(
            "LinkedIn",
            "Open Richard Kiernan on LinkedIn",
            "https://www.linkedin.com/in/richardkiernan/",
            BrandIconPath: "/images/brand/linkedin-in-bug.png")
    ];

    private static readonly IReadOnlyList<ProjectCredit> RuntimeProjects =
    [
        new(
            ".NET, ASP.NET Core and Blazor",
            "Application framework, server runtime, routing, static assets, and UI rendering.",
            "MIT",
            "https://github.com/dotnet/dotnet"),
        new(
            "Entity Framework Core and Microsoft.Data.Sqlite",
            "SQLite persistence, query mapping, and database access.",
            "MIT",
            "https://github.com/dotnet/dotnet"),
        new(
            "OpenAI .NET SDK",
            "OpenAI API integration behind the LMS AI provider layer.",
            "MIT",
            "https://github.com/openai/openai-dotnet"),
        new(
            "SSH.NET",
            "SSH terminal sessions, remote command execution, and SFTP access.",
            "MIT",
            "https://github.com/sshnet/SSH.NET"),
        new(
            "GtkSharp",
            "GTK binding packages used by the Desktop Assistant helper tray integration.",
            "LGPL-2.0",
            "https://github.com/GtkSharp/GtkSharp"),
        new(
            "QRCoder",
            "QR code generation for setup and identity flows.",
            "MIT",
            "https://github.com/Shane32/QRCoder"),
        new(
            "xterm.js and xterm-addon-fit",
            "Browser terminal emulator and fit addon used by LMS terminal windows.",
            "MIT",
            "https://github.com/xtermjs/xterm.js"),
        new(
            "PDF.js",
            "Bundled PDF viewer runtime used by LMS file preview for PDF rendering, paging, and navigation.",
            "Apache-2.0",
            "https://github.com/mozilla/pdf.js"),
        new(
            "UTIF.js",
            "Bundled TIFF decoder used by LMS image preview for TIFF and multipage TIFF files.",
            "MIT",
            "https://github.com/photopea/UTIF.js"),
        new(
            "hls.js",
            "Bundled browser HLS player used by the Media Library preview surface for FFmpeg-generated HLS streams.",
            "Apache-2.0",
            "https://github.com/video-dev/hls.js"),
        new(
            "mpegts.js",
            "Bundled MPEG-TS and FLV Media Source helper kept with the media preview client assets.",
            "Apache-2.0",
            "https://github.com/xqq/mpegts.js"),
        new(
            "h265web.js",
            "Bundled WebAssembly media playback client assets used for H.264 and H.265 browser playback experiments.",
            "CYL_Free-1.0",
            "https://github.com/numberwolf/h265web.js"),
        new(
            "SQLitePCLRaw",
            "Native SQLite bundle and provider layer used by the SQLite stack.",
            "Apache-2.0",
            "https://github.com/ericsink/SQLitePCL.raw"),
        new(
            "Bouncy Castle C#",
            "Cryptography dependency pulled in by SSH.NET.",
            "MIT",
            "https://github.com/bcgit/bc-csharp"),
        new(
            "Azure System.ClientModel",
            "Client pipeline dependency used by the OpenAI package.",
            "MIT",
            "https://github.com/Azure/azure-sdk-for-net")
    ];

    private static readonly IReadOnlyList<ProjectCredit> DevelopmentProjects =
    [
        new("xUnit.net", "Test framework.", "Apache-2.0", "https://github.com/xunit/xunit"),
        new("xUnit Visual Studio runner", "Test adapter.", "Apache-2.0", "https://github.com/xunit/visualstudio.xunit"),
        new("coverlet", "Code coverage collector.", "MIT", "https://github.com/coverlet-coverage/coverlet"),
        new("VSTest", "Microsoft test platform.", "MIT", "https://github.com/microsoft/vstest")
    ];

    private sealed record ProjectCredit(string Name, string Summary, string License, string Url)
    {
        public string SourceLabel => Url.StartsWith("https://github.com/", StringComparison.OrdinalIgnoreCase)
            ? $"github.com/{Url["https://github.com/".Length..]}"
            : Url;
    }

    private sealed record ProjectLink(
        string Label,
        string Title,
        string Url,
        UiIconGlyph? Glyph = null,
        string? BrandIconPath = null);
}
