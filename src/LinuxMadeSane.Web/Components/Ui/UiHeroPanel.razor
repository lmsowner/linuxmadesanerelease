@using System.Collections.Generic

<UiPanel Kind="UiPanelKind.Hero" Compact="@Compact" TagName="@TagName" Class="@Class" AdditionalAttributes="@AdditionalAttributes">
    <div>
        @if (!string.IsNullOrWhiteSpace(Eyebrow))
        {
            <p class="eyebrow">@Eyebrow</p>
        }
        <h1>@Title</h1>
        @if (!string.IsNullOrWhiteSpace(Description))
        {
            @if (Compact && CollapseDescriptionWhenCompact)
            {
                <details class="page-intro-details">
                    <summary>@DescriptionSummaryLabel</summary>
                    <p class="hero-copy">@Description</p>
                </details>
            }
            else
            {
                <p class="hero-copy">@Description</p>
            }
        }
        @if (ChildContent is not null)
        {
            @ChildContent
        }
    </div>

    @if (Actions is not null)
    {
        <div class="hero-actions">
            @Actions
        </div>
    }
</UiPanel>

@code {
    [Parameter] public string? Eyebrow { get; set; }
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public bool Compact { get; set; }
    [Parameter] public bool CollapseDescriptionWhenCompact { get; set; } = true;
    [Parameter] public string DescriptionSummaryLabel { get; set; } = "About this page";
    [Parameter] public string TagName { get; set; } = "section";
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }
}
