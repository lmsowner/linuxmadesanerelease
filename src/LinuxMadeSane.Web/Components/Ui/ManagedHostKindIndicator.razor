@using LinuxMadeSane.Core.Models

@if (ResolvedProfile is not null)
{
    <span class="managed-host-kind-indicator @(ResolvedProfile.IsLmsHost ? "managed-host-kind-indicator-lms" : "managed-host-kind-indicator-ssh") @Class"
          title="@ResolvedProfile.KindDescription">
        @if (ResolvedProfile.IsLmsHost)
        {
            <span class="managed-host-kind-mark" aria-hidden="true">
                <img class="managed-host-kind-logo" src="/images/lms-logo.png" alt="" />
            </span>
        }
        <span class="meta-text managed-host-kind-label">@ResolvedProfile.KindLabel</span>
    </span>
}

@code {
    [Parameter]
    public ManagedHost? Host { get; set; }

    [Parameter]
    public ManagedHostCapabilityProfile? Profile { get; set; }

    [Parameter]
    public string? Class { get; set; }

    private ManagedHostCapabilityProfile? ResolvedProfile => Profile ?? (Host is null ? null : ManagedHostCapabilities.Describe(Host));
}
