@typeparam TValue
@using System.Linq.Expressions

<UiField Label="@Label"
         Helper="@Helper"
         Compact="@Compact"
         Inline="@Inline"
         Class="@Class">
    <ChildContent>
        <InputNumber TValue="TValue"
                     Value="@Value"
                     ValueChanged="@ValueChanged"
                     ValueExpression="@ValueExpression"
                     class="@ResolvedInputClass"
                     placeholder="@Placeholder"
                     disabled="@Disabled"
                     @attributes="AdditionalAttributes" />
    </ChildContent>
    <ValidationContent>
        @if (CurrentEditContext is not null && ValueExpression is not null)
        {
            <ValidationMessage For="ValueExpression" />
        }
    </ValidationContent>
</UiField>

@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Helper { get; set; }
    [Parameter] public TValue Value { get; set; } = default!;
    [Parameter] public EventCallback<TValue> ValueChanged { get; set; }
    [Parameter] public Expression<Func<TValue>>? ValueExpression { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Compact { get; set; }
    [Parameter] public bool Inline { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? InputClass { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    [CascadingParameter] private EditContext? CurrentEditContext { get; set; }

    private string ResolvedInputClass => string.IsNullOrWhiteSpace(InputClass)
        ? "ui-control-input"
        : $"ui-control-input {InputClass}";
}
