<label class="@ShellClass"
       title="@Title">
    <input class="ui-switch-input"
           type="checkbox"
           checked="@Value"
           disabled="@Disabled"
           @onchange="HandleChangedAsync" />
    <span class="ui-switch-track" aria-hidden="true">
        <span class="ui-switch-thumb"></span>
    </span>
    <span class="ui-switch-label">@Label</span>
</label>

@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public string? Title { get; set; }
    [Parameter] public bool Value { get; set; }
    [Parameter] public EventCallback<bool> ValueChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Compact { get; set; }
    [Parameter] public string? Class { get; set; }

    private string ShellClass => string.Join(
        " ",
        new[]
        {
            "ui-switch-field",
            Compact ? "ui-switch-field-compact" : null,
            Disabled ? "disabled" : null,
            Class
        }.Where(static value => !string.IsNullOrWhiteSpace(value)));

    private async Task HandleChangedAsync(ChangeEventArgs args)
    {
        var value = args.Value switch
        {
            bool parsed => parsed,
            string text when bool.TryParse(text, out var parsed) => parsed,
            string text when string.Equals(text, "on", StringComparison.OrdinalIgnoreCase) => true,
            _ => false
        };

        Value = value;
        await ValueChanged.InvokeAsync(value);
    }
}
