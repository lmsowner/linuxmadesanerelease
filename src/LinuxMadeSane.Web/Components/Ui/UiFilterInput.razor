<div class="@CssClass">
    <span class="ui-filter-input-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="6.5" />
            <path d="m16 16 4 4" />
        </svg>
    </span>
    <input class="ui-filter-input-control"
           type="text"
           value="@ResolvedValue"
           placeholder="@Placeholder"
           title="@ResolvedTitle"
           aria-label="@ResolvedAriaLabel"
           autocomplete="off"
           spellcheck="false"
           disabled="@Disabled"
           @oninput="HandleInputAsync" />
    @if (!string.IsNullOrWhiteSpace(ResolvedValue))
    {
        <button class="ui-filter-input-clear"
                type="button"
                title="Clear filter"
                aria-label="Clear filter"
                disabled="@Disabled"
                @onclick="ClearAsync">
            <UiGlyphIcon Glyph="UiIconGlyph.Clear" />
        </button>
    }
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Filter";
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? AriaLabel { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }

    private string ResolvedValue => Value ?? string.Empty;
    private string ResolvedTitle => string.IsNullOrWhiteSpace(Title) ? Placeholder : Title.Trim();
    private string ResolvedAriaLabel => string.IsNullOrWhiteSpace(AriaLabel) ? ResolvedTitle : AriaLabel.Trim();
    private string CssClass => string.IsNullOrWhiteSpace(Class) ? "ui-filter-input" : $"ui-filter-input {Class}";

    private Task HandleInputAsync(ChangeEventArgs args) =>
        ValueChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);

    private Task ClearAsync() =>
        ValueChanged.InvokeAsync(string.Empty);
}
