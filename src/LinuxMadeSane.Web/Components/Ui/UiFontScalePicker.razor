@using Microsoft.AspNetCore.Components

<div class="ui-theme-font-scale-picker">
    <label class="ui-theme-tool-icon"
           for="@fontScaleSelectId"
           title="Text size"
           aria-label="Text size">
        <UiIcon Name="@UiIconName.TextSize" />
    </label>

    <div class="ui-combobox-shell ui-select-shell ui-theme-font-scale-shell">
        <select id="@fontScaleSelectId"
                class="ui-combobox-input ui-select-input ui-theme-font-scale-select"
                value="@Value"
                @onchange="HandleChangeAsync"
                title="Text size"
                aria-label="Text size">
            @foreach (var option in ThemeFontScaleOptionCatalog.Options)
            {
                <option value="@option.Percent">@option.Label</option>
            }
        </select>
        <span class="ui-combobox-indicator ui-select-indicator" aria-hidden="true">
            <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="m2.5 4.5 3.5 3 3.5-3" />
            </svg>
        </span>
    </div>
</div>

@code {
    private readonly string fontScaleSelectId = $"theme-font-scale-{Guid.NewGuid():N}";

    [Parameter] public int Value { get; set; } = 100;
    [Parameter] public EventCallback<int> ValueChanged { get; set; }

    private Task HandleChangeAsync(ChangeEventArgs args)
    {
        var value = int.TryParse(args.Value?.ToString(), out var parsedValue)
            ? parsedValue
            : 100;
        return ValueChanged.InvokeAsync(value);
    }
}
