<UiButton Variant="@Variant"
          Title="@ResolvedTitle"
          Disabled="@Disabled"
          Href="@Href"
          Target="@Target"
          Rel="@Rel"
          Type="@Type"
          Class="@CssClass"
          OnClientPointerDown="@OnClientPointerDown"
          OnClientClick="@OnClientClick"
          OnClick="@OnClick"
          Icon="@IconContent"
          AdditionalAttributes="@AccessibilityAttributes" />

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public string? Title { get; set; }
    [Parameter] public UiIconGlyph Glyph { get; set; }
    [Parameter] public UiButtonVariant Variant { get; set; } = UiButtonVariant.Ghost;
    [Parameter] public string Type { get; set; } = "button";
    [Parameter] public string? Href { get; set; }
    [Parameter] public string? Target { get; set; }
    [Parameter] public string? Rel { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? OnClientPointerDown { get; set; }
    [Parameter] public string? OnClientClick { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string ResolvedTitle => string.IsNullOrWhiteSpace(Title) ? Label : Title.Trim();
    private string CssClass => string.IsNullOrWhiteSpace(Class) ? "ui-icon-button" : $"ui-icon-button {Class}";
    private IReadOnlyDictionary<string, object> AccessibilityAttributes => BuildAccessibilityAttributes();

    private RenderFragment IconContent => @<UiGlyphIcon Glyph="@Glyph" />;

    private IReadOnlyDictionary<string, object> BuildAccessibilityAttributes()
    {
        var attributes = AdditionalAttributes is null
            ? new Dictionary<string, object>(StringComparer.OrdinalIgnoreCase)
            : new Dictionary<string, object>(AdditionalAttributes, StringComparer.OrdinalIgnoreCase);

        attributes["aria-label"] = ResolvedTitle;
        return attributes;
    }
}
