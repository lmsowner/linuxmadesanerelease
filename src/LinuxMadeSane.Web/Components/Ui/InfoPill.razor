@using System.Linq

@if (ResolvedTagName == "div")
{
    <div class="@CssClass" title="@ResolvedTitle">
        @PillContent
    </div>
}
else if (ResolvedTagName == "section")
{
    <section class="@CssClass" title="@ResolvedTitle">
        @PillContent
    </section>
}
else
{
    <article class="@CssClass" title="@ResolvedTitle">
        @PillContent
    </article>
}

@code {
    [Parameter] public string? Eyebrow { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Text { get; set; }
    [Parameter] public string? Meta { get; set; }
    [Parameter] public string TagName { get; set; } = "article";
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string ResolvedTagName => TagName.Equals("div", StringComparison.OrdinalIgnoreCase)
        ? "div"
        : TagName.Equals("section", StringComparison.OrdinalIgnoreCase)
            ? "section"
            : "article";

    private string CssClass => string.Join(" ", new[] { "info-pill", Class }
        .Where(static value => !string.IsNullOrWhiteSpace(value)));

    private string? ResolvedTitle => !string.IsNullOrWhiteSpace(Title)
        ? Title
        : !string.IsNullOrWhiteSpace(Text)
            ? Text
            : null;

    private RenderFragment PillContent => builder =>
    {
        var sequence = 0;

        if (!string.IsNullOrWhiteSpace(Eyebrow))
        {
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "info-pill-eyebrow");
            builder.AddContent(sequence++, Eyebrow);
            builder.CloseElement();
        }

        if (!string.IsNullOrWhiteSpace(Title))
        {
            builder.OpenElement(sequence++, "strong");
            builder.AddAttribute(sequence++, "class", "info-pill-title");
            builder.AddContent(sequence++, Title);
            builder.CloseElement();
        }

        if (!string.IsNullOrWhiteSpace(Text))
        {
            builder.OpenElement(sequence++, "p");
            builder.AddAttribute(sequence++, "class", "info-pill-text");
            builder.AddContent(sequence++, Text);
            builder.CloseElement();
        }

        if (!string.IsNullOrWhiteSpace(Meta))
        {
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "info-pill-meta");
            builder.AddContent(sequence++, Meta);
            builder.CloseElement();
        }

        if (ChildContent is not null)
        {
            builder.AddContent(sequence++, ChildContent);
        }
    };
}
