@using Microsoft.AspNetCore.Components

<div class="ui-theme-palette-picker">
    <label class="ui-theme-tool-icon"
           for="@paletteSelectId"
           title="Palette"
           aria-label="Palette">
        <UiIcon Name="@UiIconName.Palette" />
    </label>

    <div class="ui-combobox-shell ui-select-shell ui-theme-palette-shell">
        <select id="@paletteSelectId"
                class="ui-combobox-input ui-select-input ui-theme-palette-select"
                value="@Value"
                @onchange="HandleChangeAsync"
                title="Palette"
                aria-label="Palette">
            @foreach (var option in ThemePaletteOptionCatalog.Options)
            {
                <option value="@option.Id">@option.Name</option>
            }
        </select>
        <span class="ui-combobox-indicator ui-select-indicator" aria-hidden="true">
            <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="m2.5 4.5 3.5 3 3.5-3" />
            </svg>
        </span>
    </div>
</div>

@code {
    private readonly string paletteSelectId = $"theme-palette-{Guid.NewGuid():N}";

    [Parameter] public string Value { get; set; } = "smooth-grey";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    private Task HandleChangeAsync(ChangeEventArgs args) =>
        ValueChanged.InvokeAsync(args.Value?.ToString() ?? "smooth-grey");
}
