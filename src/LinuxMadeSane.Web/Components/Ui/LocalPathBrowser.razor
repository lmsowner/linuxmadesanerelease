@using LinuxMadeSane.Core.Models.Ai

<HostFileBrowserWorkspace HostId="@AiLocalMachine.ManagedHostId"
                          RootPath="@RootPath"
                          InitialPath="@InitialPath"
                          Title="@Title"
                          AllowPopout="@AllowPopout" />

@code {
    [Parameter, EditorRequired] public string RootPath { get; set; } = string.Empty;
    [Parameter] public string? InitialPath { get; set; }
    [Parameter] public string Title { get; set; } = "Mounted files";
    [Parameter] public bool AllowPopout { get; set; } = true;
}
