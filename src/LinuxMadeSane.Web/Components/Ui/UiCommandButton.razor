<UiButton Variant="@Variant"
          Size="@Size"
          Title="@ResolvedTitle"
          Disabled="@Disabled"
          Href="@Href"
          Target="@Target"
          Rel="@Rel"
          SuperscriptText="@SuperscriptText"
          Type="@Type"
          Class="@CssClass"
          OnClientPointerDown="@OnClientPointerDown"
          OnClientClick="@OnClientClick"
          OnClick="@OnClick"
          Icon="@(HideIcon ? null : IconContent)"
          AdditionalAttributes="@AdditionalAttributes">
    @Label
</UiButton>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public string? Title { get; set; }
    [Parameter] public UiIconGlyph Glyph { get; set; }
    [Parameter] public UiButtonVariant Variant { get; set; } = UiButtonVariant.Ghost;
    [Parameter] public UiButtonSize Size { get; set; } = UiButtonSize.Small;
    [Parameter] public string Type { get; set; } = "button";
    [Parameter] public string? Href { get; set; }
    [Parameter] public string? Target { get; set; }
    [Parameter] public string? Rel { get; set; }
    [Parameter] public string? SuperscriptText { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public bool HideIcon { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? OnClientPointerDown { get; set; }
    [Parameter] public string? OnClientClick { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string ResolvedTitle => string.IsNullOrWhiteSpace(Title) ? Label : Title.Trim();
    private string CssClass => string.IsNullOrWhiteSpace(Class) ? "ui-command-button" : $"ui-command-button {Class}";
    private RenderFragment IconContent => @<UiGlyphIcon Glyph="@Glyph" />;
}
