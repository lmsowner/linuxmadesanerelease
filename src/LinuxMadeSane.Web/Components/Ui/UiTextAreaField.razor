@using System.Linq.Expressions

<UiField Label="@Label"
         Helper="@Helper"
         Compact="@Compact"
         Inline="@Inline"
         Class="@Class">
    <ChildContent>
        <InputTextArea Value="@Value"
                       ValueChanged="@ValueChanged"
                       ValueExpression="@ValueExpression"
                       class="@ResolvedInputClass"
                       placeholder="@Placeholder"
                       disabled="@Disabled"
                       rows="@Rows"
                       @attributes="SanitizedAdditionalAttributes" />
    </ChildContent>
    <ValidationContent>
        @if (CurrentEditContext is not null && ValueExpression is not null)
        {
            <ValidationMessage For="ValueExpression" />
        }
    </ValidationContent>
</UiField>

@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Helper { get; set; }
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public Expression<Func<string?>>? ValueExpression { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public int Rows { get; set; } = 4;
    [Parameter] public bool Compact { get; set; }
    [Parameter] public bool Inline { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? InputClass { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private IReadOnlyDictionary<string, object>? SanitizedAdditionalAttributes => UiAdditionalAttributes.Sanitize(AdditionalAttributes);
    [CascadingParameter] private EditContext? CurrentEditContext { get; set; }

    private string ResolvedInputClass => string.IsNullOrWhiteSpace(InputClass)
        ? "ui-control-input ui-control-textarea"
        : $"ui-control-input ui-control-textarea {InputClass}";
}
