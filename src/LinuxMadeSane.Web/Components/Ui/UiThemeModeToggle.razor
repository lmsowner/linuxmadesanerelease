@using Microsoft.AspNetCore.Components

<label class="ui-theme-mode-toggle"
       title="Light/Dark Mode"
       aria-label="Light or dark mode">
    <input class="ui-theme-mode-input"
           type="checkbox"
           checked="@Value"
           @onchange="HandleChangeAsync" />
    <span class="ui-theme-mode-track" aria-hidden="true">
        <span class="ui-theme-mode-thumb">
            <UiIcon Name="@UiIconName.Contrast" />
        </span>
    </span>
</label>

@code {
    [Parameter] public bool Value { get; set; }
    [Parameter] public EventCallback<bool> ValueChanged { get; set; }

    private Task HandleChangeAsync(ChangeEventArgs args)
    {
        var value = args.Value is bool boolValue
            ? boolValue
            : string.Equals(args.Value?.ToString(), "true", StringComparison.OrdinalIgnoreCase);
        return ValueChanged.InvokeAsync(value);
    }
}
