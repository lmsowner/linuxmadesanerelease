        dashboard?.FfmpegStatus.FfprobeAvailable == false;

    private static UiPillTone GetHealthTone(MediaLibraryHealthState state) => state switch
    {
        MediaLibraryHealthState.Ready => UiPillTone.Success,
        MediaLibraryHealthState.Disabled or MediaLibraryHealthState.NotConfigured => UiPillTone.Warning,
        _ => UiPillTone.Failure
    };

    private static UiPillTone GetScanTone(MediaScanStatus status) => status switch
    {
        MediaScanStatus.Completed => UiPillTone.Success,
        MediaScanStatus.Queued or MediaScanStatus.Running or MediaScanStatus.NotScanned => UiPillTone.Warning,
        _ => UiPillTone.Failure
    };

    private static UiPillTone GetCompatibilityTone(MediaItem item) =>
        item.IsBrowserCompatible == true ? UiPillTone.Success :
        item.IsVlcCompatible == true ? UiPillTone.Neutral :
        UiPillTone.Warning;

    private static string GetCompatibilityLabel(MediaItem item)
    {
        if (item.IsBrowserCompatible == true)
        {
            return "Browser";
        }

        if (item.RequiresRemux == true)
        {
            return "VLC / remux";
        }

        return item.IsVlcCompatible == true ? "VLC" : "Unknown";
    }

    private static string GetRootCategoryLabel(MediaLibraryRoot root) =>
        root.Category == MediaLibraryCategory.Custom && !string.IsNullOrWhiteSpace(root.CustomCategoryName)
            ? root.CustomCategoryName
            : root.Category.ToString();

    private static string FormatBytes(long bytes)
    {
        string[] units = ["B", "KB", "MB", "GB", "TB"];
        var value = (double)Math.Max(0, bytes);
        var unit = 0;
        while (value >= 1024 && unit < units.Length - 1)
        {
            value /= 1024;
            unit++;
        }

        return $"{value:0.#} {units[unit]}";
    }

    private static string FormatLog(OperationLogEntry log)
    {
        var parts = new List<string> { $"[{log.Timestamp.ToLocalTime():u}] {log.Level}: {log.Message}" };
        if (!string.IsNullOrWhiteSpace(log.CommandText))
        {
            parts.Add($"$ {log.CommandText}");
        }

        if (!string.IsNullOrWhiteSpace(log.StandardOutput))
        {
            parts.Add(log.StandardOutput.Trim());
        }

        if (!string.IsNullOrWhiteSpace(log.StandardError))
        {
            parts.Add(log.StandardError.Trim());
        }

        return string.Join(Environment.NewLine, parts);
    }

    private sealed class MediaLibrarySettingsEditorAdapter(MediaLibrarySettingsEditor editor)
    {
        public bool IsEnabled { get; set; } = editor.IsEnabled;
        public MediaStreamingMode StreamingMode { get; set; } = editor.StreamingMode;
        public bool EnableDirectStreaming { get; set; } = editor.StreamingMode != MediaStreamingMode.PlaylistOnly;
        public string FfmpegPath { get; set; } = editor.FfmpegPath;
        public string FfprobePath { get; set; } = editor.FfprobePath;
        public bool EnableMetadataProbing { get; set; } = editor.EnableMetadataProbing;
        public bool EnableRemux { get; set; } = editor.EnableRemux || editor.StreamingMode is MediaStreamingMode.RemuxWhenNeeded or MediaStreamingMode.TranscodeFallback;
        public bool EnableTranscoding { get; set; } = editor.EnableTranscoding || editor.StreamingMode == MediaStreamingMode.TranscodeFallback;
        public string MaxConcurrentFfmpegJobsText { get; set; } = editor.MaxConcurrentFfmpegJobs.ToString();
        public string TempCacheFolder { get; set; } = editor.TempCacheFolder;
        public string CacheExpiryMinutesText { get; set; } = editor.CacheExpiryMinutes.ToString();
        public string MaxCacheSizeBytesText { get; set; } = editor.MaxCacheSizeBytes.ToString();
        public MediaHardwareAcceleration HardwareAcceleration { get; set; } = editor.HardwareAcceleration;
        public bool RequireLoginForPlaylists { get; set; } = editor.RequireLoginForPlaylists;
        public bool RequireLoginForStreams { get; set; } = editor.RequireLoginForStreams;
        public bool AllowLanAnonymousAccess { get; set; } = editor.AllowLanAnonymousAccess;
        public bool GenerateTemporarySignedStreamUrls { get; set; } = editor.GenerateTemporarySignedStreamUrls;
        public string SignedUrlExpiryMinutesText { get; set; } = editor.SignedUrlExpiryMinutes.ToString();
        public string IpAllowlistCsv { get; set; } = editor.IpAllowlistCsv;
        public bool ShowUnsupportedFiles { get; set; } = editor.ShowUnsupportedFiles;
        public bool AllowUnknownBrowserPlayback { get; set; } = editor.AllowUnknownBrowserPlayback;

        public MediaLibrarySettingsEditor ToEditor() =>
            new()
            {
                IsEnabled = IsEnabled,
                StreamingMode = ResolveStreamingMode(),
                FfmpegPath = FfmpegPath,
                FfprobePath = FfprobePath,
                EnableMetadataProbing = EnableMetadataProbing,
                EnableRemux = EnableRemux,
                EnableTranscoding = EnableTranscoding,
                MaxConcurrentFfmpegJobs = int.TryParse(MaxConcurrentFfmpegJobsText, out var maxJobs) ? maxJobs : 1,
                TempCacheFolder = TempCacheFolder,
                CacheExpiryMinutes = int.TryParse(CacheExpiryMinutesText, out var cacheExpiry) ? cacheExpiry : 240,
                MaxCacheSizeBytes = long.TryParse(MaxCacheSizeBytesText, out var cacheSize) ? cacheSize : 10L * 1024L * 1024L * 1024L,
                HardwareAcceleration = HardwareAcceleration,
                RequireLoginForPlaylists = RequireLoginForPlaylists,
                RequireLoginForStreams = RequireLoginForStreams,
                AllowLanAnonymousAccess = AllowLanAnonymousAccess,
                GenerateTemporarySignedStreamUrls = GenerateTemporarySignedStreamUrls,
                SignedUrlExpiryMinutes = int.TryParse(SignedUrlExpiryMinutesText, out var expiry) ? expiry : 120,
                IpAllowlistCsv = IpAllowlistCsv,
                ShowUnsupportedFiles = ShowUnsupportedFiles,
                AllowUnknownBrowserPlayback = AllowUnknownBrowserPlayback
            };

        private MediaStreamingMode ResolveStreamingMode()
        {
            if (EnableTranscoding)
            {
                return MediaStreamingMode.TranscodeFallback;
            }

            if (EnableRemux)
            {
                return MediaStreamingMode.RemuxWhenNeeded;
            }

            return EnableDirectStreaming
                ? MediaStreamingMode.DirectStream
                : MediaStreamingMode.PlaylistOnly;
        }
    }
