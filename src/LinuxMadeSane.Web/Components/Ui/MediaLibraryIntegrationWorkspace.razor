    private string BuildPlaylistUrl(string scope, string path, bool download = false)
    {
        var absolute = BuildMediaExternalUrl(path, preferHttpForExternalPlayer: !download);
        var parts = new List<string>();
        if (dashboard?.Settings.GenerateTemporarySignedStreamUrls == true)
        {
            var token = SignedUrls.CreatePlaylistToken(scope, TimeSpan.FromMinutes(dashboard.Settings.SignedUrlExpiryMinutes));
            parts.Add($"token={Uri.EscapeDataString(token)}");
        }

        if (download)
        {
            parts.Add("download=1");
        }

        return parts.Count == 0 ? absolute : $"{absolute}?{string.Join("&", parts)}";
    }

    private static string BuildRootPlaylistPath(MediaLibraryRoot root) =>
        $"/api/integrations/media-library/playlists/root/{root.Id:N}/{BuildPlaylistFileSlug(root.Name)}.m3u8";

    private static string BuildPlaylistFileSlug(string value)
    {
        var normalized = value.Trim().ToLowerInvariant();
        var builder = new StringBuilder();
        var lastWasDash = false;

        foreach (var character in normalized)
        {
            if (char.IsLetterOrDigit(character))
            {
                builder.Append(character);
                lastWasDash = false;
                continue;
            }

            if (lastWasDash)
            {
                continue;
            }

            builder.Append('-');
            lastWasDash = true;
        }

        var slug = builder.ToString().Trim('-');
        return string.IsNullOrWhiteSpace(slug)
            ? "media-folder"
            : slug;
    }

    private string BuildStreamUrl(Guid itemId)
    {
        var absolute = BuildMediaExternalUrl(
            $"/api/integrations/media-library/items/{itemId:N}/stream",
            preferHttpForExternalPlayer: true);
        if (dashboard?.Settings.GenerateTemporarySignedStreamUrls != true)
        {
            return absolute;
        }

        var token = SignedUrls.CreateStreamToken(itemId, TimeSpan.FromMinutes(dashboard.Settings.SignedUrlExpiryMinutes));
        return $"{absolute}?token={Uri.EscapeDataString(token)}";
    }

    private string BuildMediaExternalUrl(string path, bool preferHttpForExternalPlayer)
    {
        var current = Navigation.ToAbsoluteUri(path);
        var httpUrl = TryBuildDevelopmentHttpMediaUrl(path, current.Host);
        if (!preferHttpForExternalPlayer ||
            !ShouldUseDevelopmentHttpMediaUrl(current) ||
            string.IsNullOrWhiteSpace(httpUrl))
        {
            return current.ToString();
        }

        return httpUrl;
    }

    private bool ShouldUseDevelopmentHttpMediaUrl(Uri current) =>
        HostEnvironment.IsDevelopment() &&
        string.Equals(current.Scheme, Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase);

    private string? TryBuildDevelopmentHttpMediaUrl(string path, string currentHost)
    {
        foreach (var configuredUrl in EnumerateConfiguredServerUrls())
        {
            if (!Uri.TryCreate(configuredUrl, UriKind.Absolute, out var uri) ||
                !string.Equals(uri.Scheme, Uri.UriSchemeHttp, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            var builder = new UriBuilder(uri)
            {
                Host = IsLoopbackOrWildcardHost(uri.Host) ? currentHost : uri.Host,
                Path = path.StartsWith("/", StringComparison.Ordinal) ? path : $"/{path}",
                Query = string.Empty
            };

            return builder.Uri.ToString();
        }

        return null;
    }

    private IEnumerable<string> EnumerateConfiguredServerUrls()
    {
        foreach (var key in new[] { "URLS", "ASPNETCORE_URLS", "DOTNET_URLS" })
        {
            var value = Configuration[key];
            if (string.IsNullOrWhiteSpace(value))
            {
                continue;
            }

            foreach (var part in value.Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
            {
                yield return part;
            }
        }

        foreach (var child in Configuration.GetSection("Server:Urls").GetChildren())
        {
            if (!string.IsNullOrWhiteSpace(child.Value))
            {
                yield return child.Value;
            }
        }
    }

    private static bool IsLoopbackOrWildcardHost(string host) =>
        host.Equals("localhost", StringComparison.OrdinalIgnoreCase) ||
        host.Equals("127.0.0.1", StringComparison.OrdinalIgnoreCase) ||
        host.Equals("::1", StringComparison.OrdinalIgnoreCase) ||
        host.Equals("0.0.0.0", StringComparison.OrdinalIgnoreCase) ||
        host.Equals("::", StringComparison.OrdinalIgnoreCase) ||
        host.Equals("*", StringComparison.Ordinal);

