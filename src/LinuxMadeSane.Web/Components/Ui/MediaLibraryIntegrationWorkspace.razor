    private async Task RunOperationAsync(string successMessage, Func<Task> operation)
    {
        isBusy = true;
        statusMessage = string.Empty;
        statusIsError = false;

        try
        {
            await operation();
            statusMessage = successMessage;
            statusIsError = false;
        }
        catch (Exception exception)
        {
            statusMessage = exception.Message;
            statusIsError = true;
        }
        finally
        {
            isBusy = false;
        }
    }

    private void PrimeRootPathSuggestions()
    {
        rootPathSuggestionRequestVersion++;
        rootPathSuggestions = BuildCachedRootPathSuggestions(rootEditor.Path);
        isRootPathSuggestionsLoading = false;
    }

    private void QueueRootPathSuggestionsRefresh()
    {
        if (!showRootEditor)
        {
            rootPathSuggestions = [];
            isRootPathSuggestionsLoading = false;
            return;
        }

        var requestVersion = ++rootPathSuggestionRequestVersion;
        var query = rootEditor.Path;
        rootPathSuggestions = BuildCachedRootPathSuggestions(query);
        if (string.IsNullOrWhiteSpace(query))
        {
            isRootPathSuggestionsLoading = false;
            _ = InvokeAsync(StateHasChanged);
            return;
        }

        isRootPathSuggestionsLoading = true;
        _ = InvokeAsync(StateHasChanged);
        _ = RefreshRootPathSuggestionsAsync(requestVersion, query);
    }

    private async Task RefreshRootPathSuggestionsAsync(int requestVersion, string? query)
    {
        try
        {
            var suggestions = await BuildRootPathSuggestionsAsync(query);
            if (requestVersion != rootPathSuggestionRequestVersion)
            {
                return;
            }

            rootPathSuggestions = suggestions;
        }
        finally
        {
            if (requestVersion == rootPathSuggestionRequestVersion)
            {
                isRootPathSuggestionsLoading = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task<IReadOnlyList<string>> BuildRootPathSuggestionsAsync(string? query)
    {
        var normalizedQuery = NormalizeRootPathSuggestionQuery(query);
        var suggestions = BuildRootPathSuggestionSeed(query);

        foreach (var path in ScheduledTaskPathSuggestions.BuildInspectionPaths(normalizedQuery, null))
        {
            var directorySuggestions = await GetRootDirectorySuggestionsAsync(path);
            foreach (var suggestion in directorySuggestions)
            {
                suggestions.Add(ScheduledTaskPathSuggestions.NormalizeSuggestedPath(suggestion));
            }
        }

        return ScheduledTaskPathSuggestions.FilterAndOrderSuggestions(suggestions, normalizedQuery, query);
    }

    private IReadOnlyList<string> BuildCachedRootPathSuggestions(string? query)
    {
        var normalizedQuery = NormalizeRootPathSuggestionQuery(query);
        var suggestions = BuildRootPathSuggestionSeed(query);

        foreach (var path in ScheduledTaskPathSuggestions.BuildInspectionPaths(normalizedQuery, null))
        {
            foreach (var suggestion in GetCachedRootDirectorySuggestions(path))
            {
                suggestions.Add(ScheduledTaskPathSuggestions.NormalizeSuggestedPath(suggestion));
            }
        }

        return ScheduledTaskPathSuggestions.FilterAndOrderSuggestions(suggestions, normalizedQuery, query);
    }

    private SortedSet<string> BuildRootPathSuggestionSeed(string? query)
    {
        var suggestions = new SortedSet<string>(
            ScheduledTaskPathSuggestions.BuildBaseSuggestions(query, null),
            StringComparer.OrdinalIgnoreCase);
        suggestions.Add("/mnt/media");
        suggestions.Add("/media");

        if (dashboard is not null)
        {
            foreach (var root in dashboard.Roots)
            {
                suggestions.Add(ScheduledTaskPathSuggestions.NormalizeSuggestedPath(root.Path));
                suggestions.Add(ScheduledTaskPathSuggestions.GetParentDirectory(root.Path));
            }
        }

        return suggestions;
    }

    private async Task<IReadOnlyList<string>> GetRootDirectorySuggestionsAsync(string path)
    {
        var normalizedPath = ScheduledTaskPathSuggestions.NormalizeSuggestedPath(path);
        if (rootDirectorySuggestionCache.TryGetValue(normalizedPath, out var cached))
        {
            return cached;
        }

        try
        {
            cached = (await LocalFileBrowsingService.ListItemsAsync("/", normalizedPath))
                .Where(item => item.ItemType == SftpItemType.Folder)
                .Select(item => ScheduledTaskPathSuggestions.NormalizeSuggestedPath(item.FullPath))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToArray();
        }
        catch
        {
            cached = [];
        }

        rootDirectorySuggestionCache[normalizedPath] = cached;
        return cached;
    }

    private IReadOnlyList<string> GetCachedRootDirectorySuggestions(string path)
    {
        var normalizedPath = ScheduledTaskPathSuggestions.NormalizeSuggestedPath(path);
        return rootDirectorySuggestionCache.TryGetValue(normalizedPath, out var cached)
            ? cached
            : [];
    }

    private static string NormalizeRootPathSuggestionQuery(string? query)
    {
        var trimmedQuery = query?.Trim() ?? string.Empty;
        return string.IsNullOrWhiteSpace(trimmedQuery)
            ? string.Empty
            : ScheduledTaskPathSuggestions.NormalizeSuggestedPath(trimmedQuery);
    }

