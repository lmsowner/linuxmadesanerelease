    private Task ToggleSourceIpAsync(string value)
    {
        var normalized = CaddyBindAddressFormatter.NormalizeMany(value)[0];
        var selected = GetSelectedSourceIps().ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (CaddyBindAddressFormatter.IsAnyAddressList(normalized))
        {
            editor.SourceIp = selected.Contains(normalized)
                ? "127.0.0.1"
                : normalized;
            return Task.CompletedTask;
        }

        selected.RemoveWhere(CaddyBindAddressFormatter.IsAnyAddressList);
        if (!selected.Add(normalized))
        {
            selected.Remove(normalized);
        }

        editor.SourceIp = selected.Count == 0
            ? "127.0.0.1"
            : string.Join(", ", OrderSourceIps(selected));
        return Task.CompletedTask;
    }

    private IReadOnlyList<string> GetSelectedSourceIps()
    {
        try
