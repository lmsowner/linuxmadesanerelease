    private async Task LoadSelectedConfigContentAsync()
    {
        var option = SelectedConfigFile;
        if (option is null)
        {
            selectedConfigContent = "No Caddy config file is selected.";
            selectedConfigStatus = "Unavailable";
            return;
        }

        isConfigLoading = true;

        try
        {
            if (!System.IO.File.Exists(option.Path))
            {
                selectedConfigContent = $"# {option.Path} does not exist yet.";
                selectedConfigStatus = "Missing";
                return;
            }

            var content = await System.IO.File.ReadAllTextAsync(option.Path);
            selectedConfigContent = string.IsNullOrWhiteSpace(content)
                ? $"# {option.Path} is empty."
                : content;
            selectedConfigStatus = "Read only";
        }
        catch (Exception exception) when (exception is UnauthorizedAccessException or System.IO.IOException)
        {
            selectedConfigContent = $"# Unable to read {option.Path}\n# {exception.Message}";
            selectedConfigStatus = "Unreadable";
        }
        finally
        {
            isConfigLoading = false;
        }
    }

