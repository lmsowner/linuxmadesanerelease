    private string BuildEditorSnippet()
    {
        if (editor.Kind == CaddyProxyRouteKind.PortForward)
        {
            var sourceIp = CaddyBindAddressFormatter.NormalizeCsv(editor.SourceIp);
            var sourcePort = Math.Clamp(editor.SourcePort, 1, 65535);
            var destinationIp = string.IsNullOrWhiteSpace(editor.DestinationIp) ? "127.0.0.1" : editor.DestinationIp.Trim();
            var destinationPort = Math.Clamp(editor.DestinationPort, 1, 65535);
            var scheme = editor.DestinationScheme == CaddyProxyTargetScheme.Https ? "https" : "http";
            var target = $"{scheme}://{FormatHostForUri(destinationIp)}:{destinationPort}";
            var portBuilder = new StringBuilder();
            portBuilder.AppendLine($"http://:{sourcePort} {{");
            if (!CaddyBindAddressFormatter.IsAnyAddressList(sourceIp))
            {
                portBuilder.AppendLine($"    bind {CaddyBindAddressFormatter.ToCaddyBindArguments(sourceIp)}");
            }

            portBuilder.AppendLine("    encode zstd gzip");
            if (editor.DestinationScheme == CaddyProxyTargetScheme.Https)
            {
                portBuilder.AppendLine($"    reverse_proxy {target} {{");
                portBuilder.AppendLine("        transport http {");
                portBuilder.AppendLine("            tls_insecure_skip_verify");
                portBuilder.AppendLine("        }");
                portBuilder.AppendLine("    }");
            }
            else
            {
                portBuilder.AppendLine($"    reverse_proxy {target}");
            }

            portBuilder.Append('}');
            return portBuilder.ToString();
        }

        var hostname = string.IsNullOrWhiteSpace(editor.Hostname)
            ? "app.example.com"
            : editor.Hostname.Trim().TrimEnd('/');
        var upstream = string.IsNullOrWhiteSpace(editor.UpstreamUrl)
            ? "http://127.0.0.1:3000"
            : editor.UpstreamUrl.Trim();
        var address = editor.EnableTls ? hostname : $"http://{hostname}";

        var builder = new StringBuilder();
        builder.AppendLine($"{address} {{");
        builder.AppendLine("    encode zstd gzip");
        builder.AppendLine($"    reverse_proxy {upstream}");
        builder.Append('}');
        return builder.ToString();
    }

    private IReadOnlyList<string> BuildEditorWarnings()
    {
        if (editor.Kind != CaddyProxyRouteKind.PortForward)
        {
            return [];
        }

        var warnings = new List<string>();
        var edgeGatewayPort = ResolveEdgeGatewayCaddyPort();
        if (editor.SourcePort == edgeGatewayPort)
        {
            warnings.Add($"Source port {editor.SourcePort} is used by Edge Gateway.");
        }

        if (editor.SourcePort is 80 or 443)
        {
            warnings.Add("This uses a standard web port; check hostname routes before applying.");
        }

        if (CaddyBindAddressFormatter.IsAnyAddressList(editor.SourceIp))
        {
            warnings.Add("0.0.0.0 listens on every interface. Use a Tailnet or LAN IP when possible.");
        }

        return warnings;
    }

    private int ResolveEdgeGatewayCaddyPort()
    {
        var value = EdgeGatewayOptions.CaddyLocalServiceUrl;
        if (Uri.TryCreate(value, UriKind.Absolute, out var uri))
        {
            if (!uri.IsDefaultPort)
            {
                return Math.Clamp(uri.Port, 1, 65535);
            }

            return uri.Scheme.Equals(Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase) ? 443 : 80;
        }

        return 8443;
    }

