    private IReadOnlyList<CaddySourceBindOption> GetSourceBindOptions()
    {
        var options = sourceBindOptions.ToList();
        var seen = options.Select(option => option.Value).ToHashSet(StringComparer.OrdinalIgnoreCase);
        foreach (var selected in GetSelectedSourceIps())
        {
            if (seen.Add(selected))
            {
                options.Add(new CaddySourceBindOption(selected, selected, "Saved value", selected));
            }
        }

        return options;
    }

    private IEnumerable<string> OrderSourceIps(IEnumerable<string> values)
    {
        var order = sourceBindOptions
            .Select((option, index) => new { option.Value, Index = index })
            .ToDictionary(item => item.Value, item => item.Index, StringComparer.OrdinalIgnoreCase);

        return values
            .OrderBy(value => order.TryGetValue(value, out var index) ? index : int.MaxValue)
            .ThenBy(static value => value, StringComparer.OrdinalIgnoreCase);
    }

