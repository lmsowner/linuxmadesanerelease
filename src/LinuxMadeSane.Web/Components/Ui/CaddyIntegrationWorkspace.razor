@using System.Net
@using System.Net.NetworkInformation
@using System.Net.Sockets
@using System.Text
@using LinuxMadeSane.Application.Contracts.Caddy
@using LinuxMadeSane.Application.Contracts.EdgeGateway
@using LinuxMadeSane.Application.Interfaces
@using LinuxMadeSane.Core.Enums
@using LinuxMadeSane.Core.Models.Ai
@using LinuxMadeSane.Core.Models.Caddy
@using LinuxMadeSane.Core.Models.RdpOptimizer
@inject ICaddyIntegrationService CaddyIntegrationService
@inject EdgeGatewayOptions EdgeGatewayOptions

@if (!IsLocalHost)
{
    <section class="surface-card caddy-unsupported-card">
        <div class="table-header">
            <div>
                <p class="eyebrow">Caddy</p>
                <h3>Local LMS host only</h3>
                <p class="meta-text">Caddy management currently works on the machine running Linux Made Sane. Select <strong>Local machine</strong> to manage the local reverse proxy and generated Caddy config.</p>
            </div>
        </div>
    </section>
}
else if (!isLoaded || dashboard is null)
{
    <section class="surface-card caddy-loading-card">
        <p class="meta-text">Loading Caddy integration...</p>
    </section>
}
else
{
    <div class="caddy-workspace-shell">
        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <p class="callout @(statusIsError ? "error" : "success")">@statusMessage</p>
        }

        <section class="surface-card caddy-overview-card">
            <div class="caddy-overview-header">
                <div>
                    <p class="eyebrow">Caddy</p>
                    <h3>Reverse proxy manager</h3>
                </div>

                <div class="caddy-header-actions">
                    <UiCommandButton Label="Add route"
                                     Glyph="UiIconGlyph.Plus"
                                     Disabled="@(!dashboard.IsInstalled || IsBusy)"
                                     OnClick="OpenCreateRouteDialogAsync" />
                    <UiCommandButton Label="Add port forward"
                                     Glyph="UiIconGlyph.NetworkMount"
                                     Variant="UiButtonVariant.Ghost"
                                     Disabled="@(!dashboard.IsInstalled || IsBusy)"
                                     OnClick="OpenCreatePortForwardDialogAsync" />
                    <UiCommandButton Label="Reload config"
                                     Glyph="UiIconGlyph.Refresh"
                                     Variant="UiButtonVariant.Ghost"
                                     Disabled="@(!dashboard.IsInstalled || IsBusy)"
                                     OnClick="ReloadAsync" />
                    <UiCommandButton Label="@GetServiceActionLabel()"
                                     Glyph="UiIconGlyph.Restart"
                                     Variant="UiButtonVariant.Ghost"
                                     Disabled="@(!dashboard.IsInstalled || IsBusy)"
                                     OnClick="RestartAsync" />
                </div>
            </div>

            <div class="caddy-summary-grid">
                <article class="caddy-summary-tile">
                    <span class="caddy-summary-label">Installed</span>
                    <strong>@(dashboard.IsInstalled ? "Installed" : "Not installed")</strong>
                    <span class="caddy-summary-detail">@GetInstallDetail()</span>
                    <UiPill Tone="@(dashboard.IsInstalled ? UiPillTone.Success : UiPillTone.Warning)">
                        @(dashboard.IsInstalled ? "Ready" : "Needs install")
                    </UiPill>
                </article>

                <article class="caddy-summary-tile">
                    <span class="caddy-summary-label">Service</span>
                    <strong>@(dashboard.IsServiceActive ? "Running" : "Stopped")</strong>
                    <span class="caddy-summary-detail">@GetServiceDetail()</span>
                    <UiPill Tone="@(dashboard.IsServiceActive ? UiPillTone.Success : UiPillTone.Warning)">
                        @(dashboard.IsServiceActive ? "Active" : "Attention")
                    </UiPill>
                </article>

                <article class="caddy-summary-tile">
                    <span class="caddy-summary-label">Configuration</span>
                    <strong>@(dashboard.IsConfigurationValid ? "Valid" : "Needs attention")</strong>
                    <span class="caddy-summary-detail">@dashboard.ValidationSummary</span>
                    <UiPill Tone="@(dashboard.IsConfigurationValid ? UiPillTone.Success : UiPillTone.Warning)">
                        @(dashboard.IsConfigurationValid ? "Validated" : "Check config")
                    </UiPill>
                </article>

                <article class="caddy-summary-tile">
                    <span class="caddy-summary-label">Managed routes</span>
                    <strong>@dashboard.Routes.Count</strong>
                    <span class="caddy-summary-detail">@GetRouteDetail()</span>
                    <UiPill Tone="@(dashboard.IsManagedImportConfigured ? UiPillTone.Success : UiPillTone.Warning)">
                        @(dashboard.IsManagedImportConfigured ? "Import wired" : "Import missing")
                    </UiPill>
                </article>
            </div>

            @if (dashboard.IsInstalled && !dashboard.IsServiceActive)
            {
                <div class="callout warning caddy-service-action-callout">
                    <div>
                        <strong>Caddy is installed but not running.</strong>
                        <span>Start the service now. If systemd rejects it, LMS will show the exact command output below.</span>
                    </div>
                    <UiCommandButton Label="Start service"
                                     Glyph="UiIconGlyph.Run"
                                     Variant="UiButtonVariant.PrimaryMuted"
                                     Disabled="@IsBusy"
                                     OnClick="RestartAsync" />
                </div>
            }

            <section class="caddy-config-viewer" aria-label="Caddy config viewer">
                <div class="caddy-config-toolbar">
                    <label class="caddy-config-label" for="caddy-config-file">Config file</label>
                    <select id="caddy-config-file"
                            class="caddy-config-select"
                            value="@selectedConfigKey"
                            disabled="@(configFileOptions.Count == 0 || isConfigLoading)"
                            @onchange="HandleConfigSelectionChangedAsync">
                        @foreach (var option in configFileOptions)
                        {
                            <option value="@option.Key">@option.Label</option>
                        }
                    </select>

                    <UiPill Tone="@GetSelectedConfigTone()">@selectedConfigStatus</UiPill>
                </div>

                @if (SelectedConfigFile is not null)
                {
                    <div class="caddy-config-path-row">
                        <span>@SelectedConfigFile.Description</span>
                        <code>@SelectedConfigFile.Path</code>
                    </div>
                }

                <pre class="caddy-config-code" aria-readonly="true"><code>@selectedConfigContent</code></pre>
            </section>
        </section>

        @if (!dashboard.IsInstalled)
        {
            <section class="surface-card caddy-install-card">
                <div class="caddy-install-copy">
                    <p class="eyebrow">Install</p>
                    <h3>Install Caddy on this LMS host</h3>
                    <p class="meta-text">LMS will install the package, enable the systemd service, create the managed include, and wire the import into the main <code>Caddyfile</code>.</p>
                </div>

                <div class="caddy-install-actions">
                    <UiCommandButton Label="@(isInstalling ? "Installing..." : "Install Caddy")"
                                     Glyph="UiIconGlyph.Save"
                                     Variant="UiButtonVariant.Primary"
                                     Disabled="@IsBusy"
                                     OnClick="InstallAsync" />
                    <span class="meta-text">Route editing unlocks once Caddy is installed locally.</span>
                </div>
            </section>
        }
        else if (!dashboard.IsManagedImportConfigured)
        {
            <p class="callout warning">The LMS import line is missing from the main Caddyfile. Reloading or saving a route will rewrite the managed import.</p>
        }

        <section class="surface-card caddy-routes-card">
            <div class="table-header">
                <div>
                    <p class="eyebrow">Routes</p>
                    <h3>Reverse proxy routes</h3>
                    <p class="meta-text">Keep the list clean, expand the generated Caddy block only when you need to inspect what LMS will write.</p>
                </div>
                <span>@dashboard.Routes.Count item(s)</span>
            </div>

            @if (dashboard.Routes.Count == 0)
            {
                <div class="empty-state caddy-empty-state">
                    <p>No Caddy routes yet.</p>
                    <p class="meta-text">Add the first manual Caddy route here, or use Edge Gateway for Cloudflare Tunnel publishing.</p>
                </div>
            }
            else
            {
                <div class="caddy-route-list">
                    @foreach (var route in dashboard.Routes)
                    {
                        <article class="caddy-route-row @(IsRouteExpanded(route.Id) ? "expanded" : string.Empty)">
                            <div class="caddy-route-head">
                                <div class="caddy-route-copy">
                                    <div class="caddy-route-title-line">
                                        <strong>@route.Name</strong>
                                        <span class="caddy-route-kind">@route.KindLabel</span>
                                        @if (!string.IsNullOrWhiteSpace(route.Description))
                                        {
                                            <span class="caddy-route-summary">@route.Description</span>
                                        }
                                    </div>

                                    <div class="caddy-route-meta">
                                        <span><strong>@GetRouteAddressLabel(route):</strong> @route.AddressLabel</span>
                                        <span><strong>@GetRouteTargetLabel(route):</strong> @route.TargetLabel</span>
                                        <span><strong>Updated:</strong> @route.UpdatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                                    </div>

                                    @if (route.Warnings.Count > 0)
                                    {
                                        <div class="caddy-route-warnings">
                                            @foreach (var warning in route.Warnings)
                                            {
                                                <span>@warning</span>
                                            }
                                        </div>
                                    }
                                </div>

                                <div class="caddy-route-side">
                                    <span class="caddy-route-access @(route.EnableTls ? "caddy-route-access-secure" : "caddy-route-access-plain")">
                                        @(route.Kind == CaddyProxyRouteKind.PortForward ? "port" : route.EnableTls ? "https" : "http")
                                    </span>

                                    <div class="caddy-route-actions">
                                        <UiCommandButton Label="@(IsRouteExpanded(route.Id) ? "Hide config" : "Show config")"
                                                         Glyph="UiIconGlyph.Info"
                                                         Variant="UiButtonVariant.Ghost"
                                                         Disabled="@IsBusy"
                                                         OnClick="@(() => ToggleRouteExpandedAsync(route.Id))" />
                                        <UiCommandButton Label="Edit"
                                                         Glyph="UiIconGlyph.Edit"
                                                         Variant="UiButtonVariant.Ghost"
                                                         Disabled="@(!dashboard.IsInstalled || IsBusy)"
                                                         OnClick="@(() => OpenEditRouteDialogAsync(route.Id))" />
                                        <UiCommandButton Label="Delete"
                                                         Glyph="UiIconGlyph.Delete"
                                                         Variant="UiButtonVariant.Danger"
                                                         Disabled="@(!dashboard.IsInstalled || IsBusy)"
                                                         OnClick="@(() => OpenDeleteDialogAsync(route))" />
                                    </div>
                                </div>
                            </div>

                            @if (IsRouteExpanded(route.Id))
                            {
                                <div class="caddy-route-body">
                                    <pre class="caddy-route-code"><code>@route.GeneratedSnippet</code></pre>
                                </div>
                            }
                        </article>
                    }
                </div>
            }
        </section>

        @if (lastOperationLogs.Count > 0)
        {
            <section class="surface-card caddy-logs-card">
                <details class="caddy-log-details">
                    <summary>Latest system output</summary>

                    <div class="caddy-log-list">
                        @foreach (var log in lastOperationLogs)
                        {
                            <article class="caddy-log-row">
                                <div class="caddy-log-header">
                                    <strong>@log.Message</strong>
                                    <UiPill Tone="@GetLogTone(log.Level)">@log.Level</UiPill>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(log.CommandText))
                                {
                                    <pre class="caddy-log-code"><code>@log.CommandText</code></pre>
                                }

                                @if (!string.IsNullOrWhiteSpace(log.StandardError))
                                {
                                    <pre class="caddy-log-output caddy-log-output-error"><code>@log.StandardError</code></pre>
                                }
                                else if (!string.IsNullOrWhiteSpace(log.StandardOutput))
                                {
                                    <pre class="caddy-log-output"><code>@log.StandardOutput</code></pre>
                                }
                            </article>
                        }
                    </div>
                </details>
            </section>
        }
    </div>
}

@if (showEditorModal)
{
    <div class="caddy-dialog-shell" role="presentation">
        <section class="caddy-dialog-panel caddy-dialog-panel-editor"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="@editorDialogTitleId"
                 @onclick:stopPropagation="true">
            <header class="caddy-dialog-header">
                <div class="caddy-dialog-title-block">
                    <h2 id="@editorDialogTitleId">@(editor.Id.HasValue ? $"Edit {editor.Name}" : "Add Caddy route")</h2>
                    <p>@GetEditorSubtitle()</p>
                </div>
                <UiIconButton Label="Close" Glyph="UiIconGlyph.Clear" OnClick="CloseEditorDialogAsync" />
            </header>

            <div class="caddy-dialog-body">
                <EditForm id="@editorFormId"
                          Model="@editor"
                          OnValidSubmit="HandleSaveRouteAsync"
                          class="stack-form caddy-editor-form">
                    <DataAnnotationsValidator />

                    @if (!string.IsNullOrWhiteSpace(editorStatusMessage))
                    {
                        <p class="callout @(editorStatusIsError ? "error" : "success")">@editorStatusMessage</p>
                    }

                    <div class="caddy-editor-top-grid">
                        <UiSelectField TValue="CaddyProxyRouteKind"
                                       Value="@editor.Kind"
                                       ValueChanged="SetEditorKindAsync"
                                       ValueExpression="@(() => editor.Kind)"
                                       Label="Mode"
                                       Compact="true">
                            <option value="@CaddyProxyRouteKind.HostnameReverseProxy">Hostname route</option>
                            <option value="@CaddyProxyRouteKind.PortForward">Port forward</option>
                        </UiSelectField>

                        <UiTextField Value="@editor.Name"
                                     ValueChanged="SetEditorNameAsync"
                                     ValueExpression="@(() => editor.Name)"
                                     Label="Route name"
                                     Placeholder="@GetEditorNamePlaceholder()"
                                     Compact="true" />

                        <UiTextField Value="@editor.Description"
                                     ValueChanged="SetEditorDescriptionAsync"
                                     ValueExpression="@(() => editor.Description)"
                                     Label="Summary"
                                     Placeholder="Public entry for the app UI"
                                     Compact="true" />
                    </div>

                    @if (editor.Kind == CaddyProxyRouteKind.PortForward)
                    {
                        <div class="caddy-editor-port-grid">
                            <UiField Label="Source interfaces"
                                     Helper="Bind Caddy to one or more local interface IPs."
                                     Compact="true"
                                     Class="caddy-source-bind-field">
                                <ChildContent>
                                    <div class="caddy-source-bind-combo @(sourceIpPickerOpen ? "open" : null)">
                                        <button class="caddy-source-bind-button"
                                                type="button"
                                                role="combobox"
                                                aria-expanded="@sourceIpPickerOpen"
                                                @onclick="ToggleSourceIpPickerAsync">
                                            <span class="caddy-source-bind-selected">
                                                @foreach (var selectedSourceIp in GetSelectedSourceIps())
                                                {
                                                    <span class="caddy-source-bind-pill">@selectedSourceIp</span>
                                                }
                                            </span>
                                            <span class="caddy-source-bind-summary">@GetSelectedSourceIpSummary()</span>
                                        </button>

                                        @if (sourceIpPickerOpen)
                                        {
                                            <div class="caddy-source-bind-menu" role="listbox" aria-multiselectable="true">
                                                @foreach (var option in GetSourceBindOptions())
                                                {
                                                    var selected = IsSourceIpSelected(option.Value);
                                                    <button class="caddy-source-bind-option @(selected ? "selected" : null)"
                                                            type="button"
                                                            role="option"
                                                            aria-selected="@selected"
                                                            @onclick="@(() => ToggleSourceIpAsync(option.Value))">
                                                        <span class="caddy-source-bind-check" aria-hidden="true"></span>
                                                        <span class="caddy-source-bind-option-copy">
                                                            <strong>@option.Title</strong>
                                                            <span>@option.Subtitle</span>
                                                        </span>
                                                        <span class="caddy-source-bind-state">@(selected ? "Bound" : "Bind")</span>
                                                    </button>
                                                }
                                            </div>
                                        }
                                    </div>
                                </ChildContent>
                                <ValidationContent>
                                    <ValidationMessage For="@(() => editor.SourceIp)" />
                                </ValidationContent>
                            </UiField>

                            <UiNumberField TValue="int"
                                           Value="@editor.SourcePort"
                                           ValueChanged="SetEditorSourcePortAsync"
                                           ValueExpression="@(() => editor.SourcePort)"
                                           Label="Source port"
                                           Placeholder="8080"
                                           Compact="true" />

                            <UiSelectField TValue="CaddyProxyTargetScheme"
                                           Value="@editor.DestinationScheme"
                                           ValueChanged="SetEditorDestinationSchemeAsync"
                                           ValueExpression="@(() => editor.DestinationScheme)"
                                           Label="Destination"
                                           Compact="true">
                                <option value="@CaddyProxyTargetScheme.Http">HTTP</option>
                                <option value="@CaddyProxyTargetScheme.Https">HTTPS</option>
                            </UiSelectField>

                            <UiTextField Value="@editor.DestinationIp"
                                         ValueChanged="SetEditorDestinationIpAsync"
                                         ValueExpression="@(() => editor.DestinationIp)"
                                         Label="Destination IP"
                                         Helper="Internal IP or hostname."
                                         Placeholder="127.0.0.1"
                                         Compact="true" />

                            <UiNumberField TValue="int"
                                           Value="@editor.DestinationPort"
                                           ValueChanged="SetEditorDestinationPortAsync"
                                           ValueExpression="@(() => editor.DestinationPort)"
                                           Label="Destination port"
                                           Placeholder="80"
                                           Compact="true" />
                        </div>

                        @if (BuildEditorWarnings().Count > 0)
                        {
                            <div class="callout warning caddy-editor-warning-list">
                                @foreach (var warning in BuildEditorWarnings())
                                {
                                    <span>@warning</span>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="caddy-editor-address-grid">
                            <UiTextField Value="@editor.Hostname"
                                         ValueChanged="SetEditorHostnameAsync"
                                         ValueExpression="@(() => editor.Hostname)"
                                         Label="Public hostname"
                                         Helper="For example app.example.com"
                                         Placeholder="app.example.com"
                                         Compact="true" />

                            <UiTextField Value="@editor.UpstreamUrl"
                                         ValueChanged="SetEditorUpstreamUrlAsync"
                                         ValueExpression="@(() => editor.UpstreamUrl)"
                                         Label="Upstream URL"
                                         Helper="For example http://127.0.0.1:3000"
                                         Placeholder="http://127.0.0.1:3000"
                                         Compact="true" />
                        </div>

                        <UiCheckboxField Value="@editor.EnableTls"
                                         ValueChanged="SetEditorEnableTlsAsync"
                                         ValueExpression="@(() => editor.EnableTls)"
                                         Label="Terminate TLS in Caddy"
                                         Helper="Disable this only when you intentionally want a plain HTTP listener on the public side."
                                         Compact="true"
                                         Class="caddy-editor-toggle" />
                    }

                    <section class="surface-subcard caddy-editor-preview-card">
                        <div class="caddy-editor-preview-header">
                            <div class="stack-tight">
                                <strong>Generated Caddy block</strong>
                                <span class="helper-text">This is the managed snippet LMS will write into the Caddy include.</span>
                            </div>
                            <UiPill Tone="@(editor.Kind == CaddyProxyRouteKind.PortForward ? UiPillTone.Warning : editor.EnableTls ? UiPillTone.Success : UiPillTone.Warning)">
                                @(editor.Kind == CaddyProxyRouteKind.PortForward ? "port" : editor.EnableTls ? "https" : "http")
                            </UiPill>
                        </div>

                        <pre class="caddy-route-code"><code>@BuildEditorSnippet()</code></pre>
                    </section>
                </EditForm>
            </div>

            <footer class="caddy-dialog-footer">
                <UiCommandButton Label="Cancel"
                                 Glyph="UiIconGlyph.Clear"
                                 Variant="UiButtonVariant.Ghost"
                                 Disabled="@isSavingRoute"
                                 OnClick="CloseEditorDialogAsync" />
                <UiCommandButton Label="@(isSavingRoute ? "Saving..." : "Save route")"
                                 Glyph="UiIconGlyph.Save"
                                 Variant="UiButtonVariant.Primary"
                                 Disabled="@isSavingRoute"
                                 Type="submit"
                                 form="@editorFormId" />
            </footer>
        </section>
    </div>
}

@if (showDeleteModal)
{
    <div class="caddy-dialog-shell" role="presentation">
        <section class="caddy-dialog-panel caddy-dialog-panel-delete"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="@deleteDialogTitleId"
                 @onclick:stopPropagation="true">
            <header class="caddy-dialog-header">
                <div class="caddy-dialog-title-block">
                    <h2 id="@deleteDialogTitleId">Delete Caddy route</h2>
                    <p>Remove this LMS-managed route from the generated Caddy include.</p>
                </div>
                <UiIconButton Label="Close" Glyph="UiIconGlyph.Clear" OnClick="CloseDeleteDialogAsync" />
            </header>

            <div class="caddy-dialog-body">
                @if (routePendingDelete is not null)
                {
                    <div class="caddy-delete-copy">
                        <p>Delete <strong>@routePendingDelete.Name</strong>?</p>
                        <p class="meta-text">@routePendingDelete.AddressLabel -> @routePendingDelete.TargetLabel</p>
                    </div>
                }
            </div>

            <footer class="caddy-dialog-footer">
                <UiCommandButton Label="Cancel"
                                 Glyph="UiIconGlyph.Clear"
                                 Variant="UiButtonVariant.Ghost"
                                 Disabled="@isDeletingRoute"
                                 OnClick="CloseDeleteDialogAsync" />
                <UiCommandButton Label="@(isDeletingRoute ? "Deleting..." : "Delete route")"
                                 Glyph="UiIconGlyph.Delete"
                                 Variant="UiButtonVariant.Danger"
                                 Disabled="@isDeletingRoute"
                                 OnClick="DeleteRouteAsync" />
            </footer>
        </section>
    </div>
}

@code {
    private readonly string editorFormId = $"caddy-route-editor-{Guid.NewGuid():N}";
    private readonly string editorDialogTitleId = $"caddy-route-editor-title-{Guid.NewGuid():N}";
    private readonly string deleteDialogTitleId = $"caddy-route-delete-title-{Guid.NewGuid():N}";
    private readonly HashSet<Guid> expandedRouteIds = [];

    [Parameter]
    public Guid HostId { get; set; } = AiLocalMachine.ManagedHostId;

    private CaddyIntegrationDashboardViewModel? dashboard;
    private CaddyProxyRouteEditor editor = new();
    private CaddyProxyRouteListItem? routePendingDelete;
    private Guid? loadedHostId;
    private IReadOnlyList<OperationLogEntry> lastOperationLogs = [];
    private IReadOnlyList<CaddyConfigFileOption> configFileOptions = [];
    private IReadOnlyList<CaddySourceBindOption> sourceBindOptions = [];
    private string statusMessage = string.Empty;
    private string editorStatusMessage = string.Empty;
    private string selectedConfigKey = string.Empty;
    private string selectedConfigContent = "Select a Caddy config file to inspect.";
    private string selectedConfigStatus = "Read only";
    private bool statusIsError;
    private bool editorStatusIsError;
    private bool isLoaded;
    private bool showEditorModal;
    private bool showDeleteModal;
    private bool isInstalling;
    private bool isReloading;
    private bool isRestarting;
    private bool isSavingRoute;
    private bool isDeletingRoute;
    private bool isConfigLoading;
    private bool sourceIpPickerOpen;

    private bool IsLocalHost => AiLocalMachine.IsLocalMachine(HostId);
    private bool IsBusy => isInstalling || isReloading || isRestarting || isSavingRoute || isDeletingRoute;
    private CaddyConfigFileOption? SelectedConfigFile => configFileOptions.FirstOrDefault(option => option.Key == selectedConfigKey);

    protected override async Task OnParametersSetAsync()
    {
        if (loadedHostId == HostId)
        {
            return;
        }

        loadedHostId = HostId;
        expandedRouteIds.Clear();
        showEditorModal = false;
        showDeleteModal = false;
        routePendingDelete = null;
        statusMessage = string.Empty;
        editorStatusMessage = string.Empty;
        lastOperationLogs = [];

        if (!IsLocalHost)
        {
            dashboard = null;
            configFileOptions = [];
            sourceBindOptions = [];
            selectedConfigKey = string.Empty;
            selectedConfigContent = "Caddy config files are only available on the local LMS host.";
            selectedConfigStatus = "Unavailable";
            isLoaded = true;
            return;
        }

        await LoadDashboardAsync(clearStatus: true);
    }

    private async Task LoadDashboardAsync(bool clearStatus)
    {
        isLoaded = false;
        if (clearStatus)
        {
            statusMessage = string.Empty;
            statusIsError = false;
            lastOperationLogs = [];
        }

        dashboard = await CaddyIntegrationService.GetDashboardAsync();
        sourceBindOptions = BuildSourceBindOptions();
        await RefreshConfigFileOptionsAsync();
        isLoaded = true;
    }

    private async Task RefreshConfigFileOptionsAsync()
    {
        if (dashboard is null)
        {
            configFileOptions = [];
            selectedConfigKey = string.Empty;
            selectedConfigContent = "No Caddy dashboard is loaded.";
            selectedConfigStatus = "Unavailable";
            return;
        }

        configFileOptions = BuildConfigFileOptions(dashboard);
        if (configFileOptions.Count == 0)
        {
            selectedConfigKey = string.Empty;
            selectedConfigContent = "No Caddy config paths are known yet.";
            selectedConfigStatus = "Unavailable";
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedConfigKey) ||
            configFileOptions.All(option => !string.Equals(option.Key, selectedConfigKey, StringComparison.Ordinal)))
        {
            selectedConfigKey = configFileOptions[0].Key;
        }

        await LoadSelectedConfigContentAsync();
    }

    private static IReadOnlyList<CaddyConfigFileOption> BuildConfigFileOptions(CaddyIntegrationDashboardViewModel model)
    {
        var seenPaths = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var options = new List<CaddyConfigFileOption>();

        AddConfigOption(options, seenPaths, "main", "Main Caddyfile", model.MainConfigPath, "Caddy root config");
        AddConfigOption(options, seenPaths, "manual", "LMS manual routes", model.ManagedConfigPath, "Manual reverse proxy include");
        AddConfigOption(options, seenPaths, "edge", "Edge Gateway routes", "/etc/caddy/linuxmadesane/edge-gateway.caddy", "Edge Gateway include");
        AddConfigOption(options, seenPaths, "remote-lms", "Remote LMS relays", "/etc/caddy/linuxmadesane/remote-lms-relays.caddy", "SSH/Caddy LMS relay include");

        return options;
    }

    private static void AddConfigOption(
        ICollection<CaddyConfigFileOption> options,
        ISet<string> seenPaths,
        string key,
        string label,
        string path,
        string description)
    {
        if (string.IsNullOrWhiteSpace(path) || !seenPaths.Add(path))
        {
            return;
        }

        options.Add(new CaddyConfigFileOption(key, label, path, description));
    }

    private static IReadOnlyList<CaddySourceBindOption> BuildSourceBindOptions()
    {
        var options = new List<CaddySourceBindOption>
        {
            new("0.0.0.0", "All IPv4 interfaces", "Bind every IPv4 address on this host", "all interfaces 0.0.0.0"),
            new("127.0.0.1", "Loopback", "Local machine only", "loopback localhost 127.0.0.1")
        };
        var seen = options.Select(option => option.Value).ToHashSet(StringComparer.OrdinalIgnoreCase);

        try
        {
            foreach (var networkInterface in NetworkInterface.GetAllNetworkInterfaces()
                         .Where(static item => item.OperationalStatus == OperationalStatus.Up)
                         .OrderBy(static item => item.NetworkInterfaceType == NetworkInterfaceType.Loopback ? 1 : 0)
                         .ThenBy(static item => item.Name, StringComparer.OrdinalIgnoreCase))
            {
                IPInterfaceProperties properties;
                try
                {
                    properties = networkInterface.GetIPProperties();
                }
                catch
                {
                    continue;
                }

                foreach (var addressInfo in properties.UnicastAddresses)
                {
                    var address = NormalizeInterfaceAddress(addressInfo.Address);
                    if (!IsBindableInterfaceAddress(address) || !seen.Add(address.ToString()))
                    {
                        continue;
                    }

                    var interfaceLabel = string.IsNullOrWhiteSpace(networkInterface.Name)
                        ? networkInterface.NetworkInterfaceType.ToString()
                        : networkInterface.Name.Trim();
                    var family = address.AddressFamily == AddressFamily.InterNetwork ? "IPv4" : "IPv6";
                    options.Add(new CaddySourceBindOption(
                        address.ToString(),
                        address.ToString(),
                        $"{interfaceLabel} - {family}",
                        $"{networkInterface.Name} {networkInterface.Description} {networkInterface.NetworkInterfaceType} {address} {family}"));
                }
            }
        }
        catch
        {
        }

        return options;
    }

    private static IPAddress NormalizeInterfaceAddress(IPAddress address) =>
        address.IsIPv4MappedToIPv6 ? address.MapToIPv4() : address;

    private static bool IsBindableInterfaceAddress(IPAddress address) =>
        (address.AddressFamily is AddressFamily.InterNetwork or AddressFamily.InterNetworkV6) &&
        !Equals(address, IPAddress.Any) &&
        !Equals(address, IPAddress.IPv6Any) &&
        !Equals(address, IPAddress.None) &&
        !Equals(address, IPAddress.IPv6None) &&
        !IPAddress.IsLoopback(address) &&
        !address.IsIPv6LinkLocal;

    private async Task HandleConfigSelectionChangedAsync(ChangeEventArgs args)
