    private static string FormatHostForUri(string host)
    {
        var normalized = (host ?? string.Empty).Trim();
        return normalized.Contains(':', StringComparison.Ordinal) &&
               !normalized.StartsWith("[", StringComparison.Ordinal)
            ? $"[{normalized.Trim('[', ']')}]"
            : normalized;
    }

