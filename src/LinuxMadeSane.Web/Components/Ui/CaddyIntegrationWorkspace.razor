    private string GetServiceDetail()
    {
        if (dashboard is null || !dashboard.IsInstalled)
        {
            return "Install Caddy before managing the service.";
        }

        if (dashboard.IsServiceActive)
        {
            return dashboard.IsServiceEnabled
                ? "Running and enabled at boot."
                : "Running now; not enabled at boot.";
        }

        return dashboard.IsServiceEnabled
            ? "Stopped now. Start service to bring Caddy online."
            : "Stopped and not enabled. Start service before routing traffic.";
    }

    private string GetRouteDetail()
    {
        if (dashboard!.Routes.Count == 0)
        {
            return "No LMS-managed reverse proxy entries yet.";
        }

        return dashboard.Routes.Count == 1
            ? "1 LMS-managed hostname."
            : $"{dashboard.Routes.Count} LMS-managed hostnames.";
    }

