    private async Task SavePreviewAsync()
    {
        if (browser is null || selectedItem is null || !CanSavePreview)
        {
            return;
        }

        isBusy = true;
        previewIsSaving = true;
        previewMessage = "Saving file...";
        previewMessageTone = "info";

        try
        {
            var normalizedPath = ResolveBrowserPath(previewLoadedPath);
            var result = await WritePreviewFileAsync(normalizedPath, previewText);
            loadedPreviewText = previewText;
            previewLoadedPath = normalizedPath;
            previewMessage = $"Saved {selectedItem.Name} at {result.CompletedAtUtc.ToLocalTime():HH:mm:ss}.";
            previewMessageTone = "success";
            SetOperationMessage($"Saved {selectedItem.Name}.", "success");
            await RefreshCurrentListingPreserveSelectionAsync(normalizedPath);
            PersistDetachedBrowserState();
        }
        catch (Exception exception)
        {
            previewMessage = exception.Message;
            previewMessageTone = "error";
        }
        finally
        {
            previewIsSaving = false;
            isBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadPreviewAsync(SftpItem item, bool preservePanelState)
    {
        previewCts?.Cancel();
        previewCts?.Dispose();
        previewCts = new CancellationTokenSource();
        var cancellationToken = previewCts.Token;

        if (!preservePanelState)
        {
            previewPanelOpen = true;
        }

        previewIsLoading = true;
        previewIsSaving = false;
        previewIsText = false;
        previewArchiveFormat = null;
        previewArchiveEntries = [];
        previewBinaryContent = null;
        mediaPreview = null;
        previewBinaryContentType = string.Empty;
        mediaPreviewStreamUrl = string.Empty;
        mediaPreviewPlaybackUrl = string.Empty;
        previewText = string.Empty;
        loadedPreviewText = string.Empty;
        previewLoadedPath = string.Empty;
        previewMessage = string.Empty;
        previewMessageTone = "info";
        await InvokeAsync(StateHasChanged);

        if (item.ItemType == SftpItemType.Folder)
        {
            previewIsLoading = false;
            PersistDetachedBrowserState();
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            if (ArchiveFormatSupport.TryResolveFromFileName(item.Name, out var archiveFormat))
            {
                previewArchiveFormat = archiveFormat;
                previewLoadedPath = ResolveBrowserPath(item.FullPath);
                previewArchiveEntries = await ListArchivePreviewEntriesAsync(item.FullPath, archiveFormat, cancellationToken);
                if (cancellationToken.IsCancellationRequested)
                {
                    return;
                }

                if (previewArchiveEntries.Count >= ArchivePreviewMaxEntries)
                {
                    previewMessage = $"Showing the first {ArchivePreviewMaxEntries} archive entries.";
                    previewMessageTone = "warning";
                }

                return;
            }

            if (IsLocalBrowser)
            {
                var loadedMediaPreview = await MediaLibraryIntegrationService.GetPreviewForPathAsync(item.FullPath, cancellationToken);
                if (cancellationToken.IsCancellationRequested)
                {
                    return;
                }

                if (loadedMediaPreview is not null)
                {
                    mediaPreview = loadedMediaPreview;
                    mediaPreviewStreamUrl = BuildMediaPreviewStreamUrl(loadedMediaPreview.Item.Id);
                    mediaPreviewPlaybackUrl = BuildMediaPreviewPlaybackUrl(loadedMediaPreview);
                    previewLoadedPath = ResolveBrowserPath(item.FullPath);
                    return;
                }
            }

            var visualContentType = ResolveVisualPreviewContentType(item.Name);
            if (!string.IsNullOrWhiteSpace(visualContentType))
            {
                var binaryContent = await ReadBinaryPreviewFileAsync(item.FullPath, cancellationToken);
                if (cancellationToken.IsCancellationRequested)
                {
                    return;
                }

                previewLoadedPath = ResolveBrowserPath(binaryContent.FullPath);
                if (binaryContent.IsTruncated)
                {
                    previewMessage = $"Preview is limited to files up to {FormatBytes(VisualPreviewMaxBytes)}. {item.Name} is {FormatBytes(binaryContent.SizeBytes)}, so inline rendering is disabled.";
                    previewMessageTone = "warning";
                    return;
                }

                previewBinaryContent = binaryContent;
                previewBinaryContentType = visualContentType;
            }
            else
            {
                var fileContent = await ReadPreviewFileAsync(item.FullPath, cancellationToken);
                if (cancellationToken.IsCancellationRequested)
                {
                    return;
                }

                previewLoadedPath = ResolveBrowserPath(fileContent.FullPath);
                previewIsText = LooksLikeTextContent(fileContent.Content, item.Name);
                if (previewIsText)
                {
                    previewText = fileContent.Content;
                    loadedPreviewText = fileContent.Content;
                    if (fileContent.IsTruncated)
                    {
                        previewMessage = $"Showing the first {FormatBytes(Math.Min(fileContent.SizeBytes, PreviewMaxBytes))} of {FormatBytes(fileContent.SizeBytes)}. Save is disabled for truncated previews.";
                        previewMessageTone = "warning";
                    }
                }
                else
                {
                    previewMessage = "This file does not look like plain UTF-8 text, so the editor is disabled.";
                    previewMessageTone = "warning";
                }
            }
        }
        catch (Exception exception)
        {
            if (cancellationToken.IsCancellationRequested)
            {
                return;
            }

            previewMessage = exception.Message;
            previewMessageTone = "error";
        }
        finally
        {
            if (!cancellationToken.IsCancellationRequested)
            {
                previewIsLoading = false;
                PersistDetachedBrowserState();
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task RefreshCurrentListingPreserveSelectionAsync(string selectedPath)
