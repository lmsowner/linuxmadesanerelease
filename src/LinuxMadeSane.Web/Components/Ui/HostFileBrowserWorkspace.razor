    private string DescribeCurrentOwnershipPermissions()
    {
        if (ownershipPermissionsTargetItem is null)
        {
            return string.Empty;
        }

        var (special, owner, group, other) = ParseOwnershipPermissionsDigitsOrDefault(
            ResolveOwnershipPermissionsOctal(ownershipPermissionsTargetItem),
            ownershipPermissionsTargetItem.ItemType);
        return BuildOwnershipPermissionsDescription(ownershipPermissionsTargetItem.ItemType, special, owner, group, other);
    }

    private string DescribeEditedOwnershipPermissions()
    {
        var (special, owner, group, other) = GetOwnershipPermissionsDigits();
        return BuildOwnershipPermissionsDescription(
            ownershipPermissionsTargetItem?.ItemType ?? SftpItemType.File,
            special,
            owner,
            group,
            other);
    }

    private string? ValidateOwnershipPermissionsEditor() =>
        TryParseOwnershipPermissionsDigits(ownershipPermissionsEditor.PermissionsOctal, out _, out _, out _, out _)
            ? null
            : "Permissions must be a 3 or 4 digit octal value such as 775 or 2775.";

    private (int Special, int Owner, int Group, int Other) GetOwnershipPermissionsDigits() =>
        ParseOwnershipPermissionsDigitsOrDefault(
            ownershipPermissionsEditor.PermissionsOctal,
            ownershipPermissionsTargetItem?.ItemType ?? SftpItemType.File);

    private static bool TryParseOwnershipPermissionsDigits(
        string? value,
        out int special,
        out int owner,
        out int group,
        out int other)
    {
        special = owner = group = other = 0;
        var trimmed = value?.Trim() ?? string.Empty;
        if (trimmed.Length is < 3 or > 4 || trimmed.Any(character => character is < '0' or > '7'))
        {
            return false;
        }

        if (trimmed.Length == 3)
        {
            owner = trimmed[0] - '0';
            group = trimmed[1] - '0';
            other = trimmed[2] - '0';
            return true;
        }

        special = trimmed[0] - '0';
        owner = trimmed[1] - '0';
        group = trimmed[2] - '0';
        other = trimmed[3] - '0';
        return true;
    }

    private static (int Special, int Owner, int Group, int Other) ParseOwnershipPermissionsDigitsOrDefault(
        string? value,
        SftpItemType itemType)
    {
        if (TryParseOwnershipPermissionsDigits(value, out var special, out var owner, out var group, out var other))
        {
            return (special, owner, group, other);
        }

        return itemType == SftpItemType.Folder
            ? (0, 7, 5, 5)
            : (0, 6, 4, 4);
    }

    private static string ResolveOwnershipPermissionsOctal(SftpItem item)
    {
        if (TryParseOwnershipPermissionsDigits(item.PermissionsOctal, out var special, out var owner, out var group, out var other))
        {
            return BuildOwnershipPermissionsOctal(special, owner, group, other);
        }

        return item.ItemType == SftpItemType.Folder ? "755" : "644";
    }

    private static string BuildOwnershipPermissionsOctal(int special, int owner, int group, int other) =>
        special > 0 ? $"{special}{owner}{group}{other}" : $"{owner}{group}{other}";

    private static string BuildOwnershipPermissionsDescription(
        SftpItemType itemType,
        int special,
        int owner,
        int group,
        int other)
    {
        var parts = new List<string>
        {
            $"Owner {DescribeOwnershipPermissionDigit(owner, itemType)}",
            $"group {DescribeOwnershipPermissionDigit(group, itemType)}",
            $"everyone else {DescribeOwnershipPermissionDigit(other, itemType)}"
        };

        if ((special & 4) == 4)
        {
            parts.Add("setuid on");
        }

        if ((special & 2) == 2)
        {
            parts.Add("setgid on");
        }

        if ((special & 1) == 1)
        {
            parts.Add("sticky bit on");
        }

        return string.Join(" • ", parts);
    }

    private static string DescribeOwnershipPermissionDigit(int value, SftpItemType itemType)
    {
        var executeLabel = itemType == SftpItemType.Folder ? "enter" : "execute";

        return value switch
        {
            7 => $"has full access",
            6 => "can read and write",
            5 => $"can read and {executeLabel}",
            4 => "can read only",
            3 => $"can write and {executeLabel}",
            2 => "can write only",
            1 => $"can {executeLabel} only",
            _ => "has no access"
        };
    }

    private static string BuildOwnershipPermissionsSymbolic(
        SftpItemType itemType,
        int special,
        int owner,
        int group,
        int other)
    {
        var chars = new char[10];
        chars[0] = itemType switch
        {
            SftpItemType.Folder => 'd',
            SftpItemType.Link => 'l',
            _ => '-'
        };

        ApplyOwnershipPermissionTriplet(chars, 1, owner, (special & 4) == 4, stickyBit: false);
        ApplyOwnershipPermissionTriplet(chars, 4, group, (special & 2) == 2, stickyBit: false);
        ApplyOwnershipPermissionTriplet(chars, 7, other, (special & 1) == 1, stickyBit: true);

        return new string(chars);
    }

    private static void ApplyOwnershipPermissionTriplet(char[] chars, int offset, int digit, bool specialBit, bool stickyBit)
    {
        chars[offset] = (digit & 4) == 4 ? 'r' : '-';
        chars[offset + 1] = (digit & 2) == 2 ? 'w' : '-';

        var executeEnabled = (digit & 1) == 1;
        chars[offset + 2] = specialBit
            ? stickyBit
                ? (executeEnabled ? 't' : 'T')
                : (executeEnabled ? 's' : 'S')
            : executeEnabled
                ? 'x'
                : '-';
    }

