    public async ValueTask DisposeAsync()
    {
        FileActionQueueService.Changed -= HandleFileActionChanged;

        if (uploadTargetRegistered)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("lmsFileBrowser.disposeUploadTarget", uploadTargetId);
            }
            catch (JSDisconnectedException)
            {
            }
            catch (JSException)
            {
            }

            uploadTargetRegistered = false;
        }

        uploadInteropReference?.Dispose();
        uploadInteropReference = null;

        if (clipboardPollingCts is not null)
        {
            clipboardPollingCts.Cancel();
            clipboardPollingCts.Dispose();
            clipboardPollingCts = null;
        }

        if (previewCts is not null)
        {
            previewCts.Cancel();
            previewCts.Dispose();
            previewCts = null;
        }

        if (fileSearchCts is not null)
        {
            fileSearchCts.Cancel();
            fileSearchCts.Dispose();
            fileSearchCts = null;
        }

        if (operationMessageCts is not null)
        {
            operationMessageCts.Cancel();
            operationMessageCts.Dispose();
            operationMessageCts = null;
        }

        foreach (var temporaryMountPath in ownedTemporaryMountPaths.ToArray())
        {
            try
            {
                await ShareService.ReleaseTemporaryRemoteMountAsync(temporaryMountPath);
            }
            catch
            {
                // Startup cleanup handles any temporary mount that survives component disposal.
            }
        }
    }
