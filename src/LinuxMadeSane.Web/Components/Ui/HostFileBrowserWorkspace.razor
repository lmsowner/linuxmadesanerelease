    [JSInvokable]
    public async Task<IReadOnlyList<BrowserManagedUploadLaunchDescriptor>> PrepareBrowserUploadSelectionAsync(
        string? destinationDirectoryPath,
        BrowserUploadSelection? selection)
    {
        if (browser is null || selection is null)
        {
            return [];
        }

        var destinationPath = ResolveBrowserPath(string.IsNullOrWhiteSpace(destinationDirectoryPath)
            ? currentPath
            : destinationDirectoryPath);
        var selectedFiles = selection.Files
            .Where(file => !string.IsNullOrWhiteSpace(file.ClientFileId) && !string.IsNullOrWhiteSpace(file.FileName))
            .Take(MaxUploadFileCount + 1)
            .ToArray();

        DismissContextMenu();
        ClearOperationMessage();

        if (selectedFiles.Length == 0)
        {
            return [];
        }

        if (selectedFiles.Length > MaxUploadFileCount)
        {
            SetOperationMessage($"Upload rejected: select no more than {MaxUploadFileCount} files.", "warning");
            await InvokeAsync(StateHasChanged);
            return [];
        }

        var oversizedFile = selectedFiles.FirstOrDefault(file => file.SizeBytes > MaxUploadFileBytes);
        if (oversizedFile is not null)
        {
            SetOperationMessage($"{oversizedFile.FileName} is {FormatBytes(oversizedFile.SizeBytes)}. The per-file limit is {FormatBytes(MaxUploadFileBytes)}.", "warning");
            await InvokeAsync(StateHasChanged);
            return [];
        }

        await EnsureFileActionsPopupAsync();

        var launchPlan = FileActionQueueService.QueueUpload(
            workspaceId,
            new FileActionUploadRequest(
                browser.Host,
                destinationPath,
                selectedFiles
                    .Select(file => new FileActionUploadSourceItem(file.ClientFileId, file.FileName, file.SizeBytes))
                    .ToArray(),
                BuildFileActionExecutionContext()));

        SetOperationMessage($"Started upload for {DescribeItems(selectedFiles.Select(file => file.FileName).ToArray())}. Manage progress in File actions.", "success");
        await InvokeAsync(StateHasChanged);

        return launchPlan.Items
            .Select(static item => new BrowserManagedUploadLaunchDescriptor(
                item.ClientFileId,
                $"/internal/file-actions/uploads/{Uri.EscapeDataString(item.UploadToken)}/chunks",
                $"/internal/file-actions/uploads/{Uri.EscapeDataString(item.UploadToken)}/complete",
                $"/internal/file-actions/uploads/{Uri.EscapeDataString(item.UploadToken)}/cancel"))
            .ToArray();
    }

