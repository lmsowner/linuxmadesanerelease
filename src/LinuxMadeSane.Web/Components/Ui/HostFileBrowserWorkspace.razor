    private async Task CreateShareMappingAsync(bool persistOnServer)
    {
        if (browser is null)
        {
            return;
        }

        isCreatingShareMapping = true;
        shareMappingStatusMessage = persistOnServer
            ? "Creating permanent LMS mount..."
            : "Creating temporary LMS mount...";
        shareMappingStatusTone = "info";

        try
        {
            shareMappingEditor.PersistOnServer = persistOnServer;
            var result = await ShareService.CreateRemoteShareMountAsync(shareMappingEditor);
            showShareMappingModal = false;
            SetOperationMessage(result.StatusMessage, "success");

            if (!result.Persisted)
            {
                ownedTemporaryMountPaths.Add(result.LocalMountPath);
            }

            if (IsLocalBrowser && (!HasScopedRoot || IsPathWithinRoot(result.LocalMountPath)))
            {
                await LoadItemsAsync(result.LocalMountPath, preserveSessionOnFailure: canBrowse, updatePathInputOnSuccess: true);
            }
            else if (IsLocalBrowser && HasScopedRoot)
            {
                SetOperationMessage($"{result.StatusMessage} This browser is scoped to {EffectiveRootPath}; open an LMS local browser for {result.LocalMountPath} to inspect it.", "success");
            }
        }
        catch (Exception exception)
        {
            shareMappingStatusMessage = exception.Message;
            shareMappingStatusTone = "error";
        }
        finally
        {
            isCreatingShareMapping = false;
        }
    }

    private async Task SaveShareFolderAsync()
    {
        if (isSavingShareFolder || isDeletingShareFolder)
        {
            return;
        }

        isSavingShareFolder = true;
        shareFolderStatusMessage = "Saving share...";
        shareFolderStatusTone = "info";

        try
        {
            var shareId = await ShareService.SaveShareAsync(shareFolderEditor);
            var shareName = shareFolderEditor.Name;
            var shareManager = await ShareService.GetShareManagerAsync();
            var runtimeStatus = shareManager.SystemCheck?.ShareStatuses.FirstOrDefault(status => status.ShareId == shareId);

            showShareFolderDialog = false;
            SetOperationMessage(
                runtimeStatus is null || runtimeStatus.IsHealthy
                    ? $"Saved share {shareName}."
                    : $"Saved share {shareName}. {runtimeStatus.Detail}",
                GetShareOperationTone(runtimeStatus));
        }
        catch (Exception exception)
        {
            shareFolderStatusMessage = exception.Message;
            shareFolderStatusTone = "error";
        }
        finally
        {
            isSavingShareFolder = false;
        }
    }

    private async Task DeleteShareFolderAsync()
    {
        if (!shareFolderEditor.Id.HasValue || isSavingShareFolder || isDeletingShareFolder)
        {
            return;
        }

        var confirmed = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            $"Delete share {shareFolderEditor.Name}? This removes the Samba export but leaves {shareFolderEditor.SharePath} untouched.");
        if (!confirmed)
        {
            return;
        }

        isDeletingShareFolder = true;
        shareFolderStatusMessage = "Deleting share...";
        shareFolderStatusTone = "info";

        try
        {
            await ShareService.DeleteShareAsync(shareFolderEditor.Id.Value);
            showShareFolderDialog = false;
            SetOperationMessage($"Deleted share {shareFolderEditor.Name}.", "success");
        }
        catch (Exception exception)
        {
            shareFolderStatusMessage = exception.Message;
            shareFolderStatusTone = "error";
        }
        finally
        {
            isDeletingShareFolder = false;
        }
    }

    private Task OpenContextMenuAsync(FileBrowserContextMenuRequest request)
    {
        shortcutContextShortcut = null;
        var normalizedTargetPath = ResolveBrowserPath(request.TargetPath);
        var normalizedActionDirectoryPath = ResolveBrowserPath(request.ActionDirectoryPath);
        contextMenuRequest = request with
        {
            TargetPath = normalizedTargetPath,
            ActionDirectoryPath = normalizedActionDirectoryPath
