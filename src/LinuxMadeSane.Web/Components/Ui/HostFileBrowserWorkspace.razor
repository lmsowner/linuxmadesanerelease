    private void PersistDetachedBrowserState()
    {
        if (browser is null)
        {
            return;
        }

        var browserId = DetachedBrowserId ?? inlineDetachedBrowserId;
        if (!browserId.HasValue)
        {
            return;
        }

        WorkspaceState.UpdateDetachedBrowser(browserId.Value, BuildDetachedSnapshot());
    }

    private void PersistDetachedSearchState()
    {
        if (!DetachedSearchId.HasValue || browser is null)
        {
            return;
        }

        WorkspaceState.UpdateDetachedSearch(DetachedSearchId.Value, BuildDetachedSearchSnapshot());
    }

    private string BuildDetachedSearchPopupUrl(Guid searchId)
    {
        var popupUrl = $"/file-search-window/{searchId}?workspaceId={Uri.EscapeDataString(workspaceId)}";
        if (!HasScopedRoot)
        {
            return popupUrl;
        }

        return $"{popupUrl}&rootPath={Uri.EscapeDataString(EffectiveRootPath!)}&title={Uri.EscapeDataString("Find files")}";
    }

    private void EnsureInlineDetachedBrowserState()
    {
        if (browser is null || DetachedBrowserId.HasValue || DetachedSearchId.HasValue || !AllowPopout)
        {
            return;
        }

        if (inlineDetachedBrowserId.HasValue &&
            WorkspaceState.UpdateDetachedBrowser(inlineDetachedBrowserId.Value, BuildDetachedSnapshot()))
        {
            return;
        }

        inlineDetachedBrowserId = WorkspaceState.CreateDetachedBrowser(BuildDetachedSnapshot()).BrowserId;
    }

    private async Task PollClipboardAsync(CancellationToken cancellationToken)
    {
        while (!cancellationToken.IsCancellationRequested)
        {
            try
            {
                await Task.Delay(750, cancellationToken);
            }
            catch (OperationCanceledException)
            {
                break;
            }

            var clipboard = WorkspaceState.Clipboard;
            var signature = clipboard is null
                ? "none"
                : $"{clipboard.Operation}:{clipboard.HostId}:{clipboard.SourcePath}:{clipboard.CapturedAtUtc:O}";
            if (signature == observedClipboardSignature)
            {
                continue;
            }

            observedClipboardSignature = signature;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void SetOperationMessage(string message, string tone)
    {
        operationMessageCts?.Cancel();
        operationMessageCts?.Dispose();
        operationMessageCts = null;

        operationMessage = message;
        operationMessageTone = tone;

        if (!string.IsNullOrWhiteSpace(operationMessage) &&
            !string.Equals(tone, "error", StringComparison.OrdinalIgnoreCase))
        {
            operationMessageCts = new CancellationTokenSource();
            _ = AutoHideOperationMessageAsync(message, tone, operationMessageCts.Token);
        }
    }

    private void ClearOperationMessage()
    {
        operationMessageCts?.Cancel();
        operationMessageCts?.Dispose();
        operationMessageCts = null;
        operationMessage = string.Empty;
        operationMessageTone = "success";
    }

    private async Task AutoHideOperationMessageAsync(string message, string tone, CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(TimeSpan.FromSeconds(5), cancellationToken);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        if (!string.Equals(operationMessage, message, StringComparison.Ordinal) ||
            !string.Equals(operationMessageTone, tone, StringComparison.Ordinal))
        {
            return;
        }

        operationMessage = string.Empty;
        operationMessageTone = "success";

        await InvokeAsync(StateHasChanged);
    }

    private static string GetShareOperationTone(SambaShareRuntimeStatus? runtimeStatus) =>
        runtimeStatus is null || runtimeStatus.IsHealthy
            ? "success"
            : runtimeStatus.Severity == PermissionIssueSeverity.Critical
                ? "error"
                : "warning";

    private IReadOnlyList<SftpItem> GetSelectedContextItems(FileBrowserContextMenuRequest request)
    {
        if (request.Item is null)
        {
            return Array.Empty<SftpItem>();
        }

        var normalizedTargetPath = ResolveBrowserPath(request.TargetPath);
        return selectedPaths.Contains(normalizedTargetPath)
            ? SelectedItems
            : Array.Empty<SftpItem>();
    }

    private static string DescribeItems(IReadOnlyList<string> names) =>
        names.Count switch
        {
            0 => "items",
            1 => names[0],
            _ => $"{names.Count} items"
        };

    private static string BuildOwnershipPermissionsSuccessMessage(int itemCount, bool applyRecursively, int recursiveFolderCount, string? referenceName)
    {
        var resolvedReferenceName = string.IsNullOrWhiteSpace(referenceName) ? "the selected item" : referenceName;
        if (itemCount <= 1)
        {
            return applyRecursively && recursiveFolderCount > 0
                ? $"Updated owner, group, and permissions recursively for {resolvedReferenceName}."
                : $"Updated owner, group, and permissions for {resolvedReferenceName}.";
        }

        if (applyRecursively && recursiveFolderCount > 0)
        {
            return recursiveFolderCount == 1
                ? $"Updated owner, group, and permissions for {itemCount} selected items, with recursive changes applied to 1 selected folder."
                : $"Updated owner, group, and permissions for {itemCount} selected items, with recursive changes applied to {recursiveFolderCount} selected folders.";
        }

        return $"Updated owner, group, and permissions for {itemCount} selected items.";
    }

    private static string BuildSuggestedShareName(string folderPath, IReadOnlyList<SambaShareDefinition> existingShares)
    {
        var baseName = GetPathLabel(folderPath);
        if (string.IsNullOrWhiteSpace(baseName) || baseName is "/" or ".")
        {
            baseName = "share";
        }

        var existingNames = existingShares
            .Select(share => share.Name)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        if (!existingNames.Contains(baseName))
        {
            return baseName;
        }

        for (var suffix = 2; suffix < 10_000; suffix++)
        {
            var candidate = $"{baseName}-{suffix}";
            if (!existingNames.Contains(candidate))
            {
                return candidate;
            }
        }

        return $"{baseName}-{Guid.NewGuid().ToString("N")[..8]}";
    }

    private string ResolveBrowserPath(string path)
    {
        var normalizedPath = NormalizeBrowserPath(ExpandHomeShortcut(path));
        if (!HasScopedRoot)
        {
            return normalizedPath;
        }

        return NormalizePathWithinRoot(EffectiveRootPath!, normalizedPath);
    }

    private string ResolveAddressInputPath(string input)
    {
        var trimmed = input.Trim();
        if (string.IsNullOrWhiteSpace(trimmed))
        {
            return string.IsNullOrWhiteSpace(currentPath)
                ? EffectiveRootPath ?? "/"
                : currentPath;
        }

        if (trimmed.StartsWith("/", StringComparison.Ordinal) || trimmed == ".")
        {
            return ResolveBrowserPath(trimmed);
        }

        if (trimmed.StartsWith("~", StringComparison.Ordinal))
        {
            return ResolveBrowserPath(trimmed);
        }

        return ResolveBrowserPath(CombineBrowserPath(
            string.IsNullOrWhiteSpace(currentPath) ? EffectiveRootPath ?? "/" : currentPath,
            trimmed));
    }

    private string ExpandHomeShortcut(string path)
    {
        if (browser is null || string.IsNullOrWhiteSpace(path))
        {
            return path;
        }

        var trimmed = path.Trim();
        if (trimmed is not "~" && !trimmed.StartsWith("~/", StringComparison.Ordinal))
        {
            return path;
        }

        var homeDirectory = string.Equals(browser.Host.Username, "root", StringComparison.OrdinalIgnoreCase)
            ? "/root"
            : string.IsNullOrWhiteSpace(browser.Host.Username)
                ? "/home"
                : $"/home/{browser.Host.Username}";

        if (trimmed is "~" or "~/")
        {
            return homeDirectory;
        }

        return homeDirectory.TrimEnd('/') + "/" + trimmed[2..].TrimStart('/');
    }

    private void QueuePathSuggestionsRefresh(string? query)
    {
        if (browser is null)
        {
            pathSuggestions = [];
            isPathSuggestionsLoading = false;
            return;
        }

        if (!canBrowse && !HasAvailableBrowseCredentials)
        {
            pathSuggestions = [];
            isPathSuggestionsLoading = false;
            return;
        }

        var normalizedQuery = (query ?? string.Empty).Trim();
        var requestVersion = ++pathSuggestionsRequestVersion;
        pathSuggestions = BuildCachedPathSuggestions(normalizedQuery);
        var inspectionPaths = BuildPathSuggestionInspectionPaths(normalizedQuery);
        var requiresLookup = inspectionPaths.Any(path => !directoryItemCache.ContainsKey(path));
        isPathSuggestionsLoading = requiresLookup;

        if (requiresLookup)
        {
            _ = RefreshPathSuggestionsAsync(requestVersion, normalizedQuery);
        }
    }

    private async Task RefreshPathSuggestionsAsync(int requestVersion, string query)
    {
        foreach (var path in BuildPathSuggestionInspectionPaths(query))
        {
            if (directoryItemCache.ContainsKey(path))
            {
                continue;
            }

            try
            {
                directoryItemCache[path] = await ListItemsForPathAsync(path);
            }
            catch
            {
                // Ignore suggestion lookups that fail. The committed browse path still reports real errors.
            }

            if (requestVersion != pathSuggestionsRequestVersion)
            {
                return;
            }
        }

        if (requestVersion != pathSuggestionsRequestVersion)
        {
            return;
        }

        pathSuggestions = BuildCachedPathSuggestions(query);
        isPathSuggestionsLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private IReadOnlyList<string> BuildCachedPathSuggestions(string query)
    {
        var suggestions = new SortedSet<string>(StringComparer.OrdinalIgnoreCase);
        var inspectionPaths = BuildPathSuggestionInspectionPaths(query);

        if (string.IsNullOrWhiteSpace(query))
        {
            AddPathSuggestion(suggestions, EffectiveRootPath);
            AddPathSuggestion(suggestions, currentPath);
            AddPathSuggestion(suggestions, string.IsNullOrWhiteSpace(currentPath) ? null : GetParentDirectory(currentPath));
        }
        else
        {
            AddPathSuggestion(suggestions, ResolveAddressInputPath(query));
            AddPathSuggestion(suggestions, GetParentDirectory(ResolveAddressInputPath(query)));
        }

        foreach (var inspectionPath in inspectionPaths)
        {
            AddPathSuggestion(suggestions, inspectionPath);

            if (!directoryItemCache.TryGetValue(inspectionPath, out var inspectionItems))
            {
                continue;
            }

            foreach (var item in inspectionItems.Where(item => item.ItemType == SftpItemType.Folder))
            {
                AddPathSuggestion(suggestions, item.FullPath);
            }
        }

        var filtered = string.IsNullOrWhiteSpace(query)
            ? suggestions.AsEnumerable()
            : suggestions.Where(path =>
                path.StartsWith(query, StringComparison.OrdinalIgnoreCase) ||
                GetPathLabel(path).StartsWith(query, StringComparison.OrdinalIgnoreCase) ||
                path.Contains(query, StringComparison.OrdinalIgnoreCase));

        return filtered
            .Where(path => !string.Equals(path, pathInput, StringComparison.Ordinal))
            .OrderBy(path => GetPathSuggestionRank(path, query))
            .ThenBy(GetPathLabel, StringComparer.OrdinalIgnoreCase)
            .ThenBy(path => path, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private IReadOnlyList<string> BuildPathSuggestionInspectionPaths(string query)
    {
        var inspectionPaths = new List<string>();
        var effectiveQuery = string.IsNullOrWhiteSpace(query)
            ? currentPath
            : ResolveAddressInputPath(query);

        AddInspectionPath(inspectionPaths, GetParentDirectory(effectiveQuery));
        AddInspectionPath(inspectionPaths, effectiveQuery);

        if (string.IsNullOrWhiteSpace(query))
        {
            AddInspectionPath(inspectionPaths, EffectiveRootPath);
        }

        return inspectionPaths;
    }

    private void AddInspectionPath(ICollection<string> inspectionPaths, string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return;
        }

        var normalizedPath = ResolveBrowserPath(path);
        if (!IsPathVisibleInTree(normalizedPath) || inspectionPaths.Contains(normalizedPath, StringComparer.Ordinal))
        {
            return;
        }

        inspectionPaths.Add(normalizedPath);
    }

    private static int GetPathSuggestionRank(string path, string query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return path is "/" or "." ? 0 : 1;
        }

        var label = GetPathLabel(path);
        if (path.StartsWith(query, StringComparison.OrdinalIgnoreCase))
        {
            return 0;
        }

        if (label.StartsWith(query, StringComparison.OrdinalIgnoreCase))
        {
            return 1;
        }

        return path.Contains(query, StringComparison.OrdinalIgnoreCase) ? 2 : 3;
    }

    private void AddPathSuggestion(ISet<string> suggestions, string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return;
        }

        var normalizedPath = ResolveBrowserPath(path);
        if (IsPathVisibleInTree(normalizedPath))
        {
            suggestions.Add(normalizedPath);
        }
    }

    private bool IsPathWithinRoot(string path)
    {
        if (!HasScopedRoot)
        {
            return true;
        }

        var normalizedPath = NormalizeBrowserPath(path);
        return string.Equals(normalizedPath, EffectiveRootPath, StringComparison.Ordinal) ||
            normalizedPath.StartsWith(EffectiveRootPath!.TrimEnd('/') + "/", StringComparison.Ordinal);
    }

    private bool IsPathVisibleInTree(string path) =>
        !HasScopedRoot || IsPathWithinRoot(path);

    private IReadOnlyList<string> BuildVisibleBranchPaths(string path) =>
        HasScopedRoot
            ? BuildBranchPathsWithinRoot(path, EffectiveRootPath!)
            : BuildBranchPaths(path);

    private string BuildRootedPopupUrl()
    {
        var effectivePath = string.IsNullOrWhiteSpace(currentPath) ? EffectiveRootPath! : currentPath;
        return $"/file-browser-window?workspaceId={Uri.EscapeDataString(workspaceId)}&rootPath={Uri.EscapeDataString(EffectiveRootPath!)}&path={Uri.EscapeDataString(effectivePath)}&title={Uri.EscapeDataString(ResolvedExplorerTitle)}";
    }

    private string BuildDirectBrowserPopupUrl()
    {
        var browserId = DetachedBrowserId ?? inlineDetachedBrowserId;
        if (browserId.HasValue)
        {
            return $"/file-browser-window/{browserId.Value}?workspaceId={Uri.EscapeDataString(workspaceId)}";
        }

        return HasScopedRoot ? BuildRootedPopupUrl() : "/file-browser-window";
    }

    private static IReadOnlyList<string> BuildBranchPaths(string path)
    {
        var normalizedPath = NormalizeBrowserPath(path);
        if (normalizedPath is "/" or ".")
        {
            return [normalizedPath];
        }

        var hasLeadingSlash = normalizedPath.StartsWith("/", StringComparison.Ordinal);
        var parts = normalizedPath.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        var branch = new List<string>();

        if (hasLeadingSlash)
        {
            branch.Add("/");
            var current = string.Empty;
            foreach (var part in parts)
            {
                current = string.IsNullOrEmpty(current) ? $"/{part}" : $"{current}/{part}";
                branch.Add(current);
            }
        }
        else
        {
            var current = string.Empty;
            foreach (var part in parts)
            {
                current = string.IsNullOrEmpty(current) ? part : $"{current}/{part}";
                branch.Add(current);
            }
        }

        return branch;
    }

    private static IReadOnlyList<string> BuildBranchPathsWithinRoot(string path, string rootPath)
    {
        var normalizedRootPath = NormalizeBrowserPath(rootPath);
        var normalizedPath = NormalizePathWithinRoot(normalizedRootPath, path);
        if (string.Equals(normalizedPath, normalizedRootPath, StringComparison.Ordinal))
        {
            return [normalizedRootPath];
        }

        var rootParts = normalizedRootPath.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        var pathParts = normalizedPath.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        var branch = new List<string> { normalizedRootPath };

        for (var index = rootParts.Length; index < pathParts.Length; index++)
        {
            branch.Add("/" + string.Join("/", pathParts.Take(index + 1)));
        }

        return branch;
    }

    private static string NormalizePathWithinRoot(string normalizedRootPath, string path)
    {
        var candidatePath = NormalizeBrowserPath(path);
        return string.Equals(candidatePath, normalizedRootPath, StringComparison.Ordinal) ||
               candidatePath.StartsWith(normalizedRootPath.TrimEnd('/') + "/", StringComparison.Ordinal)
            ? candidatePath
            : normalizedRootPath;
    }

    private static string NormalizeBrowserPath(string path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return "/";
        }

        var trimmed = path.Trim();
        if (trimmed is "/" or ".")
        {
            return trimmed;
        }

        var hasLeadingSlash = trimmed.StartsWith("/", StringComparison.Ordinal);
        var parts = trimmed.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        var normalizedParts = new List<string>();
        foreach (var part in parts)
        {
            if (part == ".")
            {
                continue;
            }

            if (part == "..")
            {
                if (normalizedParts.Count > 0 && normalizedParts[^1] != "..")
                {
                    normalizedParts.RemoveAt(normalizedParts.Count - 1);
                }
                else if (!hasLeadingSlash)
                {
                    normalizedParts.Add(part);
                }

                continue;
            }

            normalizedParts.Add(part);
        }

        if (normalizedParts.Count == 0)
        {
            return hasLeadingSlash ? "/" : ".";
        }

        return hasLeadingSlash
            ? "/" + string.Join("/", normalizedParts)
            : string.Join("/", normalizedParts);
    }

    private static string CombineBrowserPath(string directoryPath, string name)
    {
        var normalizedDirectoryPath = NormalizeBrowserPath(directoryPath);
        var normalizedName = name.Trim().Trim('/');
        if (normalizedDirectoryPath is "/" or "")
        {
            return "/" + normalizedName;
        }

        if (normalizedDirectoryPath == ".")
        {
            return normalizedName;
        }

        return normalizedDirectoryPath.TrimEnd('/') + "/" + normalizedName;
    }

    private static string GetParentDirectory(string path)
    {
        var normalizedPath = NormalizeBrowserPath(path);
        if (normalizedPath is "/" or ".")
        {
            return normalizedPath;
        }

        var trimmed = normalizedPath.TrimEnd('/');
        var separator = trimmed.LastIndexOf('/');
        return separator <= 0 ? "/" : trimmed[..separator];
    }

    private static string GetPathLabel(string path)
    {
        var normalizedPath = NormalizeBrowserPath(path);
        if (normalizedPath is "/" or ".")
        {
            return normalizedPath;
        }

        var separator = normalizedPath.LastIndexOf('/');
        return separator >= 0 ? normalizedPath[(separator + 1)..] : normalizedPath;
    }

    private static bool IsAncestorPath(string candidatePath, string currentPath)
    {
        if (string.Equals(candidatePath, currentPath, StringComparison.Ordinal))
        {
            return false;
        }

        if (candidatePath == "/")
        {
            return currentPath.StartsWith("/", StringComparison.Ordinal);
        }

        return currentPath.StartsWith(candidatePath + "/", StringComparison.Ordinal);
    }

    private static SftpItem? FindItemByPath(IReadOnlyList<SftpItem> sourceItems, string path) =>
        sourceItems.FirstOrDefault(item => string.Equals(
            NormalizeBrowserPath(item.FullPath),
            NormalizeBrowserPath(path),
            StringComparison.Ordinal));

    private bool IsBlockedDirectoryItem(SftpItem item) =>
        item.ItemType == SftpItemType.Folder &&
        blockedDirectoryPaths.Contains(ResolveBrowserPath(item.FullPath));

    private bool CanUseSuggestedAccessUserForPath(string path)
    {
        if (IsLocalBrowser)
        {
            return false;
        }

        var suggestedUser = GetSuggestedAccessUser(path);
        return !string.IsNullOrWhiteSpace(suggestedUser) &&
               !string.Equals(suggestedUser, connectionUsername, StringComparison.Ordinal);
    }

    private static string? GetSuggestedAccessUser(string path)
    {
        var normalizedPath = NormalizeBrowserPath(path);
        const string homePrefix = "/home/";
        if (!normalizedPath.StartsWith(homePrefix, StringComparison.Ordinal))
        {
            return null;
        }

        var remainder = normalizedPath[homePrefix.Length..];
        var separatorIndex = remainder.IndexOf('/');
        var userName = separatorIndex < 0 ? remainder : remainder[..separatorIndex];
        if (string.IsNullOrWhiteSpace(userName) ||
            userName is "." or ".." ||
            userName.Contains(' ', StringComparison.Ordinal))
        {
            return null;
        }

        return userName;
    }

    private string BuildAccessGuidanceMessage(string path, string? suggestedUser)
    {
        var normalizedPath = ResolveBrowserPath(path);
        if (!string.IsNullOrWhiteSpace(suggestedUser) && !IsLocalBrowser)
        {
            return string.Equals(suggestedUser, connectionUsername, StringComparison.Ordinal)
                ? $"{normalizedPath} looks like {suggestedUser}'s home folder, but the current SSH account still cannot read it. Check that account's permissions or use an explicit terminal/sudo action."
                : $"{normalizedPath} looks like {suggestedUser}'s home folder. Switch to that SSH account and use password or public key auth for that user.";
        }

        return IsLocalBrowser
            ? $"{normalizedPath} is blocked by local filesystem permissions. Use Owner / permissions from a readable parent, or open a terminal and run sudo explicitly."
            : $"{normalizedPath} is blocked by the SSH account currently in use. Use the owning Linux account, save key-based credentials for that account, or open a terminal for explicit sudo/ACL work.";
    }

    private static bool IsAccessDeniedFailure(Exception exception)
    {
        for (Exception? current = exception; current is not null; current = current.InnerException)
        {
            if (current is UnauthorizedAccessException)
            {
                return true;
            }

            var message = current.Message;
            if (string.IsNullOrWhiteSpace(message))
            {
                continue;
            }

            if (message.Contains("Permission denied", StringComparison.OrdinalIgnoreCase) ||
                message.Contains("Access denied", StringComparison.OrdinalIgnoreCase) ||
                message.Contains("not accessible", StringComparison.OrdinalIgnoreCase) ||
                message.Contains("unauthorized", StringComparison.OrdinalIgnoreCase))
            {
                return true;
            }
        }

        return false;
    }

    private static bool IsPathNotFoundFailure(Exception exception)
    {
        for (Exception? current = exception; current is not null; current = current.InnerException)
        {
            if (current is FileAccessPathNotFoundException)
            {
                return true;
            }

            var message = current.Message;
            if (string.IsNullOrWhiteSpace(message))
            {
                continue;
            }

            if (message.Contains("No such file", StringComparison.OrdinalIgnoreCase) ||
                message.Contains("Path not found", StringComparison.OrdinalIgnoreCase) ||
                message.Contains("does not exist", StringComparison.OrdinalIgnoreCase) ||
                message.Contains("was not found", StringComparison.OrdinalIgnoreCase))
            {
                return true;
            }
        }

        return false;
    }

    private static string BuildBrowseFailureMessage(string path, Exception exception, bool isAccessDenied, bool isPathNotFound)
    {
        if (isAccessDenied)
        {
            return $"{path} is not accessible with the current credentials or filesystem permissions.";
        }

        if (isPathNotFound)
        {
            return $"{path} does not exist. Check the path, use a saved shortcut, or open the parent folder.";
        }

        return $"Could not open {path}. {exception.Message}";
    }

    private static string FormatMetadataValue(string value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatBytes(long bytes)
    {
        string[] units = ["B", "KB", "MB", "GB"];
        double value = bytes;
        var unitIndex = 0;

        while (value >= 1024 && unitIndex < units.Length - 1)
        {
            value /= 1024;
            unitIndex++;
        }

        return $"{value:0.#} {units[unitIndex]}";
    }

    private static string FormatPermissionMetadata(SftpItem item) =>
        string.IsNullOrWhiteSpace(item.PermissionsOctal)
            ? FormatMetadataValue(item.Permissions)
            : $"{FormatMetadataValue(item.Permissions)} / {item.PermissionsOctal}";

    private static ArchiveFormat ResolveRequestedArchiveFormat(ArchiveFormat requestedFormat, bool sourceIsDirectory) =>
        requestedFormat == ArchiveFormat.Gzip && sourceIsDirectory
            ? ArchiveFormat.TarGzip
            : requestedFormat;

    private static string EnsureArchiveFileName(string value, ArchiveFormat format, bool sourceIsDirectory)
    {
        var trimmed = value.Trim();
        if (HasArchiveExtensionForFormat(trimmed, format, sourceIsDirectory))
        {
            return trimmed;
        }

        return trimmed + ArchiveFormatSupport.GetExtension(format, sourceIsDirectory);
    }

    private static bool HasArchiveExtensionForFormat(string fileName, ArchiveFormat format, bool sourceIsDirectory) =>
        format switch
        {
            ArchiveFormat.Zip => fileName.EndsWith(".zip", StringComparison.OrdinalIgnoreCase),
            ArchiveFormat.SevenZip => fileName.EndsWith(".7z", StringComparison.OrdinalIgnoreCase),
            ArchiveFormat.Gzip when sourceIsDirectory => fileName.EndsWith(".tar.gz", StringComparison.OrdinalIgnoreCase) || fileName.EndsWith(".tgz", StringComparison.OrdinalIgnoreCase),
            ArchiveFormat.Gzip => fileName.EndsWith(".gz", StringComparison.OrdinalIgnoreCase),
            ArchiveFormat.TarGzip => fileName.EndsWith(".tar.gz", StringComparison.OrdinalIgnoreCase) || fileName.EndsWith(".tgz", StringComparison.OrdinalIgnoreCase),
            ArchiveFormat.Rar => fileName.EndsWith(".rar", StringComparison.OrdinalIgnoreCase),
            _ => false
        };

    private static string RemoveArchiveExtension(string fileName)
    {
        if (fileName.EndsWith(".tar.gz", StringComparison.OrdinalIgnoreCase))
        {
            return fileName[..^7];
        }

        if (fileName.EndsWith(".tgz", StringComparison.OrdinalIgnoreCase))
        {
            return fileName[..^4];
        }

        return Path.GetFileNameWithoutExtension(fileName);
    }

    private static bool LooksLikeTextContent(string content, string fileName)
    {
        if (string.IsNullOrEmpty(content))
        {
            return true;
        }

        var extension = Path.GetExtension(fileName);
        if (KnownTextExtensions.Contains(extension))
        {
            return true;
        }

        var controlCharacterCount = 0;
        foreach (var character in content)
        {
            if (character == '\0')
            {
                return false;
            }

            if (char.IsControl(character) && character is not '\r' and not '\n' and not '\t' and not '\f')
            {
                controlCharacterCount++;
            }
        }

        return controlCharacterCount <= Math.Max(1, content.Length / 40);
    }

    private static string GuessPreviewLanguage(string? fileName)
    {
        var extension = Path.GetExtension(fileName ?? string.Empty);
        return extension.ToLowerInvariant() switch
        {
            ".json" => "JSON",
            ".yaml" or ".yml" => "YAML",
            ".xml" => "XML",
            ".toml" => "TOML",
            ".ini" or ".cfg" or ".conf" => "Config",
            ".env" => "Env",
            ".service" or ".timer" or ".socket" => "Systemd",
            ".sh" or ".bash" or ".zsh" => "Shell",
            ".cs" => "C#",
            ".js" => "JavaScript",
            ".ts" => "TypeScript",
            ".css" => "CSS",
            ".html" or ".htm" => "HTML",
            ".md" => "Markdown",
            ".sql" => "SQL",
            ".py" => "Python",
            ".log" => "Log",
            _ => "Text"
        };
    }

    private static string? ResolveVisualPreviewContentType(string? fileName)
    {
        var extension = Path.GetExtension(fileName ?? string.Empty);
        return VisualPreviewContentTypes.TryGetValue(extension, out var contentType)
            ? contentType
            : null;
    }

    private static string DescribeVisualPreview(string contentType) =>
        contentType.ToLowerInvariant() switch
        {
            "application/pdf" => "PDF preview",
            "image/tiff" => "TIFF preview",
            _ when contentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase) => "Image preview",
            _ => "Preview"
        };

    private string BuildMediaPreviewStreamUrl(Guid itemId)
    {
        var absolute = NavigationManager
            .ToAbsoluteUri($"/api/integrations/media-library/items/{itemId:N}/stream")
            .ToString();
        return AppendMediaPreviewToken(absolute, itemId);
    }

    private string BuildMediaPreviewPlaybackUrl(MediaFilePreviewViewModel preview)
    {
        if (!preview.UsesTranscodedPlayback)
        {
            return BuildMediaPreviewStreamUrl(preview.Item.Id);
        }

        if (preview.Item.MediaKind == MediaKind.Video)
        {
            var hlsAbsolute = NavigationManager
                .ToAbsoluteUri($"/api/integrations/media-library/items/{preview.Item.Id:N}/preview-hls/index.m3u8")
                .ToString();
            return AppendMediaPreviewToken(hlsAbsolute, preview.Item.Id);
        }

        var absolute = NavigationManager
            .ToAbsoluteUri($"/api/integrations/media-library/items/{preview.Item.Id:N}/preview-stream")
            .ToString();
        return AppendMediaPreviewToken(absolute, preview.Item.Id);
    }

    private string? BuildMediaPreviewFallbackPlaybackUrl(MediaFilePreviewViewModel? preview)
    {
        if (preview is null ||
            !preview.UsesTranscodedPlayback ||
            preview.Item.MediaKind != MediaKind.Video)
        {
            return null;
        }

        var absolute = NavigationManager
            .ToAbsoluteUri($"/api/integrations/media-library/items/{preview.Item.Id:N}/preview-webm")
            .ToString();
        return AppendMediaPreviewToken(absolute, preview.Item.Id);
    }

    private string AppendMediaPreviewToken(string absoluteUrl, Guid itemId)
    {
        if (mediaPreview?.UseSignedStreamUrl != true)
        {
            return absoluteUrl;
        }

        var token = MediaLibrarySignedUrlService.CreateStreamToken(
            itemId,
            TimeSpan.FromMinutes(mediaPreview.SignedUrlExpiryMinutes));
        return $"{absoluteUrl}?token={Uri.EscapeDataString(token)}";
    }

