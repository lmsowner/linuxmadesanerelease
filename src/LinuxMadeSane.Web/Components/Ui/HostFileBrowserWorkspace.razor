    private async Task StartBrowserDownloadIfReadyAsync(Guid jobId)
    {
        var launchRequest = FileActionQueueService.TryBeginBrowserDownload(workspaceId, jobId);
        if (launchRequest is null)
        {
            return;
        }

        try
        {
            await JSRuntime.InvokeVoidAsync(
                "lmsFileBrowser.startManagedDownload",
                new BrowserManagedDownloadLaunchDescriptor(
                    $"/internal/file-actions/downloads/{Uri.EscapeDataString(launchRequest.DownloadToken)}/content",
                    $"/internal/file-actions/downloads/{Uri.EscapeDataString(launchRequest.DownloadToken)}/progress",
                    $"/internal/file-actions/downloads/{Uri.EscapeDataString(launchRequest.DownloadToken)}/complete",
                    $"/internal/file-actions/downloads/{Uri.EscapeDataString(launchRequest.DownloadToken)}/cancel",
                    launchRequest.FileName,
                    launchRequest.ContentType,
                    launchRequest.TotalBytes));
        }
        catch (Exception exception)
        {
            SetOperationMessage($"Download failed to start: {exception.Message}. Check File actions for details.", "warning");
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<long> EstimateDirectorySizeAsync(string rootPath)
    {
        long totalBytes = 0;
        var pending = new Stack<string>();
        pending.Push(rootPath);

        while (pending.Count > 0)
        {
            var currentPath = pending.Pop();
            IReadOnlyList<SftpItem> children;
            try
            {
                children = await ListItemsForPathAsync(currentPath);
            }
            catch
            {
                continue;
            }

            foreach (var child in children)
            {
                switch (child.ItemType)
                {
                    case SftpItemType.Folder:
                        pending.Push(ResolveBrowserPath(child.FullPath));
                        break;
                    case SftpItemType.File:
                        totalBytes += Math.Max(0, child.SizeBytes);
                        break;
                }
            }
        }

        return totalBytes;
    }

    private void HandleFileActionChanged(FileActionQueueChangedEvent changeEvent)
    {
        if (!string.Equals(changeEvent.WorkspaceId, workspaceId, StringComparison.Ordinal) ||
            browser is null)
        {
            return;
        }

        _ = InvokeAsync(async () =>
        {
            await StartBrowserDownloadIfReadyAsync(changeEvent.JobId);

            if (changeEvent.Status is not FileActionJobStatus.Succeeded and not FileActionJobStatus.CompletedWithIssues)
            {
                return;
            }

            if (!canBrowse || isBusy || isSearchingFiles)
            {
                return;
            }

            var normalizedCurrentPath = ResolveBrowserPath(currentPath);
            if (!changeEvent.AffectedLocations.Any(location =>
                    location.HostId == browser.Host.Id &&
                    string.Equals(ResolveBrowserPath(location.DirectoryPath), normalizedCurrentPath, StringComparison.Ordinal)))
            {
                return;
            }

            await LoadItemsAsync(currentPath, preserveSessionOnFailure: true, updatePathInputOnSuccess: true, showBusyState: false);
            await InvokeAsync(StateHasChanged);
        });
    }

