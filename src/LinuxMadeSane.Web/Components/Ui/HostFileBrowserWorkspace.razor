    private async Task SearchFilesAsync(FileSearchRequest request)
    {
        if (browser is null || isSearchingFiles)
        {
            return;
        }

        fileSearchCts?.Cancel();
        fileSearchCts?.Dispose();
        fileSearchCts = new CancellationTokenSource();
        var searchCancellation = fileSearchCts;

        isSearchingFiles = true;
        fileSearchRootPath = ResolveBrowserPath(request.RootPath);
        fileSearchStatusMessage = BuildFileSearchStartMessage(request);
        fileSearchStatusTone = "info";
        liveFileSearchResults.Clear();
        liveFileSearchResultPaths.Clear();
        fileSearchResponse = new FileSearchResponse(fileSearchRootPath, [], false);
        QueuePathSuggestionsRefresh(fileSearchRootPath);
        PersistDetachedSearchState();

        try
        {
            var progress = new Progress<FileSearchProgress>(update =>
            {
                if (update.Match is not null &&
                    liveFileSearchResultPaths.Add(update.Match.FullPath))
                {
                    liveFileSearchResults.Add(update.Match);
                    liveFileSearchResults.Sort(static (left, right) =>
                        StringComparer.OrdinalIgnoreCase.Compare(left.FullPath, right.FullPath));
                    fileSearchResponse = new FileSearchResponse(
                        fileSearchRootPath,
                        liveFileSearchResults.ToArray(),
                        false);
                }

                var resultCount = liveFileSearchResults.Count;
                fileSearchStatusMessage = BuildFileSearchProgressMessage(request, update.CurrentPath, resultCount);
                fileSearchStatusTone = "info";
                _ = InvokeAsync(StateHasChanged);
            });

            fileSearchResponse = await SearchFilesInternalAsync(request, progress, searchCancellation.Token);
            fileSearchStatusMessage = fileSearchResponse.Results.Count switch
            {
                0 => "No files or folders matched that search.",
                1 => "Found 1 match.",
                _ => $"Found {fileSearchResponse.Results.Count} matches."
            };

            if (fileSearchResponse.LimitReached)
            {
                fileSearchStatusMessage += " Showing the first 500 results.";
                fileSearchStatusTone = "warning";
            }
            else
            {
                fileSearchStatusTone = "success";
            }
        }
        catch (OperationCanceledException)
        {
            var resultCount = liveFileSearchResults.Count;
            fileSearchResponse = new FileSearchResponse(
                fileSearchRootPath,
                liveFileSearchResults.ToArray(),
                false);
            fileSearchStatusMessage = resultCount switch
            {
                0 => "Search cancelled.",
                1 => "Search cancelled. 1 match found before cancellation.",
                _ => $"Search cancelled. {resultCount} matches found before cancellation."
            };
            fileSearchStatusTone = "warning";
        }
        catch (Exception) when (searchCancellation.IsCancellationRequested)
        {
            var resultCount = liveFileSearchResults.Count;
            fileSearchResponse = new FileSearchResponse(
                fileSearchRootPath,
                liveFileSearchResults.ToArray(),
                false);
            fileSearchStatusMessage = resultCount switch
            {
                0 => "Search cancelled.",
                1 => "Search cancelled. 1 match found before cancellation.",
                _ => $"Search cancelled. {resultCount} matches found before cancellation."
            };
            fileSearchStatusTone = "warning";
        }
        catch (Exception exception)
        {
            fileSearchStatusMessage = exception.Message;
            fileSearchStatusTone = "error";
        }
        finally
        {
            isSearchingFiles = false;
            fileSearchCts?.Dispose();
            fileSearchCts = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private Task CancelFileSearchAsync()
