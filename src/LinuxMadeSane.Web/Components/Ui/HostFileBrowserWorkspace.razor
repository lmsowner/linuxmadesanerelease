@using LinuxMadeSane.Application.Contracts
@using LinuxMadeSane.Application.Contracts.MediaLibrary
@using LinuxMadeSane.Application.Contracts.Shares
@using LinuxMadeSane.Application.Interfaces
@using LinuxMadeSane.Core.Abstractions
@using LinuxMadeSane.Core.Enums
@using LinuxMadeSane.Core.Models
@using LinuxMadeSane.Core.Models.Ai
@using LinuxMadeSane.Core.Models.MediaLibrary
@using LinuxMadeSane.Core.Models.Shares
@using LinuxMadeSane.Infrastructure.Services
@using LinuxMadeSane.Web.Services
@using System.Text.Json
@implements IAsyncDisposable
@inject IManagedHostService HostService
@inject IShareManagementService ShareService
@inject IFileBrowserShortcutService FileBrowserShortcutService
@inject IManagedHostFileAccessService FileAccessService
@inject ITransientConnectionSecretStore ConnectionSecretStore
@inject TerminalWorkspaceAccessor TerminalWorkspaceAccessor
@inject TerminalWorkspaceRegistry TerminalWorkspaceRegistry
@inject FileBrowserWorkspaceRegistry FileBrowserWorkspaceRegistry
@inject FileActionQueueService FileActionQueueService
@inject IMediaLibraryIntegrationService MediaLibraryIntegrationService
@inject MediaLibrarySignedUrlService MediaLibrarySignedUrlService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

@* Guardrail: this workspace goes through IManagedHostFileAccessService and the transient
   secret store only. It must not reintroduce direct local/SFTP/SSH credential plumbing. *@
@if (DetachedWorkspaceUnavailable)
{
    <section class="surface-card">
        <div class="table-header">
            <h2>@DetachedWorkspaceUnavailableTitle</h2>
            <span>Unavailable</span>
        </div>
        <div class="empty-state">
            <p>@DetachedWorkspaceUnavailableMessage</p>
            <p class="meta-text">@DetachedWorkspaceUnavailableHint</p>
        </div>
    </section>
}
else if (browser is null)
{
    <section class="surface-card">
        <h2>Host not found</h2>
    </section>
}
else if (ShowDetachedSearchWorkspace)
{
    <div class="host-file-browser-shell">
        <section class="surface-card host-file-search-workspace">
            <FileSearchDialog Embedded="true"
                              ShowCloseAction="true"
                              ShowPopOutAction="false"
                              RootPath="@fileSearchRootPath"
                              ScopeLabel="@browser.Host.Name"
                              PathSuggestions="@pathSuggestions"
                              IsLoadingPathSuggestions="@isPathSuggestionsLoading"
                              IsBusy="@isSearchingFiles"
                              SearchResponse="@fileSearchResponse"
                              StatusMessage="@fileSearchStatusMessage"
                              StatusTone="@fileSearchStatusTone"
                              RootPathChanged="SetFileSearchRootPathAsync"
                              OnCancel="CancelFileSearchAsync"
                              OnClose="CloseFileSearchDialogAsync"
                              SearchRequested="SearchFilesAsync"
                              OpenLocationRequested="OpenFileSearchLocationAsync"
                              ResultSelected="PreviewFileSearchResultAsync" />
        </section>
    </div>
}
else
{
    <div class="host-file-browser-shell" @onclick="DismissContextMenu">
        <div class="host-file-browser-explorer" @ref="uploadDropTargetElement" @onclick:stopPropagation="true">
            <FileBrowserExplorer Title="@ResolvedExplorerTitle"
                                 RootPath="@EffectiveRootPath"
                                 CurrentPath="@currentPath"
                                 BlockedDirectoryPaths="@blockedDirectoryPaths"
                                 Items="@items"
                                 DirectoryNodes="@directoryNodes"
                                 SelectedPaths="@selectedPaths"
                                 SelectedItem="@selectedItem"
                                 CanBrowse="@canBrowse"
                                 IsBusy="@isBusy"
                                 ShowDetailPanel="@previewPanelOpen"
                                 DetailPanelDock="@previewDock"
                                 DetailPanelSizePx="@previewPanelSizePx"
                                 SidebarCollapsed="@foldersPaneCollapsed"
                                 DetailPanelFocused="@previewPanelFocused"
                                 NotConnectedTitle="Browser not connected"
                                 NotConnectedMessage="@NotConnectedMessage"
                                 BusyTitle="@browseBusyTitle"
                                 BusyMessage="@browseBusyMessage"
                                 RefreshRequested="RefreshCurrentPathAsync"
                                 GoUpRequested="GoUpAsync"
                                 SelectAllRequested="SetAllItemsSelectedAsync"
                                 NavigateRequested="NavigateToPathAsync"
                                 ToggleDirectoryRequested="ToggleDirectoryAsync"
                                 ItemSelectionToggled="ToggleItemSelectionAsync"
                                 ItemSelected="SelectItem"
                                 ContextMenuRequested="OpenContextMenuAsync"
                                 DetailPanelSizeChanged="OnPreviewPanelSizeChangedAsync"
                                 SidebarCollapsedChanged="OnFoldersPaneCollapsedChangedAsync"
                                 DetailPanelFocusedChanged="OnPreviewPanelFocusedChangedAsync">
                <HeaderContent>
                    <div class="host-file-browser-chrome">
                        @if (fileBrowserShortcuts.Count > 0)
                        {
                            <div class="host-file-shortcuts-row" aria-label="Folder shortcuts">
                                @foreach (var shortcut in fileBrowserShortcuts)
                                {
                                    <button type="button"
                                            class="host-file-shortcut @(IsCurrentShortcut(shortcut) ? "active" : null)"
                                            title="@shortcut.TargetPath"
                                            @onclick="@(() => NavigateToShortcutAsync(shortcut))"
                                            @oncontextmenu="@((MouseEventArgs args) => OpenShortcutContextMenuAsync(args, shortcut))"
                                            @oncontextmenu:preventDefault="true"
                                            @oncontextmenu:stopPropagation="true">
                                        <span class="host-file-shortcut-icon" aria-hidden="true">
                                            <UiGlyphIcon Glyph="UiIconGlyph.FolderOpen" />
                                        </span>
                                        <span class="host-file-shortcut-label">@shortcut.Label</span>
                                    </button>
                                }
                            </div>
                        }

                        <div class="host-file-address-row">
                            <UiPathCombobox Value="@pathInput"
                                            ValueChanged="SetPathInputAsync"
                                            CommitRequested="CommitPathInputAsync"
                                            SuggestionSelected="SelectPathSuggestionAsync"
                                            Suggestions="@pathSuggestions"
                                            Placeholder="Enter a folder path"
                                            AriaLabel="Folder path"
                                            Title="@AccessMetaText"
                                            PrefixText="@BrowserPathPrefixText"
                                            PrefixTitle="@BrowserPathPrefixTitle"
                                            IsLoadingSuggestions="@isPathSuggestionsLoading"
                                            EscapeValue="@currentPath" />

                            @if (ShowConnectionIdentityEditor)
                            {
                                <div class="host-file-address-auth @(connectionIdentityEditorOpen ? "open" : null)">
                                    <button type="button"
                                            class="host-file-address-auth-summary"
                                            title="Choose the Linux account this file browser connects as"
                                            disabled="@isBusy"
                                            @onclick="ToggleConnectionIdentityEditorAsync">
                                        <UiGlyphIcon Glyph="UiIconGlyph.User" />
                                        <span>@ConnectionIdentitySummary</span>
                                    </button>
                                    @if (connectionIdentityEditorOpen)
                                    {
                                    <div class="host-file-address-auth-panel">
                                        <p class="host-file-address-auth-help">Choose the Linux account used by this file browser. Saved host credentials are used unless you enter a password or private key here.</p>

                                        <UiTextField @bind-Value="connectionUsername"
                                                     Label="User"
                                                     Compact="true"
                                                     Class="host-file-inline-field" />

                                        <UiTextField @bind-Value="ConnectionPassword"
                                                     Label="Password"
                                                     Type="password"
                                                     Compact="true"
                                                     Class="host-file-inline-field" />

                                        <UiTextAreaField @bind-Value="ConnectionPrivateKey"
                                                         Label="Client private key PEM"
                                                         Rows="5"
                                                         Compact="true"
                                                         Class="host-file-inline-field host-file-inline-field-wide" />

                                        <UiTextField @bind-Value="ConnectionPrivateKeyPassphrase"
                                                     Label="Client key passphrase"
                                                     Type="password"
                                                     Compact="true"
                                                     Class="host-file-inline-field" />

                                        <UiCheckboxField @bind-Value="preferStoredCredentials"
                                                         Label="Use saved credentials"
                                                         Compact="true"
                                                         Class="host-file-checkbox-row" />

                                        <div class="host-file-address-auth-actions">
                                            <UiCommandButton Label="Apply"
                                                             Glyph="UiIconGlyph.Connect"
                                                             Variant="UiButtonVariant.PrimaryMuted"
                                                             Disabled="@isBusy"
                                                             OnClick="ApplyConnectionIdentityAsync" />
                                            <UiCommandButton Label="Host default"
                                                             Glyph="UiIconGlyph.Key"
                                                             Variant="UiButtonVariant.Ghost"
                                                             Disabled="@isBusy"
                                                             OnClick="ResetConnectionIdentityAsync" />
                                        </div>
                                    </div>
                                    }
                                </div>
                            }

                            <span class="host-file-address-status">@browserStatus</span>

                            @if (CanShowPopout)
                            {
                                <UiIconButton Label="Pop out"
                                              Title="Open this browser in a separate window"
                                              Glyph="UiIconGlyph.PopOut"
                                              Variant="UiButtonVariant.Toolbar"
                                              Class="host-file-address-popout"
                                              Disabled="@isBusy"
                                              OnClientPointerDown="@BuildBrowserPopupPrepareScript()"
                                              Href="@(isBusy ? null : BuildDirectBrowserPopupUrl())"
                                              Target="@BuildBrowserPopupName()"
                                              Rel="noopener"
                                              OnClientClick="@BuildPopupOpenScript()" />
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(errorMessage))
                        {
                            <p class="callout @(canBrowse ? "warning" : "error") terminal-callout">@errorMessage</p>
                        }

                        @if (ShowAccessDeniedGuidance)
                        {
                            var suggestedAccessUser = SuggestedAccessUser;
                            <section class="host-file-access-guidance" aria-label="Folder access guidance">
                                <div class="host-file-access-guidance-copy">
                                    <strong>Use the right Linux identity for this folder.</strong>
                                    <span>@BuildAccessGuidanceMessage(accessDeniedPath, suggestedAccessUser)</span>
                                </div>
                                <div class="host-file-access-guidance-actions">
                                    @if (CanUseSuggestedAccessUser)
                                    {
                                        <UiCommandButton Label="@($"Connect as {suggestedAccessUser}")"
                                                         Title="@($"Switch this browser to the {suggestedAccessUser} SSH account and enter that account's credentials.")"
                                                         Glyph="UiIconGlyph.User"
                                                         Variant="UiButtonVariant.PrimaryMuted"
                                                         OnClick="@(() => UseSuggestedAccessUserAsync(accessDeniedPath))" />
                                    }
                                    @if (browser is not null && !IsLocalBrowser)
                                    {
                                        <UiCommandButton Label="Edit credentials"
                                                         Title="Open this host's saved SSH credentials."
                                                         Glyph="UiIconGlyph.Key"
                                                         Variant="UiButtonVariant.Ghost"
                                                         Href="@($"/hosts/{browser.Host.Id}/edit")" />
                                    }
                                    @if (browser is not null)
                                    {
                                        <UiCommandButton Label="Open terminal"
                                                         Title="Use a terminal when you need explicit sudo or ACL changes."
                                                         Glyph="UiIconGlyph.Run"
                                                         Variant="UiButtonVariant.Ghost"
                                                         Href="@($"/hosts/{browser.Host.Id}/terminal")" />
                                    }
                                </div>
                            </section>
                        }

                        @if (!string.IsNullOrWhiteSpace(operationMessage))
                        {
                            <p class="callout @operationMessageTone terminal-callout">@operationMessage</p>
                        }

                        @if (Clipboard is not null)
                        {
                            <section class="surface-subcard host-file-clipboard-strip">
                                <div class="stack-tight">
                                    <strong>@ClipboardSummary</strong>
                                </div>
                                <div class="toolbar-row">
                                    <UiIconButton Label="Clear clipboard"
                                                  Title="Clear clipboard"
                                                  Glyph="UiIconGlyph.Clear"
                                                  Disabled="@isBusy"
                                                  OnClick="ClearClipboardAsync" />
                                </div>
                            </section>
                        }
                    </div>
                </HeaderContent>
                <ToolbarContent>
                    <CompactUIButton Label="Find files"
                                     Glyph="UiIconGlyph.Search"
                                     Disabled="@(!canBrowse || isBusy || isSearchingFiles)"
                                     OnClick="OpenFileSearchFromToolbarAsync" />
                    <CompactUIButton Label="New folder"
                                     Glyph="UiIconGlyph.NewFolder"
                                     Disabled="@(!canBrowse || isBusy)"
                                     OnClick="CreateFolderInCurrentPathAsync" />
                    <CompactUIButton Label="Upload"
                                     Glyph="UiIconGlyph.Upload"
                                     Disabled="@(!CanUploadToCurrentPath || isBusy)"
                                     OnClientClick="@BuildUploadPickerScript(currentPath)" />
                    <CompactUIButton Label="Download"
                                     Glyph="UiIconGlyph.Download"
                                     Disabled="@(!CanDownloadSelection || isBusy)"
                                     OnClick="DownloadSelectionAsync" />
                    <CompactUIButton Label="Actions"
                                     Title="Open file action progress"
                                     Glyph="UiIconGlyph.Run"
                                     Href="@BuildFileActionsPopupUrl()"
                                     Target="@BuildFileActionsPopupTarget()"
                                     Rel="noopener"
                                     OnClientPointerDown="@BuildFileActionsPopupPrepareScript()"
                                     OnClientClick="@BuildFileActionsPopupOpenScript()" />
                    <CompactUIButton Label="Cut"
                                     Title="Cut selected items"
                                     Glyph="UiIconGlyph.Cut"
                                     Disabled="@(!CanCutSelection || isBusy)"
                                     OnClick="CutSelectionAsync" />
                    <CompactUIButton Label="Copy"
                                     Title="Copy selected items"
                                     Glyph="UiIconGlyph.Copy"
                                     Disabled="@(!CanCopySelection || isBusy)"
                                     OnClick="CopySelectionAsync" />
                    @if (Clipboard is not null)
                    {
                        <CompactUIButton Label="Paste"
                                         Title="Paste into this folder"
                                         Glyph="UiIconGlyph.Paste"
                                         Disabled="@(!CanPasteFromClipboard || isBusy)"
                                         OnClick="PasteIntoCurrentPathAsync" />
                    }
                    <CompactUIButton Label="Delete"
                                     Title="Delete selected items"
                                     Glyph="UiIconGlyph.Delete"
                                     Disabled="@(!CanDeleteSelection || isBusy)"
                                     OnClick="DeleteSelectionAsync" />
                    <CompactUIButton Label="@(previewPanelOpen ? "Hide preview" : "Preview")"
                                     Title="Show or hide the preview and text editor panel"
                                     Glyph="UiIconGlyph.TextFile"
                                     HideIcon="@previewPanelOpen"
                                     Disabled="@(!canBrowse)"
                                     OnClick="TogglePreviewPanelAsync" />
                </ToolbarContent>
                <DetailsContent Context="item">
                    <section class="host-file-preview-panel">
                        <header class="host-file-preview-header">
                            <div class="host-file-preview-copy">
                                <div class="host-file-preview-title-row">
                                    <span class="host-file-preview-icon" aria-hidden="true">
                                        <UiGlyphIcon Glyph="@(item.ItemType == SftpItemType.Folder ? UiIconGlyph.FolderOpen : UiIconGlyph.TextFile)" />
                                    </span>
                                    <strong>@item.Name</strong>
                                </div>
                                <div class="toolbar-row host-file-preview-actions">
                                    @if (previewPanelFocused)
                                    {
                                        <UiIconButton Label="Restore browser"
                                                      Title="Restore the file browser alongside this preview"
                                                      Glyph="UiIconGlyph.Dock"
                                                      Variant="UiButtonVariant.Toolbar"
                                                      OnClick="RestorePreviewPanelAsync" />
                                    }
                                    else
                                    {
                                        <UiIconButton Label="Fill browser"
                                                      Title="Fill the file browser with this preview"
                                                      Glyph="UiIconGlyph.Dock"
                                                      Variant="UiButtonVariant.Toolbar"
                                                      OnClick="FocusPreviewPanelAsync" />
                                    }
                                    <UiIconButton Label="Dock bottom"
                                                  Title="Dock preview below the file list"
                                                  Glyph="UiIconGlyph.SplitBottom"
                                                  Variant="UiButtonVariant.Toolbar"
                                                  Disabled="@(previewDock == FileBrowserPreviewDock.Bottom)"
                                                  OnClick="@(() => SetPreviewDockAsync(FileBrowserPreviewDock.Bottom))" />
                                    <UiIconButton Label="Reload preview"
                                                  Title="Reload this file from disk"
                                                  Glyph="UiIconGlyph.Refresh"
                                                  Variant="UiButtonVariant.Toolbar"
                                                  Disabled="@(!CanReloadPreview)"
                                                  OnClick="ReloadPreviewAsync" />
                                    <UiIconButton Label="Revert changes"
                                                  Title="Discard unsaved changes"
                                                  Glyph="UiIconGlyph.Clear"
                                                  Variant="UiButtonVariant.Toolbar"
                                                  Disabled="@(!CanRevertPreview)"
                                                  OnClick="RevertPreviewAsync" />
                                    <UiIconButton Label="Save file"
                                                  Title="Save the edited text back to this file"
                                                  Glyph="UiIconGlyph.Save"
                                                  Variant="UiButtonVariant.Toolbar"
                                                  Disabled="@(!CanSavePreview)"
                                                  OnClick="SavePreviewAsync" />
                                    <UiIconButton Label="Close preview"
                                                  Title="Hide the preview panel"
                                                  Glyph="UiIconGlyph.Clear"
                                                  Variant="UiButtonVariant.Toolbar"
                                                  OnClick="ClosePreviewPanelAsync" />
                                </div>
                                <span class="meta-text file-browser-wrap host-file-preview-path">@item.FullPath</span>
                            </div>
                        </header>

                        <div class="host-file-preview-body">
                            @if (!string.IsNullOrWhiteSpace(previewMessage))
                            {
                                <p class="callout @previewMessageTone terminal-callout">@previewMessage</p>
                            }

                            @if (previewIsLoading)
                            {
                                <div class="empty-state host-file-preview-empty host-file-preview-main">
                                    <h3>Loading preview</h3>
                                    <p>Reading the current file contents.</p>
                                </div>
                            }
                            else if (item.ItemType == SftpItemType.Folder)
                            {
                                @if (IsBlockedDirectoryItem(item))
                                {
                                    var suggestedItemUser = GetSuggestedAccessUser(item.FullPath);
                                    <div class="empty-state host-file-preview-empty host-file-preview-main host-file-access-detail">
                                        <h3>Folder needs a different identity</h3>
                                        <p>@BuildAccessGuidanceMessage(item.FullPath, suggestedItemUser)</p>
                                        <div class="host-file-access-guidance-actions">
                                            @if (CanUseSuggestedAccessUserForPath(item.FullPath))
                                            {
                                                <UiCommandButton Label="@($"Connect as {suggestedItemUser}")"
                                                                 Glyph="UiIconGlyph.User"
                                                                 Variant="UiButtonVariant.PrimaryMuted"
                                                                 OnClick="@(() => UseSuggestedAccessUserAsync(item.FullPath))" />
                                            }
                                            @if (browser is not null && !IsLocalBrowser)
                                            {
                                                <UiCommandButton Label="Edit credentials"
                                                                 Glyph="UiIconGlyph.Key"
                                                                 Variant="UiButtonVariant.Ghost"
                                                                 Href="@($"/hosts/{browser.Host.Id}/edit")" />
                                            }
                                            @if (browser is not null)
                                            {
                                                <UiCommandButton Label="Open terminal"
                                                                 Glyph="UiIconGlyph.Run"
                                                                 Variant="UiButtonVariant.Ghost"
                                                                 Href="@($"/hosts/{browser.Host.Id}/terminal")" />
                                            }
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="empty-state host-file-preview-empty host-file-preview-main">
                                        <h3>Folder selected</h3>
                                        <p>Preview and editing are available for text files. Pick a file to inspect or edit it here.</p>
                                    </div>
                                }
                            }
                            else if (HasMediaPreview && mediaPreview is not null)
                            {
                                <MediaFilePreviewPanel Preview="@mediaPreview"
                                                       PlaybackUrl="@mediaPreviewPlaybackUrl"
                                                       FallbackPlaybackUrl="@BuildMediaPreviewFallbackPlaybackUrl(mediaPreview)"
                                                       StreamUrl="@mediaPreviewStreamUrl"
                                                       Class="host-file-preview-main"
                                                       Copied="HandleMediaPreviewCopiedAsync" />
                            }
                            else if (HasVisualPreview && previewBinaryContent is not null)
                            {
                                <FileVisualPreview FileName="@item.Name"
                                                   ContentType="@previewBinaryContentType"
                                                   ContentBytes="@previewBinaryContent.ContentBytes"
                                                   Class="host-file-preview-main" />
                            }
                            else if (HasArchivePreview)
                            {
                                <div class="host-file-archive-preview host-file-preview-main">
                                    <div class="host-file-archive-preview-head">
                                        <strong>@PreviewArchiveLabel</strong>
                                        <span>@($"{previewArchiveEntries.Count} item{(previewArchiveEntries.Count == 1 ? string.Empty : "s")}")</span>
                                    </div>
                                    <div class="host-file-archive-table-shell">
                                        <table class="host-file-archive-table">
                                            <thead>
                                                <tr>
                                                    <th>Name</th>
                                                    <th>Type</th>
                                                    <th>Size</th>
                                                    <th>Modified</th>
                                                    <th>Path</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var archiveEntry in previewArchiveEntries)
                                                {
                                                    <tr>
                                                        <td>@archiveEntry.Name</td>
                                                        <td>@archiveEntry.ItemType</td>
                                                        <td>@(archiveEntry.ItemType == SftpItemType.Folder ? string.Empty : FormatBytes(archiveEntry.SizeBytes))</td>
                                                        <td>@(archiveEntry.LastModifiedUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? string.Empty)</td>
                                                        <td>@archiveEntry.FullName</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            }
                            else if (!previewIsText)
                            {
                                <div class="empty-state host-file-preview-empty host-file-preview-main">
                                    <h3>Preview unavailable</h3>
                                    <p>This file is not a supported text, PDF, or image preview format, so the editor is disabled to avoid corrupting it.</p>
                                </div>
                            }
                            else
                            {
                                <UiTextCodeEditor Value="@previewText"
                                                  ValueChanged="OnPreviewTextChangedAsync"
                                                  ReadOnly="@IsPreviewReadOnly"
                                                  Disabled="@previewIsSaving"
                                                  Placeholder="File contents"
                                                  Title="@item.FullPath"
                                                  AriaLabel="@($"Editor for {item.Name}")"
                                                  Class="host-file-preview-editor host-file-preview-main" />
                            }
                        </div>

                        <footer class="host-file-preview-footer">
                            <div class="host-file-preview-pill-row">
                                <UiPill Tone="UiPillTone.Neutral" Class="host-file-preview-pill">@item.ItemType</UiPill>
                                <UiPill Tone="UiPillTone.Neutral" Class="host-file-preview-pill">@FormatPermissionMetadata(item)</UiPill>
                                @if (previewIsText)
                                {
                                    <UiPill Tone="UiPillTone.Neutral" Class="host-file-preview-pill">@PreviewLanguageLabel</UiPill>
                                }
                                else if (HasVisualPreview)
                                {
                                    <UiPill Tone="UiPillTone.Neutral" Class="host-file-preview-pill">@PreviewVisualLabel</UiPill>
                                }
                                else if (HasArchivePreview)
                                {
                                    <UiPill Tone="UiPillTone.Neutral" Class="host-file-preview-pill">@PreviewArchiveLabel</UiPill>
                                }
                                else if (HasMediaPreview)
                                {
                                    <UiPill Tone="UiPillTone.Neutral" Class="host-file-preview-pill">Media stream</UiPill>
                                }
                                @if (HasUnsavedPreviewChanges)
                                {
                                    <UiPill Tone="UiPillTone.Warning" Class="host-file-preview-pill">Unsaved</UiPill>
                                }
                                <UiPill Tone="UiPillTone.Neutral" Class="host-file-preview-pill">Owner: @FormatMetadataValue(item.OwnerName)</UiPill>
                                <UiPill Tone="UiPillTone.Neutral" Class="host-file-preview-pill">Group: @FormatMetadataValue(item.GroupName)</UiPill>
                                <UiPill Tone="UiPillTone.Neutral" Class="host-file-preview-pill">Size: @FormatBytes(item.SizeBytes)</UiPill>
                                <UiPill Tone="UiPillTone.Neutral" Class="host-file-preview-pill">Modified: @(item.LastModifiedUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "n/a")</UiPill>
                            </div>
                        </footer>
                    </section>
                </DetailsContent>
            </FileBrowserExplorer>
        </div>

        @if (contextMenuRequest is not null)
        {
            <button class="host-file-browser-context-backdrop"
                    type="button"
                    aria-label="Close file actions"
                    @onclick="DismissContextMenu"
                    @oncontextmenu="DismissContextMenu"
                    @oncontextmenu:preventDefault="true"></button>
            <div class="host-file-browser-context-menu"
                 data-lms-context-menu="true"
                 data-context-x="@contextMenuRequest.ClientX"
                 data-context-y="@contextMenuRequest.ClientY"
                 style="@ContextMenuStyle"
                 @onclick:stopPropagation="true"
                 @oncontextmenu:preventDefault="true"
                 @oncontextmenu:stopPropagation="true">
                <UiContextMenuButton Label="Copy" Glyph="UiIconGlyph.Copy" OnClick="CopyFromContextMenuAsync" Disabled="@(!CanCopyOrCutContextTarget || isBusy)" />
                <UiContextMenuButton Label="Cut" Glyph="UiIconGlyph.Cut" OnClick="CutFromContextMenuAsync" Disabled="@(!CanCopyOrCutContextTarget || isBusy)" />
                <UiContextMenuButton Label="Paste" Glyph="UiIconGlyph.Paste" OnClick="PasteFromContextMenuAsync" Disabled="@(!CanPasteIntoContextTarget || isBusy)" />
                <UiContextMenuButton Label="Upload here" Glyph="UiIconGlyph.Upload" OnClientClick="@BuildContextUploadPickerScript()" Disabled="@(!CanUploadIntoContextTarget || isBusy)" />
                <UiContextMenuButton Label="Download" Glyph="UiIconGlyph.Download" OnClick="DownloadFromContextMenuAsync" Disabled="@(!CanDownloadContextTarget || isBusy)" />
                <UiContextMenuButton Label="New folder" Glyph="UiIconGlyph.NewFolder" OnClick="CreateFolderFromContextMenuAsync" Disabled="@(!CanCreateFolderFromContextMenu || isBusy)" />
                <UiContextMenuButton Label="Find files" Glyph="UiIconGlyph.Search" OnClick="OpenFileSearchFromContextMenuAsync" Disabled="@(!CanOpenFileSearchFromContextMenu || isBusy)" />
                <UiContextMenuButton Label="Open Terminal Here" Glyph="UiIconGlyph.Run" OnClick="OpenTerminalHereFromContextMenuAsync" Disabled="@(!CanOpenTerminalFromContextMenu || isBusy)" />
                @if (CanBrowseAsContextSuggestedUser)
                {
                    <UiContextMenuButton Label="@BrowseAsContextSuggestedUserLabel"
                                         Title="Switch this browser to that Linux account and enter that account's credentials."
                                         Glyph="UiIconGlyph.User"
                                         OnClick="UseContextSuggestedUserAsync"
                                         Disabled="@isBusy" />
                }
                @if (CanCreateShortcutFromContextMenu)
                {
                    <UiContextMenuButton Label="Create shortcut" Glyph="UiIconGlyph.FolderClosed" OnClick="CreateShortcutFromContextMenuAsync" Disabled="@isBusy" />
                }
                <UiContextMenuButton Label="Share folder" Title="Create or adjust an LMS Samba share for this local folder" Glyph="UiIconGlyph.FolderOpen" OnClick="OpenShareFolderFromContextMenuAsync" Disabled="@(!CanOpenShareFolderFromContextMenu || isBusy)" />
                <UiContextMenuButton Label="Add network mount" Title="Map an SMB/CIFS share onto this LMS server" Glyph="UiIconGlyph.NetworkMount" OnClick="OpenShareMappingFromContextMenuAsync" Disabled="@(!CanOpenShareMappingFromContextMenu || isBusy)" />
                <UiContextMenuButton Label="Owner / permissions" Title="Review or change owner, group, and octal permissions for this item" Glyph="UiIconGlyph.Edit" OnClick="OpenOwnershipPermissionsFromContextMenuAsync" Disabled="@(!CanOpenOwnershipPermissionsFromContextMenu || isBusy)" />
                <UiContextMenuButton Label="Rename" Glyph="UiIconGlyph.Edit" OnClick="RenameFromContextMenuAsync" Disabled="@(!CanRenameContextTarget || isBusy)" />
                <div class="host-file-context-submenu">
                    <button class="ui-context-menu-button host-file-context-submenu-trigger"
                            type="button"
                            title="Compress"
                            aria-haspopup="menu"
                            disabled="@(!canBrowse || isBusy || !CanCompressContextTarget)">
                        <span class="ui-context-menu-button-icon" aria-hidden="true">
                            <UiGlyphIcon Glyph="UiIconGlyph.Zip" />
                        </span>
                        <span class="ui-context-menu-button-label">Compress</span>
                    </button>
                    <div class="host-file-context-submenu-panel">
                        <UiContextMenuButton Label="Zip" Glyph="UiIconGlyph.Zip" OnClick="@(() => CompressFromContextMenuAsync(ArchiveFormat.Zip))" Disabled="@(!canBrowse || isBusy || !CanCompressContextTarget)" />
                        <UiContextMenuButton Label="7Zip" Title="Requires 7z or 7zz on the selected host" Glyph="UiIconGlyph.Zip" OnClick="@(() => CompressFromContextMenuAsync(ArchiveFormat.SevenZip))" Disabled="@(!canBrowse || isBusy || !CanCompressContextTarget)" />
                        <UiContextMenuButton Label="Gzip" Title="Folders are compressed as .tar.gz" Glyph="UiIconGlyph.Zip" OnClick="@(() => CompressFromContextMenuAsync(ArchiveFormat.Gzip))" Disabled="@(!canBrowse || isBusy || !CanCompressContextTarget)" />
                        <UiContextMenuButton Label="RAR" Title="Requires rar on the selected host" Glyph="UiIconGlyph.Zip" OnClick="@(() => CompressFromContextMenuAsync(ArchiveFormat.Rar))" Disabled="@(!canBrowse || isBusy || !CanCompressContextTarget)" />
                    </div>
                </div>
                <UiContextMenuButton Label="Uncompress" Glyph="UiIconGlyph.Unzip" OnClick="UncompressFromContextMenuAsync" Disabled="@(!CanUncompressContextTarget || isBusy)" />
                <UiContextMenuButton Label="Delete" Glyph="UiIconGlyph.Delete" OnClick="DeleteFromContextMenuAsync" Disabled="@(!CanDeleteContextTarget || isBusy)" />
                @if (CanShowPopout)
                {
                    <UiContextMenuButton Label="Pop out"
                                         Glyph="UiIconGlyph.PopOut"
                                         OnClientPointerDown="@BuildBrowserPopupPrepareScript()"
                                         Href="@(isBusy ? null : BuildDirectBrowserPopupUrl())"
                                         Target="@BuildBrowserPopupName()"
                                         Rel="noopener"
                                         OnClientClick="@BuildPopupOpenScript()"
                                         Disabled="@isBusy" />
                }
            </div>
        }

        @if (shortcutContextShortcut is not null)
        {
            <button class="host-file-browser-context-backdrop"
                    type="button"
                    aria-label="Close shortcut actions"
                    @onclick="DismissContextMenu"
                    @oncontextmenu="DismissContextMenu"
                    @oncontextmenu:preventDefault="true"></button>
            <div class="host-file-browser-context-menu"
                 data-lms-context-menu="true"
                 data-context-x="@shortcutContextX"
                 data-context-y="@shortcutContextY"
                 style="@ShortcutContextMenuStyle"
                 @onclick:stopPropagation="true"
                 @oncontextmenu:preventDefault="true"
                 @oncontextmenu:stopPropagation="true">
                <UiContextMenuButton Label="Rename" Glyph="UiIconGlyph.Edit" OnClick="OpenRenameShortcutDialogAsync" />
                <UiContextMenuButton Label="Move up" Glyph="UiIconGlyph.SidebarExpand" OnClick="MoveShortcutUpAsync" Disabled="@(!CanMoveShortcutUp)" />
                <UiContextMenuButton Label="Move down" Glyph="UiIconGlyph.SidebarCollapse" OnClick="MoveShortcutDownAsync" Disabled="@(!CanMoveShortcutDown)" />
                <UiContextMenuButton Label="Delete" Glyph="UiIconGlyph.Delete" OnClick="DeleteShortcutAsync" />
            </div>
        }

        <UiModal IsOpen="@showOwnershipPermissionsModal"
                 Title="Owner / Permissions"
                 Subtitle="@OwnershipPermissionsSubtitle"
                 Class="host-file-permissions-modal"
                 CloseOnBackdrop="false"
                 OnClose="CloseOwnershipPermissionsDialogAsync">
            <ChildContent>
                @if (ownershipPermissionsTargetItem is not null)
                {
                    <EditForm Model="@ownershipPermissionsEditor" OnSubmit="SaveOwnershipPermissionsAsync" id="@ownershipPermissionsFormId">
                        <div class="host-file-permissions-layout">
                            <section class="surface-subcard host-file-permissions-card">
                                <div class="host-file-permissions-card-header">
                                    <div class="stack-tight">
                                        <h3>Current settings</h3>
                                        <p class="meta-text file-browser-wrap">@OwnershipPermissionsSelectionSummary</p>
                                    </div>
                                </div>

                                <dl class="host-file-permissions-current-grid">
                                    <div class="host-file-permissions-current-row">
                                        <dt>Owner</dt>
                                        <dd>@FormatMetadataValue(ownershipPermissionsTargetItem.OwnerName)</dd>
                                    </div>
                                    <div class="host-file-permissions-current-row">
                                        <dt>Group</dt>
                                        <dd>@FormatMetadataValue(ownershipPermissionsTargetItem.GroupName)</dd>
                                    </div>
                                    <div class="host-file-permissions-current-row">
                                        <dt>Symbolic</dt>
                                        <dd>@FormatPermissionMetadata(ownershipPermissionsTargetItem)</dd>
                                    </div>
                                    <div class="host-file-permissions-current-row">
                                        <dt>Numeric</dt>
                                        <dd>@GetCurrentOwnershipPermissionsOctal()</dd>
                                    </div>
                                </dl>

                                <p class="meta-text host-file-permissions-summary">@DescribeCurrentOwnershipPermissions()</p>
                            </section>

                            <section class="surface-subcard host-file-permissions-card">
                                <div class="host-file-permissions-card-header">
                                    <div class="stack-tight">
                                        <h3>New settings</h3>
                                        <p class="meta-text">@OwnershipPermissionsApplySummary</p>
                                    </div>
                                </div>

                                <div class="host-file-permissions-editor-grid">
                                    @if (CanUseOwnershipPermissionSelectors)
                                    {
                                        <UiComboboxField TValue="string"
                                                       Label="Owner"
                                                       Helper="Owner account"
                                                       Value="@ownershipPermissionsEditor.OwnerName"
                                                       ValueChanged="SetOwnershipPermissionsOwnerAsync"
                                                       ValueExpression="@(() => ownershipPermissionsEditor.OwnerName)"
                                                       Compact="true"
                                                       Class="host-file-permissions-field">
                                            @foreach (var owner in OwnershipPermissionOwnerOptions)
                                            {
                                                <option value="@owner">@owner</option>
                                            }
                                        </UiComboboxField>

                                        <UiComboboxField TValue="string"
                                                       Label="Group"
                                                       Helper="Filesystem group"
                                                       Value="@ownershipPermissionsEditor.GroupName"
                                                       ValueChanged="SetOwnershipPermissionsGroupAsync"
                                                       ValueExpression="@(() => ownershipPermissionsEditor.GroupName)"
                                                       Compact="true"
                                                       Class="host-file-permissions-field">
                                            @foreach (var group in OwnershipPermissionGroupOptions)
                                            {
                                                <option value="@group">@group</option>
                                            }
                                        </UiComboboxField>
                                    }
                                    else
                                    {
                                        <UiTextField Label="Owner"
                                                     Helper="Owner account"
                                                     Value="@ownershipPermissionsEditor.OwnerName"
                                                     ValueChanged="SetOwnershipPermissionsOwnerAsync"
                                                     ValueExpression="@(() => ownershipPermissionsEditor.OwnerName)"
                                                     Compact="true"
                                                     Class="host-file-permissions-field" />

                                        <UiTextField Label="Group"
                                                     Helper="Filesystem group"
                                                     Value="@ownershipPermissionsEditor.GroupName"
                                                     ValueChanged="SetOwnershipPermissionsGroupAsync"
                                                     ValueExpression="@(() => ownershipPermissionsEditor.GroupName)"
                                                     Compact="true"
                                                     Class="host-file-permissions-field" />
                                    }
                                </div>

                                <div class="host-file-permissions-mode-shell">
                                    <div class="host-file-permissions-mode-header">
                                        <UiTextField Label="Numeric permissions"
                                                     Helper="Octal such as 775 or 2775"
                                                     Value="@ownershipPermissionsEditor.PermissionsOctal"
                                                     ValueChanged="SetOwnershipPermissionsOctalAsync"
                                                     ValueExpression="@(() => ownershipPermissionsEditor.PermissionsOctal)"
                                                     Compact="true"
                                                     Class="host-file-permissions-field host-file-permissions-octal-field" />

                                        <div class="host-file-permissions-mode-preview">
                                            <span>@GetEditedOwnershipPermissionsSymbolic()</span>
                                            <p class="meta-text">@DescribeEditedOwnershipPermissions()</p>
                                        </div>
                                    </div>

                                    <table class="host-file-permissions-toggle-table">
                                        <thead>
                                            <tr>
                                                <th scope="col"></th>
                                                <th scope="col">Read</th>
                                                <th scope="col">Write</th>
                                                <th scope="col">Execute</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <th scope="row">Owner</th>
                                                <td>
                                                    <UiCompactCheckbox Label="Owner read"
                                                                       Value="@IsOwnershipPermissionBitEnabled(0, 4)"
                                                                       ValueChanged="@((bool value) => SetOwnershipPermissionBitAsync(0, 4, value))"
                                                                       Class="host-file-permissions-compact-toggle" />
                                                </td>
                                                <td>
                                                    <UiCompactCheckbox Label="Owner write"
                                                                       Value="@IsOwnershipPermissionBitEnabled(0, 2)"
                                                                       ValueChanged="@((bool value) => SetOwnershipPermissionBitAsync(0, 2, value))"
                                                                       Class="host-file-permissions-compact-toggle" />
                                                </td>
                                                <td>
                                                    <UiCompactCheckbox Label="Owner execute"
                                                                       Value="@IsOwnershipPermissionBitEnabled(0, 1)"
                                                                       ValueChanged="@((bool value) => SetOwnershipPermissionBitAsync(0, 1, value))"
                                                                       Class="host-file-permissions-compact-toggle" />
                                                </td>
                                            </tr>
                                            <tr>
                                                <th scope="row">Group</th>
                                                <td>
                                                    <UiCompactCheckbox Label="Group read"
                                                                       Value="@IsOwnershipPermissionBitEnabled(1, 4)"
                                                                       ValueChanged="@((bool value) => SetOwnershipPermissionBitAsync(1, 4, value))"
                                                                       Class="host-file-permissions-compact-toggle" />
                                                </td>
                                                <td>
                                                    <UiCompactCheckbox Label="Group write"
                                                                       Value="@IsOwnershipPermissionBitEnabled(1, 2)"
                                                                       ValueChanged="@((bool value) => SetOwnershipPermissionBitAsync(1, 2, value))"
                                                                       Class="host-file-permissions-compact-toggle" />
                                                </td>
                                                <td>
                                                    <UiCompactCheckbox Label="Group execute"
                                                                       Value="@IsOwnershipPermissionBitEnabled(1, 1)"
                                                                       ValueChanged="@((bool value) => SetOwnershipPermissionBitAsync(1, 1, value))"
                                                                       Class="host-file-permissions-compact-toggle" />
                                                </td>
                                            </tr>
                                            <tr>
                                                <th scope="row">Everyone</th>
                                                <td>
                                                    <UiCompactCheckbox Label="Everyone read"
                                                                       Value="@IsOwnershipPermissionBitEnabled(2, 4)"
                                                                       ValueChanged="@((bool value) => SetOwnershipPermissionBitAsync(2, 4, value))"
                                                                       Class="host-file-permissions-compact-toggle" />
                                                </td>
                                                <td>
                                                    <UiCompactCheckbox Label="Everyone write"
                                                                       Value="@IsOwnershipPermissionBitEnabled(2, 2)"
                                                                       ValueChanged="@((bool value) => SetOwnershipPermissionBitAsync(2, 2, value))"
                                                                       Class="host-file-permissions-compact-toggle" />
                                                </td>
                                                <td>
                                                    <UiCompactCheckbox Label="Everyone execute"
                                                                       Value="@IsOwnershipPermissionBitEnabled(2, 1)"
                                                                       ValueChanged="@((bool value) => SetOwnershipPermissionBitAsync(2, 1, value))"
                                                                       Class="host-file-permissions-compact-toggle" />
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>

                                    <div class="host-file-permissions-special-grid">
                                        <div class="host-file-permissions-special-card">
                                            <div class="host-file-permissions-special-toggle">
                                                <UiCompactCheckbox Label="Setuid"
                                                                   Value="@IsOwnershipSpecialBitEnabled(4)"
                                                                   ValueChanged="@((bool value) => SetOwnershipSpecialBitAsync(4, value))"
                                                                   Class="host-file-permissions-compact-toggle" />
                                                <span class="host-file-permissions-special-title">Setuid</span>
                                            </div>
                                            <span class="host-file-permissions-special-copy">Executable runs as the file owner.</span>
                                        </div>

                                        <div class="host-file-permissions-special-card">
                                            <div class="host-file-permissions-special-toggle">
                                                <UiCompactCheckbox Label="Setgid"
                                                                   Value="@IsOwnershipSpecialBitEnabled(2)"
                                                                   ValueChanged="@((bool value) => SetOwnershipSpecialBitAsync(2, value))"
                                                                   Class="host-file-permissions-compact-toggle" />
                                                <span class="host-file-permissions-special-title">Setgid</span>
                                            </div>
                                            <span class="host-file-permissions-special-copy">Folders keep new files in this group. Executables run as this group.</span>
                                        </div>

                                        <div class="host-file-permissions-special-card">
                                            <div class="host-file-permissions-special-toggle">
                                                <UiCompactCheckbox Label="Sticky bit"
                                                                   Value="@IsOwnershipSpecialBitEnabled(1)"
                                                                   ValueChanged="@((bool value) => SetOwnershipSpecialBitAsync(1, value))"
                                                                   Class="host-file-permissions-compact-toggle" />
                                                <span class="host-file-permissions-special-title">Sticky bit</span>
                                            </div>
                                            <span class="host-file-permissions-special-copy">In shared folders, users usually delete only their own files.</span>
                                        </div>
                                    </div>
                                </div>

                                @if (OwnershipPermissionsHasFolderTargets)
                                {
                                    <UiCheckboxField Label="Apply recursively"
                                                     Helper="@OwnershipPermissionsRecursiveHelper"
                                                     Value="@ownershipPermissionsEditor.ApplyRecursively"
                                                     ValueChanged="SetOwnershipPermissionsRecursiveAsync"
                                                     ValueExpression="@(() => ownershipPermissionsEditor.ApplyRecursively)"
                                                     Compact="true"
                                                     Class="host-file-permissions-recursive" />
                                }
                            </section>
                        </div>
                    </EditForm>
                }
            </ChildContent>
            <Footer>
                <div class="host-file-permissions-footer">
                    @if (!string.IsNullOrWhiteSpace(ownershipPermissionsStatusMessage))
                    {
                        <p class="callout @ownershipPermissionsStatusTone host-file-permissions-status">@ownershipPermissionsStatusMessage</p>
                    }

                    <div class="host-file-permissions-actions">
                        <UiCommandButton Label="Cancel"
                                         Glyph="UiIconGlyph.Clear"
                                         Variant="UiButtonVariant.Ghost"
                                         Disabled="@isSavingOwnershipPermissions"
                                         OnClick="CloseOwnershipPermissionsDialogAsync" />
                        <UiCommandButton Label="@(isSavingOwnershipPermissions ? "Applying..." : "Apply changes")"
                                         Glyph="UiIconGlyph.Save"
                                         Disabled="@isSavingOwnershipPermissions"
                                         Type="submit"
                                         form="@ownershipPermissionsFormId" />
                    </div>
                </div>
            </Footer>
        </UiModal>

        <UiModal IsOpen="@showShareMappingModal"
                 Title="Add network mount"
                 Subtitle="Map an SMB/CIFS share onto the LMS server, then browse it from the file browser."
                 Class="share-mapping-modal"
                 OnClose="CloseShareMappingModal">
            <ShareMappingForm Editor="@shareMappingEditor"
                              PreferredMountPath="@shareMappingPreferredPath"
                              StatusMessage="@shareMappingStatusMessage"
                              StatusTone="@shareMappingStatusTone"
                              IsBusy="@isCreatingShareMapping"
                              PermanentSubmitLabel="Create permanent mount"
                              TemporarySubmitLabel="Mount temporarily and browse"
                              OnCreateMount="CreateShareMappingAsync" />
        </UiModal>

        <UiModal IsOpen="@showDeleteConfirmModal"
                 Title="@DeleteConfirmTitle"
                 Subtitle="@DeleteConfirmSubtitle"
                 Class="host-file-delete-modal"
                 OnClose="CloseDeleteConfirmModalAsync">
            <ChildContent>
                <div class="host-file-delete-layout">
                    <section class="surface-subcard host-file-delete-card">
                        <div class="host-file-delete-card-header">
                            <div class="stack-tight">
                                <h3>Items to remove</h3>
                                <p class="meta-text">@DeleteConfirmSelectionSummary</p>
                            </div>
                        </div>

                        <div class="host-file-delete-item-list">
                            @foreach (var item in deleteConfirmItems.Take(6))
                            {
                                <div class="host-file-delete-item-row">
                                    <span class="host-file-delete-item-name">@item.DisplayName</span>
                                    <span class="meta-text host-file-delete-item-kind">@(item.IsDirectory ? "Folder" : "File")</span>
                                </div>
                            }
                            @if (deleteConfirmItems.Count > 6)
                            {
                                <p class="meta-text host-file-delete-overflow">+@(deleteConfirmItems.Count - 6) more</p>
                            }
                        </div>
                    </section>

                    <p class="callout warning">@DeleteConfirmImpactMessage</p>

                    <div class="toolbar-row host-file-delete-actions">
                        <UiCommandButton Label="Cancel"
                                         Glyph="UiIconGlyph.Clear"
                                         Variant="UiButtonVariant.Ghost"
                                         OnClick="CloseDeleteConfirmModalAsync" />
                        <UiCommandButton Label="@DeleteConfirmButtonLabel"
                                         Glyph="UiIconGlyph.Delete"
                                         Variant="UiButtonVariant.Danger"
                                         OnClick="ConfirmDeleteAsync" />
                    </div>
                </div>
            </ChildContent>
        </UiModal>

        <UiModal IsOpen="@showRenameItemModal"
                 Title="@RenameItemTitle"
                 Subtitle="@RenameItemSubtitle"
                 Class="host-file-rename-modal"
                 OnClose="CloseRenameItemModalAsync">
            <ChildContent>
                <div class="host-file-rename-layout">
                    <section class="surface-subcard host-file-rename-card">
                        <div class="host-file-rename-card-header">
                            <div class="stack-tight">
                                <h3>New name</h3>
                                <p class="meta-text">@renameTargetPath</p>
                            </div>
                        </div>

                        <UiTextField Label="Name"
                                     Helper="Keep the same parent folder. Only the item name changes."
                                     Value="@renameEntryName"
                                     ValueChanged="SetRenameEntryNameAsync"
                                     ValueExpression="@(() => renameEntryName)"
                                     Compact="true"
                                     Class="host-file-rename-field" />
                    </section>

                    @if (!string.IsNullOrWhiteSpace(renameStatusMessage))
                    {
                        <p class="callout @renameStatusTone">@renameStatusMessage</p>
                    }

                    <div class="toolbar-row host-file-rename-actions">
                        <UiCommandButton Label="Cancel"
                                         Glyph="UiIconGlyph.Clear"
                                         Variant="UiButtonVariant.Ghost"
                                         Disabled="@isRenamingItem"
                                         OnClick="CloseRenameItemModalAsync" />
                        <UiCommandButton Label="@(isRenamingItem ? "Renaming..." : "Rename")"
                                         Glyph="UiIconGlyph.Edit"
                                         Disabled="@isRenamingItem"
                                         OnClick="ConfirmRenameItemAsync" />
                    </div>
                </div>
            </ChildContent>
        </UiModal>

        <UiModal IsOpen="@showRenameShortcutModal"
                 Title="Rename shortcut"
                 Subtitle="@RenameShortcutSubtitle"
                 Class="host-file-rename-modal"
                 OnClose="CloseRenameShortcutModalAsync">
            <ChildContent>
                <div class="host-file-rename-layout">
                    <section class="surface-subcard host-file-rename-card">
                        <div class="host-file-rename-card-header">
                            <div class="stack-tight">
                                <h3>Shortcut label</h3>
                                <p class="meta-text">@renameShortcutTarget?.TargetPath</p>
                            </div>
                        </div>

                        <UiTextField Label="Label"
                                     Helper="This only changes the shortcut name shown in the browser."
                                     Value="@renameShortcutLabel"
                                     ValueChanged="SetRenameShortcutLabelAsync"
                                     ValueExpression="@(() => renameShortcutLabel)"
                                     Compact="true"
                                     Class="host-file-rename-field" />
                    </section>

                    <div class="toolbar-row host-file-rename-actions">
                        <UiCommandButton Label="Cancel"
                                         Glyph="UiIconGlyph.Clear"
                                         Variant="UiButtonVariant.Ghost"
                                         Disabled="@isRenamingShortcut"
                                         OnClick="CloseRenameShortcutModalAsync" />
                        <UiCommandButton Label="@(isRenamingShortcut ? "Renaming..." : "Rename")"
                                         Glyph="UiIconGlyph.Edit"
                                         Disabled="@isRenamingShortcut"
                                         OnClick="ConfirmRenameShortcutAsync" />
                    </div>
                </div>
            </ChildContent>
        </UiModal>

        <FileSearchDialog IsOpen="@showFileSearchDialog"
                          RootPath="@fileSearchRootPath"
                          ScopeLabel="@browser?.Host.Name"
                          PathSuggestions="@pathSuggestions"
                          IsLoadingPathSuggestions="@isPathSuggestionsLoading"
                          IsBusy="@isSearchingFiles"
                          SearchResponse="@fileSearchResponse"
                          StatusMessage="@fileSearchStatusMessage"
                          StatusTone="@fileSearchStatusTone"
                          ShowPopOutAction="@CanShowPopout"
                          RootPathChanged="SetFileSearchRootPathAsync"
                          OnCancel="CancelFileSearchAsync"
                          OnClose="CloseFileSearchDialogAsync"
                          PopOutClientClick="@BuildSearchPopupPrepareScript()"
                          OnPopOut="OpenFileSearchPopupAsync"
                          SearchRequested="SearchFilesAsync"
                          OpenLocationRequested="OpenFileSearchLocationAsync"
                          ResultSelected="PreviewFileSearchResultAsync" />

        <ShareEditorDialog IsOpen="@showShareFolderDialog"
                           Editor="@shareFolderEditor"
                           Identities="@shareFolderIdentities"
                           StatusMessage="@shareFolderStatusMessage"
                           StatusTone="@shareFolderStatusTone"
                           IsBusy="@(isSavingShareFolder || isDeletingShareFolder)"
                           ShowCreateAnother="false"
                           OnClose="CloseShareFolderDialogAsync"
                           OnSave="SaveShareFolderAsync"
                           OnDelete="DeleteShareFolderAsync"
                           OnCreateAnother="CloseShareFolderDialogAsync" />
    </div>
}

@code {
    [Parameter] public Guid? HostId { get; set; }
    [Parameter] public string? RootPath { get; set; }
    [Parameter] public string? InitialPath { get; set; }
    [Parameter] public string Title { get; set; } = "Filesystem explorer";
    [Parameter] public bool AllowPopout { get; set; } = true;
    [Parameter] public Guid? DetachedBrowserId { get; set; }
    [Parameter] public Guid? DetachedSearchId { get; set; }
    [Parameter] public string? WorkspaceId { get; set; }
    [Parameter] public string? ConnectionUsernameOverride { get; set; }
    [Parameter] public Guid? ConnectionSecretHandle { get; set; }
    [Parameter] public bool? PreferStoredCredentialsOverride { get; set; }

    private const int PreviewMaxBytes = 262_144;
    private const int VisualPreviewMaxBytes = 20_971_520;
    private const int ArchivePreviewMaxEntries = 500;
    private const int MaxUploadFileCount = 100;
    private const long MaxUploadFileBytes = 10L * 1024L * 1024L * 1024L;
    private const long FolderDownloadWarningBytes = 50L * 1024L * 1024L;
    private readonly string ownershipPermissionsFormId = $"host-file-permissions-{Guid.NewGuid():N}";
    private static readonly HashSet<string> KnownTextExtensions = new(StringComparer.OrdinalIgnoreCase)
    {
        ".txt", ".md", ".json", ".yaml", ".yml", ".xml", ".html", ".htm", ".css", ".scss", ".less",
        ".js", ".ts", ".jsx", ".tsx", ".cs", ".py", ".sh", ".bash", ".zsh", ".ini", ".cfg", ".conf",
        ".config", ".toml", ".env", ".properties", ".service", ".socket", ".timer", ".target",
        ".mount", ".path", ".log", ".sql", ".csv", ".tsv", ".svg"
    };
    private static readonly IReadOnlyDictionary<string, string> VisualPreviewContentTypes = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        [".pdf"] = "application/pdf",
        [".png"] = "image/png",
        [".jpg"] = "image/jpeg",
        [".jpeg"] = "image/jpeg",
        [".jfif"] = "image/jpeg",
        [".gif"] = "image/gif",
        [".bmp"] = "image/bmp",
        [".webp"] = "image/webp",
        [".avif"] = "image/avif",
        [".ico"] = "image/x-icon",
        [".tif"] = "image/tiff",
        [".tiff"] = "image/tiff"
    };

    private SftpBrowserViewModel? browser;
    private SftpItem? selectedItem;
    private IReadOnlyList<SftpItem> items = Array.Empty<SftpItem>();
    private string connectionUsername = string.Empty;
    private Guid? connectionSecretHandle;
    private string currentPath = string.Empty;
    private string pathInput = string.Empty;
    private string browserStatus = "Credentials required";
    private string browseBusyTitle = string.Empty;
    private string browseBusyMessage = string.Empty;
    private string errorMessage = string.Empty;
    private string operationMessage = string.Empty;
    private string operationMessageTone = "success";
    private bool preferStoredCredentials = true;
    private bool hasResolvedStoredBrowseCredentials;
    private string storedBrowseCredentialsFailureMessage = string.Empty;
    private bool isBusy;
    private bool canBrowse;
    private bool detachedBrowserUnavailable;
    private bool detachedSearchUnavailable;
    private IReadOnlyList<FileBrowserDirectoryNode> directoryNodes = Array.Empty<FileBrowserDirectoryNode>();
    private readonly Dictionary<string, IReadOnlyList<SftpItem>> directoryItemCache = new(StringComparer.Ordinal);
    private readonly HashSet<string> blockedDirectoryPaths = new(StringComparer.Ordinal);
