    }

    private async Task CompressAsync(FileBrowserContextMenuRequest request, ArchiveFormat requestedFormat)
    {
        if (browser is null)
        {
            return;
        }

        DismissContextMenu();
        ClearOperationMessage();
        await EnsureFileActionsPopupAsync();

        var archiveFormat = ResolveRequestedArchiveFormat(requestedFormat, request.IsDirectory);
        var parentDirectory = GetParentDirectory(request.TargetPath);
        var defaultName = EnsureArchiveFileName(request.DisplayName, archiveFormat, request.IsDirectory);
        var archiveName = await JSRuntime.InvokeAsync<string?>("prompt", "Archive file name", defaultName);
        if (string.IsNullOrWhiteSpace(archiveName))
        {
            return;
        }

        var destinationPath = CombineBrowserPath(parentDirectory, EnsureArchiveFileName(archiveName.Trim(), archiveFormat, request.IsDirectory));
        FileActionQueueService.QueueZip(
            workspaceId,
            new FileActionZipRequest(
                browser.Host,
                parentDirectory,
                ResolveBrowserPath(request.TargetPath),
                destinationPath,
                request.DisplayName,
                request.IsDirectory,
                BuildFileActionExecutionContext())
            {
                Format = archiveFormat
            });

        SetOperationMessage($"Queued compression for {request.DisplayName}. Manage progress in File actions.", "success");
        await InvokeAsync(StateHasChanged);
    }

    private Task UncompressFromContextMenuAsync()
    {
        if (contextMenuRequest is null)
        {
            return Task.CompletedTask;
        }

        return UncompressAsync(contextMenuRequest);
    }

    private async Task UncompressAsync(FileBrowserContextMenuRequest request)
    {
        if (browser is null || request.Item is null)
        {
            return;
        }

        if (!ArchiveFormatSupport.TryResolveFromFileName(request.Item.Name, out var archiveFormat))
        {
            SetOperationMessage($"{request.Item.Name} is not a supported archive.", "warning");
            return;
        }

        DismissContextMenu();
        ClearOperationMessage();
        await EnsureFileActionsPopupAsync();

        var parentDirectory = GetParentDirectory(request.TargetPath);
        var suggestedName = RemoveArchiveExtension(request.Item.Name);
        var folderName = await JSRuntime.InvokeAsync<string?>("prompt", "Extract into folder", suggestedName);
        if (string.IsNullOrWhiteSpace(folderName))
        {
            return;
        }

        var destinationPath = CombineBrowserPath(parentDirectory, folderName.Trim());
        FileActionQueueService.QueueExtract(
            workspaceId,
            new FileActionExtractRequest(
                browser.Host,
                parentDirectory,
                ResolveBrowserPath(request.TargetPath),
                destinationPath,
                request.Item.Name,
                BuildFileActionExecutionContext())
            {
                Format = archiveFormat
            });

        SetOperationMessage($"Queued extraction for {request.Item.Name}. Manage progress in File actions.", "success");
        await InvokeAsync(StateHasChanged);
    }

    private async Task ReloadAfterMutationAsync(string preferredPath, string? deletedPath = null)
    {
        directoryItemCache.Clear();

        if (!string.IsNullOrWhiteSpace(deletedPath))
        {
            blockedDirectoryPaths.Remove(ResolveBrowserPath(deletedPath));
            expandedDirectoryPaths.RemoveWhere(path =>
                string.Equals(path, ResolveBrowserPath(deletedPath), StringComparison.Ordinal) ||
                path.StartsWith(ResolveBrowserPath(deletedPath).TrimEnd('/') + "/", StringComparison.Ordinal));
        }

        var reloadPath = preferredPath;
        if (!string.IsNullOrWhiteSpace(deletedPath))
        {
            var normalizedDeletedPath = ResolveBrowserPath(deletedPath);
            if (string.Equals(currentPath, normalizedDeletedPath, StringComparison.Ordinal) ||
                currentPath.StartsWith(normalizedDeletedPath.TrimEnd('/') + "/", StringComparison.Ordinal))
            {
                reloadPath = GetParentDirectory(normalizedDeletedPath);
            }
        }

        await LoadItemsAsync(reloadPath, preserveSessionOnFailure: canBrowse, updatePathInputOnSuccess: false);
    }

