    protected override async Task OnParametersSetAsync()
    {
        detachedBrowserUnavailable = false;
        detachedSearchUnavailable = false;
        contextMenuRequest = null;
        shortcutContextShortcut = null;
        operationMessage = string.Empty;
        errorMessage = string.Empty;
        selectedItem = null;
        items = Array.Empty<SftpItem>();
        fileBrowserShortcuts = Array.Empty<FileBrowserShortcut>();
        ownershipPermissionsTargetItem = null;
        ownershipPermissionsTargetItems = Array.Empty<SftpItem>();
        showFileSearchDialog = false;
        showRenameItemModal = false;
        showRenameShortcutModal = false;
        fileSearchResponse = null;
        fileSearchStatusMessage = string.Empty;
        fileSearchStatusTone = "info";
        liveFileSearchResults.Clear();
        liveFileSearchResultPaths.Clear();
        fileSearchCts?.Cancel();
        fileSearchCts?.Dispose();
        fileSearchCts = null;
        pathSuggestions = [];
        isPathSuggestionsLoading = false;
        pathSuggestionsRequestVersion = 0;
        canBrowse = false;
        directoryNodes = Array.Empty<FileBrowserDirectoryNode>();
        directoryItemCache.Clear();
        blockedDirectoryPaths.Clear();
        expandedDirectoryPaths.Clear();
        selectedPaths.Clear();
        accessDeniedPath = string.Empty;

        DetachedFileBrowserState? detachedState = null;
        DetachedFileSearchState? detachedSearchState = null;
        if (DetachedBrowserId.HasValue)
        {
            detachedState = WorkspaceState.GetDetachedBrowser(DetachedBrowserId.Value);
            if (detachedState is null)
            {
                var detachedWorkspace = FileBrowserWorkspaceRegistry.FindDetachedBrowser(DetachedBrowserId.Value);
                if (detachedWorkspace is not null)
                {
                    workspaceId = detachedWorkspace.WorkspaceId;
                    workspaceState = detachedWorkspace.Workspace;
                    detachedState = detachedWorkspace.BrowserState;
                }

                if (detachedState is null)
                {
                    browser = null;
                    detachedBrowserUnavailable = true;
                    return;
                }
            }
        }
        else if (DetachedSearchId.HasValue)
        {
            detachedSearchState = WorkspaceState.GetDetachedSearch(DetachedSearchId.Value);
            if (detachedSearchState is null)
            {
                var detachedWorkspace = FileBrowserWorkspaceRegistry.FindDetachedSearch(DetachedSearchId.Value);
                if (detachedWorkspace is not null)
                {
                    workspaceId = detachedWorkspace.WorkspaceId;
                    workspaceState = detachedWorkspace.Workspace;
                    detachedSearchState = detachedWorkspace.SearchState;
                }

                if (detachedSearchState is null)
                {
                    browser = null;
                    detachedSearchUnavailable = true;
                    return;
                }
            }
        }

        var targetHostId = detachedState?.HostId ?? detachedSearchState?.HostId ?? HostId;
        if (!targetHostId.HasValue || targetHostId == Guid.Empty)
        {
            browser = null;
            return;
        }

        var requestedPath = detachedState?.CurrentPath ?? detachedSearchState?.RootPath ?? InitialPath ?? RootPath;
        var targetPath = string.IsNullOrWhiteSpace(RootPath)
            ? requestedPath
            : NormalizePathWithinRoot(NormalizeBrowserPath(RootPath), requestedPath ?? RootPath);
        browser = await HostService.GetSftpBrowserAsync(targetHostId.Value, targetPath);
        if (browser is null)
        {
            return;
        }

        await LoadShortcutsAsync();

        currentPath = ResolveBrowserPath(detachedState?.CurrentPath ?? detachedSearchState?.RootPath ?? InitialPath ?? browser.CurrentPath);
        pathInput = currentPath;
        previewPanelOpen = detachedState?.PreviewOpen ?? previewPanelOpen;
        previewPanelFocused = detachedState?.PreviewFocused ?? previewPanelFocused;
        previewDock = detachedState?.PreviewDock ?? previewDock;
        previewPanelSizePx = detachedState?.PreviewPanelSizePx ?? previewPanelSizePx;
        foldersPaneCollapsed = detachedState?.FoldersPaneCollapsed ?? foldersPaneCollapsed;
        connectionUsername = detachedState?.Username ?? detachedSearchState?.Username ?? ConnectionUsernameOverride ?? browser.Host.Username;
        connectionSecretHandle = detachedState?.SecretHandle ?? detachedSearchState?.SecretHandle ?? ConnectionSecretHandle;
        preferStoredCredentials = detachedState?.PreferStoredCredentials ??
            detachedSearchState?.PreferStoredCredentials ??
            PreferStoredCredentialsOverride ??
            (!string.IsNullOrWhiteSpace(browser.Host.PasswordSecretReference) ||
             !string.IsNullOrWhiteSpace(browser.Host.PrivateKeySecretReference));
        await RefreshStoredBrowseCredentialStateAsync();
        EnsureInlineDetachedBrowserState();

        browserStatus = IsLocalBrowser
            ? "Local filesystem ready"
            : detachedState is not null
                ? "Browser ready"
                : detachedSearchState is not null
                    ? "Search window ready"
                : preferStoredCredentials && HasSavedCredentials
                    ? "Saved credentials ready"
                    : preferStoredCredentials && HasConfiguredStoredCredentials
                        ? "Saved credentials unavailable"
                    : "Credentials required";

        if (HasAvailableBrowseCredentials)
        {
            await LoadItemsAsync(currentPath, preserveSessionOnFailure: false, updatePathInputOnSuccess: true);

            if (!string.IsNullOrWhiteSpace(detachedState?.SelectedPath))
            {
                var restoredSelection = FindItemByPath(items, detachedState.SelectedPath);
                if (restoredSelection is not null)
                {
                    selectedItem = restoredSelection;
                    await LoadPreviewAsync(restoredSelection, preservePanelState: true);
                }
            }
        }

        if (detachedSearchState is not null)
        {
            fileSearchRootPath = ResolveBrowserPath(detachedSearchState.RootPath);
            showFileSearchDialog = true;
        }

        if (!previewPanelOpen)
        {
            previewPanelFocused = false;
        }

        QueuePathSuggestionsRefresh(pathInput);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (contextMenuRequest is not null || shortcutContextShortcut is not null)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("lmsFileBrowser.positionContextMenus");
            }
            catch (JSDisconnectedException)
            {
            }
            catch (JSException)
            {
            }
        }

        var canRegisterUploadTarget = browser is not null &&
            canBrowse &&
            !ShowDetachedSearchWorkspace &&
            !DetachedWorkspaceUnavailable;

        if (!canRegisterUploadTarget)
        {
            if (uploadTargetRegistered)
            {
                try
                {
                    await JSRuntime.InvokeVoidAsync("lmsFileBrowser.disposeUploadTarget", uploadTargetId);
                }
                catch (JSDisconnectedException)
                {
                }
                catch (JSException)
                {
                }

                uploadTargetRegistered = false;
            }

            return;
        }

        if (uploadTargetRegistered)
        {
            return;
        }

        uploadInteropReference ??= DotNetObjectReference.Create(this);
        try
        {
            uploadTargetRegistered = await JSRuntime.InvokeAsync<bool>(
                "lmsFileBrowser.registerUploadTarget",
                uploadTargetId,
                uploadDropTargetElement,
                uploadInteropReference,
                new
                {
                    url = BuildFileActionsPopupUrl(),
                    target = BuildFileActionsPopupTarget(),
                    width = 860,
                    height = 620
                });
        }
        catch (JSDisconnectedException)
        {
            uploadTargetRegistered = false;
        }
        catch (JSException)
        {
            uploadTargetRegistered = false;
        }
    }

    private async Task LoadShortcutsAsync()
    {
        if (browser is null)
        {
            fileBrowserShortcuts = Array.Empty<FileBrowserShortcut>();
            return;
        }

        fileBrowserShortcuts = await FileBrowserShortcutService.ListAsync(browser.Host.Id);
    }

    private async Task RefreshStoredBrowseCredentialStateAsync()
    {
        hasResolvedStoredBrowseCredentials = false;
        storedBrowseCredentialsFailureMessage = string.Empty;

        if (browser is null || IsLocalBrowser || !preferStoredCredentials || !HasConfiguredStoredCredentials)
        {
            return;
        }

        try
        {
            var validation = await FileAccessService.ValidateAccessAsync(browser.Host, BuildConnectionProfile());
            hasResolvedStoredBrowseCredentials = validation.Success;
            storedBrowseCredentialsFailureMessage = validation.Success
                ? string.Empty
                : validation.FailureMessage;
        }
        catch
        {
            hasResolvedStoredBrowseCredentials = false;
            storedBrowseCredentialsFailureMessage = $"Stored SSH credentials for {browser.Host.Name} could not be resolved.";
        }
    }

    private async Task RefreshCurrentPathAsync()
    {
        DismissContextMenu();
