    private Task SetOwnershipPermissionsOctalAsync(string? value)
    {
        var trimmed = value?.Trim() ?? string.Empty;
        if (!TryParseOwnershipPermissionsDigits(trimmed, out var special, out var owner, out var group, out var other))
        {
            ownershipPermissionsStatusMessage = "Permissions must be a 3 or 4 digit octal value such as 775 or 2775.";
            ownershipPermissionsStatusTone = "error";
            return Task.CompletedTask;
        }

        ownershipPermissionsEditor.PermissionsOctal = BuildOwnershipPermissionsOctal(special, owner, group, other);
        ownershipPermissionsStatusMessage = string.Empty;
        ownershipPermissionsStatusTone = "info";
        return Task.CompletedTask;
    }

    private bool IsOwnershipPermissionBitEnabled(int digitIndex, int mask)
    {
        var (_, owner, group, other) = GetOwnershipPermissionsDigits();
        var digit = digitIndex switch
        {
            0 => owner,
            1 => group,
            _ => other
        };

        return (digit & mask) == mask;
    }

    private Task SetOwnershipPermissionBitAsync(int digitIndex, int mask, bool enabled)
    {
        var (special, owner, group, other) = GetOwnershipPermissionsDigits();
        switch (digitIndex)
        {
            case 0:
                owner = enabled ? owner | mask : owner & ~mask;
                break;
            case 1:
                group = enabled ? group | mask : group & ~mask;
                break;
            default:
                other = enabled ? other | mask : other & ~mask;
                break;
        }

        ownershipPermissionsEditor.PermissionsOctal = BuildOwnershipPermissionsOctal(special, owner, group, other);
        ownershipPermissionsStatusMessage = string.Empty;
        ownershipPermissionsStatusTone = "info";
        return Task.CompletedTask;
    }

    private bool IsOwnershipSpecialBitEnabled(int mask)
    {
        var (special, _, _, _) = GetOwnershipPermissionsDigits();
        return (special & mask) == mask;
    }

    private Task SetOwnershipSpecialBitAsync(int mask, bool enabled)
    {
        var (special, owner, group, other) = GetOwnershipPermissionsDigits();
        special = enabled ? special | mask : special & ~mask;
        ownershipPermissionsEditor.PermissionsOctal = BuildOwnershipPermissionsOctal(special, owner, group, other);
        ownershipPermissionsStatusMessage = string.Empty;
        ownershipPermissionsStatusTone = "info";
        return Task.CompletedTask;
    }

