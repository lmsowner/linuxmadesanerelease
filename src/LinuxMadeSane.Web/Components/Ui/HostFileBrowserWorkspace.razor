    private async Task CreateFolderAsync(string destinationDirectoryPath)
    {
        if (browser is null || isBusy)
        {
            return;
        }

        DismissContextMenu();
        ClearOperationMessage();

        var folderName = await JSRuntime.InvokeAsync<string?>("prompt", "Folder name", "New folder");
        if (string.IsNullOrWhiteSpace(folderName))
        {
            return;
        }

        if (!TryNormalizeLeafName(folderName, out var normalizedName, out var validationMessage))
        {
            SetOperationMessage(validationMessage, "warning");
            return;
        }

        var normalizedDestinationDirectoryPath = ResolveBrowserPath(destinationDirectoryPath);
        var destinationPath = CombineBrowserPath(normalizedDestinationDirectoryPath, normalizedName);

        isBusy = true;
        SetOperationMessage($"Creating folder {normalizedName}...", "info");
        await InvokeAsync(StateHasChanged);

        try
        {
            await CreateDirectoryAsync(destinationPath);

            if (string.Equals(normalizedDestinationDirectoryPath, currentPath, StringComparison.Ordinal))
            {
                await RefreshCurrentListingPreserveSelectionAsync(destinationPath);
                selectedPaths.Clear();
                selectedPaths.Add(destinationPath);
            }
            else
            {
                QueueDirectoryTreeRefresh(currentPath);
            }

            SetOperationMessage($"Created folder {normalizedName}.", "success");
        }
        catch (Exception exception)
        {
            SetOperationMessage($"Create folder failed: {exception.Message}", "error");
        }
        finally
        {
            isBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

