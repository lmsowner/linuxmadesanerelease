    private async Task PasteIntoDirectoryAsync(string destinationDirectoryPath)
    {
        var clipboardEntry = Clipboard;
        if (browser is null || clipboardEntry is null)
        {
            return;
        }

        DismissContextMenu();
        ClearOperationMessage();
        await EnsureFileActionsPopupAsync();

        if (!CanPasteFromClipboard)
