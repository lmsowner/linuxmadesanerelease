    private async Task LoadItemsAsync(string targetPath, bool preserveSessionOnFailure, bool updatePathInputOnSuccess, bool showBusyState = true)
    {
        if (browser is null)
        {
            return;
        }

        if (!IsLocalBrowser && !HasAvailableBrowseCredentials)
        {
            errorMessage = string.IsNullOrWhiteSpace(storedBrowseCredentialsFailureMessage)
                ? "Provide a password or private key to browse files."
                : storedBrowseCredentialsFailureMessage;
            browserStatus = "Credentials required";
            canBrowse = false;
            directoryNodes = Array.Empty<FileBrowserDirectoryNode>();
            pathSuggestions = [];
            isPathSuggestionsLoading = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (showBusyState)
        {
            isBusy = true;
        }

        errorMessage = string.Empty;
        var normalizedPath = ResolveBrowserPath(targetPath);
        var previousPath = currentPath;
        var previousItems = items;
        var previousSelectedItem = selectedItem;
        var previousCanBrowse = canBrowse;
        var previousStatus = browserStatus;
        if (showBusyState)
        {
            SetBrowseBusyState(normalizedPath, previousCanBrowse);
            await InvokeAsync(StateHasChanged);
            await Task.Yield();
        }

        try
        {
            var nextItems = await ListItemsForPathAsync(normalizedPath);
            blockedDirectoryPaths.Remove(normalizedPath);
            if (string.Equals(accessDeniedPath, normalizedPath, StringComparison.Ordinal))
            {
                accessDeniedPath = string.Empty;
            }

            items = nextItems;
            currentPath = normalizedPath;
            directoryItemCache[currentPath] = items;
            selectedItem = null;
            selectedPaths.Clear();
            ResetPreviewState(keepPanelOpen: previewPanelOpen);
            if (updatePathInputOnSuccess)
            {
                pathInput = normalizedPath;
            }

            browserStatus = IsLocalBrowser ? "Live local listing" : "Live remote listing";
            canBrowse = true;
            QueueDirectoryTreeRefresh(currentPath);
            PersistDetachedBrowserState();
            QueuePathSuggestionsRefresh(pathInput);
        }
        catch (Exception exception)
        {
            var isAccessDenied = IsAccessDeniedFailure(exception);
            var isPathNotFound = IsPathNotFoundFailure(exception);
            if (isAccessDenied)
            {
                blockedDirectoryPaths.Add(normalizedPath);
                accessDeniedPath = normalizedPath;
            }
            else if (string.Equals(accessDeniedPath, normalizedPath, StringComparison.Ordinal))
            {
                accessDeniedPath = string.Empty;
            }

            errorMessage = BuildBrowseFailureMessage(normalizedPath, exception, isAccessDenied, isPathNotFound);
            if (preserveSessionOnFailure && previousCanBrowse)
            {
                items = previousItems;
                currentPath = previousPath;
                selectedItem = FindItemByPath(previousItems, normalizedPath) ?? previousSelectedItem;
                canBrowse = true;
                browserStatus = previousStatus;
                RebuildDirectoryTree();
                QueuePathSuggestionsRefresh(pathInput);
            }
            else
            {
                browserStatus = isAccessDenied
                    ? (IsLocalBrowser ? "Folder not accessible" : "Remote path not accessible")
                    : isPathNotFound
                        ? "Folder not found"
                    : (IsLocalBrowser ? "Browse failed" : "Connection failed");
                canBrowse = false;
                directoryNodes = Array.Empty<FileBrowserDirectoryNode>();
                QueuePathSuggestionsRefresh(pathInput);
            }
        }
        finally
        {
            if (showBusyState)
            {
                isBusy = false;
                ClearBrowseBusyState();
            }
        }
    }

