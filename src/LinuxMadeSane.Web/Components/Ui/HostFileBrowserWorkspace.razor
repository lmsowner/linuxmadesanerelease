    private Task DownloadFromContextMenuAsync()
    {
        if (contextMenuRequest is null)
        {
            return Task.CompletedTask;
        }

        var item = contextMenuRequest.Item ?? new SftpItem(
            contextMenuRequest.DisplayName,
            contextMenuRequest.TargetPath,
            contextMenuRequest.IsDirectory ? SftpItemType.Folder : SftpItemType.File,
            0,
            null,
            string.Empty);

        return QueueDownloadAsync(item, GetParentDirectory(ResolveBrowserPath(item.FullPath)));
    }

    private async Task QueueDownloadAsync(SftpItem item, string actionDirectoryPath)
    {
        if (browser is null)
        {
            return;
        }

        DismissContextMenu();
        ClearOperationMessage();
        await EnsureFileActionsPopupAsync();

        var isDirectory = item.ItemType == SftpItemType.Folder;
        var estimatedSizeBytes = isDirectory
            ? await EstimateDirectorySizeAsync(ResolveBrowserPath(item.FullPath))
            : item.SizeBytes;

        if (isDirectory && estimatedSizeBytes > FolderDownloadWarningBytes)
        {
            var confirmed = await JSRuntime.InvokeAsync<bool>(
                "confirm",
                $"{item.Name} contains about {FormatBytes(estimatedSizeBytes)}. LMS will zip the folder before downloading it. Continue?");
            if (!confirmed)
            {
                return;
            }
        }

        var downloadFileName = isDirectory
            ? EnsureDownloadZipFileName(item.Name)
            : item.Name;
        var jobId = FileActionQueueService.QueueDownload(
            workspaceId,
            new FileActionDownloadRequest(
                browser.Host,
                actionDirectoryPath,
                ResolveBrowserPath(item.FullPath),
                item.Name,
                isDirectory,
                estimatedSizeBytes,
                downloadFileName,
                BuildFileActionExecutionContext()));

        SetOperationMessage($"Queued download for {item.Name}. Manage progress in File actions.", "success");
        await StartBrowserDownloadIfReadyAsync(jobId);
        await InvokeAsync(StateHasChanged);
    }

    private Task CompressFromContextMenuAsync(ArchiveFormat requestedFormat)
    {
        if (contextMenuRequest is null)
        {
