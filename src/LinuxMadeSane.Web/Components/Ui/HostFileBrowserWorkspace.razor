    private async Task OpenShareFolderFromContextMenuAsync()
    {
        if (contextMenuRequest is null || !CanOpenShareFolderFromContextMenu)
        {
            return;
        }

        var selectedFolderPath = ResolveBrowserPath(contextMenuRequest.TargetPath);
        DismissContextMenu();
        ClearOperationMessage();

        try
        {
            var identitiesTask = ShareService.GetUsersGroupsManagerAsync();
            var shareManagerTask = ShareService.GetShareManagerAsync();
            await Task.WhenAll(identitiesTask, shareManagerTask);

            shareFolderIdentities = await identitiesTask;
            var shareManager = await shareManagerTask;
            var existingShare = shareManager.Shares.FirstOrDefault(share => string.Equals(
                NormalizeBrowserPath(share.SharePath),
                selectedFolderPath,
                StringComparison.Ordinal));

            if (existingShare is not null)
            {
                shareFolderEditor = await ShareService.GetEditorAsync(existingShare.Id);
                shareFolderStatusMessage = $"This folder is already shared as {shareFolderEditor.Name}. Adjust it here.";
            }
            else
            {
                shareFolderEditor = await ShareService.GetEditorAsync(null);
                shareFolderEditor.Name = BuildSuggestedShareName(selectedFolderPath, shareManager.Shares);
                shareFolderEditor.SharePath = selectedFolderPath;
                shareFolderStatusMessage = $"Sharing {selectedFolderPath}. Review access, then save to export it through Samba.";
            }

            shareFolderStatusTone = "info";
            showShareFolderDialog = true;
        }
        catch (Exception exception)
        {
            SetOperationMessage(exception.Message, "error");
        }
    }

