    private static string BuildFileSearchProgressMessage(FileSearchRequest request, string currentPath, int resultCount)
    {
        var searchPlan = request.RequiresContentScan
            ? "Scanning names, metadata, and file contents"
            : "Scanning names and metadata";

        return resultCount switch
        {
            0 => $"{searchPlan} in {currentPath}...",
            1 => $"{searchPlan} in {currentPath}... 1 match so far.",
            _ => $"{searchPlan} in {currentPath}... {resultCount} matches so far."
        };
    }

    private static bool TryNormalizeLeafName(string value, out string normalizedName, out string validationMessage)
    {
        normalizedName = (value ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(normalizedName))
        {
            validationMessage = "Enter a name first.";
            return false;
        }

        if (string.Equals(normalizedName, ".", StringComparison.Ordinal) ||
            string.Equals(normalizedName, "..", StringComparison.Ordinal))
        {
            validationMessage = "Choose a real file or folder name.";
            return false;
        }

        if (normalizedName.Contains('/') || normalizedName.Contains('\\'))
        {
            validationMessage = "Names cannot contain path separators.";
            return false;
        }

        validationMessage = string.Empty;
        return true;
    }

