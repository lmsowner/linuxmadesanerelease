    private async Task OpenPopupAsync()
    {
        DismissContextMenu();
        ClearOperationMessage();

        if (browser is null || !CanShowPopout)
        {
            return;
        }

        Guid? detachedBrowserId = null;
        var popupUrl = HasScopedRoot ? BuildRootedPopupUrl() : string.Empty;
        var popupName = string.Empty;

        if (HasScopedRoot)
        {
            popupName = BuildBrowserPopupName();
        }
        else
        {
            var detachedBrowser = WorkspaceState.CreateDetachedBrowser(
                BuildDetachedSnapshot(ConnectionSecretStore.Clone(connectionSecretHandle)));
            detachedBrowserId = detachedBrowser.BrowserId;
            popupUrl = $"/file-browser-window/{detachedBrowser.BrowserId}?workspaceId={Uri.EscapeDataString(workspaceId)}";
            popupName = BuildBrowserPopupName();
        }

        var opened = await JSRuntime.InvokeAsync<bool>(
            "lmsTerminalWindow.openPopup",
            popupUrl,
            popupName);

        if (!opened)
        {
            if (detachedBrowserId.HasValue)
            {
                WorkspaceState.RemoveDetachedBrowser(detachedBrowserId.Value);
            }

            SetOperationMessage("Popup blocked. Allow popups for this app and try again.", "warning");
        }
    }

    private Task OpenPopupFromContextMenuAsync() =>
        OpenPopupAsync();

