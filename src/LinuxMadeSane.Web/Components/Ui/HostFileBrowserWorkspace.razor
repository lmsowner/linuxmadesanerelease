    }

    private async Task ConfirmRenameItemAsync()
    {
        if (browser is null || renameTargetItem is null || string.IsNullOrWhiteSpace(renameTargetPath))
        {
            return;
        }

        if (!TryNormalizeLeafName(renameEntryName, out var normalizedName, out var validationMessage))
        {
            renameStatusMessage = validationMessage;
            renameStatusTone = "warning";
            return;
        }

        var sourcePath = renameTargetPath;
        var destinationPath = CombineBrowserPath(GetParentDirectory(sourcePath), normalizedName);
        if (string.Equals(sourcePath, destinationPath, StringComparison.Ordinal))
        {
            await CloseRenameItemModalAsync();
            return;
        }

        isRenamingItem = true;
        renameStatusMessage = "Renaming item...";
        renameStatusTone = "info";

        try
        {
            await MovePathAsync(sourcePath, destinationPath);
            await RefreshCurrentListingPreserveSelectionAsync(destinationPath);
            QueueDirectoryTreeRefresh(currentPath);
            selectedItem = FindItemByPath(items, destinationPath);

            if (selectedItem is not null && previewPanelOpen)
            {
                await LoadPreviewAsync(selectedItem, preservePanelState: true);
            }
            else
            {
                PersistDetachedBrowserState();
                await InvokeAsync(StateHasChanged);
            }

            var oldName = renameTargetItem.Name;
            showRenameItemModal = false;
            renameTargetItem = null;
            renameTargetPath = string.Empty;
            renameEntryName = string.Empty;
            renameStatusMessage = string.Empty;
            renameStatusTone = "info";
            SetOperationMessage($"Renamed {oldName} to {normalizedName}.", "success");
        }
        catch (Exception exception)
        {
            renameStatusMessage = exception.Message;
            renameStatusTone = "error";
