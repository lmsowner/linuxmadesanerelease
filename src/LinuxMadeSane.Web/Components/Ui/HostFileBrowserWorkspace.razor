    private async Task SaveOwnershipPermissionsAsync()
    {
        if (browser is null || ownershipPermissionsTargetItem is null || isSavingOwnershipPermissions)
        {
            return;
        }

        var validationMessage = ValidateOwnershipPermissionsEditor();
        if (!string.IsNullOrWhiteSpace(validationMessage))
        {
            ownershipPermissionsStatusMessage = validationMessage;
            ownershipPermissionsStatusTone = "error";
            return;
        }

        isSavingOwnershipPermissions = true;
        ownershipPermissionsStatusMessage = "Applying owner, group, and permissions changes...";
        ownershipPermissionsStatusTone = "info";

        var targetItems = ownershipPermissionsTargetItems.Count > 0
            ? ownershipPermissionsTargetItems
            : [ownershipPermissionsTargetItem];
        var targetPaths = targetItems
            .Select(item => ResolveBrowserPath(item.FullPath))
            .Distinct(StringComparer.Ordinal)
            .ToArray();
        var applyRecursively = ownershipPermissionsEditor.ApplyRecursively;
        var recursiveFolderCount = applyRecursively
            ? targetItems.Count(item => item.ItemType == SftpItemType.Folder)
            : 0;
        var successMessage = BuildOwnershipPermissionsSuccessMessage(targetItems.Count, applyRecursively, recursiveFolderCount, ownershipPermissionsTargetItem.Name);

        try
        {
            foreach (var targetItem in targetItems)
            {
                await SetOwnershipPermissionsAsync(new FileOwnershipPermissionsChangeRequest(
                    ResolveBrowserPath(targetItem.FullPath),
                    NullIfEmpty(ownershipPermissionsEditor.OwnerName),
                    NullIfEmpty(ownershipPermissionsEditor.GroupName),
                    GetEditedOwnershipPermissionsOctal(),
                    applyRecursively && targetItem.ItemType == SftpItemType.Folder));
            }

            showOwnershipPermissionsModal = false;
            ownershipPermissionsTargetItem = null;
            ownershipPermissionsTargetItems = Array.Empty<SftpItem>();
            SetOperationMessage(successMessage, "success");

            try
            {
                await RefreshListingMetadataInPlaceAsync(targetPaths.FirstOrDefault() ?? currentPath);
            }
            catch (Exception exception)
            {
                SetOperationMessage($"{successMessage} Refresh failed: {exception.Message}", "warning");
            }
        }
        catch (Exception exception)
        {
            ownershipPermissionsStatusMessage = exception.Message;
            ownershipPermissionsStatusTone = "error";
        }
        finally
        {
            isSavingOwnershipPermissions = false;
            await InvokeAsync(StateHasChanged);
        }
    }

