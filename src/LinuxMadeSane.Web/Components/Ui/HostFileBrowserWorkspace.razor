    private async Task RefreshListingMetadataInPlaceAsync(string targetPath)
    {
        if (browser is null)
        {
            return;
        }

        if (!IsLocalBrowser && !HasAvailableBrowseCredentials)
        {
            return;
        }

        IReadOnlyList<SftpItem> refreshedItems;
        try
        {
            refreshedItems = await ListItemsForPathAsync(currentPath);
        }
        catch (Exception exception)
        {
            SetOperationMessage(
                BuildBrowseFailureMessage(
                    currentPath,
                    exception,
                    IsAccessDeniedFailure(exception),
                    IsPathNotFoundFailure(exception)),
                "warning");
            await LoadItemsAsync(GetParentDirectory(currentPath), preserveSessionOnFailure: canBrowse, updatePathInputOnSuccess: true);
            return;
        }

        var previouslySelectedPaths = selectedPaths.ToHashSet(StringComparer.Ordinal);

        items = refreshedItems;
        directoryItemCache[currentPath] = items;
        QueueDirectoryTreeRefresh(currentPath);

        selectedPaths.Clear();
        foreach (var item in items)
        {
            var normalizedPath = ResolveBrowserPath(item.FullPath);
            if (previouslySelectedPaths.Contains(normalizedPath))
            {
                selectedPaths.Add(normalizedPath);
            }
        }

        var refreshedTargetItem = FindItemByPath(items, targetPath);
        if (refreshedTargetItem is not null)
        {
            selectedItem = refreshedTargetItem;
            selectedPaths.Add(targetPath);
        }

        PersistDetachedBrowserState();
        await InvokeAsync(StateHasChanged);
    }

    private async Task ExpandCurrentBranchAsync(string path)
    {
        foreach (var branchPath in BuildVisibleBranchPaths(path))
        {
            expandedDirectoryPaths.Add(branchPath);
            await TryCacheDirectoryAsync(branchPath);
        }
    }

    private void QueueDirectoryTreeRefresh(string path)
    {
        RebuildDirectoryTree();
        var requestVersion = ++directoryTreeRefreshVersion;
        _ = RefreshDirectoryTreeAsync(requestVersion, path);
    }

    private async Task RefreshDirectoryTreeAsync(int requestVersion, string path)
    {
        try
        {
            await ExpandCurrentBranchAsync(path);
        }
        catch
        {
            return;
        }

        if (requestVersion != directoryTreeRefreshVersion ||
            !string.Equals(ResolveBrowserPath(currentPath), ResolveBrowserPath(path), StringComparison.Ordinal))
        {
            return;
        }

        RebuildDirectoryTree();
        await InvokeAsync(StateHasChanged);
    }

    private async Task<bool> TryCacheDirectoryAsync(string path)
    {
        if (!IsLocalBrowser && !canBrowse)
        {
            return false;
        }

        var normalizedPath = ResolveBrowserPath(path);
        if (directoryItemCache.ContainsKey(normalizedPath))
        {
            return true;
        }

        try
        {
            directoryItemCache[normalizedPath] = await ListItemsForPathAsync(normalizedPath);
            blockedDirectoryPaths.Remove(normalizedPath);
            return true;
        }
        catch (Exception exception)
        {
            if (IsAccessDeniedFailure(exception))
            {
                blockedDirectoryPaths.Add(normalizedPath);
            }

            return false;
        }
    }

    private void RebuildDirectoryTree()
    {
        if (!canBrowse)
        {
            directoryNodes = Array.Empty<FileBrowserDirectoryNode>();
            return;
        }

        var rootPath = GetBestTreeRootPath(currentPath);
        directoryNodes = [BuildDirectoryNode(rootPath)];
    }

    private FileBrowserDirectoryNode BuildDirectoryNode(string path)
    {
        var normalizedPath = ResolveBrowserPath(path);
        var normalizedCurrentPath = ResolveBrowserPath(currentPath);
        var childDirectories = directoryItemCache.TryGetValue(normalizedPath, out var cachedItems)
            ? cachedItems
                .Where(item => item.ItemType == SftpItemType.Folder)
                .Select(item => ResolveBrowserPath(item.FullPath))
                .Where(IsPathVisibleInTree)
                .OrderBy(item => item, StringComparer.OrdinalIgnoreCase)
                .ToArray()
            : Array.Empty<string>();

        var isExpanded = expandedDirectoryPaths.Contains(normalizedPath);
        var children = isExpanded
            ? childDirectories.Select(BuildDirectoryNode).ToArray()
            : Array.Empty<FileBrowserDirectoryNode>();

        return new FileBrowserDirectoryNode(
            GetPathLabel(normalizedPath),
            normalizedPath,
            isExpanded,
            string.Equals(normalizedPath, normalizedCurrentPath, StringComparison.Ordinal),
            IsAncestorPath(normalizedPath, normalizedCurrentPath),
            blockedDirectoryPaths.Contains(normalizedPath),
            !directoryItemCache.ContainsKey(normalizedPath) || childDirectories.Length > 0,
            children);
    }

    private string GetBestTreeRootPath(string path)
    {
        if (HasScopedRoot)
        {
            return EffectiveRootPath!;
        }

        foreach (var branchPath in BuildBranchPaths(path))
        {
            if (directoryItemCache.ContainsKey(branchPath))
            {
                return branchPath;
            }
        }

        return ResolveBrowserPath(path);
    }

