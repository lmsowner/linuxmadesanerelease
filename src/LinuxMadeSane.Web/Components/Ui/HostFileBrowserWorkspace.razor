        var jobId = FileActionQueueService.QueuePaste(
            workspaceId,
            new FileActionPasteRequest(
                clipboardEntry.Operation == FileBrowserClipboardOperation.Cut ? FileActionKind.Move : FileActionKind.Copy,
                clipboardEntry.Host,
                BuildExecutionContextForClipboard(clipboardEntry),
                browser.Host,
                destinationDirectoryPath,
                clipboardEntry.Items
                    .Select(item => new FileActionSourceItem(item.SourcePath, item.DisplayName, item.IsDirectory))
                    .ToArray(),
                BuildFileActionExecutionContext()));

        SetOperationMessage(
            $"{(clipboardEntry.Operation == FileBrowserClipboardOperation.Cut ? "Queued move" : "Queued copy")} for {DescribeItems(clipboardEntry.Items.Select(item => item.DisplayName).ToArray())} to {destinationDirectoryPath}. Manage progress in File actions.",
            "success");
