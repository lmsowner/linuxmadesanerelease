    private async Task GoUpAsync()
    {
        DismissContextMenu();

        if (string.IsNullOrWhiteSpace(currentPath) || currentPath == "/")
        {
            await LoadItemsAsync(EffectiveRootPath ?? "/", preserveSessionOnFailure: canBrowse, updatePathInputOnSuccess: true);
            return;
        }

        if (HasScopedRoot && string.Equals(currentPath, EffectiveRootPath, StringComparison.Ordinal))
        {
            return;
        }

        var normalized = currentPath.TrimEnd('/');
        var separator = normalized.LastIndexOf('/');
        var parentPath = separator <= 0 ? EffectiveRootPath ?? "/" : normalized[..separator];
        if (HasScopedRoot && !IsPathWithinRoot(parentPath))
        {
            parentPath = EffectiveRootPath!;
        }

        await LoadItemsAsync(parentPath, preserveSessionOnFailure: canBrowse, updatePathInputOnSuccess: true);
    }

    private async Task ToggleDirectoryAsync(string path)
    {
        DismissContextMenu();
        var normalizedPath = ResolveBrowserPath(path);
        if (expandedDirectoryPaths.Contains(normalizedPath))
        {
            expandedDirectoryPaths.Remove(normalizedPath);
        }
        else
        {
            var didCacheDirectory = await TryCacheDirectoryAsync(normalizedPath);
            if (didCacheDirectory)
            {
                expandedDirectoryPaths.Add(normalizedPath);
            }
            else if (blockedDirectoryPaths.Contains(normalizedPath))
            {
                accessDeniedPath = normalizedPath;
                SetOperationMessage(BuildBrowseFailureMessage(normalizedPath, new UnauthorizedAccessException(), isAccessDenied: true, isPathNotFound: false), "warning");
            }
        }

        RebuildDirectoryTree();
    }

