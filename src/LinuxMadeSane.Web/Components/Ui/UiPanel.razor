@using System.Collections.Generic
@using System.Linq

@if (ResolvedTagName == "article")
{
    <article class="@CssClass" @attributes="AdditionalAttributes">@ChildContent</article>
}
else if (ResolvedTagName == "div")
{
    <div class="@CssClass" @attributes="AdditionalAttributes">@ChildContent</div>
}
else
{
    <section class="@CssClass" @attributes="AdditionalAttributes">@ChildContent</section>
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public UiPanelKind Kind { get; set; } = UiPanelKind.Surface;
    [Parameter] public bool Compact { get; set; }
    [Parameter] public string TagName { get; set; } = "section";
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string ResolvedTagName => TagName.Equals("article", StringComparison.OrdinalIgnoreCase)
        ? "article"
        : TagName.Equals("div", StringComparison.OrdinalIgnoreCase)
            ? "div"
            : "section";

    private string CssClass => string.Join(" ", GetClasses().Where(static value => !string.IsNullOrWhiteSpace(value)));

    private IEnumerable<string?> GetClasses()
    {
        yield return "ui-panel";
        yield return Kind == UiPanelKind.Hero ? "hero-panel" : "surface-card";
        if (Compact)
        {
            yield return "compact";
        }

        yield return Class;
    }
}
