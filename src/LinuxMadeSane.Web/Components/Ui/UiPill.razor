@using System.Linq

<span class="@CssClass">
    @ChildContent
</span>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public UiPillTone Tone { get; set; } = UiPillTone.Neutral;
    [Parameter] public string? Class { get; set; }

    private string CssClass => string.Join(" ", GetClasses().Where(static value => !string.IsNullOrWhiteSpace(value)));

    private IEnumerable<string?> GetClasses()
    {
        yield return "status-pill";
        yield return Tone switch
        {
            UiPillTone.Success => "success",
            UiPillTone.Warning => "warning",
            UiPillTone.Failure => "failure",
            _ => "neutral"
        };
        yield return Class;
    }
}
