@using System.Collections.Generic
@using System.Linq

<div class="@ShellClass" @attributes="AdditionalAttributes">
    @if (!string.IsNullOrWhiteSpace(Label) || !string.IsNullOrWhiteSpace(Helper))
    {
        <div class="ui-field-copy">
            @if (!string.IsNullOrWhiteSpace(Label))
            {
                <span class="ui-field-label">@Label</span>
            }

            @if (!string.IsNullOrWhiteSpace(Helper))
            {
                <span class="ui-field-helper">@Helper</span>
            }
        </div>
    }

    <div class="ui-field-input-region">
        <div class="ui-field-control">
            @ChildContent
        </div>

        @if (ValidationContent is not null)
        {
            <div class="ui-field-validation">@ValidationContent</div>
        }
    </div>
</div>

@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Helper { get; set; }
    [Parameter] public bool Compact { get; set; }
    [Parameter] public bool Inline { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? ValidationContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string ShellClass => string.Join(" ", GetClasses().Where(static value => !string.IsNullOrWhiteSpace(value)));

    private IEnumerable<string?> GetClasses()
    {
        yield return "ui-field-shell";
        if (Compact)
        {
            yield return "ui-field-shell-compact";
        }

        if (Inline)
        {
            yield return "ui-field-shell-inline";
        }

        yield return Class;
    }
}
