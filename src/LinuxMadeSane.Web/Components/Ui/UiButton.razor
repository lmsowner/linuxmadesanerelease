@using System.Collections.Generic
@using System.Linq

@if (IsLink)
{
    @if (OnClick.HasDelegate)
    {
        <a class="@CssClass"
           href="@Href"
           title="@Title"
           target="@Target"
           rel="@Rel"
           onpointerdown="@ResolvedPointerDownClientScript"
           @onclick="OnClick"
           @attributes="AdditionalAttributes">
            @if (Icon is not null)
            {
                <span class="ui-button-icon" aria-hidden="true">@Icon</span>
            }
            <span class="ui-button-label">@ChildContent</span>
            @if (!string.IsNullOrWhiteSpace(SuperscriptText))
            {
                <sup class="ui-button-superscript">@SuperscriptText</sup>
            }
        </a>
    }
    else
    {
        <a class="@CssClass"
           href="@Href"
           title="@Title"
           target="@Target"
           rel="@Rel"
           onpointerdown="@OnClientPointerDown"
           onclick="@OnClientClick"
           @attributes="AdditionalAttributes">
            @if (Icon is not null)
            {
                <span class="ui-button-icon" aria-hidden="true">@Icon</span>
            }
            <span class="ui-button-label">@ChildContent</span>
            @if (!string.IsNullOrWhiteSpace(SuperscriptText))
            {
                <sup class="ui-button-superscript">@SuperscriptText</sup>
            }
        </a>
    }
}
else
{
    @if (OnClick.HasDelegate)
    {
        <button class="@CssClass"
                type="@Type"
                title="@Title"
                disabled="@Disabled"
                onpointerdown="@ResolvedPointerDownClientScript"
                @onclick="OnClick"
                @attributes="AdditionalAttributes">
            @if (Icon is not null)
            {
                <span class="ui-button-icon" aria-hidden="true">@Icon</span>
            }
            <span class="ui-button-label">@ChildContent</span>
            @if (!string.IsNullOrWhiteSpace(SuperscriptText))
            {
                <sup class="ui-button-superscript">@SuperscriptText</sup>
            }
        </button>
    }
    else
    {
        <button class="@CssClass"
                type="@Type"
                title="@Title"
                disabled="@Disabled"
                onpointerdown="@OnClientPointerDown"
                onclick="@OnClientClick"
                @attributes="AdditionalAttributes">
            @if (Icon is not null)
            {
                <span class="ui-button-icon" aria-hidden="true">@Icon</span>
            }
            <span class="ui-button-label">@ChildContent</span>
            @if (!string.IsNullOrWhiteSpace(SuperscriptText))
            {
                <sup class="ui-button-superscript">@SuperscriptText</sup>
            }
        </button>
    }
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Icon { get; set; }
    [Parameter] public string? Href { get; set; }
    [Parameter] public string? Target { get; set; }
    [Parameter] public string? Rel { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? SuperscriptText { get; set; }
    [Parameter] public string Type { get; set; } = "button";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public UiButtonVariant Variant { get; set; } = UiButtonVariant.Primary;
    [Parameter] public UiButtonSize Size { get; set; } = UiButtonSize.Medium;
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? OnClientPointerDown { get; set; }
    [Parameter] public string? OnClientClick { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsLink => !string.IsNullOrWhiteSpace(Href);
    private string? ResolvedPointerDownClientScript =>
        !string.IsNullOrWhiteSpace(OnClientPointerDown) ? OnClientPointerDown : OnClientClick;

    private string CssClass => string.Join(" ", GetClasses().Where(static value => !string.IsNullOrWhiteSpace(value)));

    private IEnumerable<string?> GetClasses()
    {
        yield return "ui-button";
        yield return GetVariantClass(Variant);
        if (Size == UiButtonSize.Small)
        {
            yield return "ui-button-sm";
        }

        yield return Class;
    }

    private static string GetVariantClass(UiButtonVariant variant) => variant switch
    {
        UiButtonVariant.Primary => "glass-button glass-button-primary",
        UiButtonVariant.PrimaryMuted => "glass-button glass-button-primary-muted",
        UiButtonVariant.Ghost => "glass-button glass-button-ghost",
        UiButtonVariant.Toolbar => "glass-button glass-button-toolbar",
        UiButtonVariant.Danger => "glass-button glass-button-danger",
        UiButtonVariant.Secondary => "secondary-link",
        UiButtonVariant.Action => "action-button",
        UiButtonVariant.ActionSubtle => "action-button action-button-subtle",
        _ => "glass-button glass-button-primary"
    };
}
