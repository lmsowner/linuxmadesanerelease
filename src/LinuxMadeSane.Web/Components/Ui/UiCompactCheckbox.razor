<label class="@ShellClass"
       title="@Title"
       @onclick:stopPropagation="@StopClickPropagation">
    <input class="ui-compact-checkbox-input"
           type="checkbox"
           checked="@Value"
           disabled="@Disabled"
           aria-label="@AriaLabel"
           @onchange="HandleChangedAsync" />
    <span class="ui-compact-checkbox-box" aria-hidden="true">
        <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2.2 6.2 4.8 8.7 9.8 3.5" />
        </svg>
    </span>
</label>

@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public string? Title { get; set; }
    [Parameter] public bool Value { get; set; }
    [Parameter] public EventCallback<bool> ValueChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool StopClickPropagation { get; set; } = true;
    [Parameter] public string? Class { get; set; }

    private string AriaLabel => string.IsNullOrWhiteSpace(Label) ? "Toggle selection" : Label;

    private string ShellClass => string.Join(
        " ",
        new[]
        {
            "ui-compact-checkbox",
            Disabled ? "disabled" : null,
            Class
        }.Where(static value => !string.IsNullOrWhiteSpace(value)));

    private Task HandleChangedAsync(ChangeEventArgs args) =>
        ValueChanged.InvokeAsync(args.Value is bool value && value);
}
