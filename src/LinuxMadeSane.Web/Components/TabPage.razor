@implements IDisposable

@code {
    [CascadingParameter]
    private TabControl? Owner { get; set; }

    [Parameter]
    public string Value { get; set; } = string.Empty;

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Tooltip { get; set; } = string.Empty;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public RenderFragment? Header { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    internal string HeaderElementId { get; } = $"tab-{Guid.NewGuid():N}";

    internal string PanelElementId { get; } = $"tab-panel-{Guid.NewGuid():N}";

    internal string EffectiveValue =>
        string.IsNullOrWhiteSpace(Value)
            ? Title
            : Value;

    protected override void OnInitialized()
    {
        if (Owner is null)
        {
            throw new InvalidOperationException("TabPage must be used inside TabControl.");
        }

        Owner.RegisterPage(this);
    }

    public void Dispose() =>
        Owner?.UnregisterPage(this);
}
